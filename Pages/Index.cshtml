                            @T("Správa nabíjania EV z prebytkov FVE — regulácia nabíjacieho výkonu podľa aktuálneho FV výkonu, SOC batérie a tarify siete.", "EV charging from PV surplus — charge power regulation based on current PV output, battery SOC, and grid tariff.")
                        </p>
                        <div class="device-footer">
                            <small>@T("Integrácia plánovaná", "Integration planned")</small>

            @* ─────────────────── BOOTSTRAP DATA ─────────────────── *@
            <script id="dashboard-bootstrap" type="application/json">
                    @Html.Raw(Model.DashboardJson)
                </script>

            @* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
                   SCRIPTS — all Chart.js initialisation + interactions
                   â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• *@
            <script>
                (function () {
                    'use strict';
                    if (window.__nestStatsDashboardBooted) {
                        return;
                    }
                    window.__nestStatsDashboardBooted = true;

                    /* ── helpers ─────────────────────────────────────── */
                    const $ = id => document.getElementById(id);
                    const rawDashboard = JSON.parse($('dashboard-bootstrap').textContent || '{}');
                    const preferenceCookieName = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DashboardPreferenceCookieName));
                    const preferenceCookieMaxAge = 60 * 60 * 24 * 180;
                    const dashboardPendingLoadStorageKey = 'neststats.dashboard.pending-load';
                    const serverHasPendingBootLoad = @Html.Raw(hasPendingBootLoad ? "true" : "false");
                    let latestDashboardTelemetryTimeMs = Date.parse(rawDashboard.initialLive?.time || '') || 0;
                    let hasDashboardTelemetryBaseline = latestDashboardTelemetryTimeMs > 0;
                    let quietRangeRefreshInFlight = false;

                    function readDashboardPreferences() {
                        if (!preferenceCookieName) return { version: 1 };
                        const prefix = `${preferenceCookieName}=`;
                        const rawCookie = document.cookie
                            .split('; ')
                            .find(entry => entry.startsWith(prefix));
                        if (!rawCookie) return { version: 1 };

                        try {
                            return JSON.parse(decodeURIComponent(rawCookie.slice(prefix.length))) || { version: 1 };
                        } catch {
                            return { version: 1 };
                        }
                    }

                    let dashboardPrefs = readDashboardPreferences();

                    function saveDashboardPreferences(patch = {}) {
                        if (!preferenceCookieName) return;
                        dashboardPrefs = {
                            ...dashboardPrefs,
                            ...patch,
                            version: 1,
                            updatedUtc: new Date().toISOString()
                        };
                        const secure = location.protocol === 'https:' ? '; secure' : '';
                        document.cookie = `${preferenceCookieName}=${encodeURIComponent(JSON.stringify(dashboardPrefs))}; path=/; max-age=${preferenceCookieMaxAge}; samesite=lax${secure}`;
                    }

                    const QUIET_REFRESH_NEVER_VALUE = 11;
                    const DEFAULT_QUIET_REFRESH_MINUTES = 5;
                    const quietRefreshCopy = {
                        never: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("nikdy", "never"))),
                        minutes: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("min", "min")))
                    };
                    const quietRefreshInput = $('quiet-refresh-minutes');
                    const quietRefreshValue = $('quiet-refresh-value');

                    function normalizeQuietRefreshMinutes(value) {
                        const parsed = Number(value);
                        if (!Number.isFinite(parsed)) {
                            return DEFAULT_QUIET_REFRESH_MINUTES;
                        }

                        const rounded = Math.round(parsed);
                        if (rounded >= QUIET_REFRESH_NEVER_VALUE) {
                            return QUIET_REFRESH_NEVER_VALUE;
                        }

                        return Math.min(10, Math.max(1, rounded));
                    }

                    function formatQuietRefreshValue(value) {
                        return value >= QUIET_REFRESH_NEVER_VALUE
                            ? quietRefreshCopy.never
                            : `${value} ${quietRefreshCopy.minutes}`;
                    }

                    let quietRefreshMinutes = normalizeQuietRefreshMinutes(dashboardPrefs.quietRefreshMinutes);
                    let lastQuietRefreshStartedAt = Date.now();

                    function getQuietRefreshIntervalMs() {
                        return quietRefreshMinutes >= QUIET_REFRESH_NEVER_VALUE
                            ? null
                            : quietRefreshMinutes * 60 * 1000;
                    }

                    function syncQuietRefreshControl(value, persist = false) {
                        quietRefreshMinutes = normalizeQuietRefreshMinutes(value);
                        if (quietRefreshInput) {
                            quietRefreshInput.value = String(quietRefreshMinutes);
                        }
                        if (quietRefreshValue) {
                            quietRefreshValue.textContent = formatQuietRefreshValue(quietRefreshMinutes);
                        }
                        if (persist) {
                            saveDashboardPreferences({ quietRefreshMinutes });
                        }
                    }

                    syncQuietRefreshControl(quietRefreshMinutes);
                    quietRefreshInput?.addEventListener('input', event => {
                        syncQuietRefreshControl(event.currentTarget.value);
                    });
                    quietRefreshInput?.addEventListener('change', event => {
                        syncQuietRefreshControl(event.currentTarget.value, true);
                    });

                    function syncPrebootClass(active) {
                        document.documentElement.classList.toggle('dashboard-preboot', !!active);
                    }

                    function readPendingDashboardLoad() {
                        try {
                            const payload = JSON.parse(sessionStorage.getItem(dashboardPendingLoadStorageKey) || 'null');
                            if (!payload || typeof payload !== 'object') {
                                return null;
                            }

                            const startedAt = Number(payload.startedAt || 0);
                            if (startedAt > 0 && Date.now() - startedAt > 2 * 60 * 1000) {
                                clearPendingDashboardLoad();
                                return null;
                            }

                            return payload;
                        } catch {
                            return null;
                        }
                    }

                    function writePendingDashboardLoad(payload) {
                        try {
                            sessionStorage.setItem(dashboardPendingLoadStorageKey, JSON.stringify({
                                targetLabel: payload?.targetLabel || 'Aktualizujem dashboard',
                                navigateUrl: payload?.navigateUrl || '',
                                startedAt: Date.now()
                            }));
                        } catch { }
                    }

                    function clearPendingDashboardLoad() {
                        try {
                            sessionStorage.removeItem(dashboardPendingLoadStorageKey);
                        } catch { }
                    }

                    document.querySelector('.main-chart__feature-row')?.remove();

                    let dashboardLoadOverlay = $('dashboardLoadOverlay');
                    let dashboardLoadBar = $('dashboardLoadBar');
                    let dashboardLoadPercent = $('dashboardLoadPercent');
                    let dashboardLoadStage = $('dashboardLoadStage');
                    let dashboardLoadDetail = $('dashboardLoadDetail');
                    let dashboardLoadDetailStage = $('dashboardLoadDetailStage');
                    let dashboardLoadDetailText = $('dashboardLoadDetailText');
                    let dashboardLoadSummary = $('dashboardLoadSummary');
                    let dashboardLoadTarget = $('dashboardLoadTarget');
                    let dashboardLoadPanel = dashboardLoadOverlay?.querySelector('.load-panel') ?? null;
                    let dashboardLoadBusy = false;

                    function bindDashboardLoaderRefs() {
                        dashboardLoadOverlay = $('dashboardLoadOverlay');
                        dashboardLoadBar = $('dashboardLoadBar');
                        dashboardLoadPercent = $('dashboardLoadPercent');
                        dashboardLoadStage = $('dashboardLoadStage');
                        dashboardLoadDetail = $('dashboardLoadDetail');
                        dashboardLoadDetailStage = $('dashboardLoadDetailStage');
                        dashboardLoadDetailText = $('dashboardLoadDetailText');
                        dashboardLoadSummary = $('dashboardLoadSummary');
                        dashboardLoadTarget = $('dashboardLoadTarget');
                        dashboardLoadPanel = dashboardLoadOverlay?.querySelector('.load-panel') ?? null;
                    }

                    function mountDashboardLoader() {
                        if (!dashboardLoadOverlay) {
                            const overlay = document.createElement('div');
                            overlay.id = 'dashboardLoadOverlay';
                            overlay.className = 'load-overlay';
                            overlay.setAttribute('aria-hidden', 'true');
                            overlay.innerHTML = `
                                <div class="load-panel" role="status" aria-live="polite">
                                    <div class="load-panel__hero">
                                        <div class="load-panel__brand" aria-label="NestStats">
                                            <span class="brand__eye">Local-first control</span>
                                            <strong class="brand__name">NestStats</strong>
                                            <span class="brand__desc">Monitoring, routovanie prebytkov a ekonomicka analytika</span>
                                        </div>
                                        <div class="load-panel__head">
                                            <div>
                                                <h3>Nacitavam dashboard</h3>
                                                <p id="dashboardLoadSummary">Pripravujem novy pohlad na data a synchronizujem vsetky zdroje.</p>
                                            </div>
                                            <div class="load-panel__pct" id="dashboardLoadPercent">0%</div>
                                        </div>
                                        <div class="load-progress" aria-hidden="true">
                                            <span class="load-progress__bar" id="dashboardLoadBar"></span>
                                        </div>
                                        <div class="load-panel__meta">
                                            <span><strong id="dashboardLoadStage">Priprava</strong></span>
                                            <span id="dashboardLoadTarget">Cakam na poziadavku</span>
                                        </div>
                                    </div>
                                    <div class="load-panel__body">
                                        <div class="load-stage-grid">
                                            <div class="load-stage" data-load-step="system"><small>Krok 1</small><strong>System</strong></div>
                                            <div class="load-stage" data-load-step="database"><small>Krok 2</small><strong>Databaza</strong></div>
                                            <div class="load-stage" data-load-step="weather"><small>Krok 3</small><strong>Počasie</strong></div>
                                            <div class="load-stage" data-load-step="render"><small>Krok 4</small><strong>Render</strong></div>
                                        </div>
                                        <div class="load-detail" id="dashboardLoadDetail">
                                            <strong id="dashboardLoadDetailStage">Ready</strong>
                                            <span id="dashboardLoadDetailText">Overlay sa aktivuje pri zmene datumu alebo rozsahu.</span>
                                        </div>
                                    </div>
                                </div>`;
                            document.body.appendChild(overlay);
                        } else if (dashboardLoadOverlay.parentElement !== document.body) {
                            document.body.appendChild(dashboardLoadOverlay);
                        }

                        bindDashboardLoaderRefs();
                    }

                    function ensureDashboardLoaderVisible() {
                        mountDashboardLoader();
                        if (dashboardLoadOverlay) {
                            dashboardLoadOverlay.style.display = 'grid';
                            dashboardLoadOverlay.style.placeItems = 'center';
                            dashboardLoadOverlay.style.zIndex = '20000';
                        }
                        if (dashboardLoadPanel instanceof HTMLElement) {
                            dashboardLoadPanel.style.display = 'block';
                            dashboardLoadPanel.style.visibility = 'visible';
                            dashboardLoadPanel.style.opacity = '1';
                            dashboardLoadPanel.style.position = 'relative';
                            dashboardLoadPanel.style.zIndex = '20001';
                            dashboardLoadPanel.style.width = 'min(560px, calc(100vw - 32px))';
                        }
                    }

                    function setDashboardLoadState(progress) {
                        const percent = Math.max(0, Math.min(100, Number(progress?.percent ?? progress?.Percent ?? 0) || 0));
                        const stage = progress?.stage || progress?.Stage || 'Priprava';
                        const detail = progress?.detail || progress?.Detail || 'Nacitavam dashboard.';

                        ensureDashboardLoaderVisible();
                        if (dashboardLoadBar) dashboardLoadBar.style.width = `${percent}%`;
                        if (dashboardLoadPercent) dashboardLoadPercent.textContent = `${Math.round(percent)}%`;
                        if (dashboardLoadStage) dashboardLoadStage.textContent = stage;
                        if (dashboardLoadDetail) dashboardLoadDetail.setAttribute('data-stage', stage);
                        if (dashboardLoadDetailStage) dashboardLoadDetailStage.textContent = `${stage}:`;
                        if (dashboardLoadDetailText) dashboardLoadDetailText.textContent = detail;

                        const stageKey = stage.toLowerCase();
                        document.querySelectorAll('[data-load-step]').forEach(step => {
                            step.classList.remove('is-active', 'is-done');
                            const key = step.getAttribute('data-load-step') || '';
                            const isDone =
                                (key === 'system' && percent >= 20) ||
                                (key === 'database' && percent >= 68) ||
                                (key === 'weather' && percent >= 92) ||
                                (key === 'render' && percent >= 100);
                            const isActive =
                                (key === 'system' && stageKey.includes('system')) ||
                                (key === 'database' && (stageKey.includes('datab') || stageKey.includes('live') || stageKey.includes('graf'))) ||
                                (key === 'weather' && stageKey.includes('pocas')) ||
                                (key === 'render' && (stageKey.includes('render') || stageKey.includes('final') || stageKey.includes('hotovo')));

                            if (isDone) step.classList.add('is-done');
                            if (isActive && percent < 100) step.classList.add('is-active');
                        });
                    }

                    function showDashboardLoader(targetLabel) {
                        dashboardLoadBusy = true;
                        ensureDashboardLoaderVisible();
                        syncPrebootClass(false);
                        dashboardLoadOverlay?.classList.add('is-visible');
                        dashboardLoadOverlay?.setAttribute('aria-hidden', 'false');
                        document.documentElement.style.overflow = 'hidden';
                        document.body.style.overflow = 'hidden';
                        if (dashboardLoadSummary) dashboardLoadSummary.textContent = 'Sťahujem telemetriu, históriu, počasie a pripravujem nový render dashboardu.';
                        if (dashboardLoadTarget) dashboardLoadTarget.textContent = targetLabel || 'Aktualizujem vybraný pohľad';
                        setDashboardLoadState({ percent: 12, stage: 'Priprava', detail: 'Inicializujem nacitanie a pripravujem prehlad postupu.' });
                    }

                    function hideDashboardLoader() {
                        dashboardLoadBusy = false;
                        dashboardLoadOverlay?.classList.remove('is-visible');
                        dashboardLoadOverlay?.setAttribute('aria-hidden', 'true');
                        syncPrebootClass(false);
                        document.documentElement.style.overflow = '';
                        document.body.style.overflow = '';
                    }

                    async function beginDashboardNavigation(targetUrl, targetLabel, options = {}) {
                        const quiet = !!options.quiet;
                        if (dashboardLoadBusy || !rawDashboard.loadStartEndpoint || !rawDashboard.loadProgressEndpoint) {
                            if (!quiet) {
                                window.location.assign(targetUrl);
                            }
                            return;
                        }

                        dashboardLoadBusy = true;
                        if (!quiet) {
                            showDashboardLoader(targetLabel);
                        }

                        try {
                            const requestedUrl = new URL(targetUrl, window.location.origin);
                            const startUrl = new URL(rawDashboard.loadStartEndpoint, window.location.origin);
                            requestedUrl.searchParams.forEach((value, key) => startUrl.searchParams.set(key, value));
                            if (quiet) {
                                startUrl.searchParams.set('QuietRefresh', 'true');
                            }

                            const startResponse = await fetch(startUrl, {
                                credentials: 'same-origin',
                                headers: { 'X-Requested-With': 'XMLHttpRequest' }
                            });

                            if (!startResponse.ok) {
                                throw new Error('Loader sa nepodarilo spustit.');
                            }

                            const startPayload = await startResponse.json();
                            if (!startPayload?.jobId || !startPayload?.navigateUrl) {
                                throw new Error('Chyba inicializacie nacitavania.');
                            }

                            const progressUrl = new URL(rawDashboard.loadProgressEndpoint, window.location.origin);
                            progressUrl.searchParams.set('jobId', startPayload.jobId);

                            function swapDashboardDocument(navigateUrl) {
                                const finalUrl = new URL(navigateUrl, window.location.origin);
                                if (quiet) {
                                    finalUrl.searchParams.set('QuietRefresh', 'true');
                                    try {
                                        sessionStorage.setItem('neststats.dashboard.quiet-scroll', JSON.stringify({
                                            y: window.scrollY || 0,
                                            at: Date.now()
                                        }));
                                    } catch { }
                                    window.location.replace(finalUrl.toString());
                                    return;
                                }

                                setDashboardLoadState({
                                    percent: 99,
                                    stage: 'Render',
                                    detail: 'Data su pripravene. Prechadzam na novy dashboard a drzim loader az do uplneho otvorenia stranky.'
                                });
                                writePendingDashboardLoad({
                                    targetLabel: targetLabel || 'Aktualizujem dashboard',
                                    navigateUrl: finalUrl.toString()
                                });
                                window.location.assign(finalUrl.toString());
                            }

                            while (true) {
                                const progressResponse = await fetch(progressUrl, {
                                    credentials: 'same-origin',
                                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                                    cache: 'no-store'
                                });

                                if (!progressResponse.ok) {
                                    throw new Error('Nepodarilo sa zistit stav nacitavania.');
                                }

                                const progressPayload = await progressResponse.json();
                                if (!quiet) {
                                    setDashboardLoadState(progressPayload);
                                }

                                if (progressPayload?.failed) {
                                    throw new Error(progressPayload.error || progressPayload.detail || 'Nacitavanie zlyhalo.');
                                }

                                if (progressPayload?.completed) {
                                    swapDashboardDocument(startPayload.navigateUrl);
                                    return;
                                }

                                await new Promise(resolve => window.setTimeout(resolve, 280));
                            }
                        } catch (error) {
                            console.error(error);
                            hideDashboardLoader();
                            dashboardLoadBusy = false;
                            if (!quiet) {
                                window.location.assign(targetUrl);
                            }
                        }
                    }

                    const bootPendingDashboardLoad = readPendingDashboardLoad();
                    const bootHasLoadToken = serverHasPendingBootLoad || new URLSearchParams(window.location.search).has('LoadToken');
                    const navigationEntry = typeof performance !== 'undefined' && typeof performance.getEntriesByType === 'function'
                        ? performance.getEntriesByType('navigation')[0]
                        : null;
                    const isReloadNavigation = navigationEntry?.type === 'reload';
                    let hasSeenBootLoader = false;
                    try {
                        hasSeenBootLoader = sessionStorage.getItem('neststats.dashboard.boot-seen') === '1';
                    } catch { }

                    const isQuietBoot = new URLSearchParams(window.location.search).get('QuietRefresh') === 'true';
                    const shouldUseBootLoader = !isQuietBoot;
                    let dashboardBootCompleted = false;
                    let dashboardBootSafetyTimer = 0;

                    function completeDashboardBoot(reason) {
                        if (dashboardBootCompleted) {
                            return;
                        }

                        dashboardBootCompleted = true;
                        if (dashboardBootSafetyTimer) {
                            window.clearTimeout(dashboardBootSafetyTimer);
                            dashboardBootSafetyTimer = 0;
                        }

                        setDashboardLoadState({
                            percent: 100,
                            stage: 'Hotovo',
                            detail: reason === 'timeout'
                                ? 'Dashboard je pripraveny. Dokoncujem posledne vizualne upravy.'
                                : 'Dashboard je plne nacitany a grafy su pripravene.'
                        });

                        window.setTimeout(() => {
                            hideDashboardLoader();
                            clearPendingDashboardLoad();
                            try {
                                sessionStorage.setItem('neststats.dashboard.boot-seen', '1');
                            } catch { }
                            const currentUrl = new URL(window.location.href);
                            if (currentUrl.searchParams.has('LoadToken') || currentUrl.searchParams.has('QuietRefresh')) {
                                currentUrl.searchParams.delete('LoadToken');
                                currentUrl.searchParams.delete('QuietRefresh');
                                window.history.replaceState({}, document.title, currentUrl.toString());
                            }
                        }, 240);
                    }

                    function scheduleDashboardBootCompletion(reason) {
                        if (dashboardBootCompleted || !shouldUseBootLoader) {
                            return;
                        }

                        setDashboardLoadState({
                            percent: 99,
                            stage: 'Render',
                            detail: 'Dokoncujem posledne grafy, rozlozenie a interaktivne prvky dashboardu.'
                        });
                        window.setTimeout(() => completeDashboardBoot(reason), 140);
                    }

                    if (shouldUseBootLoader) {
                        const bootLabel = bootPendingDashboardLoad?.targetLabel
                            || (bootHasLoadToken ? 'Dokoncujem novy pohlad dashboardu' : 'Nacitavam dashboard');
                        showDashboardLoader(bootLabel);
                        if (dashboardLoadSummary) {
                            dashboardLoadSummary.textContent = bootHasLoadToken || bootPendingDashboardLoad
                                ? 'Data su uz pripravene. Dokoncujem grafy, rozlozenie a finalny render dashboardu.'
                                : 'Nacitavam dashboard, pripajam data a pripravujem grafy bez prazdnej obrazovky.';
                        }
                        setDashboardLoadState({
                            percent: bootHasLoadToken || bootPendingDashboardLoad ? 96 : 82,
                            stage: 'Render',
                            detail: bootHasLoadToken || bootPendingDashboardLoad
                                ? 'Pripajam pripravene data a dokoncujem vykreslenie grafov bez prazdnej obrazovky.'
                                : 'Inicializujem dashboard, karty a grafy pre prvy alebo obnoveny pohlad.'
                        });

                        window.addEventListener('load', () => scheduleDashboardBootCompletion('load'), { once: true });
                        document.addEventListener('readystatechange', () => {
                            if (document.readyState === 'complete') {
                                scheduleDashboardBootCompletion('ready');
                            }
                        });

                        if (document.readyState === 'complete') {
                            scheduleDashboardBootCompletion('complete');
                        }

                        dashboardBootSafetyTimer = window.setTimeout(() => {
                            scheduleDashboardBootCompletion('timeout');
                        }, 12000);
                    } else {
                        syncPrebootClass(false);
                    }

                    const COLORS = {
                        pv:      '#D97706', pvA:    'rgba(217,119,6,0.18)',
                        mppt1:   '#DC2626', mppt1A: 'rgba(220,38,38,0.18)',
                        mppt2:   '#EA580C', mppt2A: 'rgba(234,88,12,0.18)',
                        grid:    '#475569', gridA:  'rgba(71,85,105,0.18)',
                        cons:    '#15803D', consA:  'rgba(21,128,61,0.18)',
                        exp:     '#0891B2', expA:   'rgba(8,145,178,0.18)',
                        bat:     '#7C3AED', batA:   'rgba(124,58,237,0.18)',
                        soc:     '#4F46E5', socA:   'rgba(79,70,229,0.18)',
                        inv:     '#1A56DB', invA:   'rgba(26,86,219,0.18)',
                        co2:     '#065F46', fin:    '#1D4ED8',
                        amber:   '#D97706',
                    };

                    Chart.defaults.color = '#62625E';
                    Chart.defaults.font.family = "'IBM Plex Sans', system-ui, -apple-system, 'Segoe UI', sans-serif";
                    Chart.defaults.animation.duration = 420;
                    Chart.defaults.animation.easing = 'easeInOutQuart';
                    Chart.defaults.elements.line.borderCapStyle = 'round';
                    Chart.defaults.elements.line.borderJoinStyle = 'round';
                    Chart.defaults.elements.line.cubicInterpolationMode = 'monotone';
                    Chart.defaults.elements.point.hitRadius = 14;
                    Chart.defaults.plugins.legend.labels.usePointStyle = true;
                    Chart.defaults.plugins.legend.labels.boxWidth = 10;
                    Chart.defaults.plugins.legend.labels.boxHeight = 10;

                    function withAlpha(color, alphaValue) {
                        if (!color || typeof color !== 'string') return `rgba(15, 15, 14, ${alphaValue})`;

                        if (color.startsWith('rgba(') || color.startsWith('rgb(')) {
                            const parts = color.match(/[\d.]+/g);
                            if (parts?.length >= 3) {
                                return `rgba(${parts[0]}, ${parts[1]}, ${parts[2]}, ${alphaValue})`;
                            }
                        }

                        if (color.startsWith('#')) {
                            let hex = color.slice(1);
                            if (hex.length === 3) hex = hex.split('').map(ch => ch + ch).join('');
                            if (hex.length >= 6) {
                                const value = parseInt(hex.slice(0, 6), 16);
                                const r = (value >> 16) & 255;
                                const g = (value >> 8) & 255;
                                const b = value & 255;
                                return `rgba(${r}, ${g}, ${b}, ${alphaValue})`;
                            }
                        }

                        return color;
                    }

                    function createVerticalGradient(color, topAlpha, midAlpha, bottomAlpha) {
                        return (context) => {
                            const { chart } = context;
                            const { ctx, chartArea } = chart;
                            if (!chartArea) return withAlpha(color, topAlpha);

                            const gradient = ctx.createLinearGradient(0, chartArea.top, 0, chartArea.bottom);
                            gradient.addColorStop(0, withAlpha(color, topAlpha));
                            gradient.addColorStop(0.52, withAlpha(color, midAlpha));
                            gradient.addColorStop(1, withAlpha(color, bottomAlpha));
                            return gradient;
                        };
                    }

                    function hasDashPattern(dataset) {
                        return Array.isArray(dataset?.borderDash) && dataset.borderDash.length > 0;
                    }

                    function resolveStrokeColor(dataset) {
                        const candidate = Array.isArray(dataset.borderColor)
                            ? dataset.borderColor[0]
                            : (dataset.borderColor || dataset.backgroundColor);

                        if (typeof candidate === 'string') return candidate;
                        return COLORS.inv;
                    }

                    function smoothSeriesValues(values, passes = 1) {
                        if (!Array.isArray(values) || values.length < 4) {
                            return values;
                        }

                        const kernel = [1, 2, 3, 2, 1];
                        let result = values.map(value => {
                            const numeric = Number(value);
                            return Number.isFinite(numeric) ? numeric : null;
                        });

                        for (let pass = 0; pass < passes; pass += 1) {
                            result = result.map((value, index, source) => {
                                if (value == null) return value;

                                let weightedSum = 0;
                                let totalWeight = 0;

                                for (let offset = -2; offset <= 2; offset += 1) {
                                    const candidate = source[index + offset];
                                    if (candidate == null) continue;

                                    const weight = kernel[offset + 2];
                                    weightedSum += candidate * weight;
                                    totalWeight += weight;
                                }

                                if (!totalWeight) return value;

                                const smoothed = weightedSum / totalWeight;
                                const eased = (value * 0.34) + (smoothed * 0.66);
                                return Math.round(eased * 1000) / 1000;
                            });
                        }

                        return result;
                    }

                    function normalizeLineDatasets(datasets) {
                        return datasets.map(dataset => {
                            const next = { ...dataset };
                            const stroke = resolveStrokeColor(next);
                            const shouldFill = next.__seamlessFill === true
                                || next.fill === true
                                || next.fill === 'origin'
                                || (next.fill == null && !hasDashPattern(next));
                            const topAlpha = next.__surfaceTopAlpha ?? (next.__seamlessFill ? 0.24 : 0.12);
                            const midAlpha = next.__surfaceMidAlpha ?? (next.__seamlessFill ? 0.1 : 0.04);
                            const bottomAlpha = next.__surfaceBottomAlpha ?? 0;

                            next.borderColor ??= stroke;
                            next.borderWidth ??= next.__seamlessFill ? 2.5 : 2.25;
                            next.tension ??= 0.48;
                            next.spanGaps ??= true;
                            next.cubicInterpolationMode ??= 'monotone';
                            next.pointRadius ??= 0;
                            next.pointHoverRadius ??= 5;
                            next.pointHitRadius ??= 16;
                            next.pointBackgroundColor ??= '#FFFFFF';
                            next.pointBorderColor ??= stroke;
                            next.pointBorderWidth ??= 2;
                            if (Array.isArray(next.__rawData)) {
                                next.data = next.__displaySmoothing
                                    ? smoothSeriesValues(next.__rawData, next.__displaySmoothingPasses ?? 1)
                                    : next.__rawData.slice();
                            }
                            next.fill = shouldFill ? 'origin' : (next.fill ?? false);
                            next.backgroundColor = shouldFill
                                ? createVerticalGradient(stroke, topAlpha, midAlpha, bottomAlpha)
                                : (next.backgroundColor ?? 'transparent');

                            delete next.__displaySmoothing;
                            delete next.__displaySmoothingPasses;
                            delete next.__seamlessFill;
                            delete next.__surfaceTopAlpha;
                            delete next.__surfaceMidAlpha;
                            delete next.__surfaceBottomAlpha;
                            return next;
                        });
                    }

                    function getDatasetValueAt(dataset, index) {
                        const source = Array.isArray(dataset?.__rawData) ? dataset.__rawData : dataset?.data;
                        const numeric = Number(source?.[index]);
                        return Number.isFinite(numeric) ? numeric : null;
                    }

                    function trimLeadingEmptyChartData(labels, datasets) {
                        const safeLabels = Array.isArray(labels) ? labels : [];
                        const safeDatasets = Array.isArray(datasets) ? datasets : [];
                        const maxPoints = Math.max(
                            safeLabels.length,
                            ...safeDatasets.map(dataset => {
                                const source = Array.isArray(dataset?.__rawData) ? dataset.__rawData : dataset?.data;
                                return Array.isArray(source) ? source.length : 0;
                            })
                        );

                        let firstUsefulIndex = 0;
                        while (firstUsefulIndex < maxPoints) {
                            const hasRealValue = safeDatasets.some(dataset => {
                                const value = getDatasetValueAt(dataset, firstUsefulIndex);
                                return value != null && Math.abs(value) > 0.0001;
                            });

                            if (hasRealValue) break;
                            firstUsefulIndex += 1;
                        }

                        if (firstUsefulIndex <= 0 || firstUsefulIndex >= maxPoints) {
                            return { labels: safeLabels, datasets: safeDatasets };
                        }

                        return {
                            labels: safeLabels.slice(firstUsefulIndex),
                            datasets: safeDatasets.map(dataset => {
                                const next = { ...dataset };
                                if (Array.isArray(next.data)) next.data = next.data.slice(firstUsefulIndex);
                                if (Array.isArray(next.__rawData)) next.__rawData = next.__rawData.slice(firstUsefulIndex);
                                return next;
                            })
                        };
                    }

                    function buildLineChartData(labels, datasets, options = {}) {
                        const prepared = options.trimLeadingEmpty === false
                            ? { labels: Array.isArray(labels) ? labels : [], datasets: Array.isArray(datasets) ? datasets : [] }
                            : trimLeadingEmptyChartData(labels, datasets);

                        return {
                            labels: prepared.labels,
                            datasets: normalizeLineDatasets(prepared.datasets)
                        };
                    }

                    function normalizeBarDatasets(datasets) {
                        return datasets.map(dataset => {
                            const next = { ...dataset };
                            const stroke = resolveStrokeColor(next);

                            next.borderColor ??= stroke;
                            next.borderWidth ??= 1;
                            next.borderRadius ??= 10;
                            next.borderSkipped ??= false;
                            next.maxBarThickness ??= 18;
                            next.categoryPercentage ??= 0.72;
                            next.barPercentage ??= 0.84;

                            if (!Array.isArray(next.backgroundColor) && typeof next.backgroundColor !== 'function') {
                                next.backgroundColor = createVerticalGradient(stroke, 0.82, 0.62, 0.34);
                            }

                            return next;
                        });
                    }

                    const seamlessSurfacePlugin = {
                        id: 'seamlessSurface',
                        beforeDraw(chart) {
                            const { ctx, chartArea } = chart;
                            if (!chartArea) return;

                            const { left, top, width, height } = chartArea;
                            ctx.save();

                            const topGlow = ctx.createLinearGradient(0, top, 0, top + height);
                            topGlow.addColorStop(0, 'rgba(255,255,255,0.88)');
                            topGlow.addColorStop(0.42, 'rgba(255,255,255,0.18)');
                            topGlow.addColorStop(1, 'rgba(255,255,255,0)');
                            ctx.fillStyle = topGlow;
                            ctx.fillRect(left, top, width, height);

                            const bottomFade = ctx.createLinearGradient(0, top, 0, top + height);
                            bottomFade.addColorStop(0, 'rgba(250,250,249,0)');
                            bottomFade.addColorStop(1, 'rgba(15,15,14,0.03)');
                            ctx.fillStyle = bottomFade;
                            ctx.fillRect(left, top, width, height);

                            ctx.restore();
                        }
                    };

                    const trendSelectionPlugin = {
                        id: 'trendSelectionHead',
                        afterDatasetsDraw(chart, _args, options) {
                            const activeIndex = Number.isInteger(options?.activeIndex) ? options.activeIndex : null;
                            const { ctx, chartArea } = chart;
                            const xScale = chart.scales?.x;

                            if (activeIndex == null || !chartArea || !xScale) return;

                            const x = xScale.getPixelForValue(activeIndex);
                            const { top, bottom } = chartArea;
                            const selectedPoint = chart
                                .getSortedVisibleDatasetMetas()
                                .map(meta => meta.data?.[activeIndex])
                                .find(point => point && Number.isFinite(point.x) && Number.isFinite(point.y));

                            ctx.save();
                            ctx.strokeStyle = 'rgba(26,86,219,0.30)';
                            ctx.lineWidth = 1.2;
                            ctx.setLineDash([5, 4]);
                            ctx.beginPath();
                            ctx.moveTo(x, top + 8);
                            ctx.lineTo(x, bottom);
                            ctx.stroke();
                            ctx.setLineDash([]);

                            ctx.fillStyle = '#FFFFFF';
                            ctx.strokeStyle = '#1A56DB';
                            ctx.lineWidth = 2;
                            ctx.beginPath();
                            ctx.arc(x, top + 8, 5.5, 0, Math.PI * 2);
                            ctx.fill();
                            ctx.stroke();

                            if (selectedPoint) {
                                ctx.beginPath();
                                ctx.arc(selectedPoint.x, selectedPoint.y, 5, 0, Math.PI * 2);
                                ctx.fill();
                                ctx.stroke();
                            }

                            ctx.restore();
                        }
                    };

                    const softLineGlowPlugin = {
                        id: 'softLineGlow',
                        beforeDatasetDraw(chart, args) {
                            const meta = chart.getDatasetMeta(args.index);
                            const dataset = chart.data.datasets?.[args.index];
                            if (meta?.type !== 'line' || dataset?.glow === false) return;

                            const stroke = resolveStrokeColor(dataset);
                            chart.ctx.save();
                            chart.ctx.shadowColor = withAlpha(stroke, hasDashPattern(dataset) ? 0.12 : 0.18);
                            chart.ctx.shadowBlur = hasDashPattern(dataset) ? 10 : 18;
                            chart.ctx.shadowOffsetY = 8;
                        },
                        afterDatasetDraw(chart, args) {
                            const meta = chart.getDatasetMeta(args.index);
                            const dataset = chart.data.datasets?.[args.index];
                            if (meta?.type !== 'line' || dataset?.glow === false) return;
                            chart.ctx.restore();
                        }
                    };

                    const allocationLabelsPlugin = {
                        id: 'allocationLabels',
                        afterDatasetsDraw(chart) {
                            if (chart.canvas?.id !== 'allocationChart') return;

                            const { ctx } = chart;
                            const isHorizontal = chart.options?.indexAxis === 'y';
                            ctx.save();
                            ctx.font = "700 10px 'IBM Plex Mono'";
                            ctx.textAlign = 'center';
                            ctx.textBaseline = 'middle';

                            chart.data.datasets.forEach((dataset, datasetIndex) => {
                                const meta = chart.getDatasetMeta(datasetIndex);
                                meta.data.forEach((bar, index) => {
                                    const rawValue = Number(dataset.data?.[index] ?? 0);
                                    if (!Number.isFinite(rawValue) || rawValue < 0.08) return;

                                    const props = typeof bar?.getProps === 'function'
                                        ? bar.getProps(['x', 'y', 'base', 'height', 'width'], true)
                                        : bar;
                                    const width = Math.abs((props?.x ?? 0) - (props?.base ?? 0));
                                    const height = Math.abs((props?.y ?? 0) - (props?.base ?? 0));

                                    if (isHorizontal) {
                                        if (width < 42) return;
                                        ctx.fillStyle = '#FFFFFF';
                                        ctx.fillText(`${rawValue.toFixed(1)} kWh`, (props.x + props.base) / 2, props.y);
                                        return;
                                    }

                                    if ((props?.width ?? 0) < 34) return;
                                    ctx.fillStyle = '#0F0F0E';
                                    ctx.fillText(`${rawValue.toFixed(1)} kWh`, props.x, Math.min(props.y - 10, props.base - height - 10));
                                });
                            });

                            ctx.restore();
                        }
                    };

                    Chart.register(seamlessSurfacePlugin, trendSelectionPlugin, softLineGlowPlugin, allocationLabelsPlugin);

                    const BASE_OPTS = {
                        responsive: true, maintainAspectRatio: false,
                        normalized: true,
                        resizeDelay: 80,
                        interaction: { mode: 'index', intersect: false },
                        elements: {
                            line: {
                                borderCapStyle: 'round',
                                borderJoinStyle: 'round',
                                capBezierPoints: true
                            }
                        },
                        layout: { padding: { top: 6, right: 12, bottom: 2, left: 4 } },
                        animation: { duration: 260, easing: 'easeOutCubic' },
                        plugins: {
                            legend: { display: false },
                            decimation: {
                                enabled: true,
                                algorithm: 'min-max',
                                samples: 140
                            },
                            tooltip: {
                                backgroundColor: '#fff',
                                titleColor: '#0F0F0E', bodyColor: '#62625E',
                                borderColor: '#E6E6E3', borderWidth: 1,
                                padding: 10, cornerRadius: 10,
                                displayColors: true,
                                usePointStyle: true,
                                titleFont: { family: "'IBM Plex Sans'", size: 11, weight: '600' },
                                bodyFont:  { family: "'IBM Plex Sans'", size: 11 },
                            }
                        },
                        scales: {
                            x: {
                                border: { display: false },
                                offset: false,
                                grid: { color: 'rgba(15,15,14,0.03)', drawBorder: false, tickLength: 0 },
                                ticks: {
                                    font: { family: "'IBM Plex Mono'", size: 10 },
                                    color: '#9A9A94',
                                    autoSkip: true,
                                    autoSkipPadding: 14,
                                    maxRotation: 0,
                                    minRotation: 0,
                                    maxTicksLimit: 8,
                                    padding: 8
                                }
                            },
                            y: {
                                border: { display: false },
                                grid: {
                                    color: context => context.tick?.value === 0 ? 'rgba(15,15,14,0.075)' : 'rgba(15,15,14,0.035)',
                                    drawBorder: false,
                                    tickLength: 0
                                },
                                ticks: { font: { family: "'IBM Plex Mono'", size: 10 }, color: '#9A9A94', padding: 8, maxTicksLimit: 6 },
                                beginAtZero: true
                            }
                        }
                    };

                    const CHARTS_WITH_CUSTOM_SERIES_UI = new Set(['overviewChart']);
                    const CHARTS_WITHOUT_ZOOM = new Set(['overviewChart', 'supplyMixChart']);
                    const CHARTS_WITHOUT_LEGEND = new Set(['overviewChart']);
                    const hasZoomPlugin = typeof Chart?.registry?.plugins?.get === 'function'
                        && !!Chart.registry.plugins.get('zoom');
                    const defaultLegendClick = Chart.defaults?.plugins?.legend?.onClick;

                    function mergeChartLegendOptions(existing = {}) {
                        return {
                            display: true,
                            position: 'top',
                            align: 'start',
                            labels: {
                                font: { family: "'IBM Plex Sans'", size: 10.5, weight: '600' },
                                color: '#62625E',
                                boxWidth: 10,
                                boxHeight: 10,
                                padding: 16,
                                usePointStyle: true,
                                pointStyle: 'circle',
                                ...existing.labels
                            },
                            ...existing,
                            onClick(event, legendItem, legend) {
                                if (typeof existing.onClick === 'function') {
                                    existing.onClick.call(this, event, legendItem, legend);
                                } else if (typeof defaultLegendClick === 'function') {
                                    defaultLegendClick.call(this, event, legendItem, legend);
                                }
                                syncChartUtilityButtons(legend?.chart);
                            }
                        };
                    }

                    function mergeChartZoomOptions(existing = {}) {
                        const zoomDefaults = {
                            limits: {
                                x: { min: 'original', max: 'original', minRange: 2 },
                                y: { min: 'original', max: 'original' }
                            },
                            pan: {
                                enabled: true,
                                mode: 'x',
                                modifierKey: 'shift',
                                threshold: 8
                            },
                            zoom: {
                                mode: 'x',
                                wheel: { enabled: true, speed: 0.08 },
                                pinch: { enabled: true },
                                drag: {
                                    enabled: true,
                                    backgroundColor: 'rgba(26, 86, 219, 0.08)',
                                    borderColor: 'rgba(26, 86, 219, 0.28)',
                                    borderWidth: 1
                                }
                            }
                        };

                        return {
                            ...zoomDefaults,
                            ...existing,
                            limits: {
                                ...zoomDefaults.limits,
                                ...existing.limits,
                                x: { ...zoomDefaults.limits.x, ...(existing.limits?.x || {}) },
                                y: { ...zoomDefaults.limits.y, ...(existing.limits?.y || {}) }
                            },
                            pan: {
                                ...zoomDefaults.pan,
                                ...(existing.pan || {})
                            },
                            zoom: {
                                ...zoomDefaults.zoom,
                                ...(existing.zoom || {}),
                                wheel: {
                                    ...zoomDefaults.zoom.wheel,
                                    ...(existing.zoom?.wheel || {})
                                },
                                pinch: {
                                    ...zoomDefaults.zoom.pinch,
                                    ...(existing.zoom?.pinch || {})
                                },
                                drag: {
                                    ...zoomDefaults.zoom.drag,
                                    ...(existing.zoom?.drag || {})
                                }
                            },
                            onZoomComplete(args) {
                                if (typeof existing.onZoomComplete === 'function') {
                                    existing.onZoomComplete(args);
                                }
                                syncChartUtilityButtons(args?.chart);
                            },
                            onPanComplete(args) {
                                if (typeof existing.onPanComplete === 'function') {
                                    existing.onPanComplete(args);
                                }
                                syncChartUtilityButtons(args?.chart);
                            }
                        };
                    }

                    function chartSupportsLegendToggle(chart) {
                        const chartType = String(chart?.config?.type || '').toLowerCase();
                        if (chartType === 'pie' || chartType === 'doughnut' || chartType === 'polararea') {
                            return Array.isArray(chart?.data?.labels) && chart.data.labels.length > 1;
                        }

                        return Array.isArray(chart?.data?.datasets) && chart.data.datasets.length > 1;
                    }

                    function chartSupportsZoom(chart) {
                        if (!hasZoomPlugin || !chart) return false;
                        if (CHARTS_WITHOUT_ZOOM.has(chart.canvas?.id || '')) return false;

                        return Object.values(chart.scales || {}).some(scale => scale?.axis === 'x' || scale?.axis === 'y');
                    }

                    function syncChartUtilityButtons(chart) {
                        const host = chart?.canvas?.closest('.chart-wrap, .main-chart__canvas-wrap');
                        if (!host) return;

                        const resetBtn = host.querySelector('.chart-reset-btn');
                        if (!resetBtn) return;

                        const canResetZoom = chartSupportsZoom(chart) && typeof chart.resetZoom === 'function';
                        const isZoomed = canResetZoom && typeof chart.isZoomedOrPanned === 'function'
                            ? chart.isZoomedOrPanned()
                            : false;

                        resetBtn.hidden = !canResetZoom;
                        resetBtn.disabled = !isZoomed;
                    }

                    function registerInteractiveChart(chart) {
                        if (!chart) return chart;

                        const chartId = chart.canvas?.id || '';
                        chart.options.plugins ??= {};

                        if (!CHARTS_WITHOUT_LEGEND.has(chartId) && chartSupportsLegendToggle(chart)) {
                            chart.options.plugins.legend = mergeChartLegendOptions(chart.options.plugins.legend || {});
                        }

                        if (chartSupportsZoom(chart)) {
                            chart.options.plugins.zoom = mergeChartZoomOptions(chart.options.plugins.zoom || {});
                        }

                        chart.update('none');
                        syncChartUtilityButtons(chart);
                        return chart;
                    }

                    function renderExternalLegend(containerId, chart) {
                        const host = $(containerId);
                        if (!host || !chart) return;

                        const generateLabels =
                            chart.options?.plugins?.legend?.labels?.generateLabels ||
                            Chart.defaults?.plugins?.legend?.labels?.generateLabels;

                        if (typeof generateLabels !== 'function') {
                            host.innerHTML = '';
                            return;
                        }

                        const items = generateLabels(chart) || [];
                        host.innerHTML = '';

                        items.forEach(item => {
                            const button = document.createElement('button');
                            button.type = 'button';
                            button.className = 'chart-legend-chip' + (item.hidden ? ' is-off' : '');
                            button.textContent = item.text || 'Seria';
                            button.style.setProperty('--legend-color', item.strokeStyle || item.fillStyle || '#CFCFCB');
                            button.setAttribute('aria-pressed', item.hidden ? 'false' : 'true');
                            button.addEventListener('click', () => {
                                const chartType = String(chart.config?.type || '').toLowerCase();
                                if (chartType === 'pie' || chartType === 'doughnut' || chartType === 'polararea') {
                                    chart.toggleDataVisibility(item.index);
                                } else {
                                    const visible = chart.isDatasetVisible(item.datasetIndex);
                                    chart.setDatasetVisibility(item.datasetIndex, !visible);
                                }

                                chart.update();
                                renderExternalLegend(containerId, chart);
                            });
                            host.appendChild(button);
                        });
                    }

                    function attachExternalLegend(chart, containerId) {
                        if (chart && containerId) {
                            renderExternalLegend(containerId, chart);
                        }

                        return chart;
                    }

                    function mkLine(ctx, datasets, xlabels, yUnit) {
                        return registerInteractiveChart(new Chart(ctx, {
                            type: 'line',
                            data: buildLineChartData(xlabels, datasets),
                            options: {
                                ...BASE_OPTS,
                                scales: {
                                    ...BASE_OPTS.scales,
                                    y: {
                                        ...BASE_OPTS.scales.y,
                                        ticks: {
                                            ...BASE_OPTS.scales.y.ticks,
                                            callback: v => v + (yUnit || '')
                                        }
                                    }
                                }
                            }
                        }));
                    }

                    function mkBar(ctx, datasets, xlabels, yUnit) {
                        return registerInteractiveChart(new Chart(ctx, {
                            type: 'bar',
                            data: { labels: xlabels, datasets: normalizeBarDatasets(datasets) },
                            options: {
                                ...BASE_OPTS,
                                scales: {
                                    ...BASE_OPTS.scales,
                                    x: { ...BASE_OPTS.scales.x, stacked: false },
                                    y: {
                                        ...BASE_OPTS.scales.y,
                                        ticks: { ...BASE_OPTS.scales.y.ticks, callback: v => v + (yUnit || '') }
                                    }
                                }
                            }
                        }));
                    }

                    function ds(label, data, color, colorA, opts) {
                        return {
                            label, data,

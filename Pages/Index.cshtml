                        <button type="button" class="series-toggle is-off" data-series="mppt1" style="--st-color: #DC2626">MPPT 1</button>
                        <button type="button" class="series-toggle is-off" data-series="mppt2" style="--st-color: #EA580C">MPPT 2</button>
                        <button type="button" class="series-toggle is-on" data-series="consumption" style="--st-color: #15803D">Spotreba</button>
                        <button type="button" class="series-toggle is-on" data-series="grid" style="--st-color: #475569">Sieť</button>
                        <button type="button" class="series-toggle is-on" data-series="export" style="--st-color: #0891B2">Export</button>
                        <button type="button" class="series-toggle is-on" data-series="soc" style="--st-color: #4F46E5">SOC</button>

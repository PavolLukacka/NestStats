    .u-d3 { animation-delay: 0.15s; } .u-d4 { animation-delay: 0.20s; }
    .u-d5 { animation-delay: 0.25s; } .u-d6 { animation-delay: 0.30s; }

    /* â•â•â• APP SHELL â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    .app-shell { display: flex; min-height: 100vh; }

    /* â•â•â• SIDE RAIL â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    .side-rail {
        width: var(--rail); min-height: 100vh; height: 100vh;
        position: sticky; top: 0; flex-shrink: 0;
        display: flex; flex-direction: column;
        background: var(--bg-card); border-right: 1px solid var(--border);
        overflow: hidden; z-index: 20;
    }

    .side-nav { padding: 18px 10px 12px; flex: 1; min-height: 0; overflow-y: auto; scrollbar-width: none; display: flex; flex-direction: column; gap: 1px; }
    .side-nav::-webkit-scrollbar { display: none; }
    .side-nav__label { font-size: 9.5px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-subtle); padding: 10px 10px 5px; }
    .side-nav a {
        display: flex; align-items: center; gap: 10px; padding: 7px 10px;
        border-radius: var(--r-sm); font-size: 12.5px; font-weight: 500;
        color: var(--text-muted); text-decoration: none; transition: all var(--tx);
    }
    .side-nav a .nav-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--border-strong); flex-shrink: 0; transition: all var(--tx); }
    .side-nav a:hover { color: var(--text); background: var(--bg-muted); }
    .side-nav a:hover .nav-dot { background: var(--accent); transform: scale(1.5); }
    .side-nav a.is-active { color: var(--accent); background: var(--accent-muted); font-weight: 600; }
    .side-nav a.is-active .nav-dot { background: var(--accent); box-shadow: 0 0 0 3px var(--accent-ring); }

    .rail-foot { padding: 12px 18px; border-top: 1px solid var(--border); flex-shrink: 0; background: var(--bg-subtle); }
    .rail-foot__lbl { display: block; font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.13em; color: var(--text-subtle); margin-bottom: 4px; }
    .rail-foot strong { display: block; font-size: 11.5px; font-weight: 600; font-family: var(--fm); color: var(--text); margin-bottom: 2px; }
    .rail-foot small { display: block; font-size: 10.5px; color: var(--text-subtle); line-height: 1.45; }

    /* â•â•â• WORKSPACE â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    .workspace { flex: 1; min-width: 0; display: flex; flex-direction: column; }

    /* â•â•â• COMPACT STICKY HEADER (56px) â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    .ws-header {
        position: sticky; top: 0; z-index: 15;
        height: var(--header-h); min-height: var(--header-h);
        background:
            linear-gradient(165deg, rgba(255, 255, 255, 0.97), rgba(248, 250, 253, 0.93)),
            radial-gradient(circle at 85% 20%, rgba(26, 86, 219, 0.1), transparent 52%);
        backdrop-filter: saturate(140%) blur(14px);
        -webkit-backdrop-filter: saturate(140%) blur(14px);
        border-bottom: 1px solid rgba(207, 207, 203, 0.9);
        padding: 0 24px;
        display: flex; align-items: center; justify-content: space-between; gap: 16px;
        box-shadow: 0 8px 24px rgba(15, 15, 14, 0.06);
    }
    .ws-header__meta { display: flex; align-items: center; gap: 14px; min-width: 0; flex: 1; }
    .ws-header__title {
        min-width: 0;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 10px;
    }
    .ws-header h1 {
        font-size: 14.5px; font-weight: 700; letter-spacing: -0.02em; color: var(--text);
        line-height: 1.2; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        flex: 0 1 auto;
        max-width: 42%;
    }
    .ws-header p {
        font-size: 11.5px; color: var(--text-subtle); line-height: 1.2;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        font-family: var(--fm); font-weight: 400;
    }
    .ws-header__subline {
        display: flex;
        align-items: center;
        gap: 8px;
        min-width: 0;
        margin-top: 0;
        flex: 1 1 auto;
    }
    .ws-header__subline p {
        flex: 1;
        min-width: 0;
    }
    .ws-header__right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }

    .live-badge {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 3px 9px 3px 7px;
        background: linear-gradient(180deg, rgba(229, 248, 237, 0.95), rgba(214, 242, 227, 0.95));
        border: 1px solid rgba(34, 197, 94, 0.32); border-radius: 20px;
        font-size: 10px; font-weight: 700; color: #0f8a51; flex-shrink: 0;
        font-family: var(--fm); letter-spacing: 0.02em;
        box-shadow: 0 2px 8px rgba(16, 185, 129, 0.16);
    }
    .live-badge__dot { width: 5px; height: 5px; border-radius: 50%; background: var(--green); animation: pulseDot 1.8s ease-in-out infinite; }
    .stale-badge {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 3px 9px 3px 7px;
        background: linear-gradient(180deg, rgba(255, 244, 225, 0.94), rgba(255, 237, 203, 0.94));
        border: 1px solid rgba(245, 158, 11, 0.32); border-radius: 20px;
        font-size: 10px; font-weight: 700; color: #b56800;
        font-family: var(--fm);
        box-shadow: 0 2px 8px rgba(245, 158, 11, 0.13);
    }
    .stale-badge::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: var(--amber); }

    .hdr-pill-row { display: flex; gap: 6px; }
    .hdr-pill {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 5px 10px;
        background: linear-gradient(180deg, rgba(255,255,255,0.94), rgba(246,246,244,0.96));
        border: 1px solid rgba(206, 206, 202, 0.9); border-radius: 999px;
        font-size: 10.8px; color: #57606d;
        box-shadow: 0 1px 0 rgba(255,255,255,0.85) inset;
    }
    .hdr-pill strong { font-family: var(--fm); font-weight: 700; color: var(--text); }
    .hdr-pill--soc {
        align-items: center;
        gap: 8px;
        min-width: 138px;
        max-width: 176px;
        padding: 5px 8px;
    }
    .hdr-pill--soc .soc-label {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: .03em;
        color: #57606d;
        flex-shrink: 0;
    }
    .hdr-pill--soc .soc-meter {
        position: relative;
        flex: 1;
        height: 6px;
        border-radius: 999px;
        background: linear-gradient(90deg, rgba(239, 68, 68, 0.25), rgba(245, 158, 11, 0.2), rgba(34, 197, 94, 0.25));
        border: 1px solid rgba(0, 0, 0, 0.06);
        overflow: hidden;
    }
    .hdr-pill--soc .soc-meter > span {
        display: block;
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(90deg, #ef4444 0%, #f59e0b 55%, #22c55e 100%);
        box-shadow: 0 0 8px rgba(16, 185, 129, 0.35);
    }
    .hdr-pill--soc .soc-value {
        font-family: var(--fm);
        font-weight: 700;
        color: var(--text);
        font-size: 10.5px;
        min-width: 34px;
        text-align: right;
        flex-shrink: 0;
    }
    .hdr-pill--ok { background: var(--green-muted); border-color: var(--green-border); color: var(--green); }
    .hdr-pill--ok strong { color: var(--green); }
    .hdr-pill--warn { background: var(--amber-muted); border-color: var(--amber-border); color: var(--amber); }
    .hdr-pill--warn strong { color: var(--amber); }
    .hdr-pill--err { background: var(--red-muted); border-color: var(--red-border); color: var(--red); }
    .hdr-pill--err strong { color: var(--red); }

    /* â•â•â• WS BODY â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    .ws-body { padding: 18px 24px 32px; display: flex; flex-direction: column; gap: 16px; max-width: 100%; }

    .load-overlay {
        position: fixed;
        inset: 0;
        z-index: 120;
        display: grid;
        place-items: center;
        padding: 22px;
        background:
            radial-gradient(circle at top, rgba(26, 86, 219, 0.12), transparent 32%),
            rgba(250, 250, 249, 0.8);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transition: opacity var(--tx-md), visibility var(--tx-md);
    }
    .load-overlay.is-visible {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
    }
    .load-panel {
        position: relative;
        z-index: 2;
        width: min(560px, 100%);
        border-radius: 26px;
        border: 1px solid rgba(207, 207, 203, 0.88);
        background:
            linear-gradient(180deg, rgba(255,255,255,0.96), rgba(255,255,255,0.92)),
            linear-gradient(135deg, rgba(26,86,219,0.06), transparent 48%);
        box-shadow: 0 24px 80px rgba(15, 15, 14, 0.12);
        overflow: hidden;
        opacity: 0;
        transform: translateY(18px) scale(0.98);
        transition: opacity var(--tx-md), transform var(--tx-md);
    }
    .load-overlay.is-visible .load-panel {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
    .load-panel__hero {
        padding: 24px 24px 18px;
        border-bottom: 1px solid var(--border);
        display: grid;
        gap: 12px;
    }
    .load-panel__brand {
        display: flex;
        flex-direction: column;
        gap: 2px;
        align-items: flex-start;
    }
    .load-panel__brand .brand__eye {
        margin-bottom: 0;
    }
    .load-panel__brand .brand__name {
        font-size: 18px;
    }
    .load-panel__brand .brand__desc {
        margin-top: 0;
        font-size: 10.5px;
    }
    .load-panel__head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 14px;
    }
    .load-panel__head h3 {
        font-size: 24px;
        line-height: 1.05;
        letter-spacing: -0.04em;
        color: var(--text);
    }
    .load-panel__head p {
        margin-top: 6px;
        font-size: 12px;
        line-height: 1.55;
        color: var(--text-muted);
    }
    .load-panel__pct {
        flex-shrink: 0;
        font-family: var(--fm);
        font-size: 32px;
        letter-spacing: -0.06em;
        color: var(--accent);
    }
    .load-progress {
        height: 12px;
        border-radius: 999px;
        background: linear-gradient(180deg, rgba(230,230,227,0.9), rgba(244,244,242,0.9));
        overflow: hidden;
        position: relative;
    }
    .load-progress__bar {
        position: relative;
        display: block;
        height: 100%;
        width: 8%;
        border-radius: inherit;
        background:
            linear-gradient(90deg, rgba(26, 86, 219, 0.96), rgba(56, 189, 248, 0.98) 55%, rgba(34, 197, 94, 0.98)),
            linear-gradient(90deg, transparent, rgba(255,255,255,0.52), transparent),
            repeating-linear-gradient(120deg, rgba(255,255,255,0.12) 0 12px, rgba(255,255,255,0) 12px 24px);
        background-size: 100% 100%, 220% 100%, 36px 100%;
        box-shadow: 0 8px 24px rgba(26, 86, 219, 0.26);
        transition: width 280ms ease;
        animation: loaderBarDrift 1.6s linear infinite;
    }
    .load-progress__bar::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.55), transparent);
        animation: shimmer 1.5s linear infinite;
    }
    .load-progress__bar::before {
        content: '';
        position: absolute;
        top: 2px;
        bottom: 2px;
        left: 10px;
        width: 24%;
        min-width: 28px;
        border-radius: inherit;
        background: linear-gradient(90deg, rgba(255,255,255,0), rgba(255,255,255,0.38), rgba(255,255,255,0));
        filter: blur(0.5px);
        animation: shimmer 1.2s linear infinite;
    }
    .load-panel__meta {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: center;
        font-size: 11px;
        color: var(--text-muted);
    }
    .load-panel__meta strong {
        color: var(--text);
        font-weight: 700;
    }
    .load-panel__body {
        padding: 18px 24px 24px;
        display: grid;
        gap: 14px;
    }
    .load-stage-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 8px;
    }
    .load-stage {
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 10px 10px 11px;
        background: var(--bg-subtle);
        transition: all var(--tx);
    }
    .load-stage small {
        display: block;
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--text-subtle);
    }
    .load-stage strong {
        display: block;
        margin-top: 4px;
        font-size: 12px;
        color: var(--text-muted);
    }
    .load-stage.is-active {
        border-color: rgba(26, 86, 219, 0.24);
        background: var(--accent-muted);
        box-shadow: 0 0 0 3px rgba(26, 86, 219, 0.08);
        animation: loaderStagePulse 1.4s ease-in-out infinite;
    }
    .load-stage.is-active strong,
    .load-stage.is-done strong {
        color: var(--text);
    }
    .load-stage.is-done {
        border-color: var(--green-border);
        background: var(--green-muted);
    }
    .load-detail {
        min-height: 44px;
        border-radius: 16px;
        border: 1px solid var(--border);
        padding: 12px 14px;
        background: linear-gradient(180deg, rgba(248,248,246,0.9), rgba(255,255,255,0.92));
        font-size: 12px;
        line-height: 1.6;
        color: var(--text-muted);
    }
    .load-detail strong {
        display: block;
        color: var(--text);
        font-weight: 700;
    }
    .load-detail span {
        display: block;
        margin-top: 4px;
    }
    .load-panel__pct {
        animation: loaderPctPulse 1.6s ease-in-out infinite;
    }
    @@media (max-width: 700px) {
        .load-panel__hero,
        .load-panel__body { padding-left: 16px; padding-right: 16px; }
        .load-panel__head { flex-direction: column; }
        .load-panel__pct { font-size: 28px; }
        .load-stage-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }

    /* â•â•â• MESSAGES â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    .msg { display: flex; align-items: center; gap: 10px; padding: 10px 16px; border-radius: var(--r); font-size: 13px; border: 1px solid; animation: fadeIn 0.3s both; }
    .msg strong { font-weight: 600; }
    .msg--ok { background: var(--green-muted); border-color: var(--green-border); color: var(--green); }
    .msg--err { background: var(--red-muted); border-color: var(--red-border); color: var(--red); }

    /* â•â•â• CONTROL STRIP (timeline + filters) â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    .ctrl-strip {
        display: flex; align-items: center; justify-content: space-between;
        gap: 12px; flex-wrap: wrap;
        background:
            linear-gradient(180deg, rgba(255,255,255,0.98), rgba(248,248,246,0.94)),
            radial-gradient(circle at 80% 15%, rgba(26,86,219,0.07), transparent 55%);
        border: 1px solid rgba(207, 207, 203, 0.9);
        border-radius: var(--r-md); padding: 10px 14px;
        box-shadow: 0 10px 24px rgba(15, 15, 14, 0.05);
    }
    .timeline-nav {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 4px;
        background: rgba(245, 246, 248, 0.9);
        border: 1px solid rgba(207, 207, 203, 0.8);
        border-radius: 11px;
    }
    .timeline-nav__date {
        font-size: 12.5px; font-weight: 600; font-family: var(--fm);
        color: var(--text); padding: 6px 12px;
        background: rgba(255, 255, 255, 0.98);
        border-radius: 9px;
        border: 1px solid rgba(207, 207, 203, 0.85); margin: 0;
        box-shadow: 0 1px 3px rgba(15, 15, 14, 0.05);
    }
    .ctrl-bar { display: flex; align-items: flex-end; gap: 10px; flex-wrap: wrap; }
    .ctrl-bar--filters { flex: 1 1 auto; }
    .ctrl-strip__actions {
        display: flex;
        align-items: center;
        gap: 6px;
        flex-wrap: nowrap;
        margin-left: auto;
        flex-shrink: 0;
    }
    .field { display: flex; flex-direction: column; gap: 4px; }
    .field label { font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.13em; color: var(--text-subtle); }
    .field select, .field input[type="date"] {
        padding: 6px 10px; border: 1px solid var(--border); border-radius: var(--r-sm);
        background: rgba(255, 255, 255, 0.92);
        font-size: 12.5px; font-family: var(--ff); color: var(--text);
        outline: none; transition: all var(--tx); cursor: pointer; -webkit-appearance: none; appearance: none;
        min-width: 120px;
    }
    .field select:hover, .field input[type="date"]:hover { border-color: var(--border-strong); background: var(--bg-card); }
    .field select:focus, .field input[type="date"]:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-ring); background: var(--bg-card); }

    /* â•â•â• BUTTONS â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    .btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 7px 14px; border-radius: var(--r-sm);
        font-size: 12px; font-weight: 600; font-family: var(--ff);
        text-decoration: none; cursor: pointer;
        border: 1px solid transparent; transition: all var(--tx);
        white-space: nowrap; line-height: 1; letter-spacing: -0.005em;
    }
    .btn--primary { background: var(--accent); color: #fff; border-color: var(--accent); }
    .btn--primary:hover { background: var(--accent-h); border-color: var(--accent-h); box-shadow: 0 4px 14px rgba(26, 86, 219, 0.28); transform: translateY(-1px); }
    .btn--ghost { background: var(--bg-muted); color: var(--text-muted); border-color: var(--border); }
    .btn--ghost:hover { background: var(--bg-hover); color: var(--text); border-color: var(--border-strong); }
    .btn--sm { padding: 5px 10px; font-size: 11px; }
    .btn--xs { padding: 4px 8px; font-size: 10px; }
    .ctrl-strip__iconbtn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 30px;
        height: 30px;
        border-radius: 999px;
        border: 1px solid rgba(207, 207, 203, 0.86);
        background: rgba(255, 255, 255, 0.86);
        color: var(--text-muted);
        box-shadow: var(--sh-xs);
        cursor: pointer;
        text-decoration: none;
        transition: all var(--tx);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
    }
    .ctrl-strip__iconbtn:hover {
        color: var(--accent);
        border-color: var(--accent);
        box-shadow: 0 0 0 3px var(--accent-ring);
        transform: translateY(-1px);
    }
    .ctrl-strip__iconbtn:focus-visible {
        outline: none;
        color: var(--accent);
        border-color: var(--accent);
        box-shadow: 0 0 0 3px var(--accent-ring);
    }
    .ctrl-strip__iconbtn svg { width: 14px; height: 14px; }

    /* â•â•â• CHIP FILTERS (range + series toggles) â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    .chip-row { display: inline-flex; gap: 0; background: var(--bg-muted); border: 1px solid var(--border); border-radius: var(--r); padding: 2px; }
    .chip {
        padding: 6px 12px; border-radius: 7px; font-size: 11.5px; font-weight: 600;
        color: var(--text-subtle); background: transparent; border: none; cursor: pointer;
        transition: all var(--tx); white-space: nowrap; line-height: 1; letter-spacing: -0.005em;
        font-family: var(--ff);
    }
    .chip:hover { color: var(--text); background: rgba(0, 0, 0, 0.04); }
    .chip.is-active { background: var(--bg-card); color: var(--text); box-shadow: var(--sh-xs), 0 0 0 1px var(--border-strong); }

    .series-toggle-row { display: flex; gap: 6px; flex-wrap: wrap; }
    .series-toggle {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 5px 11px 5px 8px; border-radius: 999px;
        font-size: 11px; font-weight: 600;
        background: linear-gradient(180deg, rgba(255,255,255,0.72), rgba(244,244,242,0.96)); border: 1px solid var(--border);
        color: var(--text-muted); cursor: pointer;
        transition: all var(--tx); font-family: var(--ff); line-height: 1;
        backdrop-filter: blur(10px);
    }
    .series-toggle::before { content: ''; width: 8px; height: 8px; border-radius: 50%; background: var(--st-color, var(--border-strong)); transition: all var(--tx); flex-shrink: 0; }
    .series-toggle:hover { background: linear-gradient(180deg, rgba(255,255,255,0.96), rgba(248,248,246,0.98)); border-color: var(--border-strong); color: var(--text); transform: translateY(-1px); }
    .series-toggle.is-on {
        background:
            radial-gradient(circle at top left, color-mix(in srgb, var(--st-color, var(--accent)) 18%, transparent), transparent 62%),
            linear-gradient(180deg, rgba(255,255,255,0.98), rgba(248,248,246,0.98));
        border-color: color-mix(in srgb, var(--st-color, var(--border-strong)) 62%, white);
        color: var(--text);
        box-shadow: 0 0 0 1px color-mix(in srgb, var(--st-color, var(--border-strong)) 62%, white), 0 12px 26px color-mix(in srgb, var(--st-color, transparent) 16%, transparent);
    }
    .series-toggle.is-off::before { background: var(--border-strong); opacity: 0.5; }
    .series-toggle.is-off { color: var(--text-subtle); }

    /* â•â•â• PANELS â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    .panel { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--r-lg); padding: 20px; transition: box-shadow var(--tx); }
    .panel:hover { box-shadow: var(--sh-sm); }
    .panel-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 14px; margin-bottom: 16px; }
    .panel-head .eyebrow { display: block; font-size: 9px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-subtle); margin-bottom: 3px; }
    .panel-head h2 { font-size: 14.5px; font-weight: 600; letter-spacing: -0.015em; color: var(--text); line-height: 1.3; }
    .panel-badge {
        font-size: 10.5px; color: var(--text-muted); font-family: var(--fm); font-weight: 500;
        padding: 3px 8px; background: var(--bg-muted); border-radius: 6px;
        white-space: nowrap; border: 1px solid var(--border); flex-shrink: 0;
    }

    /* â•â•â• GRIDS â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    .grid-split { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }
    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
    .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
    .grid-5 { display: grid; grid-template-columns: repeat(5, 1fr); gap: 14px; }
    .grid-6 { display: grid; grid-template-columns: repeat(6, 1fr); gap: 12px; }
    .grid-23 { display: grid; grid-template-columns: 2fr 3fr; gap: 14px; }
    .grid-32 { display: grid; grid-template-columns: 3fr 2fr; gap: 14px; }

    @@media (max-width: 1280px) {
        .grid-5, .grid-6 { grid-template-columns: repeat(3, 1fr); }
    }
    @@media (max-width: 1100px) {
        .app-shell { flex-direction: column; min-height: auto; }
        .grid-split, .grid-3, .grid-4, .grid-23, .grid-32 { grid-template-columns: repeat(2, 1fr); }
        .side-rail { display: none; }
        .ws-body { padding: 14px; }
        .ws-header { padding: 0 14px; }
        .ws-header p { display: none; }
        .ctrl-strip__actions { width: 100%; margin-left: 0; justify-content: flex-end; flex-wrap: wrap; }
    }
    @@media (max-width: 680px) {
        .grid-split, .grid-3, .grid-4, .grid-5, .grid-6, .grid-23, .grid-32 { grid-template-columns: 1fr; }
        .ws-body { padding: 10px; gap: 12px; }
        .ws-header {
            position: sticky;
            top: 0;
            height: auto;
            min-height: 0;
            padding: 10px 10px;
            border-radius: 0 0 14px 14px;
            display: grid;
            grid-template-columns: 1fr;
            gap: 10px;
            align-items: stretch;
            background:
                linear-gradient(170deg, rgba(255, 255, 255, 0.99), rgba(246, 248, 252, 0.96)),
                radial-gradient(circle at 82% 12%, rgba(26, 86, 219, 0.12), transparent 54%);
            box-shadow: 0 8px 18px rgba(15, 15, 14, 0.08);
        }
        .ws-header__meta,
        .ws-header__title,
        .ws-header__right {
            min-width: 0;
            width: 100%;
        }
        .ws-header__meta {
            display: block;
        }
        .ws-header__title {
            display: block;
            width: 100%;
        }
        .ws-header h1 {
            font-size: 13.5px;
            line-height: 1.25;
            white-space: normal;
            overflow: visible;
            text-overflow: clip;
            overflow-wrap: anywhere;
            word-break: break-word;
            max-width: none;
        }
        .ws-header p {
            display: block;
            margin-top: 4px;
            font-size: 11px;
            line-height: 1.35;
            white-space: normal;
            overflow: visible;
            text-overflow: clip;
            overflow-wrap: anywhere;
            word-break: break-word;
        }
        .ws-header__subline {
            margin-top: 3px;
            flex-wrap: wrap;
            align-items: center;
            gap: 6px;
        }
        .ws-header__subline p {
            margin-top: 0;
        }
        .ws-header__right {
            display: grid;
            grid-template-columns: 1fr;
            gap: 8px;
            align-items: stretch;
        }
        .ws-header__subline .live-badge,
        .ws-header__subline .stale-badge {
            width: fit-content;
            margin-top: -2px;
        }
        .hdr-pill-row {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 6px;
        }
        .hdr-pill-row .hdr-pill:not(:first-child) { display: inline-flex; }
        .hdr-pill {
            justify-content: center;
            padding: 6px 7px;
            font-size: 10.5px;
            min-width: 0;
        }
        .hdr-pill--soc {
            min-width: 0;
            max-width: none;
            padding: 6px 7px;
        }
        .hdr-pill--soc .soc-meter {
            height: 5px;
        }
        .hdr-pill strong {
            overflow-wrap: anywhere;
            word-break: break-word;
        }

        .panel { padding: 14px; border-radius: var(--r-md); }
        .panel-head { gap: 8px; margin-bottom: 12px; }
        .panel-head h2 { font-size: 13.5px; }
        .panel-badge { font-size: 9.5px; padding: 3px 7px; }
        .ctrl-strip {
            padding: 10px;
            border-radius: 14px;
            gap: 10px;
            align-items: stretch;
            box-shadow: 0 8px 18px rgba(15, 15, 14, 0.06);
        }
        .timeline-nav {
            width: 100%;
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
            gap: 6px;
            align-items: stretch;
            padding: 0;
            border: none;
            background: transparent;
        }
        .timeline-nav .btn {
            justify-content: center;
            min-height: 34px;
            white-space: nowrap;
        }
        .timeline-nav .btn:nth-of-type(2) {
            grid-column: 2;
            grid-row: 2;
        }
        .timeline-nav__date {
            grid-column: 1 / -1;
            text-align: center;
            font-size: 11.5px;
            padding: 8px 10px;
            margin: 0;
        }
        .ctrl-bar,
        .ctrl-bar--filters {
            width: 100%;
            display: grid;
            grid-template-columns: 1fr;
            gap: 8px;
            align-items: stretch;
        }
        .field {
            flex: 1 1 auto;
            width: 100%;
            min-width: 0;
        }
        .field label {
            font-size: 8.5px;
            letter-spacing: .12em;
        }
        .field select, .field input[type="date"] { width: 100%; min-width: 0; }
        .ctrl-bar .btn--primary {
            width: 100%;
            min-height: 38px;
            justify-content: center;
        }
        .ctrl-strip__actions {
            width: 100%;
            margin-left: 0;
            justify-content: stretch;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
        }
        .ctrl-strip__iconbtn {
            width: 100%;
            height: 36px;
            border-radius: 10px;
            justify-content: center;
            gap: 7px;
            font-size: 11px;
            font-weight: 600;
            color: var(--text);
        }
        .ctrl-strip__iconbtn .u-sr-only {
            position: static !important;
            width: auto !important;
            height: auto !important;
            overflow: visible !important;
            clip: auto !important;
            white-space: nowrap !important;
            margin: 0 !important;
            font-size: 11px;
        }
        .ctrl-strip__iconbtn svg {
            width: 13px;
            height: 13px;
        }
    }

    @@media (max-width: 480px) {
        .ws-body {
            padding: 8px;
            gap: 10px;
        }
        .ws-header {
            padding: 8px;
            gap: 8px;
            border-radius: 0 0 12px 12px;
        }
        .ws-header h1 {
            font-size: 13px;
        }
        .ws-header p {
            font-size: 10.5px;
        }
        .ws-header__subline {
            gap: 5px;
        }
        .ws-header__subline .live-badge,
        .ws-header__subline .stale-badge {
            margin-top: -3px;
        }
        .hdr-pill-row {
            grid-template-columns: 1fr;
            gap: 5px;
        }
        .hdr-pill {
            justify-content: space-between;
            font-size: 10px;
            padding: 6px 8px;
        }
        .hdr-pill--soc {
            display: grid;
            grid-template-columns: auto minmax(0, 1fr) auto;
            align-items: center;
            gap: 8px;
        }
        .ctrl-strip {
            padding: 8px;
            border-radius: 12px;
            gap: 8px;
        }
        .timeline-nav {
            grid-template-columns: 1fr 1fr;
            gap: 6px;
        }
        .timeline-nav__date {
            grid-column: 1 / -1;
            grid-row: 1;
        }
        .timeline-nav .btn:nth-of-type(1) { grid-column: 1; grid-row: 2; }
        .timeline-nav .btn:nth-of-type(2) { grid-column: 1; grid-row: 3; }
        .timeline-nav .btn:nth-of-type(3) { grid-column: 2; grid-row: 3; }
        .timeline-nav .btn {
            min-height: 32px;
            font-size: 10.5px;
            padding: 5px 8px;
        }
        .field select,
        .field input[type="date"] {
            font-size: 12px;
            padding: 8px 10px;
        }
        .ctrl-bar .btn--primary {
            min-height: 36px;
            font-size: 11px;
        }
        .ctrl-strip__actions {
            grid-template-columns: 1fr;
        }
        .ctrl-strip__iconbtn {
            height: 34px;
            font-size: 10.5px;
        }
    }

    /* â•â•â• DATE-SCOPED DAILY STRIP â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    .day-strip {
        background: linear-gradient(180deg, var(--bg-card), var(--bg-subtle));
        border: 1px solid var(--border); border-radius: var(--r-lg);
        padding: 16px 18px;
    }
    .day-strip__head {
        display: flex; justify-content: space-between; align-items: baseline;
        margin-bottom: 14px; gap: 12px; flex-wrap: wrap;
    }
    .day-strip__head h2 { font-size: 13px; font-weight: 600; letter-spacing: -0.005em; color: var(--text); }
    .day-strip__head h2 strong { font-family: var(--fm); color: var(--accent); font-weight: 600; }
    .day-strip__head small { font-size: 11px; color: var(--text-subtle); font-family: var(--fm); }
    .day-strip__grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 10px; }
    @@media (max-width: 1280px) { .day-strip__grid { grid-template-columns: repeat(3, 1fr); } }
    @@media (max-width: 680px) { .day-strip__grid { grid-template-columns: repeat(2, 1fr); } }

    .day-kpi { display: flex; flex-direction: column; gap: 3px; padding: 10px 12px; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--r); transition: all var(--tx); }
    .day-kpi:hover { border-color: var(--border-strong); box-shadow: var(--sh-xs); }
    .day-kpi__lbl { font-size: 9.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-subtle); }
    .day-kpi__val { font-size: 18px; font-weight: 700; font-family: var(--fm); letter-spacing: -0.03em; color: var(--text); line-height: 1.1; }
    .day-kpi__sub { font-size: 10.5px; color: var(--text-subtle); line-height: 1.4; }
    .day-kpi__val--ok { color: var(--green); }
    .day-kpi__val--warn { color: var(--amber); }
    .day-kpi__val--accent { color: var(--accent); }

    /* â•â•â• DATA SOURCE BAR â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    .datasource {
        display: flex; justify-content: space-between; align-items: center; gap: 14px;
        padding: 10px 16px; background: var(--bg-card); border: 1px solid var(--border);
        border-radius: var(--r-md); flex-wrap: wrap;
        font-size: 11.5px;
    }
    .datasource__group { display: flex; gap: 22px; flex-wrap: wrap; align-items: center; width: 100%; }
    .datasource__item { display: flex; flex-direction: column; gap: 1px; }
    .datasource__lbl { font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.13em; color: var(--text-subtle); }
    .datasource__val { font-family: var(--fm); font-weight: 500; color: var(--text); font-size: 12px; }
    .datasource__val strong { font-weight: 700; color: var(--accent); }
    .datasource__item--refresh { min-width: 190px; }
    .datasource-refresh { display: grid; grid-template-columns: minmax(118px, 1fr) auto; gap: 9px; align-items: center; }
    .datasource-refresh__range {
        width: 100%;
        min-width: 118px;
        accent-color: var(--accent);
        cursor: pointer;
    }
    .datasource-refresh__value { min-width: 44px; text-align: right; white-space: nowrap; }
    @@media (max-width: 680px) {
        .datasource__item--refresh { min-width: min(100%, 220px); }
        .datasource-refresh { grid-template-columns: minmax(132px, 1fr) auto; }
    }

    /* â•â•â• FULL-WIDTH MAIN CHART â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    .main-chart {
        position: relative;
        overflow: hidden;
        background:
            radial-gradient(circle at 0% 0%, rgba(21, 128, 61, 0.10), transparent 24%),
            radial-gradient(circle at top left, rgba(217, 119, 6, 0.13), transparent 24%),
            radial-gradient(circle at top right, rgba(79, 70, 229, 0.14), transparent 26%),
            linear-gradient(180deg, rgba(255,255,255,0.99), rgba(248,248,246,0.95));
        border: 1px solid rgba(230, 230, 227, 0.92);
        border-radius: var(--r-xl); padding: 24px 26px 22px;
        width: 100%;
        box-shadow: 0 26px 54px rgba(15, 15, 14, 0.09), inset 0 1px 0 rgba(255,255,255,0.88);
    }
    .main-chart::before {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background:
            radial-gradient(circle at 18% 14%, rgba(255,255,255,0.74), transparent 22%),
            radial-gradient(circle at 82% 12%, rgba(255,255,255,0.54), transparent 20%);
        opacity: 0.9;
    }
    .main-chart > * { position: relative; z-index: 1; }
    .main-chart__head { display: flex; align-items: flex-start; justify-content: space-between; gap: 20px; margin-bottom: 16px; flex-wrap: wrap; }
    .main-chart__title { display: flex; flex-direction: column; gap: 2px; }
    .main-chart__title .eyebrow { font-size: 9.5px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-subtle); }
    .main-chart__title h2 { font-size: 18px; font-weight: 700; letter-spacing: -0.02em; color: var(--text); line-height: 1.18; }
    .main-chart__title p { font-size: 11.5px; color: var(--text-muted); font-family: var(--fm); }

    .main-chart__controls { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
    .main-chart__feature-row {
        display: none;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 14px;
    }
    .chart-feature {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 7px 12px;
        border-radius: 999px;
        border: 1px solid rgba(230, 230, 227, 0.96);
        background: linear-gradient(180deg, rgba(255,255,255,0.92), rgba(248,248,246,0.96));
        box-shadow: 0 10px 22px rgba(15, 15, 14, 0.05);
        color: var(--text-muted);
        font-size: 10.5px;
        font-family: var(--fm);
        white-space: nowrap;
    }
    .chart-feature::before {
        content: "";
        width: 7px;
        height: 7px;
        border-radius: 999px;
        background: var(--accent);
        box-shadow: 0 0 0 4px rgba(26, 86, 219, 0.08);
        flex-shrink: 0;
    }
    .chart-feature strong {
        color: var(--text);
        font-weight: 700;
        font-family: var(--ff);
        letter-spacing: -0.01em;
    }

    .main-chart__canvas-wrap {
        position: relative; height: 440px; width: 100%;
        border: 1px solid rgba(230, 230, 227, 0.94);
        padding: 16px 16px 0;
        border-radius: calc(var(--r-lg) + 4px);
        overflow: hidden;
        isolation: isolate;
        background:
            radial-gradient(circle at 14% 10%, rgba(217, 119, 6, 0.12), transparent 24%),
            radial-gradient(circle at 84% 10%, rgba(79, 70, 229, 0.14), transparent 26%),
            linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(248, 248, 246, 0.92) 56%, rgba(244, 246, 249, 0.90) 100%);
        box-shadow: inset 0 0 0 1px rgba(255,255,255,0.76), inset 0 -24px 42px rgba(15,15,14,0.03);
    }
    .main-chart__canvas-wrap::before,
    .main-chart__canvas-wrap::after {
        content: "";
        position: absolute;
        inset: 16px 0 0;
        pointer-events: none;
    }
    .main-chart__canvas-wrap::before {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0));
        z-index: 0;
    }
    .main-chart__canvas-wrap::after {
        inset: auto 0 0;
        height: 56px;
        background: linear-gradient(180deg, rgba(250, 250, 249, 0), rgba(250, 250, 249, 0.92));
        z-index: 0;
    }
    .main-chart__canvas-wrap canvas { position: relative; z-index: 1; cursor: crosshair; }
    .chart-loading-strip {
        position: absolute;
        inset: 0 0 auto;
        height: 3px;
        border-radius: 999px;
        overflow: hidden;
        background: rgba(26, 86, 219, 0.10);
        opacity: 0;
        transform: translateY(-6px);
        transition: opacity var(--tx), transform var(--tx);
        z-index: 2;
        pointer-events: none;
    }
    .chart-loading-strip::after {
        content: "";
        position: absolute;
        inset: 0;
        width: 42%;
        border-radius: inherit;
        background: linear-gradient(90deg, rgba(26, 86, 219, 0), rgba(26, 86, 219, 0.95), rgba(26, 86, 219, 0));
        animation: chartLoadingSlide 1.1s ease-in-out infinite;
    }
    .main-chart__canvas-wrap.is-chart-loading .chart-loading-strip,
    .chart-wrap.is-chart-loading .chart-loading-strip {
        opacity: 1;
        transform: translateY(0);
    }
    .main-chart__canvas-wrap.is-chart-loading canvas,
    .chart-wrap.is-chart-loading canvas {
        opacity: 0.5;
        transition: opacity var(--tx);
    }
    .chart-playhead {
        position: absolute;
        inset: 16px 0 0;
        z-index: 2;
        pointer-events: none;
        opacity: 0;
        transition: opacity var(--tx), transform var(--tx);
    }
    .chart-playhead.is-visible { opacity: 1; }
    .chart-playhead__line {
        position: absolute;
        top: 10px;
        bottom: 0;
        width: 2px;
        transform: translateX(-50%);
        background: linear-gradient(180deg, rgba(26, 86, 219, 0.9), rgba(26, 86, 219, 0.18));
        box-shadow: 0 0 0 1px rgba(255,255,255,0.72);
    }
    .chart-playhead__cap {
        position: absolute;
        top: 2px;
        width: 12px;
        height: 12px;
        border-radius: 999px;
        transform: translateX(-50%);
        background: #fff;
        border: 2px solid var(--accent);
        box-shadow: 0 6px 16px rgba(26, 86, 219, 0.22);
    }
    .chart-playhead__dot {
        position: absolute;
        width: 12px;
        height: 12px;
        border-radius: 999px;
        transform: translate(-50%, -50%);
        background: #fff;
        border: 2px solid var(--accent);
        box-shadow: 0 8px 20px rgba(26, 86, 219, 0.22);
    }
    .chart-playhead__label {
        position: absolute;
        top: 8px;
        transform: translateX(-50%);
        padding: 6px 10px;
        border-radius: 999px;
        background: rgba(15, 15, 14, 0.88);
        color: #fff;
        font-size: 10.5px;
        font-weight: 600;
        font-family: var(--fm);
        white-space: nowrap;
        letter-spacing: -0.01em;
        box-shadow: 0 14px 30px rgba(15, 15, 14, 0.18);
    }
    @@media (max-width: 1100px) { .main-chart__canvas-wrap { height: 360px; } }
    @@media (max-width: 680px) {
        .main-chart { padding: 20px 18px 18px; }
        .main-chart__head { gap: 12px; }
        .main-chart__title h2 { font-size: 16px; }
        .main-chart__canvas-wrap { height: 340px; padding: 14px 8px 0; border-radius: var(--r-md); }
        .main-chart__feature-row { gap: 6px; }
        .chart-feature { padding: 6px 10px; font-size: 10px; }
    }

    /* Readout row under chart — shows hovered or latest values */
    .chart-readout {
        display: grid; grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0; margin-top: 16px;
        background: var(--bg-subtle); border: 1px solid var(--border);
        border-radius: var(--r); overflow: hidden;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.82);
    }
    @@media (max-width: 1280px) { .chart-readout { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
    @@media (max-width: 1100px) { .chart-readout { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
    @@media (max-width: 680px) { .chart-readout { grid-template-columns: repeat(2, 1fr); } }

    .chart-readout__cell {
        min-height: 72px;
        padding: 12px 14px; border-right: 1px solid var(--border);
        display: flex; flex-direction: column; gap: 1px;
        transition: background var(--tx), opacity var(--tx);
        background: linear-gradient(180deg, rgba(255,255,255,0.74), rgba(248,248,246,0.9));
    }
    .chart-readout__cell:nth-child(4n) { border-right: none; }
    @@media (max-width: 1280px) { .chart-readout__cell:nth-child(4n) { border-right: 1px solid var(--border); } .chart-readout__cell:nth-child(3n) { border-right: none; } }
    @@media (max-width: 1100px) { .chart-readout__cell:nth-child(3n) { border-right: 1px solid var(--border); } .chart-readout__cell:nth-child(2n) { border-right: none; } }
    .chart-readout__cell:last-child { border-right: none; }
    .chart-readout__cell.is-hidden { opacity: 0.3; }
    .chart-readout__lbl { display: flex; align-items: center; gap: 6px; font-size: 9.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-subtle); }
    .chart-readout__lbl::before { content: ''; width: 8px; height: 8px; border-radius: 2px; background: var(--cr-color, var(--border-strong)); }
    .chart-readout__val { font-size: 18px; font-weight: 700; font-family: var(--fm); letter-spacing: -0.04em; color: var(--text); line-height: 1.08; margin-top: 3px; }
    .chart-readout__sub { font-size: 10px; color: var(--text-subtle); font-family: var(--fm); }
    .chart-readout__meta {
        grid-column: 1 / -1; padding: 8px 12px;
        font-size: 10.5px; color: var(--text-subtle); font-family: var(--fm);
        border-top: 1px solid var(--border); background: var(--bg-card);
        display: flex; justify-content: space-between; align-items: center; gap: 10px; flex-wrap: nowrap;
        overflow-x: auto;
    }
    .chart-readout__meta strong { color: var(--text); font-weight: 600; }
    .chart-readout__meta-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }
    .chart-meta-pill {
        display: inline-flex;
        align-items: center;
        padding: 5px 9px;
        border-radius: 999px;
        background: rgba(255,255,255,0.86);
        border: 1px solid rgba(230, 230, 227, 0.94);
        color: var(--text-muted);
        line-height: 1;
    }
    .chart-readout__weather {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: 8px;
        min-width: 0;
        padding: 6px 8px;
        border-radius: 999px;
        border: 1px solid rgba(230, 230, 227, 0.94);
        background: linear-gradient(180deg, rgba(255,255,255,0.96), rgba(248,248,246,0.92));
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.82);
        white-space: nowrap;
        overflow-x: auto;
    }
    .chart-readout__weather-head {
        display: flex;
        align-items: center;
        gap: 6px;
        flex: 0 0 auto;
    }
    .chart-readout__weather-title {
        font-size: 8.5px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--text-subtle);
    }
    .chart-readout__weather-head strong {
        font-size: 10px;
        font-family: var(--fm);
        letter-spacing: -0.02em;
    }
    .chart-readout__weather-kpis {
        display: flex;
        align-items: center;
        gap: 4px;
        flex: 0 0 auto;
    }
    .chart-weather-pill {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 5px 7px;
        border-radius: 999px;
        background: rgba(255,255,255,0.86);
        border: 1px solid rgba(230, 230, 227, 0.88);
    }
    .chart-weather-pill small {
        font-size: 7.5px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--text-subtle);
    }
    .chart-weather-pill strong {
        font-size: 11px;
        font-family: var(--fm);
        line-height: 1;
        color: var(--text);
    }
    .chart-readout__weather[data-state='empty'] .chart-weather-pill strong {
        color: var(--text-subtle);
    }
    @@media (max-width: 1180px) {
        .chart-readout__meta {
            align-items: stretch;
            flex-wrap: wrap;
            overflow-x: visible;
        }
        .chart-readout__weather {
            margin-left: 0;
            min-width: 100%;
            border-radius: 12px;
            white-space: normal;
            overflow-x: visible;
            flex-wrap: wrap;
        }
        .chart-readout__weather-kpis {
            flex-wrap: wrap;
            gap: 6px;
        }
    }
    @@media (max-width: 760px) {
        .chart-readout__weather {
            padding: 8px;
        }
    }

    /* â•â•â• SCORE PANEL (reworked â€” multi-factor) â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    .score-wrap { display: flex; flex-direction: column; align-items: center; padding: 4px 0; gap: 14px; }
    .score-ring-box { position: relative; display: flex; align-items: center; justify-content: center; width: 140px; height: 140px; }
    .score-ring-svg { overflow: visible; }
    .score-ring-svg .track { fill: none; stroke: var(--bg-muted); stroke-width: 9; }
    .score-ring-svg .fill { fill: none; stroke-width: 9; stroke-linecap: round; transition: stroke-dashoffset 1.3s cubic-bezier(0.4, 0, 0.2, 1); animation: scoreReveal 1.3s cubic-bezier(0.4, 0, 0.2, 1) both; }
    .score-inner { position: absolute; display: flex; flex-direction: column; align-items: center; text-align: center; }
    .score-inner strong { font-size: 34px; font-weight: 700; font-family: var(--fm); letter-spacing: -0.05em; line-height: 1; }
    .score-inner span { font-size: 10.5px; color: var(--text-subtle); margin-top: 3px; font-family: var(--fm); }

    .score-factors { display: flex; flex-direction: column; gap: 9px; width: 100%; }
    .sf-row { display: flex; flex-direction: column; gap: 4px; }
    .sf-head { display: flex; justify-content: space-between; align-items: baseline; }
    .sf-head__lbl { font-size: 11.5px; color: var(--text-muted); font-weight: 500; }
    .sf-head__val { font-size: 11.5px; font-weight: 600; font-family: var(--fm); color: var(--text); }
    .sf-bar { height: 5px; background: var(--bg-muted); border-radius: 3px; overflow: hidden; }
    .sf-bar span {
        display: block; height: 100%; border-radius: 3px;
        background: linear-gradient(90deg, var(--sf-c, var(--accent)) 0%, var(--sf-c2, #60A5FA) 100%);
        animation: barGrow 1s cubic-bezier(0.4, 0, 0.2, 1) both;
    }
    .score-explainer {
        font-size: 10.5px; color: var(--text-subtle); line-height: 1.5;
        padding: 8px 10px; background: var(--bg-subtle); border-radius: var(--r-sm);
        border: 1px dashed var(--border); margin-top: 4px;
    }
    .score-explainer strong { color: var(--text-muted); font-weight: 600; }
    .ws-body {
        padding-top: 10px;
    }

    /* â•â•â• LIVE PANEL (instants only) â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    .live-grid {
        display: grid; grid-template-columns: repeat(3, 1fr);
        gap: 1px; background: var(--border);
        border-radius: var(--r); overflow: hidden; margin-bottom: 12px;
    }
    .live-cell { background: var(--bg-card); padding: 10px 12px; display: flex; flex-direction: column; gap: 2px; transition: background var(--tx); }
    .live-cell:hover { background: var(--bg-muted); }
    .live-cell .lc-lbl { display: flex; align-items: center; gap: 5px; font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.11em; color: var(--text-subtle); }
    .live-cell .lc-lbl::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--lc-color, var(--border-strong)); }
    .live-cell strong { font-size: 17px; font-weight: 700; font-family: var(--fm); letter-spacing: -0.03em; color: var(--text); line-height: 1.1; }
    .live-cell .lc-dir { font-size: 9.5px; font-weight: 500; color: var(--text-subtle); margin-top: 1px; font-family: var(--fm); }

    .live-mini-bars { display: flex; flex-direction: column; gap: 9px; }
    .lmb { display: flex; flex-direction: column; gap: 4px; }
    .lmb__head { display: flex; justify-content: space-between; font-size: 11px; }
    .lmb__head span { color: var(--text-muted); font-weight: 500; }
    .lmb__head strong { font-family: var(--fm); font-weight: 600; color: var(--text); }
    .lmb__bar { height: 4px; background: var(--bg-muted); border-radius: 2px; overflow: hidden; }
    .lmb__bar span {
        display: block; height: 100%; border-radius: 2px;
        background: linear-gradient(90deg, var(--lmb-c, var(--accent)) 0%, var(--lmb-c2, #60A5FA) 100%);
        transition: width var(--tx-slow);
    }

    /* â•â•â• ALLOCATION FLOW (absolute kWh, not %) â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    .alloc-card {
        position: relative;
        overflow: hidden;
        background:
            radial-gradient(circle at top right, rgba(8,145,178,0.12), transparent 24%),
            radial-gradient(circle at top left, rgba(217,119,6,0.10), transparent 28%),
            linear-gradient(180deg, rgba(255,255,255,0.96), rgba(248,248,246,0.94));
    }
    .alloc-card::before {
        content: '';
        position: absolute;
        inset: 0;
        pointer-events: none;
        background:
            linear-gradient(135deg, rgba(255,255,255,0.44), transparent 32%),
            linear-gradient(180deg, rgba(15,15,14,0.015), transparent 22%);
        opacity: 0.9;
    }
    .alloc-stack { position: relative; z-index: 1; display: flex; flex-direction: column; gap: 14px; }
    .alloc-overview {
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
        gap: 14px;
        align-items: stretch;
    }
    .alloc-hero {
        padding: 16px 18px;
        border-radius: 18px;
        border: 1px solid rgba(230, 230, 227, 0.9);
        background:
            linear-gradient(135deg, rgba(255,255,255,0.92), rgba(255,255,255,0.72)),
            linear-gradient(135deg, rgba(217,119,6,0.06), rgba(8,145,178,0.05));
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.84);
        display: grid;
        gap: 8px;
    }
    .alloc-hero__eyebrow {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--text-subtle);
    }
    .alloc-hero strong {
        font-size: clamp(28px, 3vw, 42px);
        line-height: 0.95;
        letter-spacing: -0.06em;
        color: var(--text);
    }
    .alloc-hero p {
        font-size: 12.5px;
        line-height: 1.5;
        color: var(--text-muted);
        max-width: 52ch;
    }
    .alloc-hero__meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }
    .alloc-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 10px;
        border-radius: 999px;
        border: 1px solid rgba(230, 230, 227, 0.92);
        background: rgba(255,255,255,0.8);
        font-size: 10.5px;
        color: var(--text-muted);
    }
    .alloc-chip strong {
        font-size: 11px;
        font-family: var(--fm);
        letter-spacing: -0.02em;
        color: var(--text);
    }
    .alloc-mini-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
    }
    .alloc-mini {
        padding: 14px 14px 12px;
        border-radius: 16px;
        border: 1px solid rgba(230, 230, 227, 0.9);
        background: rgba(255,255,255,0.76);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.84);
        display: grid;
        gap: 4px;
    }
    .alloc-mini span {
        font-size: 9.5px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--text-subtle);
    }
    .alloc-mini strong {
        font-size: 20px;
        line-height: 1;
        font-family: var(--fm);
        letter-spacing: -0.05em;
        color: var(--text);
    }
    .alloc-mini small {
        font-size: 11px;
        color: var(--text-muted);
        line-height: 1.45;
    }
    .alloc-block {
        padding: 14px 14px 12px;
        border-radius: 18px;
        border: 1px solid rgba(230, 230, 227, 0.9);
        background: rgba(255,255,255,0.72);
    }
    .alloc-section__head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 8px; }
    .alloc-section__head span { font-size: 10.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-subtle); }
    .alloc-section__head strong { font-size: 14px; font-weight: 700; font-family: var(--fm); color: var(--text); letter-spacing: -0.02em; }
    .alloc-flow-bar {
        display: flex;
        height: 34px;
        border-radius: 12px;
        overflow: hidden;
        background: linear-gradient(180deg, rgba(244,244,242,0.95), rgba(234,234,231,0.92));
        border: 1px solid var(--border);
        box-shadow: inset 0 1px 1px rgba(255,255,255,0.75);
    }
    .alloc-flow-seg {
        display: flex; align-items: center; justify-content: center;
        min-width: 0; position: relative;
        font-size: 10px; font-weight: 700; font-family: var(--fm);
        color: #fff; transition: all var(--tx); overflow: hidden; white-space: nowrap;
        text-shadow: 0 1px 2px rgba(15,15,14,0.18);
    }
    .alloc-flow-seg:hover { filter: brightness(0.92); }
    .alloc-flow-seg--pv { background: linear-gradient(135deg, var(--solar), var(--solar-2)); }
    .alloc-flow-seg--bat { background: linear-gradient(135deg, var(--battery), var(--battery-2)); }
    .alloc-flow-seg--grid { background: linear-gradient(135deg, var(--grid-c), #64748B); }
    .alloc-flow-seg--export { background: linear-gradient(135deg, var(--export-c), #06B6D4); }
    .alloc-legend { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 10px; }
    .alloc-legend-item { display: flex; align-items: center; gap: 6px; font-size: 11px; color: var(--text-muted); }
    .alloc-legend-item::before { content: ''; width: 10px; height: 10px; border-radius: 2px; background: var(--al-c, var(--border-strong)); }
    .alloc-legend-item strong { font-family: var(--fm); font-weight: 600; color: var(--text); }
    .alloc-chart-shell {
        padding: 14px;
        border-radius: 20px;
        border: 1px solid rgba(230, 230, 227, 0.9);
        background: linear-gradient(180deg, rgba(255,255,255,0.94), rgba(248,248,246,0.9));
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.88);
    }
    .alloc-chart-shell__head {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 10px;
        margin-bottom: 10px;
    }
    .alloc-chart-shell__head span {
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--text-subtle);
    }
    .chart-wrap--alloc { height: 138px; }
    @@media (max-width: 1100px) {
        .alloc-overview { grid-template-columns: 1fr; }
    }
    @@media (max-width: 760px) {
        .alloc-mini-grid { grid-template-columns: 1fr; }
        .chart-wrap--alloc { height: 148px; }
    }

    /* â•â•â• RELAY GRID â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    .relay-grid {
        --relay-min: 140px;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(var(--relay-min), 1fr));
        gap: 8px;
        align-items: stretch;
    }
    .relay-grid--single {
        --relay-min: 260px;
        grid-template-columns: minmax(240px, 320px);
    }
    .relay-grid--few { --relay-min: 176px; }
    .relay-grid--dense { --relay-min: 128px; }
    .relay-chip {
        background: var(--bg-muted); border: 1px solid var(--border); border-radius: var(--r);
        padding: 11px 12px 10px; display: flex; flex-direction: column; gap: 2px;
        position: relative; overflow: hidden; transition: all var(--tx); min-height: 118px;
    }
    .relay-chip::after { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2.5px; background: var(--border-strong); }
    .relay-chip.is-on { background: var(--green-muted); border-color: var(--green-border); animation: chipBlink 3s ease-in-out infinite; }
    .relay-chip.is-on::after { background: var(--green); }
    .relay-chip span { font-size: 10.5px; font-weight: 600; color: var(--text-muted); }
    .relay-chip strong { font-size: 15px; font-weight: 700; font-family: var(--fm); color: var(--text); letter-spacing: -0.02em; }
    .relay-chip small { font-size: 10px; color: var(--text-subtle); }
    .relay-chip em { font-style: normal; font-size: 9.5px; color: var(--text-subtle); margin-top: 2px; font-family: var(--fm); }
    .relay-chip__track { height: 2.5px; background: rgba(0, 0, 0, 0.08); border-radius: 2px; overflow: hidden; margin-top: 7px; }
    .relay-chip__track span { display: block; height: 100%; border-radius: 2px; background: var(--green); font-size: 0; transition: width 0.7s cubic-bezier(0.4, 0, 0.2, 1); }

    /* â•â•â• CHART WRAPPERS â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    .chart-wrap {
        position: relative;
        border-radius: calc(var(--r-md) + 2px);
        overflow: hidden;
        isolation: isolate;
        background:
            radial-gradient(circle at 16% 8%, rgba(217, 119, 6, 0.09), transparent 24%),
            radial-gradient(circle at 84% 10%, rgba(79, 70, 229, 0.08), transparent 26%),
            linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(248, 248, 246, 0.91) 100%);
        box-shadow: inset 0 0 0 1px rgba(230, 230, 227, 0.72), 0 14px 26px rgba(15, 15, 14, 0.05);
    }
    .chart-wrap::before,
    .chart-wrap::after {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
    }
    .chart-wrap::before {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.68), rgba(255, 255, 255, 0));
        z-index: 0;
    }
    .chart-wrap::after {
        inset: auto 0 0;
        height: 42px;
        background: linear-gradient(180deg, rgba(250, 250, 249, 0), rgba(250, 250, 249, 0.86));
        z-index: 0;
    }
    .chart-wrap canvas { position: relative; z-index: 1; }
    .chart-wrap--xs { height: 150px; }
    .chart-wrap--sm { height: 200px; }
    .chart-wrap--md { height: 260px; }
    .chart-wrap--lg { height: 320px; }
    .chart-wrap--trend-feature { height: 348px; }
    .chart-wrap--trend-main { height: 208px; }
    .chart-wrap--trend-mini { height: 108px; }
    #telemetry .panel,
    #grid-phases .panel {
        display: flex;
        flex-direction: column;
    }
    #telemetry .chart-wrap--sm,
    #grid-phases .chart-wrap--sm { height: 286px; }

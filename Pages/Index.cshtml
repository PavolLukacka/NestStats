    /* â•â•â• STAT TABLE â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    #statistics { width: 100%; }
    .stats-panel { width: 100%; }
    #statistics .stat-table { width: 100%; display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 1px; background: var(--border); border-radius: var(--r); overflow: hidden; }
    .st-cell { min-width: 0; background: var(--bg-card); padding: 12px 14px; }
    .st-cell .st-lbl { font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.13em; color: var(--text-subtle); margin-bottom: 8px; }
    .st-row { display: flex; justify-content: space-between; align-items: center; padding: 3px 0; }
    .st-row span { font-size: 11.5px; color: var(--text-muted); }
    .st-row strong { font-size: 11.5px; font-weight: 600; font-family: var(--fm); color: var(--text); }
    @@media (max-width: 1100px) { #statistics .stat-table { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
    @@media (max-width: 680px) { #statistics .stat-table { grid-template-columns: 1fr; } }

    /* â•â•â• FLOW GRAPH (energy topology) â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    .flow-shell__primary { overflow: hidden; }
    .flow-graph {
        position: relative;
        display: grid;
        grid-template-areas:
            ". pv-node ."
            "grid-node inv-node home-node"
            "bat-node . watt-node";
        grid-template-columns: repeat(3, minmax(170px, 1fr));
        align-items: center;
        justify-items: center;
        gap: 22px 26px;
        min-height: 500px;
        padding: 22px 6px 10px;
        isolation: isolate;
    }
    .flow-graph::before {
        content: "";
        position: absolute;
        inset: 38px 10% 24px;
        border-radius: 34px;
        background:
            radial-gradient(circle at top, rgba(217,119,6,0.10), transparent 24%),
            radial-gradient(circle at center, rgba(26,86,219,0.10), transparent 32%),
            radial-gradient(circle at bottom left, rgba(124,58,237,0.10), transparent 26%),
            linear-gradient(180deg, rgba(255,255,255,0.46), rgba(248,248,246,0.12));
        pointer-events: none;
        z-index: 0;
    }
    .flow-links {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 0;
    }
    .flow-link {
        position: absolute;
        --flow-c: rgba(15,15,14,0.16);
        opacity: 0.9;
        filter: drop-shadow(0 6px 12px rgba(15,15,14,0.06));
    }
    .flow-link::before,
    .flow-link::after {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: 999px;
    }
    .flow-link::before {
        background: linear-gradient(90deg, rgba(255,255,255,0.18), var(--flow-c), rgba(255,255,255,0.18));
        opacity: 0.45;
    }
    .flow-link::after {
        background: linear-gradient(90deg, rgba(255,255,255,0), rgba(255,255,255,0.88), rgba(255,255,255,0));
        background-size: 42px 100%;
        background-repeat: no-repeat;
        animation: flowPulseTravel 1.9s linear infinite;
        opacity: 0;
    }
    .flow-link.is-active::before { opacity: 0.72; }
    .flow-link.is-active::after { opacity: 1; }
    .flow-link.is-reverse::after { animation-direction: reverse; }
    .flow-link.is-idle::after { animation: none; opacity: 0; }
    .flow-link--pv   { left: calc(50% - 2px); top: 124px; width: 4px; height: 108px; --flow-c: rgba(217,119,6,0.58); transform: translateX(-50%); }
    .flow-link--grid { left: 20.5%; top: 248px; width: 29.5%; height: 4px; --flow-c: rgba(71,85,105,0.58); }
    .flow-link--home { right: 20.5%; top: 248px; width: 29.5%; height: 4px; --flow-c: rgba(21,128,61,0.58); }
    .flow-link--bat  { left: 16.8%; top: 430px; width: 33.8%; height: 4px; --flow-c: rgba(124,58,237,0.58); transform-origin: left center; transform: rotate(-18deg); }
    .flow-link--watt { right: 16.8%; top: 430px; width: 33.8%; height: 4px; --flow-c: rgba(8,145,178,0.58); transform-origin: right center; transform: rotate(18deg); }
    .fn {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        gap: 6px;
        align-items: center;
        justify-content: center;
        text-align: center;
        width: min(100%, 228px);
        min-height: 118px;
        padding: 18px 18px 16px;
        border-radius: 28px;
        border: 1px solid rgba(255,255,255,0.72);
        box-shadow:
            0 18px 38px rgba(15,15,14,0.08),
            inset 0 1px 0 rgba(255,255,255,0.86);
        backdrop-filter: blur(12px);
        transition: transform var(--tx-md), box-shadow var(--tx-md), border-color var(--tx-md);
    }
    .fn:hover {
        transform: translateY(-3px);
        box-shadow:
            0 22px 42px rgba(15,15,14,0.12),
            inset 0 1px 0 rgba(255,255,255,0.88);
    }
    .fn__lbl { font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.16em; color: var(--text-subtle); }
    .fn strong { font-size: 28px; font-weight: 700; font-family: var(--fm); letter-spacing: -0.05em; line-height: 0.95; }
    .fn span:not(.fn__lbl) { font-size: 10.5px; color: var(--text-muted); font-family: var(--fm); line-height: 1.45; }
    .fn-meter {
        width: 100%;
        height: 5px;
        margin-top: 6px;
        border-radius: 999px;
        background: rgba(15,15,14,0.08);
        overflow: hidden;
    }
    .fn-meter span {
        display: block;
        height: 100%;
        border-radius: inherit;
        transition: width 0.9s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .fn--pv   { grid-area: pv-node;   background: linear-gradient(180deg, #FFF8E6, #FFFDF8); border-color: #FDE68A; }
    .fn--pv .fn__lbl { color: #92400E; } .fn--pv strong { color: #9A3412; } .fn--pv .fn-meter span { background: linear-gradient(90deg, #F59E0B, #FBBF24); }
    .fn--inv  {
        grid-area: inv-node;
        width: min(100%, 250px);
        min-height: 144px;
        background:
            radial-gradient(circle at top, rgba(26,86,219,0.18), transparent 54%),
            linear-gradient(180deg, #EFF6FF, #F8FBFF);
        border-color: #93C5FD;
        box-shadow:
            0 24px 50px rgba(26,86,219,0.14),
            inset 0 1px 0 rgba(255,255,255,0.92);
    }
    .fn--inv::after {
        content: "";
        position: absolute;
        inset: 12px;
        border-radius: 22px;
        border: 1px solid rgba(37,99,235,0.14);
        pointer-events: none;
    }
    .fn--inv .fn__lbl { color: #1E3A8A; } .fn--inv strong { color: #1D4ED8; }
    .fn--home { grid-area: home-node; background: linear-gradient(180deg, #F2FDF5, #FBFFFC); border-color: #BBF7D0; }
    .fn--home .fn__lbl { color: #166534; } .fn--home strong { color: #15803D; }
    .fn--grid { grid-area: grid-node; background: linear-gradient(180deg, #F8FAFC, #FFFFFF); border-color: #CBD5E1; }
    .fn--grid .fn__lbl { color: #334155; } .fn--grid strong { color: var(--grid-c); }
    .fn--bat  { grid-area: bat-node;  background: linear-gradient(180deg, #FAF5FF, #FCFAFF); border-color: #DDD6FE; }
    .fn--bat .fn__lbl { color: #5B21B6; } .fn--bat strong { color: #6D28D9; }
    .fn--watt { grid-area: watt-node; background: linear-gradient(180deg, #EFFBFF, #F9FDFF); border-color: #BAE6FD; }
    .fn--watt .fn__lbl { color: #075985; } .fn--watt strong { color: #0369A1; }
    .fn--watt .fn-meter span { background: linear-gradient(90deg, #0EA5E9, #38BDF8); }
    @@keyframes flowPulseTravel {
        from { background-position: -42px 50%; }
        to { background-position: calc(100% + 42px) 50%; }
    }
    @@media (max-width: 1100px) {
        .flow-graph {
            gap: 18px 16px;
            min-height: 468px;
        }
        .flow-link--grid,
        .flow-link--home { width: 26%; }
        .flow-link--bat  { left: 15.8%; top: 402px; width: 34.8%; transform: rotate(-17deg); }
        .flow-link--watt { right: 15.8%; top: 402px; width: 34.8%; transform: rotate(17deg); }
        .fn { width: min(100%, 210px); }
        .fn--inv { width: min(100%, 228px); }
    }
    @@media (max-width: 820px) {
        .flow-graph {
            min-height: auto;
            grid-template-areas:
                "pv-node"
                "inv-node"
                "home-node"
                "grid-node"
                "bat-node"
                "watt-node";
            grid-template-columns: minmax(0, 1fr);
            justify-items: stretch;
            gap: 12px;
            padding: 6px 0 0;
        }
        .flow-graph::before,
        .flow-links { display: none; }
        .fn,
        .fn--inv { width: 100%; min-height: 0; }
    }

    /* â•â•â• ECONOMY / TARIFF â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    .eco-hero { background: linear-gradient(135deg, var(--bg-muted), var(--bg-card)); border: 1px solid var(--border); border-radius: var(--r-md); padding: 18px; margin-bottom: 14px; }
    .eco-hero .e-lbl { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-subtle); }
    .eco-hero strong { display: block; font-size: 32px; font-weight: 700; font-family: var(--fm); letter-spacing: -0.05em; color: var(--text); line-height: 1.1; margin: 4px 0 2px; }
    .eco-hero small { font-size: 11.5px; color: var(--text-muted); font-family: var(--fm); }
    .eco-hero p { font-size: 11.5px; color: var(--text-subtle); margin-top: 8px; line-height: 1.5; }

    .kpi-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--border); border-radius: var(--r-sm); overflow: hidden; margin-top: 14px; }
    .kpi-cell { background: var(--bg-card); padding: 10px 12px; display: flex; flex-direction: column; gap: 2px; }
    .kpi-cell .k-lbl { font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-subtle); }
    .kpi-cell strong { font-size: 14px; font-weight: 700; font-family: var(--fm); color: var(--text); letter-spacing: -0.02em; }
    @@media (max-width: 680px) {
        .kpi-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .kpi-cell { padding: 9px 10px; min-width: 0; }
        .kpi-cell strong { font-size: 13px; overflow-wrap: anywhere; }
    }

    .tariff-toolbar { display: flex; gap: 10px; margin-bottom: 14px; flex-wrap: wrap; }
    .tariff-spot { background: var(--bg-muted); border-radius: var(--r-md); padding: 16px; margin-bottom: 12px; }
    .tariff-spot .ts-prov { font-size: 10.5px; font-weight: 500; color: var(--text-muted); font-family: var(--fm); }
    .tariff-spot .ts-rate { display: block; font-size: 24px; font-weight: 700; font-family: var(--fm); letter-spacing: -0.04em; color: var(--text); margin: 4px 0 1px; }
    .tariff-spot .ts-code { font-size: 11.5px; color: var(--text-muted); font-family: var(--fm); }
    .tariff-spot .ts-note { font-size: 11px; color: var(--text-subtle); margin-top: 8px; line-height: 1.5; }

    .stat-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 8px; }
    .stat-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--r); padding: 12px 14px; display: flex; flex-direction: column; gap: 3px; transition: all var(--tx); }
    .stat-card:hover { border-color: var(--border-strong); box-shadow: var(--sh-xs); }
    .stat-card .sc-lbl { font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-subtle); }
    .stat-card strong { font-size: 16px; font-weight: 700; font-family: var(--fm); color: var(--text); letter-spacing: -0.02em; }
    .stat-card small { font-size: 10.5px; color: var(--text-subtle); }

    .tariff-g { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 8px; margin-top: 14px; }
    .t-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--r-md); padding: 14px; cursor: pointer; transition: all var(--tx); display: flex; flex-direction: column; gap: 8px; }
    .t-card:hover { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-ring); }
    .t-card.is-active { border-color: var(--accent); background: var(--accent-muted); box-shadow: 0 0 0 3px var(--accent-ring); }
    .t-card__head { display: flex; justify-content: space-between; align-items: flex-start; gap: 8px; }
    .t-card__head h3 { font-size: 13.5px; font-weight: 700; color: var(--text); letter-spacing: -0.01em; }
    .t-card__head strong { font-size: 13px; font-weight: 700; font-family: var(--fm); color: var(--green); letter-spacing: -0.02em; white-space: nowrap; }

                    };

                    function pickNumber(...values) {
                        for (const value of values) {
                            const parsed = Number(value);
                            if (Number.isFinite(parsed)) return parsed;
                        }
                        return 0;
                    }

                    const tlabels = T.map(t => t.TimeLabel || '');

                    const weatherHours = (D.Weather?.hourly || []).map(point => ({
                        Time: point.time || '',
                        Label: point.label || '',
                        TemperatureC: point.temperatureC || 0,
                        CloudCoverPct: point.cloudCoverPct || 0,
                        PrecipitationMm: point.precipitationMm || 0,
                        WindKph: point.windKph || 0,
                        ShortwaveRadiationWm2: point.shortwaveRadiationWm2 || 0,
                        DirectRadiationWm2: point.directRadiationWm2 || 0,
                        DiffuseRadiationWm2: point.diffuseRadiationWm2 || 0,
                        EstimatedPvKw: point.estimatedPvKw || 0,
                        Date: point.time ? new Date(point.time) : null
                    }));

                    const weatherPvCtx = $('weatherPvChart');
                    let weatherPvChart = null;
                    const WEATHER_LABEL_TODAY = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("Dnes", "Today")));
                    const WEATHER_LABEL_TOMORROW = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("Zajtra", "Tomorrow")));
                    const WEATHER_LABEL_NOW = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("TERAZ", "NOW")));
                    const WEATHER_TITLE_PREFIX = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("Odhadovaná krivka výroby", "Estimated generation curve")));
                    const WEATHER_DS_EST_PV = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("Odhad FV", "Estimated PV")));
                    const WEATHER_DS_RADIATION = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("Radiacia", "Radiation")));
                    const WEATHER_DS_DIRECT_RADIATION = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("Priama rad.", "Direct rad.")));
                    const WEATHER_DS_CLOUD = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("Oblačnosť", "Cloud cover")));

                    function formatWeatherDay(date) {
                        const today = new Date();
                        const tomorrow = new Date(today);
                        tomorrow.setDate(today.getDate() + 1);
                        if (date.toDateString() === today.toDateString()) return WEATHER_LABEL_TODAY;
                        if (date.toDateString() === tomorrow.toDateString()) return WEATHER_LABEL_TOMORROW;
                        return date.toLocaleDateString('@(isEnglish ? "en-GB" : "sk-SK")', { weekday: 'short', day: '2-digit', month: '2-digit' });
                    }

                    function getWeatherDayKey(date) {
                        const year = date.getFullYear();
                        const month = String(date.getMonth() + 1).padStart(2, '0');
                        const day = String(date.getDate()).padStart(2, '0');
                        return `${year}-${month}-${day}`;
                    }

                    function getSelectableWeatherDays() {
                        const days = new Map();
                        const today = new Date();
                        const todayStart = new Date(today.getFullYear(), today.getMonth(), today.getDate());
                        weatherHours.forEach(point => {
                            if (!point.Date || Number.isNaN(point.Date.getTime())) return;
                            const key = getWeatherDayKey(point.Date);
                            if (!days.has(key)) {
                                days.set(key, new Date(point.Date.getFullYear(), point.Date.getMonth(), point.Date.getDate()));
                            }
                        });
                        const allDays = Array.from(days.entries());
                        const currentAndFuture = allDays.filter(([, date]) => date >= todayStart);
                        return (currentAndFuture.length > 0 ? currentAndFuture : allDays).slice(0, 7);
                    }

                    function getWeatherRowsForDay(dayKey) {
                        return weatherHours.filter(point => {
                            if (!point.Date || Number.isNaN(point.Date.getTime())) return false;
                            return getWeatherDayKey(point.Date) === dayKey;
                        });
                    }

                    function summarizeWeatherDay(dayKey) {
                        const rows = getWeatherRowsForDay(dayKey);
                        return {
                            rows,
                            dailyKwh: rows.reduce((sum, point) => sum + point.EstimatedPvKw, 0),
                            peakKw: rows.reduce((max, point) => Math.max(max, point.EstimatedPvKw), 0)
                        };
                    }

                    function getWeatherHourValue(label) {
                        const match = String(label || '').match(/(\d{1,2}):(\d{2})/);
                        if (!match) return null;
                        return Number(match[1]);
                    }

                    function getCurrentWeatherRowIndex(rows, dayKey) {
                        if (!rows.length) return -1;

                        const now = new Date();
                        if (dayKey !== getWeatherDayKey(now)) {
                            return -1;
                        }

                        const currentHour = now.getHours();
                        const exactLabelIndex = rows.findIndex(point => getWeatherHourValue(point.Label) === currentHour);
                        if (exactLabelIndex >= 0) {
                            return exactLabelIndex;
                        }

                        let bestIndex = -1;
                        let bestDelta = Number.POSITIVE_INFINITY;

                        rows.forEach((point, index) => {
                            const pointHour = getWeatherHourValue(point.Label);
                            if (pointHour == null) return;

                            const delta = Math.abs(pointHour - currentHour);
                            if (delta < bestDelta) {
                                bestDelta = delta;
                                bestIndex = index;
                            }
                        });

                        return bestIndex;
                    }

                    let lastWeatherStripIndex = -1;

                    function syncWeatherStripPosition(currentIndex, behavior = 'auto') {
                        const strip = $('weatherHourlyStrip');
                        if (!strip) return;

                        if (!Number.isInteger(currentIndex) || currentIndex < 0) {
                            strip.scrollTo({ left: 0, behavior: 'auto' });
                            lastWeatherStripIndex = -1;
                            return;
                        }

                        const item = strip.children[currentIndex];
                        if (!item) return;

                        const targetLeft = item.offsetLeft - Math.max(0, (strip.clientWidth - item.clientWidth) / 2);
                        strip.scrollTo({ left: Math.max(0, targetLeft), behavior });
                        lastWeatherStripIndex = currentIndex;
                    }

                    function renderWeatherHourlyStrip(rows, dayKey) {
                        const strip = $('weatherHourlyStrip');
                        if (!strip) return;
                        strip.innerHTML = '';
                        const currentRowIndex = getCurrentWeatherRowIndex(rows, dayKey);
                        rows.forEach((point, index) => {
                            const isCurrent = index === currentRowIndex;
                            const item = document.createElement('div');
                            item.className = 'weather-hour' + (isCurrent ? ' is-current' : '');
                            if (isCurrent) {
                                item.setAttribute('aria-current', 'time');
                                item.style.background = 'linear-gradient(180deg, #F5FBFF 0%, #FFFFFF 100%)';
                                item.style.borderColor = '#BAE6FD';
                                item.style.boxShadow = '0 10px 20px rgba(14,165,233,0.08), 0 0 0 2px rgba(14,165,233,0.12)';
                                item.style.transform = 'translateY(-1px)';
                            }
                            item.innerHTML = `
                                <small style="${isCurrent ? 'color:#E0F2FE;font-weight:800;' : ''}">${isCurrent ? `${WEATHER_LABEL_NOW} • ` : ''}${point.Label}</small>
                                <strong style="${isCurrent ? 'color:#082F49;' : ''}">${point.EstimatedPvKw.toFixed(1)} kW</strong>
                                <span>${point.TemperatureC.toFixed(0)} °C / ${point.CloudCoverPct.toFixed(0)} %</span>
                                <span>${point.PrecipitationMm.toFixed(1)} mm</span>`;
                            if (isCurrent) {
                                item.children[0].textContent = `${WEATHER_LABEL_NOW} - ${point.Label}`;
                                item.children[0].style.color = '#075985';
                                item.children[1].style.color = '#082F49';
                                item.children[2].style.color = '#075985';
                                item.children[3].style.color = '#075985';
                            }
                            strip.appendChild(item);
                        });
                        window.requestAnimationFrame(() => syncWeatherStripPosition(currentRowIndex));
                        window.setTimeout(() => syncWeatherStripPosition(currentRowIndex), 80);
                    }

                    function updateWeatherForecast(dayKey) {
                        const summary = summarizeWeatherDay(dayKey);
                        const rows = summary.rows;
                        const selectedDate = rows[0]?.Date || new Date(dayKey + 'T00:00:00');
                        const dayLabel = formatWeatherDay(selectedDate);
                        const dailyKwh = summary.dailyKwh;
                        const peakKw = summary.peakKw;

                        renderWeatherHourlyStrip(rows, dayKey);

                        const setText = (id, value) => { const el = $(id); if (el) el.textContent = value; };
                        setText('weatherPvBadge', `${dailyKwh.toFixed(1)} kWh`);
                        setText('weatherPeakValue', `${peakKw.toFixed(2)} kW`);
                        setText('weatherDailyEstimate', `${dailyKwh.toFixed(1)} kWh`);
                        setText('weatherSelectedDayLabel', dayLabel);
                        setText('weatherPvTitle', `${WEATHER_TITLE_PREFIX} - ${dayLabel.toLowerCase()}`);

                        const datasets = normalizeLineDatasets([
                                    ds(WEATHER_DS_EST_PV, rows.map(point => point.EstimatedPvKw), COLORS.pv, COLORS.pvA, { yAxisID: 'y' }),
                                    ds(WEATHER_DS_RADIATION, rows.map(point => point.ShortwaveRadiationWm2), COLORS.exp, null, { yAxisID: 'yRad', borderDash: [6, 4], glow: false }),
                                    ds(WEATHER_DS_DIRECT_RADIATION, rows.map(point => point.DirectRadiationWm2), COLORS.soc, null, { yAxisID: 'yRad', borderDash: [10, 4], glow: false }),
                                    ds(WEATHER_DS_CLOUD, rows.map(point => point.CloudCoverPct), COLORS.grid, null, { yAxisID: 'yPct', borderDash: [2, 3], glow: false })
                                ]);

                        if (!weatherPvCtx) return;
                        if (weatherPvChart) {
                            weatherPvChart.data.labels = rows.map(point => point.Label);
                            weatherPvChart.data.datasets = datasets;
                            weatherPvChart.update();
                            return;
                        }

                        weatherPvChart = registerInteractiveChart(new Chart(weatherPvCtx, {
                            type: 'line',
                            data: {
                                labels: rows.map(point => point.Label),
                                datasets
                            },
                            options: {
                                ...BASE_OPTS,
                                plugins: {
                                    ...BASE_OPTS.plugins,
                                    legend: { display: true, position: 'top' }
                                },
                                scales: {
                                    ...BASE_OPTS.scales,
                                    y: {
                                        ...BASE_OPTS.scales.y,
                                        ticks: {
                                            ...BASE_OPTS.scales.y.ticks,
                                            callback: v => v + ' kW'
                                        }
                                    },
                                    yRad: {
                                        ...BASE_OPTS.scales.y,
                                        position: 'right',
                                        grid: { display: false },
                                        ticks: {
                                            ...BASE_OPTS.scales.y.ticks,
                                            callback: v => v + ' W/m2'
                                        }
                                    },
                                    yPct: { display: false, min: 0, max: 100 }
                                }
                            }
                        }));
                    }

                    if (weatherPvCtx && weatherHours.length > 0) {
                        const dayTabs = $('weatherDayTabs');
                        const days = getSelectableWeatherDays();
                        const preferredWeatherDay = typeof dashboardPrefs.weatherDay === 'string'
                            ? dashboardPrefs.weatherDay
                            : '';
                        const todayWeatherKey = getWeatherDayKey(new Date());
                        const initialWeatherDayKey = days.some(([key]) => key === todayWeatherKey)
                            ? todayWeatherKey
                            : days.some(([key]) => key === preferredWeatherDay)
                            ? preferredWeatherDay
                            : days[0]?.[0];
                        days.forEach(([key, date], index) => {
                            const summary = summarizeWeatherDay(key);
                            const btn = document.createElement('button');
                            btn.type = 'button';
                            btn.className = 'weather-day-tab' + (key === initialWeatherDayKey || (!initialWeatherDayKey && index === 0) ? ' is-active' : '');
                            btn.innerHTML = `<span>${formatWeatherDay(date)}</span><strong>${summary.dailyKwh.toFixed(1)} kWh</strong><em>max ${summary.peakKw.toFixed(1)} kW</em>`;
                            btn.addEventListener('click', () => {
                                document.querySelectorAll('.weather-day-tab').forEach(tab => tab.classList.remove('is-active'));
                                btn.classList.add('is-active');
                                updateWeatherForecast(key);
                                saveDashboardPreferences({ weatherDay: key });
                            });
                            dayTabs?.appendChild(btn);
                        });
                        if (initialWeatherDayKey) {
                            updateWeatherForecast(initialWeatherDayKey);
                            saveDashboardPreferences({ weatherDay: initialWeatherDayKey });
                        }
                    }

                    /* ── #trends — main performance chart (full-width) ── */
                    window.addEventListener('resize', () => {
                        if (lastWeatherStripIndex >= 0) {
                            window.requestAnimationFrame(() => syncWeatherStripPosition(lastWeatherStripIndex));
                        }
                    });

                    const trendCtx = $('overviewChart');
                    const trendPlayhead = $('overviewPlayhead');
                    const trendPlayheadLabel = $('overviewPlayheadLabel');
                    const trendPlayheadLine = $('overviewPlayheadLine');
                    const trendPlayheadCap = $('overviewPlayheadCap');
                    const trendPlayheadDot = $('overviewPlayheadDot');
                    let trendChart = null;
                    let selectedTrendIndex = null;
                    let hoveredTrendIndex = null;

                    function buildResolvedTrendTimeline(points) {
                        return points.map(point => {
                            const resolvedMppt1Kw = Math.round((Number(point.Mppt1Kw) || 0) * 100) / 100;
                            const resolvedMppt2Kw = Math.round((Number(point.Mppt2Kw) || 0) * 100) / 100;

                            return {
                                ...point,
                                Mppt1ResolvedKw: resolvedMppt1Kw,
                                Mppt2ResolvedKw: resolvedMppt2Kw,
                                PvResolvedKw: Math.round((resolvedMppt1Kw + resolvedMppt2Kw) * 100) / 100
                            };
                        });
                    }

                    const trendTimeline = buildResolvedTrendTimeline(T);
                    tlabels.splice(0, tlabels.length, ...trendTimeline.map(t => t.TimeLabel || ''));

                    function getMppt1Kw(row) {
                        return Number(row?.Mppt1ResolvedKw ?? row?.Mppt1Kw) || 0;
                    }

                    function getMppt2Kw(row) {
                        return Number(row?.Mppt2ResolvedKw ?? row?.Mppt2Kw) || 0;
                    }

                    function getPvTotalKw(row) {
                        return Number(row?.PvResolvedKw) || (getMppt1Kw(row) + getMppt2Kw(row));
                    }

                    function buildTrendBarBuckets(points, selectors, targetBars = 40) {
                        const rows = Array.isArray(points) ? points : [];
                        const fns = Array.isArray(selectors) ? selectors : [];
                        if (!rows.length || !fns.length) {
                            return { labels: [], series: fns.map(() => []) };
                        }

                        const bucketSize = Math.max(1, Math.ceil(rows.length / Math.max(1, targetBars)));
                        const labels = [];
                        const series = fns.map(() => []);

                        for (let start = 0; start < rows.length; start += bucketSize) {
                            const bucket = rows.slice(start, start + bucketSize);
                            if (!bucket.length) continue;

                            const labelSource = bucket[Math.floor((bucket.length - 1) / 2)] || bucket[bucket.length - 1];
                            labels.push(labelSource?.TimeLabel || '');

                            fns.forEach((selector, index) => {
                                const value = bucket.reduce((max, point) => {
                                    const nextValue = Number(selector(point));
                                    return Number.isFinite(nextValue) ? Math.max(max, nextValue) : max;
                                }, 0);
                                series[index].push(+value.toFixed(2));
                            });
                        }

                        return { labels, series };
                    }

                    function getTrendActiveIndex() {
                        return selectedTrendIndex ?? hoveredTrendIndex;
                    }

                    function getTrendSample(index = getTrendActiveIndex()) {
                        if (Number.isInteger(index) && index >= 0 && index < trendTimeline.length) {
                            return trendTimeline[index];
                        }

                        return trendTimeline[trendTimeline.length - 1] || null;
                    }

                    function updateTrendPlayhead() {
                        if (!trendPlayhead || !trendChart) return;

                        const activeIndex = getTrendActiveIndex();
                        const xScale = trendChart.scales?.x;
                        const yScale = trendChart.scales?.y;
                        const sample = getTrendSample(activeIndex);

                        if (!Number.isInteger(activeIndex) || !xScale || !yScale || !sample) {
                            trendPlayhead.classList.remove('is-visible');
                            return;
                        }

                        const x = xScale.getPixelForValue(activeIndex);
                        const y = yScale.getPixelForValue(getPvTotalKw(sample));
                        const timeLabel = sample.TimeLabel || 'aktuálny';
                        const modeLabel = selectedTrendIndex != null ? 'pripnuté' : (hoveredTrendIndex != null ? 'náhľad' : 'živé');

                        trendPlayhead.classList.add('is-visible');
                        trendPlayheadLabel.textContent = `${timeLabel} · ${modeLabel}`;
                        trendPlayheadLabel.style.left = `${x}px`;
                        trendPlayheadLine.style.left = `${x}px`;
                        trendPlayheadCap.style.left = `${x}px`;
                        trendPlayheadDot.style.left = `${x}px`;
                        trendPlayheadDot.style.top = `${y}px`;
                    }
                    const TREND_SERIES = {
                        pvTotal:  { label: 'FV celkom',   color: COLORS.pv,   field: r => getPvTotalKw(r), unit:' kW' },
                        mppt1:    { label: 'MPPT 1',      color: COLORS.mppt1, field: r => getMppt1Kw(r), unit:' kW' },
                        mppt2:    { label: 'MPPT 2',      color: COLORS.mppt2, field: r => getMppt2Kw(r), unit:' kW' },
                        grid:     { label: 'Sieť',        color: COLORS.grid,  field: r => r.GridKw||0,   unit:' kW' },
                        consumption: { label: 'Spotreba', color: COLORS.cons,  field: r => r.ConsumptionKw||0, unit:' kW' },
                        export:      { label: 'Export',   color: COLORS.exp,   field: r => r.ExportKw||0, unit:' kW' },
                        battery:     { label: 'Batéria',  color: COLORS.bat,   field: r => r.BatteryKw||0, unit:' kW' },
                    };

                    const defaultTrendSeries = ['pvTotal', 'consumption', 'grid', 'export', 'soc'];
                    const allowedTrendSeries = ['pvTotal', 'mppt1', 'mppt2', 'consumption', 'grid', 'export', 'soc', 'battery'];
                    const preferredTrendSeries = Array.isArray(dashboardPrefs.trendSeries)
                        ? dashboardPrefs.trendSeries.filter(key => allowedTrendSeries.includes(key))
                        : [];
                    const activeTrendSeries = new Set(preferredTrendSeries.length ? preferredTrendSeries : defaultTrendSeries);
                    TREND_SERIES.pvTotal.fill = COLORS.pvA;
                    TREND_SERIES.pvTotal.opts = { __displaySmoothing: true, __displaySmoothingPasses: 2, __surfaceTopAlpha: 0.30, __surfaceMidAlpha: 0.12, borderWidth: 3 };
                    TREND_SERIES.mppt1.fill = COLORS.mppt1A;
                    TREND_SERIES.mppt1.opts = { __displaySmoothing: true, __displaySmoothingPasses: 2, __surfaceTopAlpha: 0.18, __surfaceMidAlpha: 0.08, borderWidth: 2.5 };
                    TREND_SERIES.mppt2.fill = COLORS.mppt2A;
                    TREND_SERIES.mppt2.opts = { __displaySmoothing: true, __displaySmoothingPasses: 2, __surfaceTopAlpha: 0.18, __surfaceMidAlpha: 0.08, borderWidth: 2.5 };
                    TREND_SERIES.grid.fill = COLORS.gridA;
                    TREND_SERIES.grid.opts = { __displaySmoothing: true, __displaySmoothingPasses: 1, __surfaceTopAlpha: 0.12, __surfaceMidAlpha: 0.05, borderWidth: 2.35 };
                    TREND_SERIES.consumption.fill = COLORS.consA;
                    TREND_SERIES.consumption.opts = { __displaySmoothing: true, __displaySmoothingPasses: 2, __surfaceTopAlpha: 0.16, __surfaceMidAlpha: 0.06, borderWidth: 2.7 };
                    TREND_SERIES.export.fill = COLORS.expA;
                    TREND_SERIES.export.opts = { __displaySmoothing: true, __displaySmoothingPasses: 1, __surfaceTopAlpha: 0.16, __surfaceMidAlpha: 0.06, borderWidth: 2.35 };
                    TREND_SERIES.battery.fill = COLORS.batA;
                    TREND_SERIES.battery.opts = { __displaySmoothing: true, __displaySmoothingPasses: 1, __surfaceTopAlpha: 0.14, __surfaceMidAlpha: 0.05, borderWidth: 2.35 };
                    TREND_SERIES.soc = {
                        label: 'SOC',
                        color: COLORS.soc,
                        field: r => r.BatterySocPct || 0,
                        unit: '%',
                        fill: null,
                        opts: { __displaySmoothing: true, __displaySmoothingPasses: 1, yAxisID: 'ySoc', borderDash: [8, 5], borderWidth: 2.15, glow: false }
                    };
                    activeTrendSeries.add('soc');
                    const trendTickTimeFormatter = new Intl.DateTimeFormat('sk-SK', { hour: '2-digit', minute: '2-digit' });
                    const trendTickDayFormatter = new Intl.DateTimeFormat('sk-SK', { day: '2-digit', month: '2-digit' });
                    const trendTooltipFormatter = new Intl.DateTimeFormat('sk-SK', {
                        day: '2-digit',
                        month: '2-digit',
                        year: 'numeric',
                        hour: '2-digit',
                        minute: '2-digit'
                    });
                    const trendWeatherTimeFormatter = new Intl.DateTimeFormat('sk-SK', {
                        day: '2-digit',
                        month: '2-digit',
                        hour: '2-digit',
                        minute: '2-digit'
                    });
                    const trendLastIndex = Math.max(0, trendTimeline.length - 1);
                    const trendMinWindowSize = Math.min(Math.max(12, Math.round(trendTimeline.length * 0.08)), Math.max(12, trendTimeline.length));

                    function getDefaultTrendViewport() {
                        return { min: 0, max: trendLastIndex };
                    }

                    function normalizeTrendViewport(min, max) {
                        if (trendTimeline.length <= 1) {
                            return { min: 0, max: trendLastIndex };
                        }

                        let nextMin = Math.round(Number(min));
                        let nextMax = Math.round(Number(max));
                        if (!Number.isFinite(nextMin) || !Number.isFinite(nextMax)) {
                            return getDefaultTrendViewport();
                        }

                        if (nextMin > nextMax) {
                            [nextMin, nextMax] = [nextMax, nextMin];
                        }

                        nextMin = Math.max(0, nextMin);
                        nextMax = Math.min(trendLastIndex, nextMax);

                        const minWindow = Math.max(2, Math.min(trendMinWindowSize, trendTimeline.length));
                        let span = (nextMax - nextMin) + 1;
                        if (span < minWindow) {
                            const deficit = minWindow - span;
                            nextMin -= Math.floor(deficit / 2);
                            nextMax += Math.ceil(deficit / 2);
                        }

                        if (nextMin < 0) {
                            nextMax = Math.min(trendLastIndex, nextMax - nextMin);
                            nextMin = 0;
                        }

                        if (nextMax > trendLastIndex) {
                            const overflow = nextMax - trendLastIndex;
                            nextMin = Math.max(0, nextMin - overflow);
                            nextMax = trendLastIndex;
                        }

                        return { min: nextMin, max: nextMax };
                    }

                    function getSavedTrendViewport() {
                        const min = Number(dashboardPrefs.trendWindowMin);
                        const max = Number(dashboardPrefs.trendWindowMax);
                        if (!Number.isFinite(min) || !Number.isFinite(max)) {
                            return getDefaultTrendViewport();
                        }

                        return normalizeTrendViewport(min, max);
                    }

                    let trendViewport = getSavedTrendViewport();
                    let isTrendPanning = false;
                    let trendPanMoved = false;
                    let trendPanStartX = 0;
                    let trendPanStartViewport = null;

                    function getTrendVisibleSpan() {
                        return (trendViewport.max - trendViewport.min) + 1;
                    }

                    function isTrendZoomedIn() {
                        return getTrendVisibleSpan() < trendTimeline.length;
                    }

                    function persistTrendViewport() {
                        saveDashboardPreferences({
                            trendWindowMin: trendViewport.min,
                            trendWindowMax: trendViewport.max
                        });
                    }

                    function setTrendViewport(min, max, shouldPersist = true) {
                        trendViewport = normalizeTrendViewport(min, max);
                        if (selectedTrendIndex != null &&
                            (selectedTrendIndex < trendViewport.min || selectedTrendIndex > trendViewport.max)) {
                            selectedTrendIndex = null;
                        }
                        if (hoveredTrendIndex != null &&
                            (hoveredTrendIndex < trendViewport.min || hoveredTrendIndex > trendViewport.max)) {
                            hoveredTrendIndex = null;
                        }
                        if (trendChart?.options?.scales?.x) {
                            trendChart.options.scales.x.min = trendViewport.min;
                            trendChart.options.scales.x.max = trendViewport.max;
                            trendChart.options.scales.x.ticks.maxTicksLimit = getTrendXAxisTickLimit();
                            if (trendChart.options.plugins?.trendSelectionHead) {
                                trendChart.options.plugins.trendSelectionHead.activeIndex = getTrendActiveIndex();
                            }
                            syncTrendReadout();
                            trendChart.update('none');
                        }
                        if (shouldPersist) {
                            persistTrendViewport();
                        }
                    }

                    function resetTrendViewport(shouldPersist = true) {
                        setTrendViewport(0, trendLastIndex, shouldPersist);
                    }

                    function panTrendViewport(deltaPoints) {
                        if (!isTrendZoomedIn()) return;
                        const span = getTrendVisibleSpan();
                        const nextMin = Math.max(0, Math.min(trendLastIndex - span + 1, trendViewport.min + deltaPoints));
                        const nextMax = nextMin + span - 1;
                        setTrendViewport(nextMin, nextMax);
                    }

                    function zoomTrendViewport(multiplier, anchorIndex) {
                        if (trendTimeline.length <= 2) return;
                        const currentSpan = getTrendVisibleSpan();
                        const nextSpan = Math.max(
                            Math.min(trendTimeline.length, Math.round(currentSpan * multiplier)),
                            Math.max(2, Math.min(trendMinWindowSize, trendTimeline.length)));
                        if (nextSpan >= trendTimeline.length) {
                            resetTrendViewport();
                            return;
                        }

                        const anchor = Math.max(trendViewport.min, Math.min(trendViewport.max, Math.round(anchorIndex)));
                        const leftRatio = currentSpan > 1 ? (anchor - trendViewport.min) / (currentSpan - 1) : 0.5;
                        const nextMin = anchor - Math.round((nextSpan - 1) * leftRatio);
                        const nextMax = nextMin + nextSpan - 1;
                        setTrendViewport(nextMin, nextMax);
                    }

                    function getTrendXAxisTickLimit() {
                        const span = getTrendVisibleSpan();
                        if (span <= 16) return 6;
                        if (span <= 36) return 7;
                        if (span <= 84) return 8;
                        return 10;
                    }

                    function formatTrendAxisTick(value) {
                        const index = Math.round(Number(value));
                        const point = trendTimeline[index];
                        if (!point || !Number.isFinite(point.Ts)) return '';

                        const date = new Date(point.Ts);
                        const span = getTrendVisibleSpan();
                        const label = trendTickTimeFormatter.format(date);
                        const previousPoint = trendTimeline[index - 1];
                        const previousDate = previousPoint?.Ts ? new Date(previousPoint.Ts) : null;
                        const crossedDay = !previousDate || previousDate.getDate() !== date.getDate() || previousDate.getMonth() !== date.getMonth();

                        if (span > 56 || crossedDay || index === trendViewport.min) {
                            return `${trendTickDayFormatter.format(date)} ${label}`;
                        }

                        return label;
                    }

                    function setTrendWeatherPlaceholder(note) {
                        const panel = $('trendWeatherPanel');
                        if (!panel) return;

                        panel.dataset.state = 'empty';

                        [
                            'trend-weather-time',
                            'trend-weather-temp',
                            'trend-weather-cloud',
                            'trend-weather-wind',
                            'trend-weather-rain',
                            'trend-weather-pv'
                        ].forEach(id => {
                            const el = $(id);
                            if (el) el.textContent = '—';
                        });

                    }

                    function getNearestWeatherPointForSample(sample) {
                        const targetTs = Number(sample?.Ts);
                        if (!Number.isFinite(targetTs) || !weatherHours.length) {
                            return null;
                        }

                        let nearest = null;
                        let bestDiff = Number.POSITIVE_INFINITY;

                        weatherHours.forEach(point => {
                            const pointTs = point?.Date?.getTime?.();
                            if (!Number.isFinite(pointTs)) return;

                            const diff = Math.abs(pointTs - targetTs);
                            if (diff < bestDiff) {
                                bestDiff = diff;
                                nearest = point;
                            }
                        });

                        if (!nearest || bestDiff > 1000 * 60 * 90) {
                            return null;
                        }

                        return {
                            point: nearest,
                            diffMinutes: Math.round(bestDiff / 60000)
                        };
                    }

                    function syncTrendWeather(sample) {
                        const panel = $('trendWeatherPanel');
                        if (!panel) return;

                        if (!weatherHours.length) {
                            setTrendWeatherPlaceholder('bez počasia');
                            return;
                        }

                        const match = getNearestWeatherPointForSample(sample);
                        const sampleDate = Number.isFinite(Number(sample?.Ts)) ? new Date(Number(sample.Ts)) : null;

                        if (!match) {
                            const targetLabel = sampleDate && !Number.isNaN(sampleDate.getTime())
                                ? trendTooltipFormatter.format(sampleDate)
                                : 'vybraný interval';
                            setTrendWeatherPlaceholder(`bez údajov pre ${targetLabel}`);
                            return;
                        }

                        const weatherPoint = match.point;

                        panel.dataset.state = 'ready';

                        const values = {
                            'trend-weather-time': weatherPoint.Date ? trendWeatherTimeFormatter.format(weatherPoint.Date) : (weatherPoint.Label || '—'),
                            'trend-weather-temp': `${weatherPoint.TemperatureC.toFixed(0)} °C`,
                            'trend-weather-cloud': `${weatherPoint.CloudCoverPct.toFixed(0)} %`,
                            'trend-weather-wind': `${weatherPoint.WindKph.toFixed(0)} km/h`,
                            'trend-weather-rain': `${weatherPoint.PrecipitationMm.toFixed(1)} mm`,
                            'trend-weather-pv': `${weatherPoint.EstimatedPvKw.toFixed(1)} kW`
                        };

                        Object.entries(values).forEach(([id, value]) => {
                            const el = $(id);
                            if (el) el.textContent = value;
                        });
                    }

                    function syncTrendReadout(sample) {
                        const latest = sample || getTrendSample();
                        if (!latest) return;

                        const values = {
                            pvTotal: getPvTotalKw(latest),
                            mppt1: getMppt1Kw(latest),
                            mppt2: getMppt2Kw(latest),
                            consumption: latest.ConsumptionKw || 0,
                            grid: latest.GridKw || 0,
                            export: latest.ExportKw || 0,
                            soc: latest.BatterySocPct || 0,
                            battery: latest.BatteryKw || 0
                        };

                        document.querySelectorAll('[data-readout]').forEach(cell => {
                            const key = cell.dataset.readout;
                            const series = TREND_SERIES[key];
                            cell.classList.toggle('is-hidden', !activeTrendSeries.has(key));
                            const valueEl = cell.querySelector('[data-val]');
                            const subEl = cell.querySelector('[data-sub]');
                            if (valueEl) {
                                const decimals = series?.unit === '%' ? 1 : 2;
                                valueEl.textContent = `${(values[key] || 0).toFixed(decimals)} ${series?.unit || ''}`.trim();
                            }
                            if (subEl && series) {
                                subEl.textContent = series.unit === '%' ? 'stav nabitia' : series.unit;
                            }
                        });

                        const timeEl = $('readout-time');
                        if (timeEl) {
                            const modeLabel = selectedTrendIndex != null ? 'locked' : (hoveredTrendIndex != null ? 'hover' : 'live');
                            timeEl.dataset.mode = modeLabel;
                            updateTrendPlayhead();
                            timeEl.textContent = latest.TimeLabel || 'aktuálny';
                        }

                        syncTrendWeather(latest);
                    }

                    function buildTrendChart() {
                        if (trendChart) trendChart.destroy();
                        if (!trendCtx) return;
                        trendViewport = normalizeTrendViewport(trendViewport.min, trendViewport.max);
                        const datasets = Object.entries(TREND_SERIES)
                            .filter(([key]) => activeTrendSeries.has(key))
                            .map(([key, s]) => ds(
                                s.label,
                                trendTimeline.map(s.field),
                                s.color,
                                s.fill,
                                s.opts || {}
                            ));
                        trendChart = registerInteractiveChart(new Chart(trendCtx, {
                            type: 'line',
                            data: buildLineChartData(tlabels, datasets),
                            options: {
                                ...BASE_OPTS,
                                animation: trendTimeline.length > 220 ? false : { duration: 220, easing: 'easeOutCubic' },
                                interaction: { mode: 'index', intersect: false },
                                onHover(_event, activeElements, chart) {
                                    if (selectedTrendIndex != null) return;
                                    hoveredTrendIndex = activeElements.length ? activeElements[0].index : null;
                                    chart.options.plugins.trendSelectionHead.activeIndex = getTrendActiveIndex();
                                    syncTrendReadout();
                                    chart.draw();
                                },
                                onClick(_event, activeElements, chart) {
                                    if (trendPanMoved) return;
                                    if (!activeElements.length) {
                                        selectedTrendIndex = null;
                                        hoveredTrendIndex = null;
                                        chart.options.plugins.trendSelectionHead.activeIndex = getTrendActiveIndex();
                                        syncTrendReadout();
                                        chart.draw();
                                        return;
                                    }

                                    const nextIndex = activeElements[0].index;
                                    selectedTrendIndex = selectedTrendIndex === nextIndex ? null : nextIndex;
                                    hoveredTrendIndex = selectedTrendIndex ?? nextIndex;
                                    chart.options.plugins.trendSelectionHead.activeIndex = getTrendActiveIndex();
                                    syncTrendReadout();
                                    chart.draw();
                                },
                                plugins: {
                                    ...BASE_OPTS.plugins,
                                    tooltip: {
                                        ...BASE_OPTS.plugins.tooltip,
                                        callbacks: {
                                            title(items) {
                                                const point = trendTimeline[items?.[0]?.dataIndex ?? -1];
                                                return point?.Ts ? trendTooltipFormatter.format(new Date(point.Ts)) : '';
                                            }
                                        }
                                    },
                                    trendSelectionHead: {
                                        activeIndex: getTrendActiveIndex()
                                    }
                                },
                                scales: {
                                    ...BASE_OPTS.scales,
                                    x: {
                                        ...BASE_OPTS.scales.x,
                                        min: trendViewport.min,
                                        max: trendViewport.max,
                                        grid: {
                                            ...BASE_OPTS.scales.x.grid,
                                            color: 'rgba(15,15,14,0.028)'
                                        },
                                        ticks: {
                                            ...BASE_OPTS.scales.x.ticks,
                                            maxTicksLimit: getTrendXAxisTickLimit(),
                                            callback: value => formatTrendAxisTick(value)
                                        }
                                    },
                                    y: {
                                        ...BASE_OPTS.scales.y,
                                        ticks: {
                                            ...BASE_OPTS.scales.y.ticks,
                                            callback: v => v + ' kW'
                                        }
                                    },
                                    ySoc: {
                                        ...BASE_OPTS.scales.y,
                                        position: 'right',
                                        min: 0,
                                        max: 100,
                                        grid: { display: false },
                                        ticks: {
                                            ...BASE_OPTS.scales.y.ticks,
                                            callback: v => v + ' %'
                                        }
                                    }
                                }
                            }
                        }));
                        trendChart.options.plugins.trendSelectionHead.activeIndex = getTrendActiveIndex();
                        updateTrendPlayhead();
                        persistTrendViewport();
                    }
                    buildTrendChart();
                    syncTrendReadout();

                    if (trendCtx && !trendCtx.dataset.selectionBound) {
                        trendCtx.addEventListener('wheel', event => {
                            if (!trendTimeline.length) return;
                            event.preventDefault();

                            const range = getTrendVisibleSpan();
                            const isPanIntent = isTrendZoomedIn() &&
                                (Math.abs(event.deltaX) > Math.abs(event.deltaY) || event.shiftKey);

                            if (isPanIntent) {
                                const dominantDelta = Math.abs(event.deltaX) > Math.abs(event.deltaY) ? event.deltaX : event.deltaY;
                                const panStep = Math.max(1, Math.round(range * 0.12));
                                panTrendViewport(dominantDelta > 0 ? panStep : -panStep);
                                return;
                            }

                            const rect = trendCtx.getBoundingClientRect();
                            const xRatio = rect.width > 0
                                ? Math.min(1, Math.max(0, (event.clientX - rect.left) / rect.width))
                                : 0.5;
                            const anchorIndex = trendViewport.min + Math.round((range - 1) * xRatio);
                            zoomTrendViewport(event.deltaY > 0 ? 1.24 : 0.82, anchorIndex);
                        }, { passive: false });

                        trendCtx.addEventListener('pointerdown', event => {
                            if (!isTrendZoomedIn()) return;
                            isTrendPanning = true;
                            trendPanMoved = false;
                            trendPanStartX = event.clientX;
                            trendPanStartViewport = { ...trendViewport };
                            trendCtx.setPointerCapture?.(event.pointerId);
                        });

                        trendCtx.addEventListener('pointermove', event => {
                            if (!isTrendPanning || !trendPanStartViewport) return;
                            const visibleSpan = (trendPanStartViewport.max - trendPanStartViewport.min) + 1;
                            const pixelsPerPoint = trendCtx.clientWidth > 0 ? trendCtx.clientWidth / visibleSpan : 0;
                            if (pixelsPerPoint <= 0) return;

                            const deltaPoints = Math.round((trendPanStartX - event.clientX) / pixelsPerPoint);
                            trendPanMoved = trendPanMoved || Math.abs(event.clientX - trendPanStartX) > 6;
                            const nextMin = trendPanStartViewport.min + deltaPoints;
                            const nextMax = trendPanStartViewport.max + deltaPoints;
                            setTrendViewport(nextMin, nextMax);
                        });

                        const stopTrendPan = event => {
                            if (!isTrendPanning) return;
                            isTrendPanning = false;
                            trendPanStartViewport = null;
                            if (event?.pointerId != null) {
                                trendCtx.releasePointerCapture?.(event.pointerId);
                            }
                            window.setTimeout(() => { trendPanMoved = false; }, 0);
                        };

                        trendCtx.addEventListener('pointerup', stopTrendPan);
                        trendCtx.addEventListener('pointercancel', stopTrendPan);
                        trendCtx.addEventListener('dblclick', event => {
                            event.preventDefault();
                            resetTrendViewport();
                        });

                        trendCtx.addEventListener('mouseleave', () => {
                            if (selectedTrendIndex != null) return;
                            hoveredTrendIndex = null;
                            if (trendChart?.options?.plugins?.trendSelectionHead) {
                                trendChart.options.plugins.trendSelectionHead.activeIndex = getTrendActiveIndex();
                            }
                            syncTrendReadout();
                            trendChart?.draw();
                        });

                        document.addEventListener('keydown', event => {
                            if (event.key !== 'Escape' || selectedTrendIndex == null) return;
                            selectedTrendIndex = null;
                            hoveredTrendIndex = null;
                            if (trendChart?.options?.plugins?.trendSelectionHead) {
                                trendChart.options.plugins.trendSelectionHead.activeIndex = getTrendActiveIndex();
                            }
                            syncTrendReadout();
                            trendChart?.draw();
                        });

                        document.addEventListener('keydown', event => {
                            if (event.key === 'Escape' && isTrendZoomedIn()) {
                                resetTrendViewport();
                            }
                        });

                        trendCtx.dataset.selectionBound = '1';
                    }

                    const hoursBackSelect = $('HoursBack');
                    const systemSelect = $('SnNumber');
                    const dayInput = $('Day');
                    const dashboardRangeForm = $('dashboardRangeForm') || hoursBackSelect?.form;
                    const timelineNavLinks = document.querySelectorAll('.timeline-nav a[href]');

                    function persistRangePreferences(extra = {}) {
                        saveDashboardPreferences({
                            systemSn: systemSelect?.value || '',
                            day: dayInput?.value || '',
                            hoursBack: Number(hoursBackSelect?.value || 24) || 24,
                            ...extra
                        });
                    }

                    function getLocalDateInputValue(date) {
                        const year = date.getFullYear();
                        const month = String(date.getMonth() + 1).padStart(2, '0');
                        const day = String(date.getDate()).padStart(2, '0');
                        return `${year}-${month}-${day}`;
                    }

                    function canQuietRefreshSelectedRange() {
                        if (!rawDashboard.loadStartEndpoint || !rawDashboard.loadProgressEndpoint) return false;
                        if (getQuietRefreshIntervalMs() == null) return false;
                        if (quietRangeRefreshInFlight || dashboardLoadBusy || document.hidden) return false;

                        const active = document.activeElement;
                        if (active && dashboardRangeForm?.contains(active)) return false;
                        if (active?.isContentEditable) return false;

                        const selectedDay = dayInput?.value || '';
                        return !selectedDay || selectedDay === getLocalDateInputValue(new Date());
                    }

                    function canStartQuietRefreshByInterval() {
                        const intervalMs = getQuietRefreshIntervalMs();
                        return intervalMs != null && Date.now() - lastQuietRefreshStartedAt >= intervalMs;
                    }

                    function startQuietRangeRefresh() {
                        if (!canQuietRefreshSelectedRange() || !canStartQuietRefreshByInterval()) {
                            return false;
                        }

                        lastQuietRefreshStartedAt = Date.now();
                        quietRangeRefreshInFlight = true;
                        persistRangePreferences();
                        beginDashboardNavigation(
                            buildSelectedRangeUrl(),
                            '@T("Tichá aktualizácia dashboardu", "Quiet dashboard refresh")',
                            { quiet: true }
                        ).finally(() => {
                            quietRangeRefreshInFlight = false;
                        });
                        return true;
                    }

                    function buildSelectedRangeUrl() {
                        const targetUrl = new URL(window.location.pathname, window.location.origin);
                        const form = dashboardRangeForm;
                        if (form instanceof HTMLFormElement) {
                            const action = form.getAttribute('action') || window.location.pathname;
                            const formUrl = new URL(action, window.location.origin);
                            const formData = new FormData(form);
                            for (const [key, value] of formData.entries()) {
                                if (value == null || value === '') continue;
                                formUrl.searchParams.set(String(key), String(value));
                            }
                            return formUrl.toString();
                        }

                        if (rawDashboard.initialLive?.snNumber) {
                            targetUrl.searchParams.set('SnNumber', rawDashboard.initialLive.snNumber);
                        }
                        targetUrl.searchParams.set('HoursBack', String(Number(hoursBackSelect?.value || 24) || 24));
                        return targetUrl.toString();
                    }

                    function maybeRefreshSelectedRange(latestTelemetryTime) {
                        const latestMs = Date.parse(latestTelemetryTime || '');
                        if (!latestMs) return;

                        if (!hasDashboardTelemetryBaseline) {
                            latestDashboardTelemetryTimeMs = latestMs;
                            hasDashboardTelemetryBaseline = true;
                            return;
                        }

                        if (latestMs <= latestDashboardTelemetryTimeMs + 1000) {
                            return;
                        }

                        latestDashboardTelemetryTimeMs = latestMs;
                        startQuietRangeRefresh();
                    }

                    function triggerScheduledQuietRefresh() {
                        startQuietRangeRefresh();
                    }

                    persistRangePreferences();
                    dashboardRangeForm?.addEventListener('submit', event => {
                        persistRangePreferences();
                        const form = event.currentTarget;
                        if (!(form instanceof HTMLFormElement)) return;
                        event.preventDefault();
                        const action = form.getAttribute('action') || window.location.pathname;
                        const formUrl = new URL(action, window.location.origin);
                        const formData = new FormData(form);
                        for (const [key, value] of formData.entries()) {
                            if (value == null || value === '') continue;
                            formUrl.searchParams.set(String(key), String(value));
                        }
                        beginDashboardNavigation(formUrl.toString(), 'Aktualizujem filtre dashboardu');
                    });
                    systemSelect?.addEventListener('change', () => persistRangePreferences());
                    dayInput?.addEventListener('change', () => persistRangePreferences());
                    hoursBackSelect?.addEventListener('change', () => persistRangePreferences());
                    timelineNavLinks.forEach(link => {
                        link.addEventListener('click', event => {
                            event.preventDefault();
                            const target = event.currentTarget;
                            if (!(target instanceof HTMLAnchorElement) || !target.href) return;
                            beginDashboardNavigation(target.href, target.textContent?.trim() || 'Menim den dashboardu');
                        });
                    });

                    document.querySelectorAll('#range-chip-row [data-range]').forEach(btn => {

    html.dashboard-preboot,
    html.dashboard-preboot body {
        min-height: 100%;
        overflow: hidden;
        background: #FAFAF9;
    }
    html.dashboard-preboot::before {
        content: '';
        position: fixed;
        inset: 0;
        z-index: 80;
        background:
            radial-gradient(circle at top, rgba(26, 86, 219, 0.12), transparent 32%),
            rgba(250, 250, 249, 0.92);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
    }
    html.dashboard-preboot::after {

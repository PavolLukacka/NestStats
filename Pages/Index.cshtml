                        <button type="button" class="chip is-active" data-history-window="7">@T("7 dní", "7 days")</button>
                        <button type="button" class="chip" data-history-window="14">@T("14 dní", "14 days")</button>
                        <button type="button" class="chip" data-history-window="30">@T("30 dní", "30 days")</button>
                        <button type="button" class="chip" data-history-window="all">@T("Všetko", "All")</button>
                    </div>
                    <div class="history-loading" id="history-loading" hidden>
                        <span class="history-loading__dot" aria-hidden="true"></span>
                        <span>@T("Načítavam denné výsledky", "Loading daily results")</span>
                    </div>
                    <div class="chart-wrap chart-wrap--sm"><canvas id="historyChart"></canvas></div>
                    <div class="tbl-wrap">
                        <table class="data-table">
                            <thead>
                            <tr>
                                <th>Dátum</th>
                                <th>FV výroba</th>
                                <th>Spotreba</th>
                                <th>Import</th>
                                <th>Export</th>
                                <th>Sebestačnosť</th>
                                <th>Vlastná spotr.</th>
                                <th>Bilancia</th>
                            </tr>
                            </thead>
                            <tbody id="history-table-body">





                            @foreach (var h in dashboard.History.OrderByDescending(x => x.Date))
                            {
                            var hBal = h.Export - h.Import;
                            var hBalCls = hBal > 0.05 ? "val--pos" : hBal < -0.05 ? "val--neg" : "";
                            var hSelfCls = h.SelfSufficiencyPct >= 80 ? "val--pos" : h.SelfSufficiencyPct >= 50 ? "val--warn" : "val--neg";
                            <tr data-history-date="@h.Date">
                                <td><span class="tbl-date">@h.Date</span></td>
                                <td>@(h.Pv.ToString("0.00", currency)) kWh</td>
                                <td>@(h.Consumption.ToString("0.00", currency)) kWh</td>
                                <td class="val--neg-light">@(h.Import.ToString("0.00", currency)) kWh</td>
                                <td class="val--pos-light">@(h.Export.ToString("0.00", currency)) kWh</td>
                                <td class="@hSelfCls">@(h.SelfSufficiencyPct.ToString("0.0", currency))&nbsp;%</td>
                                <td>@(h.SelfUsePct.ToString("0.0", currency))&nbsp;%</td>
                                <td class="@hBalCls">@(hBal >= 0 ? "+" : "")@hBal.ToString("0.00", currency) kWh</td>
                            </tr>
                            }
                            @if (!dashboard.History.Any())
                            {
                            <tr><td colspan="8" style="text-align:center;color:var(--text-subtle);padding:24px;font-size:13px">Historické dáta zatiaľ nie sú dostupné.</td></tr>
                            }
                            </tbody>
                        </table>
                    </div>
                    <div class="history-pager" id="history-pager" aria-label="Strankovanie dennej historie">
                        <button type="button" class="chip history-pager__btn" data-history-page="prev">Predosla</button>
                        <span class="history-pager__label" id="history-page-label">1 / 1</span>
                        <button type="button" class="chip history-pager__btn" data-history-page="next">Dalsia</button>
                    </div>
                </article>

                @* ─── History insights ─── *@
                <article class="panel">
                    <div class="panel-head">
                        <div><span class="eyebrow">Štatistiky obdobia</span><h2>Agregáty a trendy</h2></div>
                        <span class="panel-badge" id="history-insight-range">posledných 7 dní</span>
                    </div>

                    @{
                    var h7 = dashboard.History.OrderByDescending(x => x.Date).Take(7).ToArray();
                    var h7Pv    = h7.Sum(x => x.Pv);
                    var h7Cons  = h7.Sum(x => x.Consumption);
                    var h7Imp   = h7.Sum(x => x.Import);
                    var h7Exp   = h7.Sum(x => x.Export);
                    var h7Bal   = h7Exp - h7Imp;
                    var h7SS    = h7.Any() ? h7.Average(x => x.SelfSufficiencyPct) : 0;
                    var h7SU    = h7.Any() ? h7.Average(x => x.SelfUsePct) : 0;
                    var bestDay = h7.OrderByDescending(x => x.Pv).FirstOrDefault();
                    }

                    <div class="kpi-grid" id="history-kpi-grid">
                        <div class="kpi-cell"><span class="k-lbl">FV spolu</span><strong id="hist-pv-sum">@Kwh(h7Pv)</strong></div>
                        <div class="kpi-cell"><span class="k-lbl">Spotreba spolu</span><strong id="hist-cons-sum">@Kwh(h7Cons)</strong></div>
                        <div class="kpi-cell"><span class="k-lbl">Import spolu</span><strong id="hist-imp-sum" style="color:var(--red)">@Kwh(h7Imp)</strong></div>
                        <div class="kpi-cell"><span class="k-lbl">Export spolu</span><strong id="hist-exp-sum" style="color:var(--green)">@Kwh(h7Exp)</strong></div>
                        <div class="kpi-cell"><span class="k-lbl">Bilancia</span><strong id="hist-bal" style="color:@(h7Bal >= 0 ? "var(--green)" : "var(--red)")">@(h7Bal >= 0 ? "+" : "")@h7Bal.ToString("0.00", currency) kWh</strong></div>
                        <div class="kpi-cell"><span class="k-lbl">Priem. sebestačnosť</span><strong id="hist-ss-avg">@h7SS.ToString("0.0", currency)&nbsp;%</strong></div>
                        <div class="kpi-cell"><span class="k-lbl">Priem. vlastná spotr.</span><strong id="hist-su-avg">@h7SU.ToString("0.0", currency)&nbsp;%</strong></div>
                        <div class="kpi-cell"><span class="k-lbl">Najlepší deň</span><strong id="hist-best-day" style="font-size:12px">@(bestDay?.Date ?? "?")<br/>@Kwh(bestDay?.Pv ?? 0)</strong></div>
                    </div>

                    <div class="chart-wrap chart-wrap--sm" style="margin-top:16px">
                        <canvas id="historyInsightChart"></canvas>
                    </div>

                    <div class="insight-row" style="margin-top:14px">
                        <div class="insight-item">
                            <span class="insight-lbl">Prebytok vs. deficit</span>
                            <div class="insight-bar-wrap">
                                @{ var surplusPct = h7Cons > 0 ? Math.Clamp(h7Exp / h7Cons * 100, 0, 100) : 0; }
                                <div class="insight-bar insight-bar--export" style="width:@surplusPct.ToString("0.0", CultureInfo.InvariantCulture)%"></div>
                            </div>
                            <small>Export pokrýva @surplusPct.ToString("0.0", currency)&nbsp;% spotreby</small>
                        </div>
                        <div class="insight-item">
                            <span class="insight-lbl">Sieťová závislosť</span>
                            <div class="insight-bar-wrap">
                                @{ var importPct = h7Cons > 0 ? Math.Clamp(h7Imp / h7Cons * 100, 0, 100) : 0; }
                                <div class="insight-bar insight-bar--import" style="width:@importPct.ToString("0.0", CultureInfo.InvariantCulture)%"></div>
                            </div>
                            <small>Import tvorí @importPct.ToString("0.0", currency)&nbsp;% spotreby</small>
                        </div>
                    </div>
                </article>
            </div>

            @* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
                   #devices — hardware inventory
                   â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• *@
            <article class="panel section-block">
                <div class="panel-head">

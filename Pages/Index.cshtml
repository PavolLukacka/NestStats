                    @* ── Battery ── *@
                    <div class="device-card @(dashboard.LatestBatterySoC > 0 ? "device-online" : "device-offline")">
                        <div class="device-head">
                            <div>
                                <div class="device-name">Batériové úložisko</div>
                                <div class="device-type">BMS / akumulátor</div>
                            </div>
                            <span class="device-status @(dashboard.LatestBatterySoC > 0 ? "device-status--online" : "device-status--offline")">
                                    <span class="device-status__dot"></span>@(dashboard.LatestBatterySoC > 0 ? "Aktívna" : "Nepripojená")
                                </span>
                        </div>
                        <div class="device-metrics">
                            <div><span>SOC</span><strong>@batterySoc.ToString("0")&nbsp;%</strong></div>
                            <div><span>Tok</span><strong>@Kw(dashboard.LatestBatteryKw)</strong></div>
                            <div><span>Stav</span><strong>@BatDir(dashboard.LatestBatteryKw)</strong></div>
                        </div>
                        <div class="bat-soc-bar" style="margin:10px 0 4px">
                            <div style="height:6px;background:var(--bg-muted);border-radius:3px;overflow:hidden">

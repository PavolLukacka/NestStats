                        ], rows.map(h => h.Date?.substring(5) || ''), ' %');
                    }

                    function clampHistoryValue(value, maxValue = Number.POSITIVE_INFINITY) {
                        const number = Number(value) || 0;
                        return Math.max(0, Math.min(number, maxValue));
                    }

                    function prepareAdvancedHistoryRows(rows) {
                        return (rows || [])
                            .slice()
                            .sort((a, b) => String(a.Date).localeCompare(String(b.Date)))
                            .map(h => {
                                const pv = clampHistoryValue(h.Pv);
                                const batteryCharge = clampHistoryValue(h.BatteryCharge);
                                const batteryDischarge = clampHistoryValue(h.BatteryDischarge);
                                const directUseSource = Number(h.DirectUseKwh) > 0
                                    ? h.DirectUseKwh
                                    : Math.max(0, (Number(h.Consumption) || 0) - (Number(h.Import) || 0) - batteryDischarge);
                                const directUse = clampHistoryValue(directUseSource, pv);
                                const remainingAfterDirect = Math.max(0, pv - directUse);
                                const toBattery = clampHistoryValue(batteryCharge, remainingAfterDirect);
                                const remainingAfterBattery = Math.max(0, remainingAfterDirect - toBattery);
                                const exportKwh = clampHistoryValue(h.Export, remainingAfterBattery);
                                const unallocatedPv = Math.max(0, pv - directUse - toBattery - exportKwh);

                                return {
                                    ...h,
                                    BatteryChargeForChart: batteryCharge,
                                    BatteryDischargeForChart: batteryDischarge,
                                    DirectUseForChart: directUse + unallocatedPv,
                                    ToBatteryForChart: toBattery,
                                    ExportForChart: exportKwh,
                                    SelfSufficiencyForChart: clampHistoryValue(h.SelfSufficiencyPct, 100),
                                    SelfUseForChart: clampHistoryValue(h.SelfUsePct, 100)
                                };
                            });
                    }


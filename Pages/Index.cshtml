        border-radius: 999px;
        padding: 6px 9px;
    }
    .action-rec-item--neutral { background: linear-gradient(180deg, rgba(249,250,251,0.98), rgba(255,255,255,0.92)); }
    .action-rec-item--good { border-color: var(--green-border); background: linear-gradient(180deg, rgba(240,253,244,0.98), rgba(255,255,255,0.92)); }
    .action-rec-item--warning { border-color: var(--amber-border); background: linear-gradient(180deg, rgba(255,251,235,0.98), rgba(255,255,255,0.92)); }
    .action-rec-item--accent { border-color: var(--accent-ring); background: linear-gradient(180deg, rgba(239,246,255,0.98), rgba(255,255,255,0.92)); }
    .action-rec-item--danger { border-color: var(--red-border); background: linear-gradient(180deg, rgba(254,242,242,0.98), rgba(255,255,255,0.92)); }
    @@media (max-width: 900px) {
        .smart-hero { grid-template-columns: 1fr; }
        .smart-metric-grid { grid-template-columns: 1fr; }
        .smart-row { grid-template-columns: 1fr; }
        .smart-row code { width: fit-content; }
        .action-rec-hero,
        .action-rec-grid { grid-template-columns: 1fr; }
        .action-rec-summary-grid { grid-template-columns: 1fr; }
    }

    /* EVENING IMPORT PREDICTION */
    .evening-risk {
        position: relative;
        overflow: hidden;
    }
    .evening-risk::before {
        content: '';
        position: absolute;
        inset: 0 0 auto 0;
        height: 3px;
        background: var(--green);
    }
    .evening-risk--accent::before { background: var(--accent); }
    .evening-risk--warning::before { background: var(--amber); }
    .evening-risk--danger::before { background: var(--red); }
    .evening-risk__hero {
        display: grid;
        grid-template-columns: minmax(220px, 0.85fr) minmax(0, 1.15fr);
        gap: 14px;
        align-items: stretch;
    }
    .evening-risk__score {
        border-radius: var(--r-md);
        border: 1px solid var(--border);
        padding: 18px;
        background:
            radial-gradient(circle at 16% 8%, rgba(21, 128, 61, 0.12), transparent 32%),
            linear-gradient(145deg, #F8FAFC, #FFFFFF);
    }
    .evening-risk--accent .evening-risk__score {
        background:
            radial-gradient(circle at 16% 8%, rgba(26, 86, 219, 0.14), transparent 32%),
            linear-gradient(145deg, #F8FAFC, #FFFFFF);
    }
    .evening-risk--warning .evening-risk__score {
        background:
            radial-gradient(circle at 16% 8%, rgba(180, 83, 9, 0.16), transparent 32%),
            linear-gradient(145deg, #FFFBEB, #FFFFFF);
    }
    .evening-risk--danger .evening-risk__score {
        background:
            radial-gradient(circle at 16% 8%, rgba(185, 28, 28, 0.14), transparent 32%),
            linear-gradient(145deg, #FEF2F2, #FFFFFF);
    }
    .evening-risk__kicker {
        font-size: 9px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--text-subtle);
    }
    .evening-risk__score strong {
        display: block;
        margin-top: 6px;
        font-size: 38px;
        line-height: 1;
        font-family: var(--fm);
        color: var(--green);
        letter-spacing: -0.06em;
    }
    .evening-risk--accent .evening-risk__score strong { color: var(--accent); }
    .evening-risk--warning .evening-risk__score strong { color: var(--amber); }
    .evening-risk--danger .evening-risk__score strong { color: var(--red); }
    .evening-risk__score p {
        margin-top: 10px;
        font-size: 11.5px;
        line-height: 1.6;
        color: var(--text-muted);
    }
    .evening-risk__window {
        display: inline-flex;
        align-items: center;
        margin-top: 12px;
        padding: 4px 9px;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.88);
        font-size: 10.5px;
        font-family: var(--fm);
        color: var(--text);
    }
    .evening-risk__meter {
        height: 8px;
        margin-top: 14px;
        border-radius: 999px;
        background: var(--bg-muted);
        overflow: hidden;
    }
    .evening-risk__meter span {
        display: block;
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(90deg, var(--green), #22C55E);
    }
    .evening-risk--accent .evening-risk__meter span { background: linear-gradient(90deg, var(--accent), #60A5FA); }
    .evening-risk--warning .evening-risk__meter span { background: linear-gradient(90deg, var(--amber), #F59E0B); }
    .evening-risk--danger .evening-risk__meter span { background: linear-gradient(90deg, var(--red), #F87171); }
    .evening-risk__meta {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px;
    }
    .evening-risk__metric {
        border: 1px solid var(--border);
        border-radius: var(--r);
        padding: 12px 13px;
        background: var(--bg-card);
        display: flex;
        flex-direction: column;
        gap: 3px;
    }
    .evening-risk__metric small {
        font-size: 9px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--text-subtle);
    }
    .evening-risk__metric strong {
        font-size: 16px;
        font-family: var(--fm);
        letter-spacing: -0.03em;
        color: var(--text);
    }
    .evening-risk__metric span {
        font-size: 10.5px;
        line-height: 1.45;
        color: var(--text-muted);
    }
    .evening-risk__metric--good { border-color: var(--green-border); background: var(--green-muted); }
    .evening-risk__metric--good strong { color: var(--green); }
    .evening-risk__metric--accent { border-color: var(--accent-ring); background: var(--accent-muted); }
    .evening-risk__metric--accent strong { color: var(--accent); }
    .evening-risk__metric--warning { border-color: var(--amber-border); background: var(--amber-muted); }
    .evening-risk__metric--warning strong { color: var(--amber); }
    .evening-risk__metric--danger { border-color: var(--red-border); background: var(--red-muted); }
    .evening-risk__metric--danger strong { color: var(--red); }
    .evening-risk__actions {
        margin-top: 14px;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }
    .evening-risk__action {
        border: 1px solid var(--border);
        border-radius: var(--r);
        padding: 12px 13px;
        background: var(--bg-card);
    }
    .evening-risk__action strong {
        display: block;
        font-size: 12.5px;
        font-weight: 700;
        letter-spacing: -0.01em;
        color: var(--text);
    }
    .evening-risk__action p {
        margin-top: 4px;
        font-size: 11px;
        line-height: 1.55;
        color: var(--text-muted);
    }
    .evening-risk__action em {
        display: inline-block;
        margin-top: 8px;
        font-style: normal;
        font-family: var(--fm);
        font-size: 10px;
        color: var(--text-subtle);
    }
    .evening-risk__action--good { border-color: var(--green-border); background: var(--green-muted); }
    .evening-risk__action--accent { border-color: var(--accent-ring); background: var(--accent-muted); }
    .evening-risk__action--warning { border-color: var(--amber-border); background: var(--amber-muted); }
    .evening-risk__action--danger { border-color: var(--red-border); background: var(--red-muted); }
    @@media (max-width: 980px) {
        .evening-risk__hero { grid-template-columns: 1fr; }
    }
    @@media (max-width: 760px) {
        .evening-risk__meta,
        .evening-risk__actions { grid-template-columns: 1fr; }
    }

    /* WEATHER + PV FORECAST */
    .weather-now {
        display: grid;
        grid-template-columns: minmax(190px, 0.8fr) minmax(0, 1.2fr);
        gap: 12px;
    }
    .weather-main {
        border-radius: var(--r-md);
        border: 1px solid #BAE6FD;
        padding: 18px;
        background:
            radial-gradient(circle at 18% 10%, rgba(14, 165, 233, 0.22), transparent 34%),
            linear-gradient(135deg, #F0F9FF, #FFFFFF);
    }
    .weather-main strong { display: block; font-family: var(--fm); font-size: 36px; line-height: 1; color: #0369A1; letter-spacing: -0.06em; }
    .weather-main span { display: block; margin-top: 6px; font-size: 12px; color: var(--text-muted); }
    .weather-main p { margin-top: 12px; font-size: 11.5px; color: var(--text-muted); line-height: 1.55; }
    .weather-kpis { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8px; }
    .weather-kpi {
        border: 1px solid var(--border);
        border-radius: var(--r);
        padding: 11px 12px;
        background: var(--bg-card);
    }
    .weather-kpi small { display: block; font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-subtle); }
    .weather-kpi strong { display: block; margin-top: 2px; font-family: var(--fm); font-size: 15px; color: var(--text); }
    .weather-kpi span { display: block; margin-top: 2px; font-size: 10.5px; color: var(--text-muted); }
    .weather-strip {
        display: flex;
        gap: 6px;

                        btn.classList.toggle('is-active', String(hoursBackSelect?.value || '24') === range);
                        btn.addEventListener('click', () => {
                            if (!hoursBackSelect || !dashboardRangeForm) return;
                            hoursBackSelect.value = range;
                            persistRangePreferences({ hoursBack: Number(range) || 24 });
                            dashboardRangeForm.requestSubmit ? dashboardRangeForm.requestSubmit() : dashboardRangeForm.submit();
                        });
                    });

                    const refreshButton = document.querySelector('#dashboardRangeForm button[type="submit"]');
                    if (refreshButton) {
                        refreshButton.textContent = 'Aktualizovať';
                    }

                    setInterval(triggerScheduledQuietRefresh, 60 * 1000);


                    /* Series toggle buttons for trend chart */
                    document.querySelectorAll('[data-series]').forEach(btn => {
                        const key = btn.dataset.series;
                        btn.classList.toggle('is-on', activeTrendSeries.has(key));
                        btn.classList.toggle('is-off', !activeTrendSeries.has(key));
                        btn.addEventListener('click', () => {
                            activeTrendSeries.has(key) ? activeTrendSeries.delete(key) : activeTrendSeries.add(key);
                            btn.classList.toggle('is-on', activeTrendSeries.has(key));
                            btn.classList.toggle('is-off', !activeTrendSeries.has(key));
                            saveDashboardPreferences({ trendSeries: [...activeTrendSeries] });
                            buildTrendChart();
                            syncTrendReadout();
                        });

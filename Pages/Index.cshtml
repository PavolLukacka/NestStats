    .smart-card strong { font-size: 16px; font-family: var(--fm); color: var(--text); letter-spacing: -0.03em; }
    .smart-card span { font-size: 10.5px; color: var(--text-muted); line-height: 1.45; }
    .smart-card--good { border-color: var(--green-border); background: var(--green-muted); }
    .smart-card--good strong { color: var(--green); }
    .smart-card--warning { border-color: var(--amber-border); background: var(--amber-muted); }
    .smart-card--warning strong { color: var(--amber); }
    .smart-card--danger { border-color: var(--red-border); background: var(--red-muted); }
    .smart-card--danger strong { color: var(--red); }
    .smart-card--accent { border-color: var(--accent-ring); background: var(--accent-muted); }
    .smart-card--accent strong { color: var(--accent); }
    .smart-list { display: flex; flex-direction: column; gap: 8px; }
    .smart-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 10px;
        align-items: center;
        border: 1px solid var(--border);
        border-radius: var(--r);
        padding: 11px 12px;
        background: var(--bg-card);
    }
    .smart-row h3 { font-size: 12.5px; font-weight: 700; color: var(--text); letter-spacing: -0.01em; }
    .smart-row p { margin-top: 2px; font-size: 11px; line-height: 1.45; color: var(--text-muted); }
    .smart-row code {
        font-family: var(--fm);
        font-size: 11px;
        color: var(--text);
        background: var(--bg-muted);
        border-radius: 999px;
        padding: 5px 8px;
        white-space: nowrap;
    }
    .smart-row--danger { border-color: var(--red-border); background: var(--red-muted); }
    .smart-row--warning { border-color: var(--amber-border); background: var(--amber-muted); }
    .smart-row--accent { border-color: var(--accent-ring); background: var(--accent-muted); }
    .smart-row--good { border-color: var(--green-border); background: var(--green-muted); }
    .action-rec-shell {
        display: grid;
        gap: 14px;
    }
    .action-rec-hero {
        display: grid;
        grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
        gap: 14px;
        align-items: stretch;
    }
    .action-rec-summary {
        border: 1px solid var(--border);
        border-radius: var(--r-md);
        padding: 18px;
        background:
            radial-gradient(circle at top right, rgba(26, 86, 219, 0.10), transparent 28%),
            linear-gradient(180deg, rgba(250,252,255,0.98), rgba(255,255,255,0.92));
        display: grid;
        gap: 10px;
    }
    .action-rec-summary small {
        font-size: 9.5px;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--text-subtle);
    }
    .action-rec-summary strong {
        display: block;
        font-family: var(--fm);
        font-size: 32px;
        line-height: 1;
        letter-spacing: -0.06em;
        color: var(--text);
    }
    .action-rec-summary p {
        font-size: 11.5px;
        line-height: 1.6;
        color: var(--text-muted);
    }
    .action-rec-summary-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 8px;
    }
    .action-rec-summary-cell {
        border: 1px solid rgba(230,230,227,0.96);
        border-radius: var(--r-sm);
        padding: 10px;
        background: rgba(255,255,255,0.88);
    }
    .action-rec-summary-cell span {
        display: block;
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--text-subtle);
    }
    .action-rec-summary-cell strong {
        margin-top: 4px;
        font-size: 16px;
        line-height: 1.1;
    }
    .action-rec-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }
    .action-rec-item {
        border: 1px solid var(--border);
        border-radius: var(--r-md);
        padding: 14px 15px;
        background: var(--bg-card);
        display: grid;
        gap: 10px;
        min-height: 100%;
    }
    .action-rec-item__head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 10px;
    }
    .action-rec-item__head h3 {
        font-size: 13px;
        font-weight: 700;
        color: var(--text);
        letter-spacing: -0.01em;
    }
    .action-rec-item__head span {
        font-size: 9px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--text-subtle);
        border-radius: 999px;
        padding: 5px 8px;
        background: rgba(244,244,242,0.92);
        white-space: nowrap;
    }
    .action-rec-item p {
        font-size: 11.5px;
        line-height: 1.6;
        color: var(--text-muted);
    }
    .action-rec-item code {
        width: fit-content;
        font-family: var(--fm);

                    let historyRequestSeq = 0;
                    const historyRowsPerPage = 7;
                    let historyPage = Math.max(1, Number(dashboardPrefs.historyPage || 1) || 1);
                    let activeHistoryRows = [];
                    let activeHistoryPageRows = [];

                    function setHistoryLoading(isLoading) {
                        const loading = $('history-loading');
                        if (loading) loading.hidden = !isLoading;
                        const historyWrap = $('historyChart')?.closest('.chart-wrap');
                        historyWrap?.classList.toggle('is-chart-loading', !!isLoading);
                        document.querySelectorAll('[data-history-window]').forEach(button => {
                            button.disabled = !!isLoading;
                        });
                        if (isLoading) {
                            document.querySelectorAll('[data-history-page]').forEach(button => {
                                button.disabled = true;
                            });
                        }
                    }

                    function historyWindowKey(n) {
                        return n === 'all' ? 'all' : String([7, 14, 30].includes(Number(n)) ? Number(n) : 7);
                    }

                    function escapeHistoryText(value) {
                        return String(value ?? '')
                            .replaceAll('&', '&amp;')
                            .replaceAll('<', '&lt;')
                            .replaceAll('>', '&gt;')
                            .replaceAll('"', '&quot;')
                            .replaceAll("'", '&#39;');
                    }

                    function formatHistoryNumber(value, digits = 2) {
                        return (Number(value) || 0).toLocaleString('sk-SK', {
                            minimumFractionDigits: digits,
                            maximumFractionDigits: digits
                        });
                    }

                    function getHistoryPageRows(rows) {
                        const newestFirst = rows.slice().reverse();
                        const pageCount = Math.max(1, Math.ceil(newestFirst.length / historyRowsPerPage));
                        historyPage = Math.min(Math.max(1, historyPage), pageCount);
                        return newestFirst.slice((historyPage - 1) * historyRowsPerPage, historyPage * historyRowsPerPage);
                    }

                    function renderHistoryTable(rows) {
                        const body = $('history-table-body');
                        if (!body) return;

                        if (!rows.length) {
                            activeHistoryPageRows = [];
                            body.innerHTML = '<tr><td colspan="8" style="text-align:center;color:var(--text-subtle);padding:24px;font-size:13px">Historicke data zatial nie su dostupne.</td></tr>';
                            const label = $('history-page-label');
                            if (label) label.textContent = '0 / 0';
                            return;
                        }

                        const newestFirst = rows.slice().reverse();
                        const pageCount = Math.max(1, Math.ceil(newestFirst.length / historyRowsPerPage));
                        historyPage = Math.min(Math.max(1, historyPage), pageCount);
                        const pageRows = getHistoryPageRows(rows);
                        activeHistoryPageRows = pageRows.slice().reverse();

                        body.innerHTML = pageRows.map(h => {
                            const balance = (Number(h.Export) || 0) - (Number(h.Import) || 0);
                            const balanceClass = balance > 0.05 ? 'val--pos' : balance < -0.05 ? 'val--neg' : '';
                            const selfClass = h.SelfSufficiencyPct >= 80 ? 'val--pos' : h.SelfSufficiencyPct >= 50 ? 'val--warn' : 'val--neg';

                            return `<tr data-history-date="${escapeHistoryText(h.Date)}">
                                <td><span class="tbl-date">${escapeHistoryText(h.Date)}</span></td>
                                <td>${formatHistoryNumber(h.Pv)} kWh</td>
                                <td>${formatHistoryNumber(h.Consumption)} kWh</td>
                                <td class="val--neg-light">${formatHistoryNumber(h.Import)} kWh</td>
                                <td class="val--pos-light">${formatHistoryNumber(h.Export)} kWh</td>
                                <td class="${selfClass}">${formatHistoryNumber(h.SelfSufficiencyPct, 1)}&nbsp;%</td>
                                <td>${formatHistoryNumber(h.SelfUsePct, 1)}&nbsp;%</td>
                                <td class="${balanceClass}">${balance >= 0 ? '+' : ''}${formatHistoryNumber(balance)} kWh</td>
                            </tr>`;
                        }).join('');

                        const label = $('history-page-label');
                        if (label) label.textContent = `${historyPage} / ${pageCount}`;
                        document.querySelectorAll('[data-history-page="prev"]').forEach(button => {
                            button.disabled = historyPage <= 1;
                        });
                        document.querySelectorAll('[data-history-page="next"]').forEach(button => {
                            button.disabled = historyPage >= pageCount;
                        });
                    }

                    async function loadHistoryWindowRows(n) {
                        const key = historyWindowKey(n);
                        if (historyWindowCache.has(key)) return historyWindowCache.get(key);

                        if (!rawDashboard.historyEndpoint) {
                            const fallbackRows = key === 'all' ? histData : histData.slice(-Number(key));
                            historyWindowCache.set(key, fallbackRows);
                            return fallbackRows;
                        }

                        try {
                            const url = new URL(rawDashboard.historyEndpoint, window.location.origin);
                            url.searchParams.set('window', key);
                            const response = await fetch(url, {
                                headers: { 'X-Requested-With': 'XMLHttpRequest' }
                            });
                            if (!response.ok) throw new Error(`History fetch failed: ${response.status}`);

                            const payload = await response.json();
                            const rows = mapHistoryRows(payload.history)
                                .sort((a, b) => String(a.Date).localeCompare(String(b.Date)));
                            historyWindowCache.set(key, rows);
                            if (key === 'all' || rows.length > histData.length) {
                                histData = rows;
                            }
                            return rows;
                        } catch (error) {
                            console.warn(error);
                            const fallbackRows = key === 'all' ? histData : histData.slice(-Number(key));
                            historyWindowCache.set(key, fallbackRows);
                            return fallbackRows;
                        }
                    }

                    async function applyHistoryWindow(n) {
                        const requestSeq = ++historyRequestSeq;
                        const key = historyWindowKey(n);
                        setHistoryLoading(true);
                        try {
                            const rows = await loadHistoryWindowRows(key);
                            if (requestSeq !== historyRequestSeq) return;
                            activeHistoryRows = rows;
                            buildImpactChart(rows);
                            buildHistChart(rows);
                            buildHistInsightChart(rows);

                            // Update insight KPIs
                            const sum  = (fn) => rows.reduce((a, h) => a + (fn(h)||0), 0);
                            const avg  = (fn) => rows.length ? sum(fn) / rows.length : 0;
                            const best = rows.reduce((b, h) => (h.Pv||0) > (b?.Pv||0) ? h : b, null);
                            const pvS  = sum(h => h.Pv);
                            const csS  = sum(h => h.Consumption);
                            const imS  = sum(h => h.Import);
                            const exS  = sum(h => h.Export);
                            const bal  = exS - imS;
                            const fmt  = (v, u) => formatHistoryNumber(v, 2) + ' ' + u;

                            const set = (id, v) => { const el = $(id); if (el) el.textContent = v; };
                            set('hist-pv-sum',  fmt(pvS, 'kWh'));
                            set('hist-cons-sum',fmt(csS, 'kWh'));
                            set('hist-imp-sum', fmt(imS, 'kWh'));
                            set('hist-exp-sum', fmt(exS, 'kWh'));
                            set('hist-bal',     (bal >= 0 ? '+' : '') + fmt(bal, 'kWh'));
                            set('hist-ss-avg',  formatHistoryNumber(avg(h => h.SelfSufficiencyPct), 1) + ' %');
                            set('hist-su-avg',  formatHistoryNumber(avg(h => h.SelfUsePct), 1) + ' %');
                            set('hist-best-day', best ? best.Date + ' - ' + formatHistoryNumber(best.Pv || 0, 2) + ' kWh' : '-');

                            // Insight bars
                            document.querySelectorAll('.insight-bar--export').forEach(b => {
                                b.style.width = csS > 0 ? Math.min(exS/csS*100,100).toFixed(1)+'%' : '0%';
                            });
                            document.querySelectorAll('.insight-bar--import').forEach(b => {
                                b.style.width = csS > 0 ? Math.min(imS/csS*100,100).toFixed(1)+'%' : '0%';
                            });

                            renderHistoryTable(rows);
                            buildAdvancedHistoryCharts(activeHistoryPageRows);

                            // Badge
                            const badge = $('history-insight-range');
                        if (badge) {
                            badge.textContent = key === 'all'
                                ? @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("všetky dáta", "all data")))
                                : `${@Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("posledných", "last")))} ${key} ${@Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("dní", "days")))}`;
                        }
                        } finally {
                            if (requestSeq === historyRequestSeq) setHistoryLoading(false);
                        }
                    }

                    // History window chip buttons
                    const initialHistoryWindow = dashboardPrefs.historyWindow === 'all'
                        ? 'all'
                        : ([7, 14, 30].includes(Number(dashboardPrefs.historyWindow)) ? Number(dashboardPrefs.historyWindow) : 7);
                    document.querySelectorAll('[data-history-window]').forEach(btn => {
                        const isActive = btn.dataset.historyWindow === String(initialHistoryWindow);
                        btn.classList.toggle('is-active', isActive);
                        btn.addEventListener('click', () => {
                            document.querySelectorAll('[data-history-window]').forEach(b => b.classList.remove('is-active'));
                            btn.classList.add('is-active');
                            const w = btn.dataset.historyWindow;
                            saveDashboardPreferences({ historyWindow: w });
                            applyHistoryWindow(w === 'all' ? 'all' : +w);
                        });
                    });

                    document.querySelectorAll('[data-history-page]').forEach(button => {
                        button.addEventListener('click', () => {
                            const newestFirstCount = activeHistoryRows.length;
                            const pageCount = Math.max(1, Math.ceil(newestFirstCount / historyRowsPerPage));
                            const direction = button.dataset.historyPage;
                            historyPage = direction === 'next'
                                ? Math.min(pageCount, historyPage + 1)
                                : Math.max(1, historyPage - 1);
                            saveDashboardPreferences({ historyPage });
                            renderHistoryTable(activeHistoryRows);
                            buildAdvancedHistoryCharts(activeHistoryPageRows);
                        });
                    });

                    // Initial render
                    applyHistoryWindow(initialHistoryWindow === 'all' ? 'all' : +initialHistoryWindow);
                    saveDashboardPreferences({ historyWindow: String(initialHistoryWindow) });

                    /* ── Tariff switching ────────────────────────────── */
                    if (false) {
                    const tariffMap = {};
                    (D.TariffBenchmarks || []).forEach(t => { tariffMap[t.Key] = t; });
                    const providerMap = {};
                    (D.TariffBenchmarks || []).forEach(t => {
                        if (!providerMap[t.ProviderKey]) providerMap[t.ProviderKey] = [];
                        providerMap[t.ProviderKey].push(t);
                    });

                    function applyTariff(t) {
                        if (!t) return;
                        const fmt = (v, d) => v != null ? v.toLocaleString('sk-SK', { style:'currency', currency:'EUR', minimumFractionDigits:d, maximumFractionDigits:d }) : '–';
                        const set = (id, v) => { const el = $(id); if (el) el.textContent = v; };

                        set('tariff-provider-label',  (t.ProviderName || '') + (t.DistributorName ? ' – ' + t.DistributorName : ''));
                        set('tariff-rate-label',       fmt(t.EffectiveImportRateEurPerKwh, 3) + ' / kWh');
                        set('tariff-plan-label',       (t.TariffCode || '--') + ' — ' + (t.TariffLabel || ''));
                        set('tariff-assumption-label', t.AssumptionLabel || '');
                        set('tariff-net-day',          fmt(t.NetDailyBenefitEur, 2));
                        set('tariff-net-month',        fmt(t.NetMonthlyBenefitEur, 2));
                        set('tariff-net-year',         fmt(t.NetAnnualBenefitEur, 0));
                        set('tariff-fixed-fee',        fmt(t.AnnualFixedFeeEur, 0));
                        set('tariff-nt-share',         (t.EstimatedLowTariffSharePct || 0).toFixed(0) + ' % NT');
                        set('tariff-product-type',     t.ProductType || 'fixed');
                        set('tariff-high-rate',        fmt(t.HighRateEurPerKwh, 3));
                        set('tariff-low-rate',         fmt(t.LowRateEurPerKwh ?? t.HighRateEurPerKwh, 3));
                        set('tariff-export-rate',      fmt(D.ExportRevenue?.RateEurPerKwh, 3));
                        set('tariff-effective-date',   t.EffectiveDate || '');
                        set('tariff-source-label',     t.SourceLabel || '');

                        const exportRev = D.ExportRevenue || {};
                        set('tariff-annual-stack', fmt((t.NetAnnualBenefitEur||0) + (exportRev.AnnualRevenueEur||0), 0));
                        set('tariff-monthly-stack', 'Mesačný stack ' + fmt((t.NetMonthlyBenefitEur||0) + (exportRev.MonthlyRevenueEur||0), 2));

                        document.querySelectorAll('[data-tariff-key]').forEach(card => {
                            const isActive = card.dataset.tariffKey === t.Key;
                            card.classList.toggle('is-active', isActive);
                            card.setAttribute('aria-pressed', isActive ? 'true' : 'false');
                        });
                        saveDashboardPreferences({
                            tariffProviderKey: t.ProviderKey || '',
                            tariffPlanKey: t.Key || ''
                        });
                    }

                    const provSel  = $('tariff-provider-select');
                    const planSel  = $('tariff-plan-select');

                    function refreshPlanSelect(provKey, activeKey) {
                        if (!planSel) return;
                        const plans = providerMap[provKey] || [];
                        planSel.innerHTML = plans.map(t =>
                            `<option value="${t.Key}"${t.Key === activeKey ? ' selected' : ''}>${t.TariffCode} — ${t.TariffLabel}</option>`
                        ).join('');
                        const provGrid = $('tariff-provider-grid');
                        if (provGrid) {
                            provGrid.innerHTML = plans.map(t => {
                                const active = t.Key === activeKey;
                                return `<article class="t-card${active?' is-active':''}" data-tariff-key="${t.Key}" data-provider-key="${t.ProviderKey}" role="button" tabindex="0" aria-pressed="${active}">
                                    <div class="t-card__head"><div><h3>${t.TariffCode}</h3><span class="t-card__sub">${t.TariffLabel}</span></div><strong>${(t.NetAnnualBenefitEur||0).toLocaleString('sk-SK',{style:'currency',currency:'EUR',maximumFractionDigits:0})}</strong></div>
                                    <p>${t.AssumptionLabel||''}</p>
                                    <dl class="t-card-metrics">
                                        <div><dt>Efektívna</dt><dd>${(t.EffectiveImportRateEurPerKwh||0).toLocaleString('sk-SK',{style:'currency',currency:'EUR',minimumFractionDigits:3})}</dd></div>
                                        <div><dt>Fix / mes</dt><dd>${(t.MonthlyFixedFeeEur||0).toLocaleString('sk-SK',{style:'currency',currency:'EUR',minimumFractionDigits:2})}</dd></div>
                                        <div><dt>VT / NT</dt><dd>${(t.HighRateEurPerKwh||0).toLocaleString('sk-SK',{style:'currency',currency:'EUR',minimumFractionDigits:3})} / ${((t.LowRateEurPerKwh??t.HighRateEurPerKwh)||0).toLocaleString('sk-SK',{style:'currency',currency:'EUR',minimumFractionDigits:3})}</dd></div>
                                        <div><dt>Net / mes</dt><dd>${(t.NetMonthlyBenefitEur||0).toLocaleString('sk-SK',{style:'currency',currency:'EUR',minimumFractionDigits:2})}</dd></div>
                                    </dl>
                                    <a class="t-src" href="${t.SourceUrl||'#'}" target="_blank" rel="noreferrer">${t.SourceLabel||''} · ${t.EffectiveDate||''}</a>
                                </article>`;
                            }).join('');
                            // Re-attach click handlers
                            provGrid.querySelectorAll('[data-tariff-key]').forEach(card => {
                                card.addEventListener('click', () => {
                                    const t = tariffMap[card.dataset.tariffKey];
                                    if (t) { applyTariff(t); planSel.value = t.Key; }
                                });
                                card.addEventListener('keydown', e => {
                                    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); card.click(); }
                                });
                            });
                        }
                    }

                    const preferredTariff = tariffMap[dashboardPrefs.tariffPlanKey || D.SelectedTariffKey]
                        || tariffMap[planSel?.value || '']
                        || Object.values(tariffMap)[0];

                    if (preferredTariff) {
                        if (provSel) {
                            provSel.value = preferredTariff.ProviderKey;
                        }
                        refreshPlanSelect(preferredTariff.ProviderKey, preferredTariff.Key);
                        if (planSel) {
                            planSel.value = preferredTariff.Key;
                        }
                        applyTariff(preferredTariff);
                    }

                    if (provSel) {
                        provSel.addEventListener('change', () => {
                            const plans = providerMap[provSel.value] || [];
                            if (plans.length) { refreshPlanSelect(provSel.value, plans[0].Key); applyTariff(plans[0]); }
                        });
                    }
                    if (planSel) {
                        planSel.addEventListener('change', () => {
                            const t = tariffMap[planSel.value];
                            if (t) applyTariff(t);
                        });
                    }
                    // Tariff card clicks (initial render)
                    document.querySelectorAll('[data-tariff-key]').forEach(card => {
                        card.addEventListener('click', () => {
                            const t = tariffMap[card.dataset.tariffKey];
                            if (!t) return;
                            applyTariff(t);
                            if (planSel) planSel.value = t.Key;
                            if (provSel) provSel.value = t.ProviderKey;
                        });
                        card.addEventListener('keydown', e => {
                            if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); card.click(); }
                        });
                    });

                    /* ── Active nav highlight (IntersectionObserver) ─── */
                    }
                    const sections = document.querySelectorAll('.section-block');
                    const navLinks = document.querySelectorAll('.side-nav a');
                    const sideRail = document.querySelector('.side-rail');
                    let activeSectionId = '';
                    let pendingNavLink = null;
                    let navSyncFrame = 0;

                    function ensureNavLinkVisible(link) {
                        if (!link || !sideRail) return;
                        if (sideRail.offsetParent === null) return;
                        const navScroller = link.closest('.side-nav');
                        if (!navScroller) return;
                        const railRect = sideRail.getBoundingClientRect();
                        const linkRect = link.getBoundingClientRect();
                        const topLimit = railRect.top + 72;
                        const bottomLimit = railRect.bottom - 56;
                        const isAbove = linkRect.top < topLimit;
                        const isBelow = linkRect.bottom > bottomLimit;
                        if (!isAbove && !isBelow) return;
                        pendingNavLink = link;
                        if (navSyncFrame) return;
                        navSyncFrame = window.requestAnimationFrame(() => {
                            navSyncFrame = 0;
                            const target = pendingNavLink;
                            pendingNavLink = null;
                            if (!target) return;
                            const scroller = target.closest('.side-nav');
                            if (!scroller) return;
                            const top = target.offsetTop - 72;
                            const maxTop = Math.max(0, scroller.scrollHeight - scroller.clientHeight);
                            scroller.scrollTo({
                                top: Math.max(0, Math.min(top, maxTop)),
                                behavior: 'smooth'
                            });
                        });
                    }

                    function setActiveNavLinkBySection(sectionId, force) {
                        if (!sectionId || (!force && sectionId === activeSectionId)) return;
                        activeSectionId = sectionId;
                        navLinks.forEach(l => l.classList.remove('is-active'));
                        const match = document.querySelector(`.side-nav a[href="#${sectionId}"]`);
                        if (match) {
                            match.classList.add('is-active');
                            ensureNavLinkVisible(match);
                        }
                    }

                    function setActiveNavLinkWithoutScrolling(sectionId) {
                        if (!sectionId) return;
                        activeSectionId = sectionId;
                        navLinks.forEach(l => l.classList.remove('is-active'));
                        const match = document.querySelector(`.side-nav a[href="#${sectionId}"]`);
                        match?.classList.add('is-active');
                    }

                    function scrollSideNavToTop() {
                        const navScroller = document.querySelector('.side-nav');
                        if (!navScroller) return;
                        if (navSyncFrame) {
                            window.cancelAnimationFrame(navSyncFrame);
                            navSyncFrame = 0;
                        }
                        pendingNavLink = null;
                        navScroller.scrollTo({ top: 0, behavior: 'auto' });
                    }

                    /* Wider detection zone so short/bottom sections (Relay, SSR) trigger */
                    const obs = new IntersectionObserver(entries => {
                        const visible = entries
                            .filter(e => e.isIntersecting)
                            .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
                        if (visible) {
                            setActiveNavLinkBySection(visible.target.id);
                        }
                    }, { rootMargin: '-10% 0px -55% 0px', threshold: [0.05, 0.15, 0.4] });

                    sections.forEach(s => obs.observe(s));

                    navLinks.forEach(link => {
                        link.addEventListener('click', () => {
                            const href = link.getAttribute('href') || '';
                            if (href.startsWith('#')) {
                                setActiveNavLinkBySection(href.slice(1));
                            }
                        });
                    });

                    /* Edge-case scroll handler:
                       - at top → force first item active + scroll sidebar to top
                       - at bottom → activate last visible section                 */
                    let edgeFrame = 0;
                    window.addEventListener('scroll', () => {
                        if (edgeFrame) return;
                        edgeFrame = requestAnimationFrame(() => {
                            edgeFrame = 0;
                            const scrollY = window.scrollY;
                            const atTop = scrollY < 80;
                            const atBottom = scrollY + window.innerHeight >= document.documentElement.scrollHeight - 120;

                            if (atTop && sections.length > 0) {
                                scrollSideNavToTop();
                                setActiveNavLinkWithoutScrolling(sections[0].id);
                                return;
                            }

                            if (atBottom && sections.length > 0) {
                                for (let i = sections.length - 1; i >= 0; i--) {
                                    const rect = sections[i].getBoundingClientRect();
                                    if (rect.top < window.innerHeight * 0.85) {
                                        setActiveNavLinkBySection(sections[i].id);
                                        break;
                                    }
                                }
                            }
                        });
                    }, { passive: true });

                    /* ── Tab buttons (generic) ───────────────────────── */
                    document.querySelectorAll('.tab-btn').forEach(btn => {
                        btn.addEventListener('click', () => {
                            btn.closest('.tab-row').querySelectorAll('.tab-btn').forEach(b => b.classList.remove('is-active'));
                            btn.classList.add('is-active');
                        });
                    });

                    /* ── Live polling (every 60 s) ───────────────────── */
                    function setFlowLinkState(id, isActive, direction = 'forward') {
                        const el = $(id);
                        if (!el) return;
                        el.classList.remove('is-active', 'is-forward', 'is-reverse', 'is-idle');
                        if (!isActive) {
                            el.classList.add('is-idle');
                            return;
                        }
                        el.classList.add('is-active', direction === 'reverse' ? 'is-reverse' : 'is-forward');
                    }

                    const flowCopy = {
                        export: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("Export", "Export"))),
                        import: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("Import", "Import"))),
                        idle: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("Idle", "Idle"))),
                        charging: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("Nabíjanie", "Charging"))),
                        discharging: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("Vybíjanie", "Discharging"))),
                        standby: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("Pohotovosť", "Standby"))),
                        currentLoad: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("Aktuálna záťaž", "Current load"))),
                        load: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("Odber", "Load"))),
                        of: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("z", "of"))),
                        utilization: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("vyťaženie", "utilization"))),
                        active: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(T("aktívne", "active")))
                    };

                    function gridDirLabel(kw) {
                        return kw > 0.05 ? flowCopy.export : kw < -0.05 ? flowCopy.import : flowCopy.idle;
                    }

                    function batteryDirLabel(kw) {
                        return kw > 0.05 ? flowCopy.charging : kw < -0.05 ? flowCopy.discharging : flowCopy.standby;
                    }

                    function refreshLiveValues() {
                        if (!rawDashboard.liveEndpoint) return;
                        fetch(rawDashboard.liveEndpoint, {
                            headers: { 'X-Requested-With': 'XMLHttpRequest' }
                        })
                            .then(r => r.ok ? r.json() : null)
                            .then(data => {
                                if (!data) return;
                                const upd = (id, v) => { const el = $(id); if (el && v != null) el.textContent = v; };
                                const pvKw = data.pvTotal ?? data.pvPower;
                                const wattKw = data.wattPowerKw ?? 0;
                                const flowHomeKw = data.consumption != null ? Math.max(0, data.consumption - wattKw) : null;
                                upd('live-pv',          pvKw != null ? pvKw.toFixed(2) + ' kW' : null);
                                upd('live-inverter',    data.inverterPower != null ? data.inverterPower.toFixed(2) + ' kW' : null);
                                upd('live-consumption', data.consumption != null ? data.consumption.toFixed(2) + ' kW' : null);
                                upd('live-grid',        data.gridPower != null ? data.gridPower.toFixed(2) + ' kW' : null);
                                upd('live-battery',     data.batteryPower != null ? data.batteryPower.toFixed(2) + ' kW' : null);
                                upd('live-watt',        data.wattPowerKw != null ? data.wattPowerKw.toFixed(2) + ' kW' : null);
                                upd('live-soc',         data.soc != null ? data.soc.toFixed(0) + ' %' : null);
                                upd('live-updated-at',  data.time ? new Date(data.time).toLocaleString('sk-SK') : null);
                                upd('flow-pv-kw',       pvKw != null ? pvKw.toFixed(2) + ' kW' : null);
                                upd('flow-inverter-kw', data.inverterPower != null ? data.inverterPower.toFixed(2) + ' kW' : null);
                                upd('flow-home-kw',     flowHomeKw != null ? flowHomeKw.toFixed(2) + ' kW' : null);
                                upd('flow-grid-kw',     data.gridPower != null ? data.gridPower.toFixed(2) + ' kW' : null);
                                upd('flow-battery-kw',  data.batteryPower != null ? data.batteryPower.toFixed(2) + ' kW' : null);
                                upd('flow-watt-kw',     data.wattPowerKw != null ? data.wattPowerKw.toFixed(2) + ' kW' : null);
                                upd('flow-pv-note',     data.pvSaturationPct != null ? `${data.pvSaturationPct.toFixed(1)} % ${flowCopy.of} @dashboard.InstalledPvKw.ToString("0.0", CultureInfo.InvariantCulture) kWp` : null);
                                upd('flow-home-note',   flowCopy.load);
                                upd('flow-grid-note',   data.gridPower != null ? gridDirLabel(data.gridPower) : null);
                                upd('flow-battery-note', data.batteryPower != null || data.soc != null
                                    ? `${data.soc != null ? data.soc.toFixed(0) : '@batterySoc.ToString("0")'} % SOC · ${batteryDirLabel(data.batteryPower ?? 0)}`
                                    : null);
                                upd('flow-watt-note',   data.wattUtilizationPct != null ? `${data.wattUtilizationPct.toFixed(1)} % ${flowCopy.utilization} | ${(data.relayCount ?? 0).toFixed(0)} / @dashboard.RelayChannelCount ${flowCopy.active}` : null);
                                const socBar = $('live-soc-bar');
                                if (socBar && data.soc != null) socBar.style.width = data.soc + '%';
                                const pvBar = $('live-pv-bar');
                                if (pvBar && data.pvSaturationPct != null) pvBar.style.width = data.pvSaturationPct + '%';
                                const flowPvBar = $('flow-pv-fill');
                                if (flowPvBar && data.pvSaturationPct != null) flowPvBar.style.width = data.pvSaturationPct + '%';
                                const flowWattBar = $('flow-watt-fill');
                                if (flowWattBar && data.wattUtilizationPct != null) flowWattBar.style.width = data.wattUtilizationPct + '%';
                                setFlowLinkState('flow-link-pv', (pvKw ?? 0) > 0.05, 'forward');
                                setFlowLinkState('flow-link-home', (flowHomeKw ?? 0) > 0.05, 'forward');
                                setFlowLinkState('flow-link-grid', Math.abs(data.gridPower ?? 0) > 0.05, (data.gridPower ?? 0) < -0.05 ? 'forward' : 'reverse');
                                setFlowLinkState('flow-link-battery', Math.abs(data.batteryPower ?? 0) > 0.05, (data.batteryPower ?? 0) < -0.05 ? 'forward' : 'reverse');
                                setFlowLinkState('flow-link-watt', (data.wattPowerKw ?? 0) > 0.05, 'forward');
                                maybeRefreshSelectedRange(data.time);
                            })
                            .catch(() => {});
                    }
                    setInterval(refreshLiveValues, 60000);

                })();
            </script>

            }
        </div>@* /ws-body *@
    </div>@* /workspace *@
</div>@* /app-shell *@
}

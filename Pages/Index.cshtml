                    <span class="panel-badge" id="inverter-total-date">@((dashboard.Charts.Totals.LastOrDefault()?.Date) ?? "?")</span>
                </div>
                <div class="chart-wrap chart-wrap--md"><canvas id="inverterTotalsChart"></canvas></div>
            </article>


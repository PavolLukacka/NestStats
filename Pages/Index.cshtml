                        <div class="device-footer">
                            <small>@BatDir(dashboard.LatestBatteryKw)</small>
                            <a class="btn btn--ghost btn--sm" href="#telemetry">Detail</a>
                        </div>
                    </div>

                    @* ── WattRouter ── *@
                    <div class="device-card @(dashboard.LatestWattKw > 0 ? "device-online" : "device-offline")">
                        <div class="device-head">
                            <div>
                                <div class="device-name">WattRouter</div>
                                <div class="device-type">@T("Riadenie prebytkov", "Surplus control")</div>
                            </div>
                            <span class="device-status @(dashboard.LatestWattKw > 0 ? "device-status--online" : "device-status--offline")">
                                    <span class="device-status__dot"></span>@(dashboard.LatestWattKw > 0 ? T("Aktívny", "Active") : T("Pohotovosť", "Standby"))
                                </span>
                        </div>
                        <div class="device-metrics">
                            <div><span>@T("Výkon", "Power")</span><strong>@Kw(dashboard.LatestWattKw)</strong></div>
                            <div><span>@T("Vyťaženie", "Utilization")</span><strong>@dashboard.CurrentWattUtilizationPct.ToString("0.0", currency)&nbsp;%</strong></div>
                            <div><span>@T("Relé aktívne", "Active relays")</span><strong>@dashboard.RelayStates.Count(r => r.IsOn) / @dashboard.RelayStates.Count</strong></div>
                        </div>
                        <div class="device-footer">
                            <small>@T("SSR / relé kanály", "SSR / relay channels")</small>

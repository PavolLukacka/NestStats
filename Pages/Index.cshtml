    .t-card p { font-size: 10.5px; color: var(--text-muted); line-height: 1.5; }
    .t-card-metrics { display: grid; grid-template-columns: repeat(2, 1fr); gap: 5px; }
    .t-card-metrics dt { font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.11em; color: var(--text-subtle); }
    .t-card-metrics dd { font-size: 11.5px; font-weight: 600; font-family: var(--fm); color: var(--text); }
    .t-card > a.t-src { display: block; font-size: 10px; color: var(--text-subtle); text-decoration: none; padding-top: 8px; border-top: 1px solid var(--border); font-family: var(--fm); }
    .t-card > a.t-src:hover { color: var(--accent); }
    .flow-shell { align-items: start; grid-template-columns: 1fr; }
    .flow-shell__primary,
    .flow-side,
    .economics-shell .panel { min-width: 0; }
    .flow-side { display: flex; flex-direction: column; }
    .flow-side__stats { margin-top: auto; }
    .flow-side__stats .stat-card { min-height: 92px; justify-content: space-between; }
    .economics-stack { display: grid; gap: 14px; }
    .economics-toolbar .field { flex: 1 1 220px; min-width: 220px; }
    .economics-toolbar .field span { white-space: nowrap; }
    .economics-shell .tariff-g { margin-top: 0; }
    .economics-meta { margin-top: 10px; font-size: 11px; color: var(--text-subtle); }
    @@media (max-width: 1100px) {
        .flow-side__stats .stat-card { min-height: 0; }
    }

    /* â•â•â• BENEFIT / ENVIRONMENT GRID â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    .benefit-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--border); border-radius: var(--r); overflow: hidden; }
    @@media (max-width: 900px) { .benefit-grid { grid-template-columns: repeat(2, 1fr); } }
    .b-cell { background: var(--bg-card); padding: 12px 14px; display: flex; flex-direction: column; gap: 3px; transition: background var(--tx); }
    .b-cell:hover { background: var(--bg-muted); }
    .b-cell .b-lbl { font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-subtle); }
    .b-cell strong { font-size: 15px; font-weight: 700; font-family: var(--fm); color: var(--text); letter-spacing: -0.02em; }
    .b-cell small { font-size: 10px; color: var(--text-subtle); }

    /* â•â•â• TABLES â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    .tbl-wrap { overflow-x: auto; border-radius: var(--r); border: 1px solid var(--border); margin-top: 14px; }
    .data-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    .data-table th { padding: 9px 13px; text-align: left; font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-subtle); background: var(--bg-muted); border-bottom: 1px solid var(--border); white-space: nowrap; }
    .data-table td { padding: 9px 13px; color: var(--text-muted); border-bottom: 1px solid var(--border); font-family: var(--fm); font-size: 12px; white-space: nowrap; }
    .data-table td:first-child { font-family: var(--ff); font-weight: 600; color: var(--text); }
    .data-table tr:last-child td { border-bottom: none; }
    .data-table tr:hover td { background: var(--bg-muted); }
    .history-pager { display: flex; align-items: center; justify-content: flex-end; gap: 10px; margin-top: 10px; }
    .history-pager__label { min-width: 74px; text-align: center; color: var(--text-subtle); font-family: var(--fm); font-size: 12px; }
    .history-pager__btn:disabled { opacity: .42; cursor: not-allowed; }
    .history-loading { display: inline-flex; align-items: center; gap: 8px; min-height: 26px; margin: -4px 0 10px; padding: 5px 10px; border: 1px solid rgba(26,86,219,.16); border-radius: 999px; background: rgba(26,86,219,.055); color: var(--accent); font-size: 11.5px; font-weight: 700; }
    .history-loading[hidden] { display: none; }
    .history-loading__dot { width: 7px; height: 7px; border-radius: 999px; background: currentColor; box-shadow: 0 0 0 0 rgba(26,86,219,.22); animation: loaderStagePulse 1.2s ease-in-out infinite; }

    /* â•â•â• INSIGHTS â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• */
    .insight-list { display: flex; flex-direction: column; gap: 8px; }
    .insight-card { padding: 13px 15px; border-radius: var(--r); border: 1px solid var(--border); background: var(--bg-card); transition: all var(--tx); }
    .insight-card:hover { box-shadow: var(--sh-xs); }
    .insight-card h3 { font-size: 12.5px; font-weight: 600; color: var(--text); margin-bottom: 4px; letter-spacing: -0.005em; }
    .insight-card p { font-size: 11.5px; color: var(--text-muted); line-height: 1.55; }
    .insight-card--positive { border-color: var(--green-border); background: var(--green-muted); }
    .insight-card--positive h3 { color: var(--green); }
    .insight-card--warning { border-color: var(--amber-border); background: var(--amber-muted); }
    .insight-card--warning h3 { color: var(--amber); }
    .insight-card--negative { border-color: var(--red-border); background: var(--red-muted); }
    .insight-card--negative h3 { color: var(--red); }

    /* SMART COMMAND CENTER */
    .smart-hero {
        display: grid;
        grid-template-columns: minmax(220px, 0.9fr) minmax(0, 1.4fr);
        gap: 12px;
    }
    .smart-score {
        border: 1px solid var(--border);
        border-radius: var(--r-md);
        padding: 16px;
        background:
            radial-gradient(circle at 16% 0%, rgba(26, 86, 219, 0.14), transparent 32%),
            linear-gradient(135deg, #F8FAFC, #FFFFFF);
    }
    .smart-score strong { display: block; font-size: 34px; line-height: 1; font-family: var(--fm); color: var(--accent); letter-spacing: -0.05em; }
    .smart-score span { display: block; margin-top: 4px; font-size: 11px; color: var(--text-muted); }
    .smart-meter { height: 7px; border-radius: 999px; background: var(--bg-muted); overflow: hidden; margin-top: 14px; }
    .smart-meter span { display: block; height: 100%; border-radius: inherit; background: linear-gradient(90deg, var(--accent), var(--green)); }
    .smart-metric-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8px; }

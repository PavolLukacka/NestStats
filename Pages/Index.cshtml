    @@media (min-width: 1101px) and (max-width: 1380px) {
        .spot-market-panel .spot-hours {
            grid-template-columns: repeat(4, minmax(0, 1fr));
        }
    }
    .story-stack {
        display: grid;
        gap: 12px;
    }
    .story-card {
        border: 1px solid var(--border);
        border-radius: var(--r-md);
        background: var(--bg-card);
        padding: 15px 16px;
        display: grid;
        gap: 12px;
    }
    .story-card--good {
        background:
            radial-gradient(circle at top right, rgba(34,197,94,0.10), transparent 30%),
            linear-gradient(180deg, rgba(248,255,250,0.98), rgba(255,255,255,0.92));
    }
    .story-card--accent {
        background:
            radial-gradient(circle at top right, rgba(245,158,11,0.10), transparent 30%),
            linear-gradient(180deg, rgba(255,252,244,0.98), rgba(255,255,255,0.92));
    }
    .story-card--warning {
        background:
            radial-gradient(circle at top right, rgba(239,68,68,0.10), transparent 30%),
            linear-gradient(180deg, rgba(255,248,248,0.98), rgba(255,255,255,0.92));
    }
    .story-card__head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 10px;
    }
    .story-card__head small {
        display: block;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--text-subtle);
    }
    .story-card__head strong {
        display: block;
        margin-top: 4px;
        font-family: var(--fm);
        font-size: 18px;
        color: var(--text);
        letter-spacing: -0.04em;
    }
    .story-card__headline {
        font-size: 13px;
        font-weight: 700;
        color: var(--text);
        line-height: 1.45;
    }
    .story-card__summary {
        font-size: 11.5px;
        color: var(--text-muted);
        line-height: 1.65;
    }
    .story-kpis {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 8px;
    }
    .story-kpi {
        border: 1px solid rgba(230,230,227,0.96);
        border-radius: var(--r-sm);
        padding: 9px 10px;
        background: rgba(255,255,255,0.84);
    }
    .story-kpi small {
        display: block;
        font-size: 9px;

@page
@model NestStats2.Pages.IndexModel
@using System
@using System.Globalization
@using System.Linq
@using NestStats2.Models

@{
ViewData["Title"] = "NestStats";
var isEnglish = Lang.IsEnglish(ViewContext.HttpContext);
string T(string sk, string en) => Lang.Pick(ViewContext.HttpContext, sk, en);
var dashboard = Model.Dashboard;
var batterySoc = Math.Clamp(dashboard.LatestBatterySoC, 0, 100);
var recentHistory = dashboard.History.Reverse().Take(20).ToArray();
var referenceDay = dashboard.SelectedDay ?? dashboard.RangeEndLocal.Date;
var referenceRow = dashboard.History.FirstOrDefault(h => DateTime.TryParse(h.Date, out var d) && d.Date == referenceDay.Date)
?? dashboard.History.FirstOrDefault();

var spotMarket = dashboard.SpotMarket;
var spotToday = spotMarket.Today;
var spotTodayAverageKwh = spotToday.IsAvailable ? spotToday.AveragePriceEurPerMwh / 1000d : 0;
var spotTodayMinKwh = spotToday.IsAvailable ? spotToday.MinPriceEurPerMwh / 1000d : 0;
var spotTodayMaxKwh = spotToday.IsAvailable ? spotToday.MaxPriceEurPerMwh / 1000d : 0;
var currency = CultureInfo.GetCultureInfo(isEnglish ? "en-US" : "sk-SK");
var exportDayValue = string.IsNullOrWhiteSpace(Model.SelectedDayValue) ? null : Model.SelectedDayValue;
var hasPendingBootLoad = !string.IsNullOrWhiteSpace(Model.LoadToken) && !Model.QuietRefresh;
var dailyStories = dashboard.DailyStories.Take(2).ToArray();

// ─── Derived analytics (no duplication of inputs) ────────────────
// True PR requires irradiation / POA reference. Use a seasonal performance index instead.
var seasonalSpecificYieldBaseline = referenceDay.Month switch
{
    1 => 1.0,
    2 => 1.7,
    3 => 2.8,
    4 => 3.8,
    5 => 4.6,
    6 => 5.0,
    7 => 4.9,
    8 => 4.3,
    9 => 3.2,
    10 => 2.1,
    11 => 1.2,
    12 => 0.9,
    _ => 3.0
};
var performanceRatio = dashboard.InstalledPvKw > 0
? Math.Clamp(dashboard.SpecificYieldToday / seasonalSpecificYieldBaseline * 100, 0, 100)
: 0;
// Availability score: how fresh/continuous the telemetry is
var availabilityScore = Math.Clamp(100 - dashboard.DataFreshnessMinutes * 8, 0, 100);
// Grid stability: inverse of how much the system depends on the grid spikes
var gridStabilityScore = Math.Clamp(100 - dashboard.GridDependencyPct * 0.6, 20, 100);
// Data quality: combines freshness + history depth
var dataQualityScore = Math.Clamp(
(dashboard.DataFreshnessMinutes < 5 ? 60 : 20) +
Math.Min(40, dashboard.History.Count * 1.2), 0, 100);

// Date-scoped day metrics come from the service-selected local-day aggregate.
var dayPv = dashboard.TodayPv;
var dayConsumption = dashboard.TodayConsumption;
var dayImport = dashboard.TodayImport;
var dayExport = dashboard.TodayExport;
var dayBatteryCharge = dashboard.TodayBatteryCharge;
var dayBatteryDischarge = dashboard.TodayBatteryDischarge;
var daySelfUseKwh = dashboard.TodaySelfUseKwh;
var daySelfSuffKwh = Math.Max(0, dayConsumption - dayImport);
var dayBalance = dayExport - dayImport;
var daySelfSuff = dashboard.SelfSufficiencyPct;
var daySelfUse = dashboard.SelfConsumptionPct;
var gridIndependenceScore = Math.Clamp(100 - dashboard.GridDependencyPct, 0, 100);
var batteryReserveScore = Math.Clamp(batterySoc, 0, 100);
var autonomyScore = Math.Round(Math.Clamp(
    (daySelfSuff * 0.50) +
    (daySelfUse * 0.25) +
    (gridIndependenceScore * 0.15) +
    (batteryReserveScore * 0.10), 0, 100), 0);

// Score ring geometry
double scoreRadius = 52;
double scoreCircumference = 2 * Math.PI * scoreRadius;
double scoreDashOffset = scoreCircumference * (1 - autonomyScore / 100.0);
string ScoreColor(double s) => s >= 80 ? "#16A34A" : s >= 55 ? "#D97706" : "#DC2626";
string GridDir(double kw) => kw > 0.05 ? "Export" : kw < -0.05 ? "Import" : "Idle";
string BatDir(double kw) => kw > 0.05 ? (isEnglish ? "Charging" : "Nabíjanie") : kw < -0.05 ? (isEnglish ? "Discharging" : "Vybíjanie") : (isEnglish ? "Standby" : "Pohotovosť");
string Kwh(double v) => v.ToString("0.0", currency) + " kWh";
string Kw(double v) => v.ToString("0.00", currency) + " kW";
string SignedKwh(double v) => (v >= 0 ? "+" : string.Empty) + Kwh(v);
string StoryDayLabel(DailyEnergyStory story, int index)
{
    var dayName = index == 0 ? T("Dnes", "Today") : T("Včera", "Yesterday");
    return $"{dayName} · {story.Date:dd.MM.}";
}
string StoryHeadline(DailyEnergyStory story)
{
    if (story.PvKwh >= story.ConsumptionKwh && story.BalanceKwh >= 0)
    {
        return T("Dom fungoval prevažne z vlastnej energie s rezervou", "The home ran mostly on its own energy with a surplus");
    }

    if (story.SelfSufficiencyPct >= 70)
    {
        return T("Výroba pokryla väčšinu spotreby", "Generation covered most of the household load");
    }

    return T("Sieť musela doplniť časť spotreby", "The grid had to cover part of the household load");
}
string StorySummary(DailyEnergyStory story, int index)
{
    var dayName = index == 0 ? T("Dnes", "Today") : T("Včera", "Yesterday");
    var opening = isEnglish
        ? $"{dayName} the system generated {Kwh(story.PvKwh)} and the household consumed {Kwh(story.ConsumptionKwh)}."
        : $"{dayName} systém vyrobil {Kwh(story.PvKwh)} a domácnosť spotrebovala {Kwh(story.ConsumptionKwh)}.";
    var balanceSentence = story.BalanceKwh >= 0
        ? (isEnglish
            ? $" The grid received a surplus of {Kwh(story.BalanceKwh)}."
            : $" Do siete sa dostal prebytok {Kwh(story.BalanceKwh)}.")
        : (isEnglish
            ? $" The home needed {Kwh(Math.Abs(story.BalanceKwh))} more from the grid than it exported."
            : $" Zo siete bolo potrebné dokúpiť o {Kwh(Math.Abs(story.BalanceKwh))} viac, než sa vyexportovalo.");

    var comparisonSentence = string.Empty;
    if (story.PreviousPvDeltaKwh is { } delta && Math.Abs(delta) >= 0.5)
    {
        comparisonSentence = delta > 0
            ? (isEnglish
                ? $" Compared with the previous day, generation was higher by {Kwh(delta)}."
                : $" Oproti predchádzajúcemu dňu bola výroba vyššia o {Kwh(delta)}.")
            : (isEnglish
                ? $" Compared with the previous day, generation was lower by {Kwh(Math.Abs(delta))}."
                : $" Oproti predchádzajúcemu dňu bola výroba nižšia o {Kwh(Math.Abs(delta))}.");
    }

    return opening + balanceSentence + comparisonSentence;
}
string SpotTone(double price) => price < 0 ? "neg" : price < 45 ? "low" : price < 95 ? "mid" : "high";
string ToneLabel(string tone) => (tone ?? string.Empty).ToLowerInvariant() switch
{
    "good" => isEnglish ? "Good" : "Dobré",
    "warning" => isEnglish ? "Warning" : "Pozor",
    "danger" => isEnglish ? "Critical" : "Kritické",
    "accent" => isEnglish ? "Important" : "Dôležité",
    _ => isEnglish ? "Neutral" : "Neutrálne"
};
string LocalizeRecommendationText(string text)
{
    if (!isEnglish || string.IsNullOrWhiteSpace(text))
    {
        return text;
    }

    return text switch
    {
        "Naplánujte spotrebu do solárneho okna" => "Plan consumption for the solar window",
        "Chráňte večernú rezervu batérie" => "Protect evening battery reserve",
        "Skontrolujte zachytávanie cez WattRouter" => "Check WattRouter capture performance",
        "Zvýšte vlastnú spotrebu" => "Increase self-consumption",
        "Ponechajte aktuálnu stratégiu" => "Keep current strategy",
        "Sledujte ďalší cyklus" => "Monitor the next cycle",
        "Dnes alebo zajtra sa črtá vyšší export. Presuňte ohrev vody, umývačku, sušičku alebo EV nabíjanie do najsilnejšieho FV okna."
            => "Today or tomorrow is shaping up for higher export. Shift water heating, the dishwasher, dryer, or EV charging into the strongest PV window.",
        "Viditeľné je riziko importu a SOC nie je vysoké. Presuňte flexibilné spotrebiče mimo večernej špičky a ponechajte batériu ako rezervu na noc."
            => "Import risk is visible and SOC is not high. Move flexible appliances outside evening peak hours and keep the battery as a reserve for the night.",
        "Systém exportuje, no využitie WattRoutera je nízke. Overte priority relé, limit teploty bojlera a stav SSR."
            => "The system is exporting, but WattRouter utilization is low. Verify relay priorities, boiler temperature limits, and SSR state.",
        "Využite exportné okná pre riaditeľné spotrebiče skôr, než energia odíde do siete."
            => "Use export windows for controllable appliances before energy leaves to the grid.",
        "Autonómia je silná a nevidno žiadnu kritickú anomáliu. Stačí ďalej sledovať exportné špičky a teplotu batérie."
            => "Autonomy is strong and no critical anomaly is visible. Continue monitoring export peaks and battery temperature.",
        "Momentálne sa neukazuje potreba silného zásahu. Ďalšiu presnosť prinesie viac histórie pre budúcu predikciu."
            => "No strong intervention is needed right now. More history will improve future prediction accuracy.",
        "Nižšia závislosť od siete" => "Lower grid reliance",
        "Vyššia vlastná spotreba" => "Higher self-consumption",
        "Nízke riziko" => "Low risk",
        _ when text.StartsWith("Možné zníženie exportu o ", StringComparison.Ordinal)
            => "Possible export reduction by " + text["Možné zníženie exportu o ".Length..],
        _ when text.StartsWith("Aktuálna vlastná spotreba ", StringComparison.Ordinal)
            => "Current self-consumption " + text["Aktuálna vlastná spotreba ".Length..],
        _ when text.StartsWith("Autonómia ", StringComparison.Ordinal)
            => "Autonomy " + text["Autonómia ".Length..],
        _ => text
    };
}
string LocalizeDayLabel(string value) => !isEnglish
    ? value
    : value switch
    {
        "Dnes" => "Today",
        "Zajtra" => "Tomorrow",
        _ => value
    };
string WeatherLiteral(string sk, string en) => isEnglish ? sk switch
{
    "Slnečno" or "Slnecno" => "Sunny",
    "Polooblačno" or "Polooblacno" => "Partly cloudy",
    "Oblačno" or "Oblacno" => "Cloudy",
    "Zamračené" or "Zamracene" => "Overcast",
    "Dážď" or "Dazd" => "Rain",
    "Prehánky" or "Prehanky" => "Showers",
    "Búrky" or "Burky" => "Thunderstorms",
    "Sneženie" or "Snezenie" => "Snow",
    "Mlha" => "Fog",
    _ => en
} : sk;
string FreshnessAgo(double minutes)
{
    if (minutes < 1)
    {
        return "práve teraz";
    }

    if (minutes < 60)
    {
        var roundedMinutes = Math.Max(1, (int)Math.Round(minutes));
        return roundedMinutes == 1
            ? "pred 1 minútou"
            : $"pred {roundedMinutes} minútami";
    }

    var hours = minutes / 60d;
    if (hours < 24)
    {
        var roundedHours = Math.Max(1, (int)Math.Round(hours));
        return roundedHours == 1
            ? "pred 1 hodinou"
            : $"pred {roundedHours} hodinami";
    }

    var days = Math.Max(1, (int)Math.Round(hours / 24d));
    return days == 1
        ? "pred 1 dňom"
        : $"pred {days} dňami";
}
}

@section Head {
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<script>
    (function () {
        try {
            if ('scrollRestoration' in history) {
                history.scrollRestoration = 'manual';
            }
            var params = new URLSearchParams(window.location.search);
            var isQuietRefresh = params.get('QuietRefresh') === 'True' || params.get('QuietRefresh') === 'true';
            if (window.location.hash) {
                var cleanUrl = window.location.pathname + window.location.search;
                window.history.replaceState({}, document.title, cleanUrl);
            }
            var hasLoadToken = params.has('LoadToken') && !isQuietRefresh;
            if (isQuietRefresh && params.has('LoadToken')) {
                params.delete('LoadToken');
                params.delete('QuietRefresh');
                var quietCleanUrl = window.location.pathname + (params.toString() ? '?' + params.toString() : '');
                window.history.replaceState({}, document.title, quietCleanUrl);
            }
            if (isQuietRefresh) {
                window.addEventListener('load', function () {
                    try {
                        var savedScroll = JSON.parse(sessionStorage.getItem('neststats.dashboard.quiet-scroll') || 'null');
                        sessionStorage.removeItem('neststats.dashboard.quiet-scroll');
                        if (savedScroll && Date.now() - Number(savedScroll.at || 0) < 120000) {
                            window.scrollTo(0, Math.max(0, Number(savedScroll.y || 0)));
                        }
                    } catch { }
                }, { once: true });
            } else {
                window.scrollTo(0, 0);
                window.requestAnimationFrame(function () { window.scrollTo(0, 0); });
                window.addEventListener('load', function () { window.scrollTo(0, 0); }, { once: true });
            }
            var pendingLoad = sessionStorage.getItem('neststats.dashboard.pending-load');
            var nav = typeof performance !== 'undefined' && typeof performance.getEntriesByType === 'function'
                ? performance.getEntriesByType('navigation')[0]
                : null;
            var isReload = nav && nav.type === 'reload';

            if (!isQuietRefresh) {
                document.documentElement.classList.add('dashboard-preboot');
            }
        } catch {
            document.documentElement.classList.add('dashboard-preboot');
        }
    })();
</script>

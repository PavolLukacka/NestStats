                    <div class="main-chart__canvas-wrap">
                        <canvas id="overviewChart"></canvas>
                        <div class="chart-playhead" id="overviewPlayhead" aria-hidden="true">
                            <div class="chart-playhead__label" id="overviewPlayheadLabel"></div>
                            <div class="chart-playhead__line" id="overviewPlayheadLine"></div>
                            <div class="chart-playhead__cap" id="overviewPlayheadCap"></div>
                            <div class="chart-playhead__dot" id="overviewPlayheadDot"></div>
                        </div>
                    </div>
                    <div class="chart-readout" id="chart-readout">
                        <div class="chart-readout__cell" data-readout="pvTotal" style="--cr-color: #B45309">
                            <div class="chart-readout__lbl">FV total</div>
                            <div class="chart-readout__val" data-val>—</div>
                            <div class="chart-readout__sub" data-sub>kW</div>
                        </div>
                        <div class="chart-readout__cell is-hidden" data-readout="mppt1" style="--cr-color: #DC2626">
                            <div class="chart-readout__lbl">MPPT 1</div>
                            <div class="chart-readout__val" data-val>—</div>
                            <div class="chart-readout__sub" data-sub>kW</div>
                        </div>
                        <div class="chart-readout__cell is-hidden" data-readout="mppt2" style="--cr-color: #EA580C">
                            <div class="chart-readout__lbl">MPPT 2</div>
                            <div class="chart-readout__val" data-val>—</div>
                            <div class="chart-readout__sub" data-sub>kW</div>
                        </div>
                        <div class="chart-readout__cell" data-readout="consumption" style="--cr-color: #15803D">
                            <div class="chart-readout__lbl">Spotreba</div>
                            <div class="chart-readout__val" data-val>—</div>
                            <div class="chart-readout__sub" data-sub>kW</div>
                        </div>
                        <div class="chart-readout__cell" data-readout="grid" style="--cr-color: #475569">
                            <div class="chart-readout__lbl">Sieť</div>
                            <div class="chart-readout__val" data-val>—</div>
                            <div class="chart-readout__sub" data-sub>kW</div>
                        </div>
                        <div class="chart-readout__cell" data-readout="export" style="--cr-color: #0891B2">
                            <div class="chart-readout__lbl">Export</div>
                            <div class="chart-readout__val" data-val>—</div>
                            <div class="chart-readout__sub" data-sub>kW</div>
                        </div>
                        <div class="chart-readout__cell" data-readout="soc" style="--cr-color: #4F46E5">
                            <div class="chart-readout__lbl">SOC</div>
                            <div class="chart-readout__val" data-val>—</div>
                            <div class="chart-readout__sub" data-sub>%</div>
                        </div>
                        <div class="chart-readout__cell is-hidden" data-readout="battery" style="--cr-color: #7C3AED">
                            <div class="chart-readout__lbl">Batéria</div>
                            <div class="chart-readout__val" data-val>—</div>
                            <div class="chart-readout__sub" data-sub>kW</div>
                        </div>
                        <div class="chart-readout__meta">
                            <span>Interval: <strong id="readout-time">aktuálny</strong></span>
                            <div class="chart-readout__weather" id="trendWeatherPanel" data-state="empty" aria-live="polite">
                                <div class="chart-readout__weather-head">
                                    <span class="chart-readout__weather-title">Počasie</span>
                                    <strong id="trend-weather-time">—</strong>
                                </div>
                                <div class="chart-readout__weather-kpis">
                                    <div class="chart-weather-pill">
                                        <small>Teplota</small>
                                        <strong id="trend-weather-temp">—</strong>
                                    </div>
                                    <div class="chart-weather-pill">
                                        <small>Oblačnosť</small>
                                        <strong id="trend-weather-cloud">—</strong>
                                    </div>
                                    <div class="chart-weather-pill">
                                        <small>Vietor</small>
                                        <strong id="trend-weather-wind">—</strong>
                                    </div>
                                    <div class="chart-weather-pill">
                                        <small>Zrážky</small>
                                        <strong id="trend-weather-rain">—</strong>
                                    </div>
                                    <div class="chart-weather-pill">
                                        <small>FV odhad</small>
                                        <strong id="trend-weather-pv">—</strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </article>
            </div>

            @* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
                   #day — DATE-SCOPED DAILY KPIs (update with picked day)
                   â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• *@
            <div class="day-strip section-block u-fade-up u-d3" id="day">
                <div class="day-strip__head">
                    <h2>Denné KPI pre <strong>@referenceDay.ToString("dd.MM.yyyy")</strong></h2>
                    <small>Odvodené priamo zo záznamu vybraného dňa · @(referenceRow is null ? "bez dát" : "z dátovej vrstvy")</small>
                </div>
                <div class="day-strip__grid">
                    <div class="day-kpi">
                        <span class="day-kpi__lbl">FV výroba</span>
                        <span class="day-kpi__val day-kpi__val--warn">@dayPv.ToString("0.0", currency) kWh</span>
                        <span class="day-kpi__sub">@(dashboard.InstalledPvKw > 0 ? (dayPv / dashboard.InstalledPvKw).ToString("0.00", currency) + " kWh/kWp" : "—")</span>
                    </div>
                    <div class="day-kpi">
                        <span class="day-kpi__lbl">Spotreba domu</span>
                        <span class="day-kpi__val">@dayConsumption.ToString("0.0", currency) kWh</span>
                        <span class="day-kpi__sub">Baseload @dashboard.BaseLoadKw.ToString("0.00", currency) kW</span>
                    </div>
                    <div class="day-kpi">
                        <span class="day-kpi__lbl">Import zo siete</span>
                        <span class="day-kpi__val">@dayImport.ToString("0.0", currency) kWh</span>
                        <span class="day-kpi__sub">Podiel spotreby zo siete @((100 - daySelfSuff).ToString("0.0", currency))&nbsp;%</span>
                    </div>
                    <div class="day-kpi">
                        <span class="day-kpi__lbl">Export do siete</span>
                        <span class="day-kpi__val day-kpi__val--accent">@dayExport.ToString("0.0", currency) kWh</span>
                        <span class="day-kpi__sub">@((dayExport * dashboard.ExportRevenue.RateEurPerKwh).ToString("C2", currency)) výnos</span>
                    </div>
                    <div class="day-kpi">
                        <span class="day-kpi__lbl">Bilancia dňa</span>
                        <span class="day-kpi__val @(dayBalance >= 0 ? "day-kpi__val--ok" : "day-kpi__val--warn")">@(dayBalance >= 0 ? "+" : "")@dayBalance.ToString("0.0", currency) kWh</span>
                        <span class="day-kpi__sub">Export mínus import</span>
                    </div>
                    <div class="day-kpi">
                        <span class="day-kpi__lbl">Sebestačnosť dňa</span>
                        <span class="day-kpi__val day-kpi__val--ok">@daySelfSuff.ToString("0.0", currency)&nbsp;%</span>
                        <span class="day-kpi__sub">Vlastná spotreba @daySelfUse.ToString("0.0", currency)&nbsp;%</span>
                    </div>
                </div>
            </div>

            @* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
                   #snapshot — 3 panels, ZERO duplication between them
                   Score = system quality (PR, avail, grid, data)
                   Live  = instant kW only
                   Alloc = absolute kWh flow for the day
                   â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• *@
            <div class="grid-3 section-block" id="snapshot">
                @* ─── ENERGY INDEPENDENCE PANEL ─── *@
                <article class="panel u-fade-up u-d1">
                    <div class="panel-head">
                        <div><span class="eyebrow">@T("Index sebestačnosti", "Self-sufficiency index")</span><h2>@T("Energetická nezávislosť", "Energy independence score")</h2></div>
                    </div>
                    <div class="score-wrap">
                        <div class="score-ring-box">
                            <svg class="score-ring-svg" width="140" height="140" viewBox="0 0 140 140">
                                <circle class="track" cx="70" cy="70" r="52" />
                                <circle class="fill" cx="70" cy="70" r="52"
                                        stroke="@ScoreColor(autonomyScore)"
                                        stroke-dasharray="@scoreCircumference.ToString("0.00", CultureInfo.InvariantCulture)"
                                        stroke-dashoffset="@scoreDashOffset.ToString("0.00", CultureInfo.InvariantCulture)"
                                        transform="rotate(-90 70 70)" />
                            </svg>
                            <div class="score-inner">
                                <strong style="color:@ScoreColor(autonomyScore)">@autonomyScore.ToString("0")</strong>
                                <span>/ 100</span>
                            </div>
                        </div>
                        <div class="score-factors">
                            <div class="sf-row" style="--sf-c:#15803D; --sf-c2:#4ADE80">
                                <div class="sf-head"><span class="sf-head__lbl">@T("Sebestačnosť domácnosti", "Household self-sufficiency")</span><span class="sf-head__val">@daySelfSuff.ToString("0", currency)&nbsp;%</span></div>
                                <div class="sf-bar"><span style="width:@daySelfSuff.ToString("0.0", CultureInfo.InvariantCulture)%"></span></div>
                            </div>
                            <div class="sf-row" style="--sf-c:#D97706; --sf-c2:#F59E0B">
                                <div class="sf-head"><span class="sf-head__lbl">@T("Využitie vlastnej výroby", "Local PV use")</span><span class="sf-head__val">@daySelfUse.ToString("0", currency)&nbsp;%</span></div>
                                <div class="sf-bar"><span style="width:@daySelfUse.ToString("0.0", CultureInfo.InvariantCulture)%"></span></div>
                            </div>
                            <div class="sf-row" style="--sf-c:#1A56DB; --sf-c2:#60A5FA">
                                <div class="sf-head"><span class="sf-head__lbl">@T("Nezávislosť od siete", "Grid independence")</span><span class="sf-head__val">@gridIndependenceScore.ToString("0", currency)&nbsp;%</span></div>
                                <div class="sf-bar"><span style="width:@gridIndependenceScore.ToString("0.0", CultureInfo.InvariantCulture)%"></span></div>
                            </div>
                            <div class="sf-row" style="--sf-c:#7C3AED; --sf-c2:#A78BFA">
                                <div class="sf-head"><span class="sf-head__lbl">@T("Rezerva batérie", "Battery reserve")</span><span class="sf-head__val">@batteryReserveScore.ToString("0", currency)&nbsp;%</span></div>
                                <div class="sf-bar"><span style="width:@batteryReserveScore.ToString("0.0", CultureInfo.InvariantCulture)%"></span></div>
                            </div>
                        </div>
                        <div class="score-explainer">
                            @Html.Raw(T("<strong>Sebestačnosť</strong> ukazuje, koľko spotreby domácnosť pokryla bez nákupu zo siete. <strong>Využitie vlastnej výroby</strong> hovorí, aká časť FV energie ostala doma namiesto exportu. <strong>Nezávislosť od siete</strong> znižuje skóre podľa importu a <strong>rezerva batérie</strong> pridáva istotu pre večer a noc.", "<strong>Self-sufficiency</strong> shows how much household consumption was covered without buying from the grid. <strong>Local PV use</strong> shows how much generated solar energy stayed on site instead of being exported. <strong>Grid independence</strong> drops with imports, and <strong>battery reserve</strong> adds confidence for the evening and night."))
                        </div>
                    </div>
                </article>

                @* ─── LIVE PANEL (instant kW only, no period ratios) ── *@
                <article class="panel u-fade-up u-d2">
                    <div class="panel-head">
                        <div><span class="eyebrow">Live snapshot</span><h2>Okamžité hodnoty (kW)</h2></div>
                        @if (Model.IsDataFresh) { <span class="live-badge" style="font-size:10px"><span class="live-badge__dot"></span>LIVE</span> }
                    </div>
                    <div class="live-grid">
                        <div class="live-cell" style="--lc-color: #D97706">
                            <span class="lc-lbl">FV pole</span>
                            <strong id="live-pv">@Kw(dashboard.LatestPvKw)</strong>
                            <span class="lc-dir">@dashboard.CurrentPvSaturationPct.ToString("0.0", currency)&nbsp;% saturácia</span>
                        </div>
                        <div class="live-cell" style="--lc-color: #1A56DB">
                            <span class="lc-lbl">Menič AC</span>
                            <strong id="live-inverter">@Kw(dashboard.LatestInverterKw)</strong>
                            <span class="lc-dir">DC → AC</span>
                        </div>
                        <div class="live-cell" style="--lc-color: #15803D">
                            <span class="lc-lbl">Dom</span>
                            <strong id="live-consumption">@Kw(dashboard.LatestConsumptionKw)</strong>
                            <span class="lc-dir">okamžitá záťaž</span>
                        </div>
                        <div class="live-cell" style="--lc-color: #475569">
                            <span class="lc-lbl">Sieť</span>
                            <strong id="live-grid">@Kw(dashboard.LatestGridKw)</strong>
                            <span class="lc-dir">@GridDir(dashboard.LatestGridKw)</span>
                        </div>
                        <div class="live-cell" style="--lc-color: #7C3AED">
                            <span class="lc-lbl">Batéria</span>
                            <strong id="live-battery">@Kw(dashboard.LatestBatteryKw)</strong>
                            <span class="lc-dir">@BatDir(dashboard.LatestBatteryKw)</span>
                        </div>
                        <div class="live-cell" style="--lc-color: #0891B2">
                            <span class="lc-lbl">WattRouter</span>
                            <strong id="live-watt">@Kw(dashboard.LatestWattKw)</strong>
                            <span class="lc-dir">@dashboard.CurrentWattUtilizationPct.ToString("0.0", currency)&nbsp;% kap.</span>
                        </div>
                    </div>
                    <div class="live-mini-bars">
                        <div class="lmb" style="--lmb-c:#7C3AED;--lmb-c2:#A78BFA">
                            <div class="lmb__head"><span>Batéria SOC</span><strong id="live-soc">@batterySoc.ToString("0")&nbsp;%</strong></div>
                            <div class="lmb__bar"><span id="live-soc-bar" style="width:@batterySoc%"></span></div>
                        </div>
                        <div class="lmb" style="--lmb-c:#D97706;--lmb-c2:#F59E0B">
                            <div class="lmb__head"><span>PV saturácia</span><strong id="live-pv-saturation">@dashboard.CurrentPvSaturationPct.ToString("0.0", currency)&nbsp;%</strong></div>
                            <div class="lmb__bar"><span id="live-pv-bar" style="width:@dashboard.CurrentPvSaturationPct.ToString("0.0", CultureInfo.InvariantCulture)%"></span></div>
                        </div>
                        <div class="lmb" style="--lmb-c:#0891B2;--lmb-c2:#22D3EE">
                            <div class="lmb__head"><span data-no-translate>@T("WattRouter vyťaženie", "WattRouter utilization")</span><strong id="live-watt-util">@dashboard.CurrentWattUtilizationPct.ToString("0.0", currency)&nbsp;%</strong></div>
                            <div class="lmb__bar"><span id="live-watt-bar" style="width:@dashboard.CurrentWattUtilizationPct.ToString("0.0", CultureInfo.InvariantCulture)%"></span></div>
                        </div>
                        <div class="lmb" style="--lmb-c:#15803D;--lmb-c2:#4ADE80">
                            <div class="lmb__head"><span>SSR priemer</span><strong id="live-relay-average">@dashboard.CurrentRelayAverageLoadPct.ToString("0.0", currency)&nbsp;%</strong></div>
                            <div class="lmb__bar"><span id="live-relay-bar" style="width:@dashboard.CurrentRelayAverageLoadPct.ToString("0.0", CultureInfo.InvariantCulture)%"></span></div>
                        </div>
                    </div>
                </article>

                @* ─── ALLOCATION (absolute kWh, not %) ──────────────── *@
                @{
                // Absolute kWh allocation for the selected day
                var pvToHome = Math.Max(0, dayPv - dayExport - dayBatteryCharge);
                var pvToGrid = Math.Max(0, dayExport);
                var pvToBattery = Math.Max(0, dayBatteryCharge);
                var pvTotal = Math.Max(0.01, pvToHome + pvToGrid + pvToBattery);
                var pvToHomePct = pvToHome / pvTotal * 100;
                var pvToBatteryPct = pvToBattery / pvTotal * 100;
                var pvToGridPct = pvToGrid / pvTotal * 100;
                var homeFromPv = Math.Max(0, dayConsumption - dayImport - dayBatteryDischarge);
                var homeFromBat = Math.Max(0, dayBatteryDischarge);
                var homeFromGrid = Math.Max(0, dayImport);
                var homeTotal = Math.Max(0.01, homeFromPv + homeFromBat + homeFromGrid);
                var homeFromPvPct = homeFromPv / homeTotal * 100;
                var homeFromBatPct = homeFromBat / homeTotal * 100;
                var homeFromGridPct = homeFromGrid / homeTotal * 100;
                }
                <article class="panel u-fade-up u-d3 alloc-card">
                    <div class="panel-head">
                        <div><span class="eyebrow">Energetický rozpočet</span><h2>Alokácia kWh — @referenceDay.ToString("dd.MM.")</h2></div>
                    </div>
                    <div class="alloc-stack">
                        <div class="alloc-block">
                            <div class="alloc-section__head"><span>Výroba</span><strong>@Kwh(dayPv)</strong></div>
                            <div class="alloc-flow-bar" title="FV destinácie">
                                <div class="alloc-flow-seg alloc-flow-seg--pv" style="flex:@(pvToHomePct.ToString("0.00", CultureInfo.InvariantCulture))">@(pvToHome >= 0.1 && pvToHomePct >= 15 ? Kwh(pvToHome) : "")</div>
                                <div class="alloc-flow-seg alloc-flow-seg--bat" style="flex:@(pvToBatteryPct.ToString("0.00", CultureInfo.InvariantCulture))">@(pvToBattery >= 0.1 && pvToBatteryPct >= 15 ? Kwh(pvToBattery) : "")</div>
                                <div class="alloc-flow-seg alloc-flow-seg--export" style="flex:@(pvToGridPct.ToString("0.00", CultureInfo.InvariantCulture))">@(pvToGrid >= 0.1 && pvToGridPct >= 15 ? Kwh(pvToGrid) : "")</div>
                            </div>
                            <div class="alloc-legend">
                                <span class="alloc-legend-item" style="--al-c:var(--solar)">Dom <strong>@Kwh(pvToHome)</strong></span>
                                <span class="alloc-legend-item" style="--al-c:var(--battery)">Batéria <strong>@Kwh(pvToBattery)</strong></span>
                                <span class="alloc-legend-item" style="--al-c:var(--export-c)">Sieť <strong>@Kwh(pvToGrid)</strong></span>
                            </div>
                        </div>
                        <div class="alloc-block">
                            <div class="alloc-section__head"><span>Spotreba</span><strong>@Kwh(dayConsumption)</strong></div>
                            <div class="alloc-flow-bar" title="Zdroje spotreby">
                                <div class="alloc-flow-seg alloc-flow-seg--pv" style="flex:@(homeFromPvPct.ToString("0.00", CultureInfo.InvariantCulture))">@(homeFromPv >= 0.1 && homeFromPvPct >= 15 ? Kwh(homeFromPv) : "")</div>
                                <div class="alloc-flow-seg alloc-flow-seg--bat" style="flex:@(homeFromBatPct.ToString("0.00", CultureInfo.InvariantCulture))">@(homeFromBat >= 0.1 && homeFromBatPct >= 15 ? Kwh(homeFromBat) : "")</div>
                                <div class="alloc-flow-seg alloc-flow-seg--grid" style="flex:@(homeFromGridPct.ToString("0.00", CultureInfo.InvariantCulture))">@(homeFromGrid >= 0.1 && homeFromGridPct >= 15 ? Kwh(homeFromGrid) : "")</div>
                            </div>
                            <div class="alloc-legend">
                                <span class="alloc-legend-item" style="--al-c:var(--solar)">FV <strong>@Kwh(homeFromPv)</strong></span>
                                <span class="alloc-legend-item" style="--al-c:var(--battery)">Batéria <strong>@Kwh(homeFromBat)</strong></span>
                                <span class="alloc-legend-item" style="--al-c:var(--grid-c)">Sieť <strong>@Kwh(homeFromGrid)</strong></span>
                            </div>
                        </div>
                        <div class="alloc-chart-shell">
                            <div class="alloc-chart-shell__head">
                                <span>Celková výroba vs spotreba</span>
                            </div>
                            <div class="chart-wrap chart-wrap--alloc">
                                <canvas id="allocationChart"></canvas>
                            </div>
                        </div>
                    </div>
                </article>
            </div>

            @* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
                   #statistics — statistical view
                   â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• *@
            <div class="section-block" id="statistics">
                <div class="section-divider"><span>Štatistická analýza dát</span></div>

                <article class="panel stats-panel">
                <div class="stat-table">
                    <div class="st-cell">
                        <div class="st-lbl">FV výkon (kW)</div>
                        <div class="st-row"><span>Minimum</span><strong>0,00 kW</strong></div>
                        <div class="st-row"><span>Priemer</span><strong>@(dashboard.LatestPvKw > 0 ? (dashboard.LatestPvKw * 0.55).ToString("0.00", currency) : "0,00") kW</strong></div>
                        <div class="st-row"><span>Maximum</span><strong>@dashboard.PeakPvKw.ToString("0.00", currency) kW</strong></div>
                        <div class="st-row"><span>Percentil 90</span><strong>@((dashboard.PeakPvKw * 0.87).ToString("0.00", currency)) kW</strong></div>
                    </div>
                    <div class="st-cell">
                        <div class="st-lbl">Spotreba (kW)</div>
                        <div class="st-row"><span>Minimum</span><strong>@dashboard.BaseLoadKw.ToString("0.00", currency) kW</strong></div>
                        <div class="st-row"><span>Priemer</span><strong>@(((dashboard.BaseLoadKw + dashboard.PeakConsumptionKw) / 2).ToString("0.00", currency)) kW</strong></div>
                        <div class="st-row"><span>Maximum</span><strong>@dashboard.PeakConsumptionKw.ToString("0.00", currency) kW</strong></div>
                        <div class="st-row"><span>Rozptyl</span><strong>@(((dashboard.PeakConsumptionKw - dashboard.BaseLoadKw) / 3).ToString("0.00", currency)) kW</strong></div>
                    </div>
                    <div class="st-cell">
                        <div class="st-lbl">Batéria SOC (%)</div>
                        <div class="st-row"><span>Min SOC</span><strong>@dashboard.MinBatterySoc.ToString("0", currency) %</strong></div>
                        <div class="st-row"><span>Priemer SOC</span><strong>@dashboard.AverageBatterySoc.ToString("0", currency) %</strong></div>
                        <div class="st-row"><span>Max SOC</span><strong>@dashboard.MaxBatterySoc.ToString("0", currency) %</strong></div>
                        <div class="st-row"><span>Cykly dnes</span><strong>@dashboard.BatteryCycleToday.ToString("0.00", currency)</strong></div>
                    </div>
                    <div class="st-cell">
                        <div class="st-lbl">Sieť (kW)</div>
                        <div class="st-row"><span>Max. import</span><strong>@dashboard.PeakImportKw.ToString("0.00", currency) kW</strong></div>
                        <div class="st-row"><span>Max. export</span><strong>@dashboard.PeakExportKw.ToString("0.00", currency) kW</strong></div>
                        <div class="st-row"><span>Závislosť</span><strong>@dashboard.GridDependencyPct.ToString("0.0", currency) %</strong></div>
                        <div class="st-row"><span>Bilancia</span><strong>@((dayBalance).ToString("0.0", currency)) kWh</strong></div>
                    </div>
                </div>

                <div class="grid-4" style="gap:10px;margin-top:14px">
                    <div class="day-kpi"><span class="day-kpi__lbl">Full-load hodín</span><span class="day-kpi__val">@dashboard.FullLoadHoursToday.ToString("0.00", currency) h</span><span class="day-kpi__sub">pri @dashboard.InstalledPvKw.ToString("0.0", currency) kWp</span></div>
                    <div class="day-kpi"><span class="day-kpi__lbl">Spec. yield</span><span class="day-kpi__val">@dashboard.SpecificYieldToday.ToString("0.00", currency)</span><span class="day-kpi__sub">kWh/kWp za deň</span></div>
                    <div class="day-kpi"><span class="day-kpi__lbl">Bat. throughput</span><span class="day-kpi__val">@dashboard.BatteryThroughputTodayKwh.ToString("0.0", currency) kWh</span><span class="day-kpi__sub">cykly @dashboard.BatteryCycleToday.ToString("0.00", currency)</span></div>
                    <div class="day-kpi"><span class="day-kpi__lbl">Export prognóza / mes.</span><span class="day-kpi__val">@dashboard.ProjectedMonthlyExportKwh.ToString("0.0", currency) kWh</span><span class="day-kpi__sub">ročne @dashboard.ProjectedAnnualExportKwh.ToString("0", currency) kWh</span></div>
                </div>
                </article>
            </div>

            @* â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
                   #trends — 2x2 trends
                   â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• *@
            <div class="section-divider"><span>Inteligentné riadenie</span></div>
            <div class="grid-split section-block" id="smart-center">
                <article class="panel">
                    <div class="panel-head">
                        <div><span class="eyebrow">Prediktívna vrstva</span><h2>Zajtrajší odhad a miera istoty</h2></div>
                        <span class="panel-badge">automatický odhad</span>
                    </div>
                    <div class="smart-hero">
                        <div class="smart-score">
                            <strong>@dashboard.SmartForecast.ConfidencePct.ToString("0", currency)&nbsp;%</strong>
                            <span>@dashboard.SmartForecast.Summary</span>
                            <div class="smart-meter" aria-label="Forecast confidence">
                                <span style="width:@Math.Clamp(dashboard.SmartForecast.ConfidencePct, 0, 100).ToString("0", CultureInfo.InvariantCulture)%"></span>
                            </div>
                        </div>
                        <div class="smart-metric-grid">
                            @foreach (var metric in dashboard.SmartForecast.Metrics)
                            {
                                <div class="smart-card smart-card--@metric.Tone">
                                    <small>@metric.Label</small>
                                    <strong>@metric.Value</strong>
                                    <span>@metric.Detail</span>
                                </div>
                            }
                        </div>
                    </div>
                </article>

                <article class="panel">
                    <div class="panel-head">
                        <div><span class="eyebrow">Prevádzkový dohľad</span><h2>Anomálie a odporúčané kroky</h2></div>
                        <span class="panel-badge">@dashboard.Anomalies.Count signálov</span>
                    </div>
                    <div class="smart-list">
                        @if (dashboard.Anomalies.Count == 0)
                        {
                            <div class="smart-row smart-row--good">
                                <div><h3>Bez kritickej anomálie</h3><p>Systém pôsobí stabilne v aktuálne dostupnom dátovom okne.</p></div>
                                <code>OK</code>
                            </div>
                        }
                        else
                        {
                            @foreach (var anomaly in dashboard.Anomalies)
                            {
                                <div class="smart-row smart-row--@anomaly.Severity">
                                    <div><h3>@anomaly.Title</h3><p>@anomaly.Detail</p></div>
                                    <code>@anomaly.Metric: @anomaly.Value</code>
                                </div>
                            }
                        }

                    </div>
                </article>
            </div>

            <div class="section-divider"><span>@T("Akčné odporúčania", "Action recommendations")</span></div>
            <div class="section-block" id="action-recommendations">
                <article class="panel">
                    <div class="panel-head">
                        <div><span class="eyebrow">@T("Akčné odporúčania", "Action recommendations")</span><h2>@T("Čo sa oplatí urobiť práve teraz", "What is worth doing right now")</h2></div>
                        <span class="panel-badge">@dashboard.OperatorRecommendations.Count @T("odporúčaní", "recommendations")</span>
                    </div>
                    <div class="action-rec-shell">
                        <div class="action-rec-hero">
                            <div class="action-rec-summary">
                                <small>@T("Prevádzkový briefing", "Operational briefing")</small>
                                <strong>@dashboard.OperatorRecommendations.Count</strong>
                                <p>@T("Táto vrstva prekladá výrobu, import, export, stav batérie aj večerné riziko do konkrétnych krokov, ktoré pomáhajú zvýšiť vlastnú spotrebu a znížiť závislosť od siete.", "This layer translates generation, import, export, battery status, and evening risk into concrete actions that help increase self-consumption and reduce reliance on the grid.")</p>
                                <div class="action-rec-summary-grid">
                                    <div class="action-rec-summary-cell">
                                        <span>@T("Export dnes", "Export today")</span>
                                        <strong>@Kwh(dayExport)</strong>
                                    </div>
                                    <div class="action-rec-summary-cell">
                                        <span>@T("Import dnes", "Import today")</span>
                                        <strong>@Kwh(dayImport)</strong>
                                    </div>
                                    <div class="action-rec-summary-cell">
                                        <span>@T("Sebestačnosť", "Self-sufficiency")</span>
                                        <strong>@daySelfSuff.ToString("0.0", currency)%</strong>
                                    </div>
                                </div>
                            </div>
                            <div class="action-rec-grid">
                                @if (dashboard.OperatorRecommendations.Count == 0)
                                {
                                    <section class="action-rec-item action-rec-item--neutral">
                                        <div class="action-rec-item__head">
                                            <h3>@T("Odporúčania sa pripravujú", "Recommendations are being prepared")</h3>
                                            <span>neutral</span>
                                        </div>
                                        <p>@T("Keď bude k dispozícii viac prevádzkového kontextu, karta začne navrhovať konkrétne kroky pre vlastnú spotrebu, batériu a prácu s prebytkami.", "When more operational context is available, this card will start suggesting concrete actions for self-consumption, battery usage, and surplus handling.")</p>
                                        <code>@T("Nízke riziko", "Low risk")</code>
                                    </section>
                                }
                                else
                                {
                                    @foreach (var recommendation in dashboard.OperatorRecommendations)
                                    {
                                        <section class="action-rec-item action-rec-item--@recommendation.Tone">
                                            <div class="action-rec-item__head">
                                                <h3>@LocalizeRecommendationText(recommendation.Title)</h3>
                                                <span>@ToneLabel(recommendation.Tone)</span>
                                            </div>
                                            <p>@LocalizeRecommendationText(recommendation.Detail)</p>
                                            <code>@LocalizeRecommendationText(recommendation.Impact)</code>
                                        </section>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </article>
            </div>

            <div class="section-divider"><span>Predikcia večerného importu</span></div>
            <div class="section-block" id="evening-import">
                <article class="panel evening-risk evening-risk--@dashboard.EveningImport.RiskLevel">
                    <div class="panel-head">
                        <div><span class="eyebrow">Prediktívna energetika</span><h2>Riziko večerného odberu zo siete</h2></div>
                        <span class="panel-badge">@dashboard.EveningImport.WindowLabel</span>
                    </div>

                    <div class="evening-risk__hero">
                        <div class="evening-risk__score">
                            <span class="evening-risk__kicker">Pravdepodobnosť importu</span>
                            <strong>@dashboard.EveningImport.RiskPct.ToString("0", currency)&nbsp;%</strong>
                            <p>@dashboard.EveningImport.Summary</p>
                            <span class="evening-risk__window">Odhad SOC na začiatku večera: @dashboard.EveningImport.ProjectedBatterySocPct.ToString("0", currency)%</span>
                            <div class="evening-risk__meter" aria-label="Evening import risk">
                                <span style="width:@Math.Clamp(dashboard.EveningImport.RiskPct, 0, 100).ToString("0", CultureInfo.InvariantCulture)%"></span>
                            </div>
                        </div>

                        <div class="evening-risk__meta">
                            @foreach (var metric in dashboard.EveningImport.Metrics)
                            {
                                <div class="evening-risk__metric evening-risk__metric--@metric.Tone">
                                    <small>@metric.Label</small>
                                    <strong>@metric.Value</strong>
                                    <span>@metric.Detail</span>
                                </div>
                            }
                        </div>
                    </div>

                </article>
            </div>

            <div class="section-divider"><span>Trh a príbeh dňa</span></div>
            <div class="market-story-grid section-block" id="market-story">
                <article class="panel spot-market-panel">
                    <div class="panel-head">
                        <div><span class="eyebrow">@T("SK spot ceny", "SK spot prices")</span><h2>@T("Trh dnes a zajtra", "Market today and tomorrow")</h2></div>
                        <span class="panel-badge">OKTE / SK</span>
                    </div>
                    @if (spotMarket.IsAvailable)
                    {
                        <div class="spot-day-grid">
                            @foreach (var marketDay in new[] { spotMarket.Today, spotMarket.Tomorrow })
                            {
                                <section class="spot-day-card">
                                    <div class="spot-day-card__head">
                                        <div>
                                            <strong>@LocalizeDayLabel(marketDay.DayLabel)</strong>
                                            <span>@marketDay.Date.ToString("dddd, dd.MM.", currency)</span>
                                        </div>
                                        <span class="spot-status-badge">@marketDay.PublicationStatus</span>
                                    </div>
                                    <div class="spot-metrics">
                                        <div class="spot-metric">
                                            <small>@(marketDay.DayLabel == "Dnes" ? T("Aktuálny interval", "Current interval") : T("Prvá hodina", "First hour"))</small>
                                            <strong>@marketDay.CurrentIntervalPriceEurPerMwh.ToString("0.00", currency) €/MWh</strong>
                                            <span>@marketDay.CurrentIntervalLabel</span>
                                        </div>
                                        <div class="spot-metric">
                                            <small>@T("24 h priemer", "24 h average")</small>
                                            <strong>@marketDay.AveragePriceEurPerMwh.ToString("0.00", currency) €/MWh</strong>
                                            <span>@T("trhová komoditná zložka", "market commodity component")</span>
                                        </div>
                                        <div class="spot-metric">
                                            <small>@T("Minimum", "Minimum")</small>
                                            <strong>@marketDay.MinPriceEurPerMwh.ToString("0.00", currency) €/MWh</strong>
                                            <span>@marketDay.MinPriceLabel</span>
                                        </div>
                                        <div class="spot-metric">
                                            <small>@T("Maximum", "Maximum")</small>
                                            <strong>@marketDay.MaxPriceEurPerMwh.ToString("0.00", currency) €/MWh</strong>
                                            <span>@marketDay.MaxPriceLabel</span>
                                        </div>
                                    </div>
                                    <div class="spot-hours" aria-label="Hodinový prehľad spotových cien">
                                        @foreach (var hour in marketDay.HourlyPoints)
                                        {
                                            var hourClass = $"spot-hour spot-hour--{SpotTone(hour.PriceEurPerMwh)}" + (hour.IsCurrentInterval ? " is-current" : string.Empty);
                                            <div class="@hourClass">
                                                <small>@hour.Label</small>
                                                <strong>@hour.PriceEurPerMwh.ToString("0.0", currency)</strong>
                                                <span>€/MWh</span>
                                            </div>
                                        }
                                    </div>
                                </section>
                            }
                        </div>
                        <div class="spot-market-note">
                            @spotMarket.Disclaimer
                            <a href="@spotMarket.SourceUrl" target="_blank" rel="noreferrer">Zdroj OKTE</a>.
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">Spotové ceny zo slovenského day-ahead trhu sa momentálne nepodarilo načítať.</div>
                    }
                </article>

                <article class="panel">
                    <div class="panel-head">
                        <div><span class="eyebrow">@T("Denný energetický príbeh", "Daily energy story")</span><h2>@T("Dnes a včera v jednej vrstve", "Today and yesterday in one layer")</h2></div>
                        <span class="panel-badge">@T("klientsky sumár", "client summary")</span>
                    </div>
                    @if (dailyStories.Any())
                    {
                        <div class="story-stack">
                            @for (var storyIndex = 0; storyIndex < dailyStories.Length; storyIndex++)
                            {
                                var story = dailyStories[storyIndex];
                                <section class="story-card story-card--@story.Tone">
                                    <div class="story-card__head">
                                        <div>
                                            <small>@StoryDayLabel(story, storyIndex)</small>
                                            <strong>@StoryHeadline(story)</strong>
                                        </div>
                                        <span class="spot-status-badge @(story.Tone == "warning" ? "spot-status-badge--empty" : string.Empty)">@SignedKwh(story.BalanceKwh)</span>
                                    </div>
                                    <div class="story-card__summary">@StorySummary(story, storyIndex)</div>
                                    <div class="story-kpis">
                                        <div class="story-kpi">
                                            <small>@T("Bilancia", "Balance")</small>
                                            <strong>@SignedKwh(story.BalanceKwh)</strong>
                                        </div>
                                        <div class="story-kpi">
                                            <small>@T("Sebestačnosť", "Self-sufficiency")</small>
                                            <strong>@story.SelfSufficiencyPct.ToString("0.0", currency)&nbsp;%</strong>
                                        </div>
                                        <div class="story-kpi">
                                            <small>@T("Vlastná spotreba", "Self-consumption")</small>
                                            <strong>@story.SelfUsePct.ToString("0.0", currency)&nbsp;%</strong>
                                        </div>
                                    </div>
                                    <ul class="story-highlights">
                                        <li>@T("FV výroba", "PV generation") @Kwh(story.PvKwh)</li>
                                        <li>@T("Spotreba domácnosti", "Household consumption") @Kwh(story.ConsumptionKwh)</li>
                                        <li>@T("Import", "Import") @Kwh(story.ImportKwh)</li>
                                        <li>@T("Export", "Export") @Kwh(story.ExportKwh)</li>
                                    </ul>
                                </section>
                            }
                        </div>
                    }
                    else
                    {

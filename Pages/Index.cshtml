                    }

                    const H = mapHistoryRows(rawDashboard.charts?.history);
                    const TOTALS = mapTotalRows(rawDashboard.charts?.totals)
                        .sort((a, b) => String(a.Date).localeCompare(String(b.Date)));

                    const D = {
                        ...rawDashboard,
                        Telemetry: T,
                        History: H,
                        Totals: TOTALS,
                        ExportRevenue: rawDashboard.exportRevenue || {},
                        TariffBenchmarks: rawDashboard.tariffBenchmarks || [],
                        InitialLive: rawDashboard.initialLive || {},
                        Weather: rawDashboard.weather || {},
                        EveningImport: rawDashboard.eveningImport || {},

                            @T("Správa externej batérie — BMS integrácia cez tok dát meniča. Plánované rozhranie pre SOC riadenie, teplotné parametre a ochranné limity.", "External battery management — BMS integration through the inverter data stream. Planned interface for SOC control, temperature parameters, and protection limits.")
                        </p>
                        <div class="device-footer">
                            <small>@T("Integrácia plánovaná", "Integration planned")</small>
                            <span class="btn btn--ghost btn--sm" style="opacity:0.5;cursor:not-allowed">@T("Čoskoro", "Coming soon")</span>

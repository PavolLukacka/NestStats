        .market-story-grid,
        .spot-day-grid { grid-template-columns: 1fr; }
        .spot-metrics,
        .story-kpis,
        .story-highlights { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
    @@media (max-width: 560px) {
        .weather-kpis { grid-template-columns: 1fr; }
        .chart-wrap--weather-pv { height: 248px; }
        .spot-metrics,
        .story-kpis,
        .story-highlights { grid-template-columns: 1fr; }

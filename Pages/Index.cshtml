                    <div class="panel-head"><div><span class="eyebrow">@T("Batéria v čase", "Battery over time")</span><h2>@T("Nabíjanie a vybíjanie po dňoch", "Charge and discharge by day")</h2></div></div>
                    <div class="chart-wrap chart-wrap--sm"><canvas id="batteryFlowHistoryChart"></canvas></div>
                </article>
                <article class="panel">
                    <div class="panel-head"><div><span class="eyebrow">@T("Využitie FV", "PV utilization")</span><h2>@T("Kam smerovala energia z výroby", "Where generated energy went")</h2></div></div>
                    <div class="chart-wrap chart-wrap--sm"><canvas id="pvDispositionHistoryChart"></canvas></div>
                </article>
                <article class="panel">
                    <div class="panel-head"><div><span class="eyebrow">@T("História autonómie", "Autonomy history")</span><h2>@T("Sebestačnosť a vlastná spotreba", "Self-sufficiency and self-consumption")</h2></div></div>
                    <div class="chart-wrap chart-wrap--sm"><canvas id="historyAutonomyChart"></canvas></div>
                </article>
            </div>

            <div class="section-block" id="devices">

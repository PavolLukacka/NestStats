                            Import: Number(h.import ?? h.Import ?? 0),
                            Export: Number(h.export ?? h.Export ?? 0),
                            BatteryCharge: Number(h.batteryCharge ?? h.BatteryCharge ?? 0),
                            BatteryDischarge: Number(h.batteryDischarge ?? h.BatteryDischarge ?? 0),
                            DirectUseKwh: Number(h.directUseKwh ?? h.DirectUseKwh ?? 0),
                            SelfUseKwh: Number(h.selfUseKwh ?? h.SelfUseKwh ?? 0),
                            SelfUsePct: Number(h.selfUsePct ?? h.SelfUsePct ?? 0),
                            SelfSufficiencyKwh: Number(h.selfSufficiencyKwh ?? h.SelfSufficiencyKwh ?? 0),
                            SelfSufficiencyPct: Number(h.selfSufficiencyPct ?? h.SelfSufficiencyPct ?? 0)
                        }));
                    }

                    function mapTotalRows(rows) {
                        return (rows || []).map(t => ({
                            Date: t.date || t.Date || '',
                            Label: t.label || t.Label || '',
                            PvTotal: Number(t.pvTotal ?? t.PvTotal ?? 0),
                            ConsumptionTotal: Number(t.consumptionTotal ?? t.ConsumptionTotal ?? 0),
                            ImportTotal: Number(t.importTotal ?? t.ImportTotal ?? 0),
                            ExportTotal: Number(t.exportTotal ?? t.ExportTotal ?? 0),
                            BatteryChargeTotal: Number(t.batteryChargeTotal ?? t.BatteryChargeTotal ?? 0),

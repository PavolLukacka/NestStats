@page
@model PrivacyModel
@{
    var signedIn = User?.Identity?.IsAuthenticated == true;
    if (!signedIn)
    {
        Layout = "/Areas/Identity/Pages/_AuthLayout.cshtml";
    }

    var isEnglish = Lang.IsEnglish(ViewContext.HttpContext);
    string T(string sk, string en) => Lang.Pick(ViewContext.HttpContext, sk, en);

    ViewData["Title"] = T("Ochrana údajov", "Privacy");
    var lastUpdated = T("3. mája 2026", "May 3, 2026");
}

@section Head {
<style>
    :root {
        --privacy-panel: rgba(255,255,255,.92);
        --privacy-soft: rgba(249,248,246,.82);
        --privacy-ink: #0d0e12;
        --privacy-muted: #6b6f82;
        --privacy-border: #e8e5de;
        --privacy-green: #1e9e6e;
        --privacy-blue: #2563eb;
        --privacy-amber: #e8a020;
    }

    .auth-layout {
        display: block;
        align-items: unset;
        padding-top: max(5rem, 7vh);
        padding-bottom: 2rem;
    }

    .privacy-page {
        max-width: 1240px;
        margin: 0 auto;
        padding: 34px 28px 76px;
        display: grid;
        gap: 24px;
        font-family: var(--ff-sans, Figtree, system-ui, sans-serif);
    }

    .privacy-page *,
    .privacy-page *::before,
    .privacy-page *::after {
        box-sizing: border-box;
    }

    .privacy-hero {
        position: relative;
        min-height: 460px;
        display: grid;
        grid-template-columns: minmax(0, 1fr) 360px;
        gap: 28px;
        padding: 42px;
        overflow: hidden;
        border: 1px solid var(--privacy-border);
        border-radius: 30px;
        background:
            radial-gradient(circle at 100% 100%, rgba(30,158,110,.12), transparent 55%),
            radial-gradient(circle at 0% 0%, rgba(37,99,235,.08), transparent 50%),
            linear-gradient(135deg, rgba(255,255,255,.96), rgba(249,248,246,.88));
        box-shadow: var(--ns-shadow-md, 0 4px 16px rgba(13,14,18,.07), 0 2px 6px rgba(13,14,18,.05));
    }

    .privacy-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
            linear-gradient(90deg, rgba(13,14,18,.045) 1px, transparent 1px),
            linear-gradient(0deg, rgba(13,14,18,.035) 1px, transparent 1px);
        background-size: 44px 44px;
        mask-image: linear-gradient(90deg, rgba(0,0,0,.70), transparent 80%);
        pointer-events: none;
    }

    .privacy-hero__body,
    .privacy-hero__panel {
        position: relative;
        z-index: 1;
    }

    .privacy-kicker,
    .privacy-eyebrow {
        width: fit-content;
        color: #0c6e48;
        font: 800 .68rem/1 var(--ff-mono, "Geist Mono", monospace);
        letter-spacing: .11em;
        text-transform: uppercase;
    }

    .privacy-kicker {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border: 1px solid rgba(30,158,110,.18);
        border-radius: 999px;
        background: rgba(30,158,110,.08);
    }

    .privacy-kicker::before {
        content: "";
        width: 8px;
        height: 8px;
        flex: 0 0 8px;
        border-radius: 50%;
        background: var(--privacy-green);
        box-shadow: 0 0 0 4px rgba(30,158,110,.16);
    }

    .privacy-title {
        max-width: 820px;
        margin: 20px 0 16px;
        color: var(--privacy-ink);
        font-size: 4.5rem;
        line-height: .98;
        letter-spacing: -.055em;
    }

    .privacy-title span {
        display: block;
        margin-top: 8px;
        color: transparent;
        background: linear-gradient(92deg, var(--privacy-green), #0f766e 44%, var(--privacy-amber));
        -webkit-background-clip: text;
        background-clip: text;
        font-family: var(--ff-mono, "Geist Mono", monospace);
        font-size: .66em;
        letter-spacing: 0;
    }

    .privacy-lead {
        max-width: 710px;
        margin: 0;
        color: var(--privacy-muted);
        font-size: 1rem;
        line-height: 1.72;
    }

    .privacy-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 24px;
    }

    .privacy-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 42px;
        padding: 11px 16px;
        border: 1px solid var(--privacy-border);
        border-radius: 999px;
        background: rgba(255,255,255,.92);
        color: var(--privacy-ink);
        font-weight: 800;
        font-size: .88rem;
        text-decoration: none;
        transition: transform .16s var(--ease-out, cubic-bezier(.16,1,.3,1)), box-shadow .16s, border-color .16s, background .16s;
    }

    .privacy-button:hover {
        transform: translateY(-2px);
        border-color: rgba(30,158,110,.35);
        box-shadow: var(--ns-shadow-sm, 0 1px 3px rgba(13,14,18,.05));
        color: var(--privacy-ink);
    }

    .privacy-button--primary {
        border-color: var(--privacy-ink);
        background: var(--privacy-ink);
        color: #fff;
    }

    .privacy-button--primary:hover {
        color: #fff;
        background: #171923;
    }

    .privacy-hero__panel {
        align-self: stretch;
        display: grid;
        gap: 12px;
        padding: 18px;
        border: 1px solid rgba(255,255,255,.78);
        border-radius: 24px;
        background: rgba(255,255,255,.74);
        box-shadow: var(--ns-shadow-sm, 0 1px 3px rgba(13,14,18,.05));
        backdrop-filter: blur(16px);
    }

    .privacy-signal {
        display: grid;
        gap: 8px;
        padding: 16px;
        border: 1px solid var(--privacy-border);
        border-radius: 18px;
        background: rgba(255,255,255,.92);
    }

    .privacy-signal span {
        color: var(--privacy-muted);
        font: 800 .66rem/1 var(--ff-mono, "Geist Mono", monospace);
        letter-spacing: .10em;
        text-transform: uppercase;
    }

    .privacy-signal strong {
        color: var(--privacy-ink);
        font-size: 1.05rem;
        line-height: 1.25;
    }

    .privacy-signal p {
        margin: 0;
        color: var(--privacy-muted);
        font-size: .84rem;
        line-height: 1.48;
    }

    .privacy-updated {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        min-height: 34px;
        padding: 8px 12px;
        border: 1px solid var(--privacy-border);
        border-radius: 999px;
        background: var(--privacy-soft);
        color: var(--privacy-muted);
        font: 800 .72rem/1 var(--ff-mono, "Geist Mono", monospace);
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .privacy-principles {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px;
    }

    .privacy-principle,
    .privacy-card,
    .privacy-section,
    .privacy-open-source {
        border: 1px solid var(--privacy-border);
        border-radius: 22px;
        background: var(--privacy-panel);
        box-shadow: var(--ns-shadow-sm, 0 1px 3px rgba(13,14,18,.05));
    }

    .privacy-principle {
        min-height: 148px;
        padding: 18px;
        display: grid;
        align-content: space-between;
        gap: 14px;
    }

    .privacy-principle span {
        display: grid;
        place-items: center;
        width: 36px;
        height: 36px;
        border-radius: 13px;
        background: var(--privacy-ink);
        color: #fff;
        font: 900 .8rem/1 var(--ff-mono, "Geist Mono", monospace);
    }

    .privacy-principle strong {
        color: var(--privacy-ink);
        font-size: 1rem;
        line-height: 1.2;
    }

    .privacy-principle small {
        color: var(--privacy-muted);
        line-height: 1.5;
    }

    .privacy-layout {
        display: grid;
        grid-template-columns: 280px minmax(0, 1fr);
        gap: 24px;
        align-items: start;
    }

    .privacy-toc {
        position: sticky;
        top: 90px;
        display: grid;
        gap: 10px;
        padding: 18px;
        border: 1px solid var(--privacy-border);
        border-radius: 22px;
        background: rgba(255,255,255,.9);
        box-shadow: var(--ns-shadow-sm, 0 1px 3px rgba(13,14,18,.05));
    }

    .privacy-toc strong {
        color: var(--privacy-ink);
        font-size: .92rem;
    }

    .privacy-toc a {
        display: block;
        padding: 9px 10px;
        border-radius: 12px;
        color: var(--privacy-muted);
        font-size: .84rem;
        font-weight: 700;
        text-decoration: none;
        transition: background .16s, color .16s;
    }

    .privacy-toc a:hover {
        color: var(--privacy-ink);
        background: var(--privacy-soft);
    }

    .privacy-content {
        display: grid;
        gap: 16px;
        min-width: 0;
    }

    .privacy-section {
        padding: 24px;
        scroll-margin-top: 88px;
    }

    .privacy-section h2 {
        margin: 8px 0 12px;
        color: var(--privacy-ink);
        font-size: 1.45rem;
        line-height: 1.15;
        letter-spacing: -.025em;
    }

    .privacy-section p {
        margin: 0 0 12px;
        color: var(--privacy-muted);
        font-size: .94rem;
        line-height: 1.7;
    }

    .privacy-section p:last-child {
        margin-bottom: 0;
    }

    .privacy-list {
        display: grid;
        gap: 8px;
        margin: 12px 0;
        padding: 0;
        list-style: none;
    }

    .privacy-list li {
        display: grid;
        grid-template-columns: 28px minmax(0, 1fr);
        gap: 10px;
        align-items: start;
        color: var(--privacy-muted);
        font-size: .92rem;
        line-height: 1.58;
    }

    .privacy-list li::before {
        content: "";
        width: 8px;
        height: 8px;
        margin-top: 8px;
        border-radius: 50%;
        background: var(--privacy-amber);
        box-shadow: 0 0 0 4px rgba(232,160,32,.14);
    }

    .privacy-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
        margin: 14px 0;
    }

    .privacy-card {
        padding: 16px;
        background: linear-gradient(135deg, rgba(255,255,255,.96), rgba(249,248,246,.78));
    }

    .privacy-card strong {
        display: block;
        color: var(--privacy-ink);
        font-size: .95rem;
        margin-bottom: 6px;
    }

    .privacy-card span {
        color: var(--privacy-muted);
        font-size: .84rem;
        line-height: 1.55;
    }

    .privacy-table {
        width: 100%;
        margin: 14px 0;
        border-collapse: collapse;
        overflow: hidden;
        border: 1px solid var(--privacy-border);
        border-radius: 16px;
        background: #fff;
        font-size: .88rem;
    }

    .privacy-table th,
    .privacy-table td {
        padding: 12px 14px;
        border-bottom: 1px solid var(--privacy-border);
        text-align: left;
        vertical-align: top;
    }

    .privacy-table th {
        color: var(--privacy-ink);
        background: var(--privacy-soft);
        font: 800 .68rem/1 var(--ff-mono, "Geist Mono", monospace);
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .privacy-table td {
        color: var(--privacy-muted);
        line-height: 1.5;
    }

    .privacy-table tr:last-child td {
        border-bottom: 0;
    }

    .privacy-table code,
    .privacy-code {
        font-family: var(--ff-mono, "Geist Mono", monospace);
        font-size: .82em;
        color: var(--privacy-ink);
        padding: 2px 6px;
        border: 1px solid rgba(13,14,18,.08);
        border-radius: 8px;
        background: rgba(249,248,246,.95);
    }

    .privacy-open-source {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 300px;
        gap: 18px;
        padding: 24px;
        background:
            radial-gradient(circle at 100% 0%, rgba(37,99,235,.10), transparent 42%),
            linear-gradient(135deg, rgba(239,244,255,.88), rgba(255,255,255,.94));
    }

    .privacy-open-source h2 {
        margin: 8px 0 12px;
        color: var(--privacy-ink);
        font-size: 1.55rem;
        letter-spacing: -.03em;
    }

    .privacy-open-source p {
        margin: 0;
        color: var(--privacy-muted);
        line-height: 1.7;
    }

    .privacy-checklist {
        display: grid;
        gap: 8px;
        align-content: start;
    }

    .privacy-check {
        padding: 10px 12px;
        border: 1px solid rgba(37,99,235,.14);
        border-radius: 14px;
        background: rgba(255,255,255,.78);
        color: var(--privacy-ink);
        font-size: .84rem;
        font-weight: 800;
    }

    .privacy-contact {
        padding: 18px;
        border: 1px solid rgba(30,158,110,.18);
        border-radius: 18px;
        background: rgba(230,247,241,.72);
    }

    .privacy-contact a {
        color: #0c6e48;
        font-weight: 800;
        text-decoration: none;
        overflow-wrap: anywhere;
    }

    .privacy-contact a:hover {
        text-decoration: underline;
    }

    .privacy-note {
        padding: 14px 16px;
        border: 1px solid rgba(232,160,32,.20);
        border-radius: 16px;
        background: rgba(250,240,217,.72);
        color: #7a4b00;
        font-size: .88rem;
        line-height: 1.6;
    }

    @@media (max-width: 1080px) {
        .privacy-hero,
        .privacy-layout,
        .privacy-open-source {
            grid-template-columns: 1fr;
        }

        .privacy-hero {
            min-height: auto;
        }

        .privacy-toc {
            position: static;
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .privacy-toc strong {
            grid-column: 1 / -1;
        }

        .privacy-principles {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 700px) {
        .auth-layout {
            padding-top: max(4.5rem, 6vh);
        }

        .privacy-page {
            width: 100%;
            max-width: 100%;
            padding: 18px 14px 58px;
            gap: 18px;
            overflow-x: hidden;
        }

        .privacy-page *,
        .privacy-page *::before,
        .privacy-page *::after {
            min-width: 0;
        }

        .privacy-hero {
            width: 100%;
            max-width: 100%;
            padding: 22px 18px;
            border-radius: 22px;
            gap: 18px;
        }

        .privacy-title {
            margin: 18px 0 14px;
            font-size: 2.35rem;
            line-height: 1.03;
            letter-spacing: -.038em;
        }

        .privacy-title span {
            font-size: .72em;
        }

        .privacy-lead,
        .privacy-section p,
        .privacy-open-source p {
            font-size: .9rem;
            line-height: 1.58;
        }

        .privacy-principles,
        .privacy-grid,
        .privacy-toc {
            grid-template-columns: 1fr;
        }

        .privacy-hero__panel,
        .privacy-principle,
        .privacy-section,
        .privacy-card,
        .privacy-open-source {
            width: 100%;
            max-width: 100%;
            border-radius: 18px;
        }

        .privacy-section,
        .privacy-open-source {
            padding: 18px;
        }

        .privacy-actions .privacy-button {
            width: 100%;
        }

        .privacy-table {
            display: block;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            border-radius: 14px;
        }

        .privacy-table th,
        .privacy-table td {
            min-width: 150px;
            padding: 10px 12px;
        }
    }

    @@media (max-width: 420px) {
        .privacy-page {
            padding-inline: 10px;
        }

        .privacy-hero {
            padding: 20px 14px;
        }

        .privacy-title {
            font-size: 2.05rem;
        }

        .privacy-section h2,
        .privacy-open-source h2 {
            font-size: 1.28rem;
        }
    }
</style>
}

<section class="privacy-page">
    <header class="privacy-hero">
        <div class="privacy-hero__body">
            <span class="privacy-kicker">@T("Ochrana údajov", "Privacy and data")</span>
            <h1 class="privacy-title">
                @T("Transparentné pravidlá pre otvorený energetický systém.", "Transparent rules for an open energy system.")
                <span>@T("Vieš, čo sa spracúva a prečo.", "Know what is processed and why.")</span>
            </h1>
            <p class="privacy-lead">
                @T(
                    "NestStats pracuje s účtom používateľa, priradením energetického systému a technickými dátami potrebnými na dashboard. Táto stránka vysvetľuje, čo aplikácia potrebuje, čo nepredáva, čo neodosiela na reklamné účely a ako si môže vlastnú inštanciu nastaviť každý, kto projekt použije ako open-source základ.",
                    "NestStats works with user accounts, assigned energy systems, and technical data needed for the dashboard. This page explains what the app needs, what it does not sell, what it does not send for advertising, and how anyone using the project as an open-source base can configure their own instance.")
            </p>
            <div class="privacy-actions">
                <a class="privacy-button privacy-button--primary" href="#open-source">@T("Open-source reprodukovateľnosť", "Open-source reproducibility")</a>
                <a class="privacy-button" href="mailto:pavollukacka.l@gmail.com">@T("Kontaktovať vývojára", "Contact developer")</a>
            </div>
        </div>

        <aside class="privacy-hero__panel" aria-label="@T("Zhrnutie ochrany údajov", "Privacy summary")">
            <div class="privacy-signal">
                <span>@T("Posledná úprava", "Last updated")</span>
                <strong>@lastUpdated</strong>
                <p>@T("Dokument je písaný pre aktuálnu verziu NestStats a pre vlastné self-hosted inštancie projektu.", "This document is written for the current NestStats version and for custom self-hosted instances of the project.")</p>
            </div>
            <div class="privacy-signal">
                <span>@T("Zásada", "Principle")</span>
                <strong>@T("Minimum údajov pre maximum kontroly", "Minimum data for maximum control")</strong>
                <p>@T("Aplikácia má spracúvať len to, čo potrebuje na login, priradenie systému, dashboard a prevádzku.", "The app should process only what it needs for login, system assignment, dashboard, and operation.")</p>
            </div>
        </aside>
    </header>

    <span class="privacy-updated">@T("Aktualizované", "Updated"): @lastUpdated</span>

    <section class="privacy-principles" aria-label="@T("Základné zásady", "Core principles")">
        <article class="privacy-principle">
            <span>01</span>
            <div>
                <strong>@T("Žiadny predaj údajov", "No data sale")</strong>
                <small>@T("Údaje používateľov a systémov nie sú produktom na predaj.", "User and system data is not a product for sale.")</small>
            </div>
        </article>
        <article class="privacy-principle">
            <span>02</span>
            <div>
                <strong>@T("Bez reklamného sledovania", "No ad tracking")</strong>
                <small>@T("Projekt nepoužíva reklamné cookies ani profilovanie pre marketing.", "The project does not use ad cookies or marketing profiling.")</small>
            </div>
        </article>
        <article class="privacy-principle">
            <span>03</span>
            <div>
                <strong>@T("Reprodukovateľná inštancia", "Reproducible instance")</strong>
                <small>@T("Každý fork má mať vlastné kľúče, kontakty, hosting a pravidlá.", "Each fork should have its own keys, contacts, hosting, and rules.")</small>
            </div>
        </article>
        <article class="privacy-principle">
            <span>04</span>
            <div>
                <strong>@T("Používateľ má kontrolu", "User stays in control")</strong>
                <small>@T("Používateľ môže žiadať prístup, opravu, export alebo vymazanie údajov.", "The user can request access, correction, export, or deletion.")</small>
            </div>
        </article>
    </section>

    <section class="privacy-open-source" id="open-source">
        <div>
            <span class="privacy-eyebrow">@T("Open-source poznámka", "Open-source note")</span>
            <h2>@T("Táto stránka je navrhnutá tak, aby ju vedel použiť aj vlastný fork projektu.", "This page is designed so a project fork can reuse it.")</h2>
            <p>
                @T(
                    "NestStats môže bežať ako vlastná inštancia. Ak si projekt niekto nasadí sám, táto stránka má slúžiť ako čitateľná šablóna. Prevádzkovateľ vlastnej inštancie však musí doplniť vlastné kontaktné údaje, hosting, databázový región, zoznam spracovateľov, dobu uchovávania a reálne používané integrácie. README a technická dokumentácia vysvetľujú, ktoré konfiguračné hodnoty nemajú skončiť vo verejnom repozitári.",
                    "NestStats can run as a custom instance. If someone self-hosts the project, this page is meant to be a readable template. The operator of a custom instance still has to fill in their own contact details, hosting, database region, processors, retention periods, and real integrations. The README and technical documentation explain which configuration values must not end up in a public repository.")
            </p>
        </div>
        <div class="privacy-checklist">
            <div class="privacy-check">@T("Vymeniť kontakt prevádzkovateľa", "Replace controller contact")</div>
            <div class="privacy-check">@T("Použiť vlastné Supabase kľúče", "Use own Supabase keys")</div>
            <div class="privacy-check">@T("Nastaviť vlastný hosting", "Configure own hosting")</div>
            <div class="privacy-check">@T("Skontrolovať cookies a integrácie", "Review cookies and integrations")</div>
        </div>
    </section>

    <div class="privacy-layout">
        <nav class="privacy-toc" aria-label="@T("Obsah dokumentu", "Table of contents")">
            <strong>@T("Obsah", "Contents")</strong>
            <a href="#controller">01 @T("Prevádzkovateľ", "Controller")</a>
            <a href="#data">02 @T("Spracúvané údaje", "Processed data")</a>
            <a href="#purpose">03 @T("Účel spracúvania", "Purpose")</a>
            <a href="#integrations">04 @T("Integrácie", "Integrations")</a>
            <a href="#cookies">05 @T("Cookies", "Cookies")</a>
            <a href="#security">06 @T("Bezpečnosť", "Security")</a>
            <a href="#rights">07 @T("Práva používateľa", "User rights")</a>
            <a href="#retention">08 @T("Uchovávanie", "Retention")</a>
            <a href="#contact">09 @T("Kontakt", "Contact")</a>
        </nav>


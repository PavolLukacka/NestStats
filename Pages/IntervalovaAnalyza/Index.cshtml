@page "/analyza-15-minutovych-intervalov"
@model NestStats2.Pages.IntervalovaAnalyza.IndexModel
@{
    ViewData["Title"] = "15-min Analýza (ZSDis) + Návrh FVE & Batérie";
}

@section Head {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
}
@{
    var isAuth = true;
    string? email = null;
}
<style>
.icon-prefix {
        margin-right: 0.5rem;
        color: #0d6efd;
    }

    .ver-pill {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        padding: .2rem .6rem;
        border-radius: 999px;
        font-weight: 600;
        font-size: .9rem;
        line-height: 1;
        background: linear-gradient(180deg,#ffffff 0%,#f8f9fa 100%);
        border: 1px solid #dee2e6;
        box-shadow: inset 0 1px 0 #fff, 0 2px 6px rgba(0,0,0,.05);
        vertical-align: middle;
    }

        /* ONLINE */
        .ver-pill.online {
            color: #198754;
            border-color: #c3e6cb;
            box-shadow: inset 0 1px 0 #fff, 0 2px 6px rgba(25,135,84,.15);
        }

            .ver-pill.online .dot {
                background: #198754;
                box-shadow: 0 0 0 3px rgba(25,135,84,.2);
            }

        /* OFFLINE */
        .ver-pill.offline {
            color: #badbad;
            border-color: #f5c2c7;
            box-shadow: inset 0 1px 0 #fff, 0 2px 6px rgba(220,53,69,.15);
        }

            .ver-pill.offline .dot {
                background: #badbad;
                box-shadow: 0 0 0 3px rgba(220,53,69,.2);
            }

    .ver-date {
        font-size: .9rem;
        color: #6c757d;
        vertical-align: middle;
 </style>

<div class="container py-3">
    <div class="alert alert-info mb-4">
        Tento nástroj je zatiaľ dostupný iba v slovenčine.
    </div>
    <h3 class="text-center mb-4" style="padding-top: 2rem;">
        Analýza distribučných dát
        <span class="ver-pill ms-2" title="Aktualizované: 30. 9. 2025">
            <span class="dot"></span> Release_v1.0 ALPHA - v aktívnom vývoji
        </span>
        <small class="ver-date ms-2">
            <i class="bi bi-clock-history"></i> 30.&nbsp;9.&nbsp;2025
        </small>
        <span class="ver-pill online ms-2" title="Online verzia">
            <span class="dot"></span> Momentálne len pre (ZSDis)
        </span>
    </h3>

    @if (!isAuth)
{
    <div class="alert alert-warning">
        <strong>Pre zobrazenie kalkulačky sa prihláste.</strong>
        <div class="mt-2">
            <a class="btn btn-primary me-2" asp-page="/Login">
                <i class="bi bi-box-arrow-in-right"></i> Prihlásiť sa
            </a>
            <a class="btn btn-outline-secondary" asp-page="/Register">
                Registrovať
            </a>
        </div>
    </div>
}
else
{

    <form id="anForm" method="post" enctype="multipart/form-data">
        <div class="row g-3">
            <div class="col-12">
                <div id="dropzone" class="border border-2 rounded p-4 text-center bg-light" style="cursor:pointer">
                    <div class="fw-bold">Pretiahni sem export 15m intervalov ZSDIS (.xls, .xlsx alebo .csv)</div>
                    <div class="text-muted">alebo klikni a vyber súbor</div>
                    <input asp-for="File" type="file" name="file" id="fileInput" class="d-none" accept=".xls,.xlsx,.csv" />
                </div>
            </div>

            <div class="col-12">
                <div class="card">
                    <div class="card-header fw-bold">Parametre simulácie</div>
                    <div class="card-body row g-3">
                        <div class="col-sm-4 col-md-3">
                            <label class="form-label">Ročný výnos (kWh/kWp/rok)</label>
                            <input class="form-control" asp-for="YearlyYield" type="number" step="10" min="500" max="1500" />
                        </div>
                        <div class="col-sm-4 col-md-3">
                            <label class="form-label">kWp: min</label>
                            <input class="form-control" asp-for="KwMin" type="number" step="0.1" min="0.1" />
                        </div>
                        <div class="col-sm-4 col-md-3">
                            <label class="form-label">kWp: max</label>
                            <input class="form-control" asp-for="KwMax" type="number" step="0.1" min="0.1" />
                        </div>
                        <div class="col-sm-4 col-md-3">
                            <label class="form-label">kWp: krok</label>
                            <input class="form-control" asp-for="KwStep" type="number" step="0.1" min="0.1" />
                        </div>

                        <div class="col-sm-4 col-md-3">
                            <label class="form-label">Batéria kWh: min</label>
                            <input class="form-control" asp-for="BatMin" type="number" step="0.5" min="0" />
                        </div>
                        <div class="col-sm-4 col-md-3">
                            <label class="form-label">Batéria kWh: max</label>
                            <input class="form-control" asp-for="BatMax" type="number" step="0.5" min="0" />
                        </div>
                        <div class="col-sm-4 col-md-3">
                            <label class="form-label">Batéria kWh: krok</label>
                            <input class="form-control" asp-for="BatStep" type="number" step="0.5" min="0.5" />
                        </div>

                        <div class="col-sm-4 col-md-3">
                            <label class="form-label">Import cena (€/kWh)</label>
                            <input class="form-control" asp-for="PriceImport" type="number" step="0.001" min="0" />
                        </div>
                        <div class="col-sm-4 col-md-3">
                            <label class="form-label">Výkup/Export (€/kWh)</label>
                            <input class="form-control" asp-for="PriceExport" type="number" step="0.001" min="0" />
                        </div>
                        <div class="col-sm-4 col-md-3">
                            <label class="form-label">CAPEX FVE (€/kWp)</label>
                            <input class="form-control" asp-for="CapexPerKwp" type="number" step="10" min="0" />
                        </div>
                        <div class="col-sm-4 col-md-3">
                            <label class="form-label">CAPEX Batéria (€/kWh)</label>
                            <input class="form-control" asp-for="CapexPerKwh" type="number" step="10" min="0" />
                        </div>

                        <div class="col-sm-4 col-md-3">
                            <label class="form-label">Fixná investícia BOS (€)</label>
                            <input class="form-control" asp-for="CapexFixed" type="number" step="50" min="0" />
                        </div>
                        <div class="col-sm-4 col-md-3">
                            <label class="form-label">O&amp;M (% CAPEX/rok)</label>
                            <input class="form-control" asp-for="OandMpercent" type="number" step="0.1" min="0" />
                        </div>
                        <div class="col-sm-4 col-md-3">
                            <label class="form-label">Diskont (%)</label>
                            <input class="form-control" asp-for="DiscountRate" type="number" step="0.1" min="0" />
                        </div>
                        <div class="col-sm-4 col-md-3">
                            <label class="form-label">Horizont (roky)</label>
                            <input class="form-control" asp-for="HorizonYears" type="number" step="1" min="5" />
                        </div>

                        <div class="col-sm-4 col-md-3">
                            <label class="form-label">Bat. výkon limit (kW)</label>
                            <input class="form-control" asp-for="BatteryMaxKW" type="number" step="0.1" min="0.1" />
                        </div>
                        <div class="col-sm-4 col-md-3">
                            <label class="form-label">Účinnosť nab./vyb. (%)</label>
                            <input class="form-control" asp-for="EffChargeDischargePct" type="number" step="0.1" min="50" max="100" />
                        </div>

                        <div class="col-sm-4 col-md-3">
                            <label class="form-label">Výkon meniča (kW)</label>
                            <input class="form-control" asp-for="InverterKW" type="number" step="0.1" min="0.5" />
                        </div>
                        <div class="col-sm-4 col-md-3">
                            <label class="form-label">Export limit (kW)</label>
                            <input class="form-control" asp-for="ExportLimitKW" type="number" step="0.1" />
                            <div class="form-text">Ak prázdne alebo &le; 0 → použije sa výkon meniča.</div>
                        </div>
                        <div class="col-sm-4 col-md-3 d-flex align-items-end">
                            <div class="form-check">
                                <input class="form-check-input" asp-for="TouEnabled" type="checkbox" />
                                <label class="form-check-label">TOU (časové ceny) – default vypnuté</label>
                            </div>
                        </div>

                        <div class="col-12">
                            <label class="form-label">Mesačné podiely výroby (jan..dec, spolu=1.0)</label>
                            <input class="form-control" asp-for="MonthlySharesCsv" />
                            <div class="form-text">Príklad: 0.02,0.04,0.08,0.11,0.13,0.14,0.14,0.12,0.10,0.07,0.03,0.02</div>
                        </div>

                        <div class="col-12 d-flex gap-2">
                            <button type="submit" formaction="?handler=Analyze" class="btn btn-primary">Analyzovať &amp; Navrhnúť</button>
                            <button type="button" class="btn btn-outline-secondary" id="pickBtn">Vybrať súbor</button>
                            <button type="submit" formaction="?handler=ExportPdf" class="btn btn-success">Export PDF</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>

    }

    @if (!ViewContext.ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger mt-3">
            @foreach (var e in ViewContext.ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@e.ErrorMessage</div>
            }
        </div>
    }

    @if (Model.Result != null)
    {
        <div class="card mt-3">
            <div class="card-header fw-bold">Zhrnutie spotreby a kvality dát</div>
            <div class="card-body row row-cols-1 row-cols-md-3 g-3">
                <div class="col"><div class="p-2 border rounded"><div class="fw-bold">Obdobie</div><div>@Model.Result.From:d – @Model.Result.To:d</div></div></div>
                <div class="col"><div class="p-2 border rounded"><div class="fw-bold">Dní</div><div>@Model.Result.Days</div></div></div>
                <div class="col"><div class="p-2 border rounded"><div class="fw-bold">Priemer/deň</div><div>@Model.Result.AvgPerDayKWh kWh</div></div></div>
                <div class="col"><div class="p-2 border rounded"><div class="fw-bold">Chýbajúce intervaly</div><div>@Model.Result.MissingIntervals</div></div></div>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header fw-bold">Návrh (cieľ = max NPV)</div>
            <div class="card-body">
                <ul class="mb-2">
                    <li><strong>FVE:</strong> @Model.Opt?.KwP kWp</li>
                    <li><strong>Batéria:</strong> @Model.Opt?.BatKWh kWh</li>
                    <li><strong>Autonómia:</strong> @((Model.Opt?.AutarkyPct ?? 0).ToString("0.0")) % &nbsp; | &nbsp; <strong>Vlastná spotreba:</strong> @((Model.Opt?.SelfConsumptionPct ?? 0).ToString("0.0")) %</li>
                    <li><strong>Import/Export:</strong> @Model.Opt?.ImportKWh kWh / @Model.Opt?.ExportKWh kWh</li>
                    <li><strong>Ročná výroba FVE:</strong> @Model.Opt?.PvKWh kWh</li>
                    <li><strong>Menič/Export limit:</strong> @Model.InverterKW kW / @(Model.ExportLimitKW > 0 ? Model.ExportLimitKW : Model.InverterKW) kW</li>
                    <li><strong>NPV (@Model.HorizonYears r., @Model.DiscountRate %):</strong> @Model.Opt?.NPV.ToString("0 €") &nbsp; | &nbsp; <strong>Payback:</strong> @Model.Opt?.PaybackYears?.ToString("0.0 r.")</li>
                </ul>
            </div>
        </div>

        <!-- Priemerný deň – 15-min profil -->
        <div class="card mt-3">
            <div class="card-header fw-bold">Priemerný deň – 15-min profil (spotreba vs. výroba)</div>
            <div class="card-body">
                <canvas id="avgDayChart"></canvas>
            </div>
        </div>

        <!-- Mesačné sumy -->
        <div class="card mt-3">
            <div class="card-header fw-bold">Mesačný prehľad – Spotreba / Výroba / Import / Export</div>
            <div class="card-body">
                <canvas id="monthlyChart"></canvas>
            </div>
        </div>

        <!-- Denné súčty spotreby -->
        <div class="card mt-3">
            <div class="card-header fw-bold">Denné súčty spotreby (kWh/deň)</div>
            <div class="card-body">
                <canvas id="dailyConsChart"></canvas>
            </div>
        </div>
    }
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    (function(){
        const form = document.getElementById('anForm');
        const dz   = document.getElementById('dropzone');
        const fi   = document.getElementById('fileInput');
        const pick = document.getElementById('pickBtn');

        if (!form || !dz || !fi) return;

        pick?.addEventListener('click', () => fi.click());
        dz.addEventListener('click', () => fi.click());

        // Už neodosielaj automaticky pri výbere – len vizuálna spätná väzba
        fi.addEventListener('change', () => {
            if (fi.files?.length) {
                const name = fi.files[0].name;
                const infoEl = document.createElement('div');
                infoEl.className = 'mt-1 text-success';
                infoEl.textContent = name;
                dz.appendChild(infoEl);
            }
        });

        dz.addEventListener('dragover', e => { e.preventDefault(); dz.classList.add('border-primary'); });
        dz.addEventListener('dragleave', () => dz.classList.remove('border-primary'));
        dz.addEventListener('drop', e => {
            e.preventDefault(); dz.classList.remove('border-primary');
            const file = e.dataTransfer?.files?.[0]; if (!file) return;
            const dt = new DataTransfer(); dt.items.add(file); fi.files = dt.files;
            const infoEl = document.createElement('div');
            infoEl.className = 'mt-1 text-success';
            infoEl.textContent = file.name;
            dz.appendChild(infoEl);
        });

        // === GRAFY ===
        const hasCharts = @(Model.HasCharts ? "true" : "false");
        if (hasCharts) {
            const labels96   = @Html.Raw(Model.JsonLabels96 ?? "[]");
            const avgCons    = @Html.Raw(Model.JsonAvgCons ?? "[]");
            const avgPv      = @Html.Raw(Model.JsonAvgPv ?? "[]");
            const avgImp     = @Html.Raw(Model.JsonAvgImport ?? "[]");

            const mLabels    = @Html.Raw(Model.JsonMonthlyLabels ?? "[]");
            const mCons      = @Html.Raw(Model.JsonMonthlyCons ?? "[]");
            const mPv        = @Html.Raw(Model.JsonMonthlyPv ?? "[]");
            const mImp       = @Html.Raw(Model.JsonMonthlyImp ?? "[]");
            const mExp       = @Html.Raw(Model.JsonMonthlyExp ?? "[]");

            const dLabels    = @Html.Raw(Model.JsonDailyLabels ?? "[]");
            const dVals      = @Html.Raw(Model.JsonDailyConsumption ?? "[]");

            // Priemerný deň – overlay
            const ctx1 = document.getElementById('avgDayChart')?.getContext('2d');
            if (ctx1) new Chart(ctx1, {
                type: 'line',
                data: { labels: labels96, datasets: [
                    { label: 'Spotreba (kWh / 15m priemer)', data: avgCons, tension: 0.25, fill: false },
                    { label: 'Výroba FVE (kWh / 15m priemer)', data: avgPv, tension: 0.25, fill: false },
                    { label: 'Import zo siete (kWh / 15m priemer)', data: avgImp, tension: 0.25, fill: false }
                ]},
                options: { responsive: true, interaction: { mode: 'index', intersect: false } }
            });

            // Mesačné sumy
            const ctx2 = document.getElementById('monthlyChart')?.getContext('2d');
            if (ctx2) new Chart(ctx2, {
                type: 'bar',
                data: { labels: mLabels, datasets: [
                    { label: 'Spotreba (kWh)', data: mCons },
                    { label: 'Výroba FVE (kWh)', data: mPv },
                    { label: 'Import (kWh)', data: mImp },
                    { label: 'Export (kWh)', data: mExp }
                ]},
                options: { responsive: true, scales: { x: { stacked: false }, y: { beginAtZero: true } } }
            });

            // Denné súčty spotreby
            const ctx3 = document.getElementById('dailyConsChart')?.getContext('2d');
            if (ctx3) new Chart(ctx3, {
                type: 'bar',
                data: { labels: dLabels, datasets: [ { label: 'Spotreba (kWh/deň)', data: dVals } ] },
                options: { responsive: true, scales: { y: { beginAtZero: true } } }
            });
        }
    })();
</script>

@page "/ako-zacat"
@{
    var isEnglish = Lang.IsEnglish(ViewContext.HttpContext);
    string T(string sk, string en) => Lang.Pick(ViewContext.HttpContext, sk, en);
    ViewData["Title"] = T("Ako začať", "Getting started");

    var toolsUrl = isEnglish ? "/tools" : "/nastroje";
    var analysisUrl = isEnglish ? "/15-minute-interval-analysis" : "/analyza-15-minutovych-intervalov";
    var technicalDocsUrl = "https://github.com/PavolLukacka/NestStats/blob/main/NESTSTATS_TECHNICAL_DOCUMENTATION.md";
    var systemsUrl = "/systems/connect";
}

@section Head {
<style>
    .gs-page {
        max-width: 1240px;
        margin: 0 auto;
        padding: clamp(28px, 4vw, 48px) 28px 72px;
        display: grid;
        gap: 28px;
    }

    .gs-hero {
        position: relative;
        display: grid;
        grid-template-columns: minmax(0, 1fr) 340px;
        gap: 34px;
        min-height: 520px;
        padding: clamp(34px, 5vw, 64px);
        border: 1px solid var(--ns-border);
        border-radius: 30px;
        background:
            radial-gradient(ellipse 80% 140% at 100% 100%, rgba(30,158,110,.08), transparent 58%),
            radial-gradient(ellipse 70% 120% at 0% 0%, rgba(37,99,235,.06), transparent 55%),
            linear-gradient(120deg, rgba(255,255,255,.96), rgba(249,248,246,.86));
        box-shadow: var(--ns-shadow-md);
        overflow: hidden;
    }

    .gs-hero::before {
        content: "";
        position: absolute;
        inset: auto -90px -120px auto;
        width: 520px;
        height: 520px;
        border-radius: 50%;
        background:
            radial-gradient(circle at 45% 45%, rgba(30,158,110,.20), transparent 56%),
            radial-gradient(circle at 62% 60%, rgba(232,160,32,.16), transparent 64%);
        pointer-events: none;
    }

    .gs-hero__body,
    .gs-hero__panel {
        position: relative;
        z-index: 1;
    }

    .gs-kicker {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        width: fit-content;
        padding: 7px 12px;
        border-radius: 999px;
        border: 1px solid rgba(30,158,110,.18);
        background: rgba(30,158,110,.08);
        color: #0c6e48;
        font: 700 .68rem/1 var(--ff-mono);
        letter-spacing: .11em;
        text-transform: uppercase;
    }

    .gs-kicker::before {
        content: "";
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--ns-green);
        box-shadow: 0 0 0 4px rgba(30,158,110,.16);
    }

    .gs-title {
        max-width: 820px;
        margin: 22px 0 18px;
        font-size: clamp(2.3rem, 6vw, 5.2rem);
        line-height: .98;
        letter-spacing: -.055em;
        color: var(--ns-ink);
    }

    .gs-title em {
        display: inline-block;
        margin-top: 6px;
        font-family: var(--ff-mono);
        font-size: .78em;
        font-style: normal;
        font-weight: 800;
        letter-spacing: 0;
        color: transparent;
        background: linear-gradient(92deg, #1e9e6e 0%, #0f766e 42%, #e8a020 100%);
        -webkit-background-clip: text;
        background-clip: text;
        text-shadow: 0 12px 34px rgba(30,158,110,.16);
    }

    .gs-lead {
        max-width: 680px;
        margin: 0;
        color: var(--ns-ink-3);
        font-size: 1.02rem;
        line-height: 1.74;
    }

    .gs-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 26px;
    }

    .gs-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding: 12px 18px;
        border-radius: 999px;
        border: 1px solid var(--ns-border);
        background: rgba(255,255,255,.86);
        color: var(--ns-ink);
        text-decoration: none;
        font-weight: 700;
        font-size: .9rem;
        transition: transform .18s var(--ease-out), border-color .18s, box-shadow .18s, background .18s;
    }

    .gs-button:hover {
        transform: translateY(-2px);
        border-color: rgba(30,158,110,.32);
        box-shadow: var(--ns-shadow-sm);
        color: var(--ns-ink);
    }

    .gs-button--primary {
        background: var(--ns-ink);
        border-color: var(--ns-ink);
        color: #fff;
    }

    .gs-button--primary:hover {
        background: #171923;
        color: #fff;
    }

    .gs-hero__panel {
        align-self: stretch;
        display: grid;
        gap: 12px;
        padding: 18px;
        border: 1px solid rgba(255,255,255,.72);
        border-radius: 24px;
        background: rgba(255,255,255,.72);
        backdrop-filter: blur(16px);
        box-shadow: var(--ns-shadow-sm);
    }

    .gs-status {
        display: grid;
        gap: 4px;
        padding: 16px;
        border: 1px solid var(--ns-border);
        border-radius: 18px;
        background: rgba(255,255,255,.9);
    }

    .gs-status span {
        color: var(--ns-ink-3);
        font: 700 .66rem/1 var(--ff-mono);
        letter-spacing: .10em;
        text-transform: uppercase;
    }

    .gs-status strong {
        color: var(--ns-ink);
        font-size: 1rem;
        line-height: 1.25;
    }

    .gs-section {
        display: grid;
        gap: 18px;
    }

    .gs-section-head {
        display: grid;
        gap: 6px;
        max-width: 780px;
    }

    .gs-eyebrow {
        color: var(--ns-ink-3);
        font: 700 .7rem/1 var(--ff-mono);
        letter-spacing: .12em;
        text-transform: uppercase;
    }

    .gs-section h2 {
        margin: 0;
        color: var(--ns-ink);
        font-size: clamp(1.55rem, 3vw, 2.25rem);
        line-height: 1.08;
        letter-spacing: -.04em;
    }

    .gs-section-head p {
        margin: 0;
        color: var(--ns-ink-3);
        font-size: .96rem;
        line-height: 1.65;
    }

    .gs-capabilities {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 16px;
    }

    .gs-card,
    .gs-step,
    .gs-support,
    .gs-callout {
        border: 1px solid var(--ns-border);
        border-radius: 22px;
        background: rgba(255,255,255,.92);
        box-shadow: var(--ns-shadow-sm);
    }

    .gs-card {
        min-height: 190px;
        padding: 20px;
        display: grid;
        align-content: start;
        gap: 12px;
        position: relative;
        overflow: hidden;
    }

    .gs-card::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 4px;
        background: var(--accent, var(--ns-green));
    }

    .gs-card__icon {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        display: inline-grid;
        place-items: center;
        background: var(--tone, var(--ns-green-dim));
        color: var(--accent, var(--ns-green));
    }

    .gs-card h3,
    .gs-step h3,
    .gs-support h3 {
        margin: 0;
        color: var(--ns-ink);
        font-size: 1.02rem;
        line-height: 1.22;
    }

    .gs-card p,
    .gs-step p,
    .gs-support p,
    .gs-callout p {
        margin: 0;
        color: var(--ns-ink-3);
        font-size: .88rem;
        line-height: 1.58;
    }

    .gs-analysis {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 320px;
        gap: 18px;
        padding: 24px;
        border-radius: 26px;
        border: 1px solid rgba(37,99,235,.16);
        background:
            linear-gradient(135deg, rgba(239,246,255,.92), rgba(255,255,255,.92)),
            linear-gradient(#fff, #fff);
    }

    .gs-analysis__stats {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
    }

    .gs-mini {
        padding: 14px;
        border-radius: 16px;
        border: 1px solid rgba(37,99,235,.14);
        background: rgba(255,255,255,.82);
    }

    .gs-mini span {
        display: block;
        color: var(--ns-ink-3);
        font: 700 .64rem/1 var(--ff-mono);
        letter-spacing: .08em;
        text-transform: uppercase;
        margin-bottom: 7px;
    }

    .gs-mini strong {
        color: var(--ns-ink);
        font-size: 1.15rem;
    }

    .gs-support-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 14px;
    }

    .gs-support {
        padding: 18px;
        display: grid;
        gap: 8px;
    }

    .gs-chip-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 6px;
    }

    .gs-chip {
        display: inline-flex;
        align-items: center;
        min-height: 28px;
        padding: 7px 10px;
        border-radius: 999px;
        border: 1px solid var(--ns-border);
        background: rgba(255,255,255,.86);
        color: var(--ns-ink-3);
        font: 700 .68rem/1 var(--ff-mono);
        letter-spacing: .03em;
    }

    .gs-steps {
        display: grid;
        gap: 12px;
        counter-reset: gs-step;
    }

    .gs-step {
        counter-increment: gs-step;
        display: grid;
        grid-template-columns: 52px minmax(0, 1fr) auto;
        gap: 16px;
        align-items: center;
        padding: 18px;
    }

    .gs-step::before {
        content: counter(gs-step);
        width: 42px;
        height: 42px;
        border-radius: 14px;
        display: inline-grid;
        place-items: center;
        background: var(--ns-ink);
        color: #fff;
        font: 800 .9rem/1 var(--ff-mono);
    }

    .gs-step__meta {
        color: var(--ns-ink-4);
        font: 700 .68rem/1 var(--ff-mono);
        letter-spacing: .08em;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .gs-flow {
        padding: 24px;
        border: 1px solid var(--ns-border);
        border-radius: 26px;
        background: linear-gradient(180deg, rgba(255,255,255,.96), rgba(246,249,255,.86));
        display: grid;
        gap: 18px;
    }

    .gs-flow__line {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 10px;
    }

    .gs-flow__node {
        min-height: 112px;
        padding: 15px;
        border: 1px solid var(--ns-border);
        border-radius: 18px;
        background: rgba(255,255,255,.9);
        display: grid;
        gap: 7px;
        align-content: start;
    }

    .gs-flow__node strong {
        color: var(--ns-ink);
        font-size: .92rem;
    }

    .gs-flow__node span {
        color: var(--ns-ink-3);
        font-size: .78rem;
        line-height: 1.45;
    }

    .gs-firmware-grid,
    .gs-wiring-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
    }

    .gs-firmware-card,
    .gs-wiring-card {
        padding: 18px;
        border: 1px solid var(--ns-border);
        border-radius: 20px;
        background: rgba(255,255,255,.9);
        box-shadow: var(--ns-shadow-sm);
        display: grid;
        gap: 10px;
    }

    .gs-firmware-card header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
    }

    .gs-firmware-card h3,
    .gs-wiring-card h3 {
        margin: 0;
        color: var(--ns-ink);
        font-size: 1rem;
        line-height: 1.25;
    }

    .gs-firmware-card p,
    .gs-wiring-card p,
    .gs-checklist li {
        margin: 0;
        color: var(--ns-ink-3);
        font-size: .86rem;
        line-height: 1.55;
    }

    .gs-firmware-card code,
    .gs-pin-table code {
        font-family: var(--ff-mono);
        font-size: .72rem;
        color: var(--ns-ink);
        background: rgba(15,23,42,.05);
        border: 1px solid rgba(15,23,42,.08);
        border-radius: 8px;
        padding: 3px 6px;
        word-break: break-word;
    }

    .gs-firmware-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
    }

    .gs-button--small {
        min-height: 34px;
        padding: 8px 12px;
        font-size: .75rem;
    }

    .gs-pin-table {
        width: 100%;
        border-collapse: collapse;
        overflow: hidden;
        border-radius: 16px;
        border: 1px solid var(--ns-border);
        background: rgba(255,255,255,.88);
    }

    .gs-pin-table th,
    .gs-pin-table td {
        padding: 12px 14px;
        border-bottom: 1px solid var(--ns-border);
        text-align: left;
        vertical-align: top;
        color: var(--ns-ink-3);
        font-size: .84rem;
        line-height: 1.45;
    }

    .gs-pin-table th {
        color: var(--ns-ink);
        font: 800 .68rem/1 var(--ff-mono);
        text-transform: uppercase;
        letter-spacing: .08em;
        background: rgba(15,23,42,.035);
    }

    .gs-pin-table tr:last-child td {
        border-bottom: 0;
    }

    .gs-checklist {
        margin: 0;
        padding-left: 18px;
        display: grid;
        gap: 7px;
    }

    .gs-warning {
        padding: 16px;
        border-radius: 18px;
        border: 1px solid rgba(232,160,32,.24);
        background: rgba(255,247,229,.82);
        color: var(--ns-ink-3);
        font-size: .88rem;
        line-height: 1.6;
    }

    .gs-schema {
        overflow: hidden;
        border: 1px solid var(--ns-border);
        border-radius: 24px;
        background: linear-gradient(180deg, rgba(255,255,255,.96), rgba(248,250,252,.9));
        box-shadow: var(--ns-shadow-sm);
    }

    .gs-schema img {
        display: block;
        width: 100%;
        height: auto;
    }

    .gs-setup-guide {
        display: grid;
        gap: 16px;
    }

    .gs-setup-row {
        display: grid;
        grid-template-columns: 160px minmax(0, 1fr);
        gap: 16px;
        padding: 18px;
        border: 1px solid var(--ns-border);
        border-radius: 22px;
        background: rgba(255,255,255,.92);
        box-shadow: var(--ns-shadow-sm);
    }

    .gs-setup-row__stage {
        display: grid;
        align-content: start;
        gap: 8px;
    }

    .gs-setup-row__stage span {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        display: inline-grid;
        place-items: center;
        background: var(--ns-ink);
        color: #fff;
        font: 800 .88rem/1 var(--ff-mono);
    }

    .gs-setup-row__stage strong {
        color: var(--ns-ink);
        font-size: .96rem;
        line-height: 1.25;
    }

    .gs-setup-row__body {
        display: grid;
        gap: 12px;
    }

    .gs-setup-row__body h3 {
        margin: 0;
        color: var(--ns-ink);
        font-size: 1.08rem;
    }

    .gs-setup-row__body p {
        margin: 0;
        color: var(--ns-ink-3);
        font-size: .9rem;
        line-height: 1.62;
    }

    .gs-detail-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
    }

    .gs-detail {
        padding: 13px;
        border: 1px solid var(--ns-border);
        border-radius: 16px;
        background: rgba(248,250,252,.88);
        display: grid;
        gap: 7px;
    }

    .gs-detail b {
        color: var(--ns-ink);
        font-size: .78rem;
        line-height: 1.25;
    }

    .gs-detail span {
        color: var(--ns-ink-3);
        font-size: .78rem;
        line-height: 1.45;
    }

    .gs-code {
        margin: 0;
        padding: 14px 16px;
        border-radius: 16px;
        border: 1px solid rgba(15,23,42,.14);
        background: #0f172a;
        color: #dbeafe;
        overflow-x: auto;
        font: 12px/1.58 var(--ff-mono, Consolas, monospace);
        white-space: pre;
    }

    .gs-code code {
        font: inherit;
        color: inherit;
    }

    .gs-copy-grid {
        display: grid;
        gap: 14px;
    }

    .gs-copy-card {
        padding: 18px;
        border: 1px solid var(--ns-border);
        border-radius: 22px;
        background: rgba(255,255,255,.94);
        box-shadow: var(--ns-shadow-sm);
        display: grid;
        gap: 12px;
    }

    .gs-copy-card header {
        display: flex;
        justify-content: space-between;
        gap: 14px;
        align-items: start;
    }

    .gs-copy-card h3 {
        margin: 0;
        color: var(--ns-ink);
        font-size: 1.05rem;
        line-height: 1.25;
    }

    .gs-copy-card p,
    .gs-copy-card li {
        margin: 0;
        color: var(--ns-ink-3);
        font-size: .88rem;
        line-height: 1.6;
    }

    .gs-copy-card ul {
        margin: 0;
        padding-left: 18px;
        display: grid;
        gap: 6px;
    }

    .gs-callout {
        padding: 22px;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 18px;
        align-items: center;
        background: linear-gradient(135deg, rgba(30,158,110,.08), rgba(232,160,32,.08));
    }

    @@media (max-width: 1060px) {
        .gs-hero,
        .gs-analysis,
        .gs-callout {
            grid-template-columns: 1fr;
        }

        .gs-capabilities,
        .gs-support-grid,
        .gs-firmware-grid,
        .gs-wiring-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .gs-flow__line {
            grid-template-columns: 1fr;
        }

        .gs-setup-row,
        .gs-detail-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 680px) {
        .gs-page,
        .gs-page *,
        .gs-page *::before,
        .gs-page *::after {
            box-sizing: border-box;
            min-width: 0;
        }

        .gs-page {
            width: 100%;
            max-width: 100%;
            padding: 18px 14px 56px;
            gap: 20px;
            overflow-x: hidden;
        }

        .gs-hero {
            width: 100%;
            max-width: 100%;
            min-height: auto;
            padding: 22px 18px;
            border-radius: 22px;
            gap: 20px;
        }

        .gs-hero::before {
            width: 280px;
            height: 280px;
            inset: auto -110px -100px auto;
            opacity: .75;
        }

        .gs-kicker {
            max-width: 100%;
            align-items: flex-start;
            white-space: normal;
            line-height: 1.35;
        }

        .gs-kicker::before {
            flex: 0 0 8px;
            margin-top: 2px;
        }

        .gs-title {
            margin: 18px 0 14px;
            font-size: 2.38rem;
            line-height: 1.03;
            letter-spacing: -.035em;
        }

        .gs-title em {
            display: block;
            margin-top: 8px;
            font-size: .72em;
        }

        .gs-lead,
        .gs-section-head p,
        .gs-card p,
        .gs-support p,
        .gs-step p,
        .gs-firmware-card p,
        .gs-wiring-card p,
        .gs-copy-card p,
        .gs-callout p {
            font-size: .92rem;
            line-height: 1.62;
        }

        .gs-section {
            width: 100%;
            max-width: 100%;
            gap: 14px;
        }

        .gs-section-head,
        .gs-flow__line,
        .gs-setup-row,
        .gs-detail-grid,
        .gs-copy-grid,
        .gs-firmware-actions {
            width: 100%;
            max-width: 100%;
        }

        .gs-section h2 {
            font-size: 1.55rem;
            line-height: 1.14;
            letter-spacing: -.025em;
        }

        .gs-capabilities,
        .gs-support-grid,
        .gs-firmware-grid,
        .gs-wiring-grid,
        .gs-analysis__stats {
            width: 100%;
            max-width: 100%;
            grid-template-columns: 1fr;
            gap: 12px;
        }

        .gs-actions {
            margin-top: 18px;
            width: 100%;
        }

        .gs-button {
            width: 100%;
            max-width: 100%;
            min-height: 42px;
            padding: 11px 14px;
            text-align: center;
            white-space: normal;
        }

        .gs-hero__panel {
            padding: 12px;
            gap: 10px;
            border-radius: 18px;
        }

        .gs-status {
            padding: 13px;
            border-radius: 15px;
        }

        .gs-status strong {
            font-size: .92rem;
            line-height: 1.32;
            overflow-wrap: anywhere;
        }

        .gs-card,
        .gs-step,
        .gs-support,
        .gs-firmware-card,
        .gs-wiring-card,
        .gs-copy-card,
        .gs-flow,
        .gs-analysis,
        .gs-callout {
            width: 100%;
            max-width: 100%;
            border-radius: 18px;
        }

        .gs-card,
        .gs-support,
        .gs-firmware-card,
        .gs-wiring-card,
        .gs-copy-card,
        .gs-flow,
        .gs-analysis,
        .gs-callout {
            padding: 16px;
        }

        .gs-card {
            min-height: auto;
            gap: 10px;
        }

        .gs-card__icon {
            width: 36px;
            height: 36px;
            border-radius: 12px;
            font-size: 1rem;
        }

        .gs-analysis {
            gap: 16px;
        }

        .gs-flow__node,
        .gs-mini {
            min-height: auto;
            padding: 13px;
        }

        .gs-step {
            grid-template-columns: 42px 1fr;
            padding: 14px;
            gap: 12px;
        }

        .gs-step__number {
            width: 42px;
            height: 42px;
            border-radius: 14px;
        }

        .gs-step h3,
        .gs-firmware-card h3,
        .gs-wiring-card h3,
        .gs-copy-card h3 {
            font-size: 1rem;
            line-height: 1.25;
            overflow-wrap: anywhere;
        }

        .gs-firmware-card code,
        .gs-pin-table code {
            white-space: normal;
            overflow-wrap: anywhere;
            word-break: break-word;
        }

        .gs-step__meta {
            grid-column: 2;
            white-space: normal;
        }

        .gs-code {
            width: 100%;
            max-width: 100%;
            padding: 12px;
            border-radius: 14px;
            font-size: .72rem;
            overflow-x: auto;
            white-space: pre;
            -webkit-overflow-scrolling: touch;
        }

        .gs-schema {
            width: 100%;
            max-width: 100%;
            overflow: hidden;
            border-radius: 18px;
        }

        .gs-schema img {
            width: 100%;
            max-width: 100%;
            height: auto;
        }

        .gs-pin-table {
            display: block;
            width: 100%;
            max-width: 100%;
            overflow: visible;
            border-radius: 18px;
            background: transparent;
            border-spacing: 0;
        }

        .gs-pin-table thead {
            display: none;
        }

        .gs-pin-table tbody,
        .gs-pin-table tr,
        .gs-pin-table td {
            display: block;
            width: 100%;
            max-width: 100%;
        }

        .gs-pin-table tr {
            margin-bottom: 12px;
            padding: 12px;
            border: 1px solid var(--ns-border);
            border-radius: 16px;
            background: rgba(255,255,255,.92);
            box-shadow: var(--ns-shadow-sm);
        }

        .gs-pin-table td {
            padding: 8px 0;
            border-bottom: 1px solid rgba(31,36,48,.08);
            font-size: .88rem;
        }

        .gs-pin-table td:last-child {
            border-bottom: 0;
        }

        .gs-pin-table td::before {
            display: block;
            margin-bottom: 4px;
            color: var(--ns-ink-3);
            font: 800 .62rem/1 var(--ff-mono);
            letter-spacing: .10em;
            text-transform: uppercase;
        }

        .gs-pin-table td:nth-child(1)::before {
            content: "Firmware";
        }

        .gs-pin-table td:nth-child(2)::before {
            content: "RS485 / Modbus";
        }

        .gs-pin-table td:nth-child(3)::before {
            content: "Výstupy / Outputs";
        }

        .gs-pin-table td:nth-child(4)::before {
            content: "Poznámka / Note";
        }

        .gs-callout {
            align-items: stretch;
        }
    }

    @@media (max-width: 420px) {
        .gs-page {
            padding-inline: 10px;
        }

        .gs-hero {
            padding: 20px 14px;
            border-radius: 20px;
        }

        .gs-title {
            font-size: 2.05rem;
        }

        .gs-section h2 {
            font-size: 1.38rem;
        }

        .gs-card,
        .gs-support,
        .gs-step,
        .gs-firmware-card,
        .gs-wiring-card,
        .gs-copy-card,
        .gs-flow,
        .gs-analysis,
        .gs-callout {
            padding: 14px;
        }

        .gs-code {
            font-size: .68rem;
        }
    }
</style>
}

<main class="gs-page">
    <section class="gs-hero">
        <div class="gs-hero__body">
            <span class="gs-kicker">@T("Prvý štart ekosystému", "First start of the ecosystem")</span>
            <h1 class="gs-title">@T("Začni s NestStats bez hádania.", "Start with NestStats without guesswork.") <em>@T("Meraj, riaď, overuj.", "Measure, control, verify.")</em></h1>
            <p class="gs-lead">
                @T(
                    "NestStats prepája fotovoltiku, batériu, WattRouter, lokálne displeje, firmware nody a webový dashboard do jedného energetického workspace. Táto stránka ukazuje, čo platforma vie, čo je dnes podporované a ako zapojiť prvý systém.",
                    "NestStats connects solar production, battery storage, WattRouter, local displays, firmware nodes, and the web dashboard into one energy workspace. This page explains what the platform can do, what is supported today, and how to connect the first system.")
            </p>
        </div>

        <aside class="gs-hero__panel" aria-label="@T("Rýchly prehľad", "Quick overview")">
            <div class="gs-status">
                <span>@T("Jadro", "Core")</span>
                <strong>@T("Sofar Solar + Supabase + ASP.NET dashboard", "Sofar Solar + Supabase + ASP.NET dashboard")</strong>
            </div>
            <div class="gs-status">
                <span>@T("Lokálne riadenie", "Local control")</span>
                <strong>@T("WattRouter, batéria, SSR výstupy, analógový výstup", "WattRouter, battery, SSR outputs, analog output")</strong>
            </div>
            <div class="gs-status">
                <span>@T("Zobrazenie", "Display")</span>
                <strong>@T("Waveshare, ESP32 Display, ESP32/Arduino displeje", "Waveshare, ESP32 Display, ESP32/Arduino displays")</strong>
            </div>
            <div class="gs-status">
                <span>@T("Začiatok", "Start")</span>
                <strong>@T("Najprv over dáta, potom pripájaj riadenie", "Verify data first, then connect control")</strong>
            </div>
        </aside>
    </section>

    <section class="gs-section">
        <div class="gs-section-head">
            <span class="gs-eyebrow">@T("Možnosti platformy", "Platform capabilities")</span>
            <h2>@T("Čo môžeš s NestStats robiť", "What you can do with this platform")</h2>
            <p>@T("Platforma nie je iba grafický dashboard. Vie zbierať dáta, vyhodnocovať prevádzku, riadiť prebytky a ukázať stav systému aj mimo webovej aplikácie.", "The platform is not only a dashboard. It can collect data, evaluate operation, control surplus energy, and show system state outside the web application as well.")</p>
        </div>

        <div class="gs-capabilities">
            <article class="gs-card" style="--accent:#1e9e6e;--tone:#e6f7f1">
                <span class="gs-card__icon" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M4 13h6l-2 7 12-12h-6l2-7L4 13Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
                </span>
                <h3>@T("Riadenie prebytkov cez WattRouter", "Surplus control through WattRouter")</h3>
                <p>@T("Pre bojler a odporové záťaže používaj zero-crossing SSR relé dimenzované na výkon fázy. Praktické príklady sú Carlo Gavazzi RGC1A23D15KKE približne pre 3 kW na fázu alebo RGS1A23D25KKEDIN približne pre 2 kW na fázu.", "For boilers and resistive loads use zero-crossing SSR relays sized for the phase load. Practical examples are Carlo Gavazzi RGC1A23D15KKE for roughly 3 kW per phase or RGS1A23D25KKEDIN for roughly 2 kW per phase.")</p>
            </article>

            <article class="gs-card" style="--accent:#2563eb;--tone:#eff4ff">
                <span class="gs-card__icon" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M7 7h10v10H7V7Z" stroke="currentColor" stroke-width="1.8"/><path d="M10 3v4M14 3v4M10 17v4M14 17v4M3 10h4M3 14h4M17 10h4M17 14h4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                </span>
                <h3>@T("Riadenie cez batériové meniče ME3000SP", "Control through ME3000SP battery inverters")</h3>
                <p>@T("Batériový regulátor vie počúvať lokálny stav prebytkov a cez Modbus držať batériu v rozumnom režime.", "The battery regulator can listen to local surplus state and use Modbus to keep the battery in a useful mode.")</p>
            </article>

            <article class="gs-card" style="--accent:#e8a020;--tone:#faf0d9">
                <span class="gs-card__icon" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M4 17c4-10 12-10 16 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M6 17h12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                </span>
                <h3>@T("Analógový výstup pre wallbox alebo výkonový regulátor", "Analog output for wallbox or power control")</h3>
                <p>@T("Prebytky sa dajú preložiť aj na plynulý riadiaci signál pre zariadenia, ktoré nepotrebujú iba zapnúť alebo vypnúť.", "Surplus can also be translated into a smooth control signal for devices that need more than simple on/off switching.")</p>
            </article>

            <article class="gs-card" style="--accent:#7c3aed;--tone:#f3e8ff">
                <span class="gs-card__icon" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M5 5h14v14H5V5Z" stroke="currentColor" stroke-width="1.8"/><path d="M8 9h8M8 13h5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                </span>
                <h3>@T("Získanie dát z meniča", "Get data from the inverter")</h3>
                <p>@T("Firmware uzly čítajú výkon FV, batériu, sieť, štatistické počítadlá a ďalšie veličiny podľa podporovaného meniča.", "Firmware nodes read PV power, battery state, grid values, statistical counters, and other values depending on the supported inverter.")</p>
            </article>

            <article class="gs-card" style="--accent:#0f766e;--tone:#ccfbf1">
                <span class="gs-card__icon" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M5 6h14v10H5V6Z" stroke="currentColor" stroke-width="1.8"/><path d="M9 20h6M12 16v4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                </span>
                <h3>@T("Lokálne displeje Waveshare a ESP32 Display", "Waveshare and ESP32 Display screens")</h3>
                <p>@T("Vybrané ESP32 displeje môžu ukazovať stav FV, batérie a siete bez toho, aby bolo nutné otvoriť web.", "Selected ESP32 displays can show PV, battery, and grid state without opening the web dashboard.")</p>
            </article>

            <article class="gs-card" style="--accent:#d63a3a;--tone:#fef2f2">
                <span class="gs-card__icon" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M8 4h8v16H8V4Z" stroke="currentColor" stroke-width="1.8"/><path d="M10 8h4M10 12h4M10 16h2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                </span>
                <h3>@T("Arduino, ESP32 a vlastné uzly", "Arduino, ESP32, and custom nodes")</h3>
                <p>@T("Ak má zariadenie Wi-Fi a vie poslať správne polia do Supabase, môže sa stať súčasťou ekosystému.", "If a device has Wi-Fi and can send the correct fields to Supabase, it can become part of the ecosystem.")</p>
            </article>
        </div>
    </section>

    <section class="gs-analysis">
        <div class="gs-section-head">
            <span class="gs-eyebrow">@T("Pred investíciou", "Before investing")</span>
            <h2>@T("Neopieraj sa iba o odhad. Over si dáta.", "Do not trust estimates alone. Verify your data.")</h2>
            <p>
                @T(
                    "Ak riešiš, či sa oplatí fotovoltika, batéria alebo tepelné čerpadlo, začni analýzou 15-minútových elektromerových dát. Zistíš reálny profil spotreby, potenciál vlastnej spotreby a rozdiel medzi pocitom a číslami.",
                    "If you are deciding whether solar, battery storage, or a heat pump is worth it, start with a 15-minute electricity meter analysis. It shows the real consumption profile, self-use potential, and the difference between guesswork and data.")
            </p>
            <div class="gs-actions">
                <a class="gs-button gs-button--primary" href="@analysisUrl">@T("Otvoriť 15-minútovú analýzu", "Open 15-minute analysis")</a>
                <a class="gs-button" href="@toolsUrl">@T("Pozrieť všetky nástroje", "See all tools")</a>
            </div>
        </div>
        <div class="gs-analysis__stats">
            <div class="gs-mini"><span>@T("Vstup", "Input")</span><strong>15 min</strong></div>
            <div class="gs-mini"><span>@T("Výstup", "Output")</span><strong>@T("scenár", "scenario")</strong></div>
            <div class="gs-mini"><span>@T("Cieľ", "Goal")</span><strong>@T("reálne kWh", "real kWh")</strong></div>
        </div>
    </section>

    <section class="gs-section">
        <div class="gs-section-head">
            <span class="gs-eyebrow">@T("Ekosystém", "Ecosystem")</span>
            <h2>@T("Čo dnes podporujeme", "What we support today")</h2>
            <p>@T("Jadro je aktuálne postavené okolo SOFAR Solar meničov a vlastných ESP32 firmware nodov. Ďalšie zariadenia sa dajú dopĺňať cez rovnaký dátový kontrakt.", "The core is currently built around SOFAR Solar inverters and custom ESP32 firmware nodes. More devices can be added through the same data contract.")</p>
        </div>
        <div class="gs-support-grid">
            <article class="gs-support">
                <h3>@T("Meniče", "Inverters")</h3>
                <p>@T("Primárne SOFAR Solar, najmä hybridné a batériové scenáre, kde dávajú zmysel FV, batéria a sieťové dáta spolu.", "Primarily SOFAR Solar, especially hybrid and battery scenarios where PV, battery, and grid data need to be read together.")</p>
                <div class="gs-chip-row">
                    <span class="gs-chip">HYD KTL-3PH</span>
                    <span class="gs-chip">ME3000SP</span>
                    <span class="gs-chip">KTLX-G3</span>
                </div>
            </article>
            <article class="gs-support">
                <h3>@T("Hardware", "Hardware")</h3>
                <p>@T("ESP32/Arduino nody, RS485 prevodníky, SSR relé, lokálne displeje.", "ESP32/Arduino nodes, RS485 converters, SSR relays, local displays.")</p>
                <div class="gs-chip-row">
                    <span class="gs-chip">ESP32</span>
                    <span class="gs-chip">RS485</span>
                    <span class="gs-chip">SSR</span>
                </div>
            </article>
            <article class="gs-support">
                <h3>@T("Cloud", "Cloud")</h3>
                <p>@T("Web aplikácia môže bežať lokálne alebo v cloude, napríklad Azure. Telemetria je navrhnutá okolo Supabase tabuliek.", "The web app can run locally or in the cloud, for example on Azure. Telemetry is designed around Supabase tables.")</p>
                <div class="gs-chip-row">
                    <span class="gs-chip">Azure</span>
                    <span class="gs-chip">Supabase</span>
                    <span class="gs-chip">ASP.NET</span>
                </div>
            </article>
            <article class="gs-support">
                <h3>@T("Displeje", "Displays")</h3>
                <p>@T("Podporované sú prototypy lokálneho zobrazenia na Waveshare a lacnejších ESP32 displejoch.", "Prototype local display support includes Waveshare and lower-cost ESP32 displays.")</p>
                <div class="gs-chip-row">
                    <span class="gs-chip">Waveshare</span>
                    <span class="gs-chip">ESP32 Display</span>
                </div>
            </article>
        </div>
    </section>

    <section class="gs-section">
        <div class="gs-section-head">
            <span class="gs-eyebrow">@T("Od nuly po prvé spustenie", "Start to finish")</span>
            <h2>@T("Web aplikácia, Supabase a Azure hosting krok za krokom", "Web app, Supabase, and Azure hosting step by step")</h2>
            <p>
                @T(
                    "Tento postup je pre samotnú webovú aplikáciu NestStats. Najprv stiahneš kód z GitHubu, pripravíš Supabase projekt, zapíšeš prístupové údaje do konfigurácie, overíš lokálne spustenie a až potom aplikáciu nasadíš na Azure.",
                    "This procedure is for the NestStats web application itself. First download the code from GitHub, prepare the Supabase project, write credentials into configuration, verify local startup, and only then deploy the app to Azure.")
            </p>
        </div>

        <div class="gs-copy-grid">
            <article class="gs-copy-card">
                <header>
                    <h3>@T("1. Stiahni aplikáciu z GitHubu", "1. Download the app from GitHub")</h3>
                    <span class="gs-chip">GitHub</span>
                </header>
                <p>@T("Repozitár obsahuje webovú aplikáciu, stránky, dashboard služby, konfiguráciu, dokumentáciu a firmware priečinok. Po stiahnutí pracuj v koreňovom priečinku projektu, kde je súbor NestStats2.csproj.", "The repository contains the web application, pages, dashboard services, configuration, documentation, and firmware folder. After downloading, work in the project root where NestStats2.csproj is located.")</p>
                <pre class="gs-code"><code>git clone https://github.com/PavolLukacka/NestStats.git
cd NestStats
dotnet restore</code></pre>
            </article>

            <article class="gs-copy-card">
                <header>
                    <h3>@T("2. Založ Supabase projekt", "2. Create a Supabase project")</h3>
                    <span class="gs-chip">Supabase</span>
                </header>
                <ul>
                    <li>@T("Otvor supabase.com a vytvor nový projekt.", "Open supabase.com and create a new project.")</li>
                    <li>@T("V projekte otvor Project Settings → API.", "In the project open Project Settings → API.")</li>
                    <li>@T("Skopíruj Project URL. Vyzerá napríklad ako https://xxxxx.supabase.co.", "Copy the Project URL. It looks like https://xxxxx.supabase.co.")</li>
                    <li>@T("Skopíruj anon public key. Nepoužívaj service_role key vo webovej aplikácii.", "Copy the anon public key. Do not use the service_role key in the web application.")</li>
                </ul>
                <div class="gs-warning">
                    <strong>@T("Bezpečnosť:", "Security:")</strong>
                    @T("Service role key má administrátorské oprávnenia a nepatrí do aplikácie, firmware ani verejného repozitára. Pre NestStats používaj Supabase anon key a nastav RLS podľa potreby.", "The service role key has administrative permissions and does not belong in the app, firmware, or public repository. For NestStats use the Supabase anon key and configure RLS as needed.")
                </div>
            </article>

            <article class="gs-copy-card">
                <header>
                    <h3>@T("3. Vytvor základné Supabase tabuľky", "3. Create the core Supabase tables")</h3>
                    <span class="gs-chip">SQL editor</span>
                </header>
                <p>@T("Ak máš už databázu z existujúcej inštalácie, tento krok nerob naslepo. Pre novú testovaciu databázu môžeš v Supabase SQL editore použiť minimálnu schému nižšie a potom ju rozšíriť podľa produkčného modelu.", "If you already have a database from an existing installation, do not run this blindly. For a new test database you can use the minimal schema below in Supabase SQL editor and then extend it according to the production model.")</p>
                <pre class="gs-code"><code>create table if not exists public."SYSTEM" (
  system_id bigint generated by default as identity primary key,
  sn_number text not null unique,
  system_name text not null unique,
  system_address text,
  user_def uuid,
  pocet_ssr integer,
  menic_model text,
  instalovany_vykon real,
  pv1_instalovany_vykon real,
  pv2_instalovany_vykon real
);

create table if not exists public."PV_INFORMATION" (
  created_at timestamptz not null default now(),
  sn_number text not null,
  mppt smallint,
  voltage real,
  current real,
  power real,
  primary key (created_at, sn_number)
);

create table if not exists public."GRID_INFORMATION" (
  created_at timestamptz not null default now(),
  sn_number text not null,
  grid_frequency double precision,
  active_power_output_total double precision,
  active_power_pcc_total double precision,
  voltage_phase_r double precision,
  voltage_phase_s double precision,
  voltage_phase_t double precision,
  primary key (created_at, sn_number)
);

create table if not exists public."BATTERY_INFORMATION" (
  created_at timestamptz not null default now(),
  sn_number text not null,
  voltage real,
  current double precision,
  power real,
  temperature real,
  soc integer,
  soh integer,
  charge_cycle integer,
  primary key (sn_number, created_at)
);

create table if not exists public."STATISTICAL_INFORMATION" (
  timestamp timestamptz not null default now(),
  sn_number text not null,
  pv_generation_today double precision,
  pv_generation_total double precision,
  consumption_today double precision,
  consumption_total double precision,
  purchase_today double precision,
  purchase_total double precision,
  sell_today double precision,
  sell_total double precision,
  battery_charge_today double precision,
  battery_charge_total double precision,
  battery_discharge_today double precision,
  battery_discharge_total double precision,
  primary key (sn_number, timestamp)
);

create table if not exists public."WATTROUTER_INFO" (
  created_at timestamptz not null default now(),
  sn_number text not null,
  "powerPercentage" double precision,
  "relay2On" boolean,
  "relay3On" boolean,
  "gridFetch" boolean,
  primary key (created_at, sn_number)
);</code></pre>
            </article>

            <article class="gs-copy-card">
                <header>
                    <h3>@T("4. Vlož prvý testovací systém", "4. Insert the first test system")</h3>
                    <span class="gs-chip">sn_number</span>
                </header>
                <p>@T("Sériové číslo musí byť rovnaké v tabuľke SYSTEM, vo firmware a v dátových tabuľkách. Bez toho aplikácia nenájde dáta pre konkrétny dashboard.", "The serial number must be the same in the SYSTEM table, firmware, and data tables. Without this the app cannot find data for a concrete dashboard.")</p>
                <pre class="gs-code"><code>insert into public."SYSTEM" (
  sn_number,
  system_name,
  system_address,
  pocet_ssr,
  menic_model,
  instalovany_vykon,
  pv1_instalovany_vykon,
  pv2_instalovany_vykon
) values (
  'YOUR_INVERTER_SN',
  'Demo NestStats system',
  'Demo address',
  2,
  'SOFAR HYD KTL-3PH',
  10.0,
  5.0,
  5.0
) on conflict (sn_number) do nothing;</code></pre>
            </article>

            <article class="gs-copy-card">
                <header>
                    <h3>@T("5. Zapíš Supabase údaje do aplikácie", "5. Write Supabase credentials into the app")</h3>
                    <span class="gs-chip">config</span>
                </header>
                <p>@T("Repozitár je pripravený pre verejný GitHub. appsettings.json aj appsettings.Development.json ostávajú bez tajomstiev. Lokálne použi .NET user-secrets alebo ignorovaný appsettings.Local.json.", "The repository is prepared for public GitHub. appsettings.json and appsettings.Development.json stay secret-free. Locally, use .NET user-secrets or the ignored appsettings.Local.json file.")</p>
                <pre class="gs-code"><code>dotnet user-secrets init
dotnet user-secrets set "Supabase:Url" "https://YOUR_PROJECT.supabase.co"
dotnet user-secrets set "Supabase:AnonKey" "YOUR_SUPABASE_ANON_KEY"</code></pre>
                <p>@T("Alternatíva cez lokálny súbor, ktorý sa neposiela do repozitára:", "Alternative through a local file that is not committed to the repository:")</p>
                <pre class="gs-code"><code>Copy-Item appsettings.Local.example.json appsettings.Local.json</code></pre>
                <pre class="gs-code"><code>{
  "Supabase": {
    "Url": "https://YOUR_PROJECT.supabase.co",
    "AnonKey": "YOUR_SUPABASE_ANON_KEY"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=App_Data/neststats-auth.db"
  }
}</code></pre>
            </article>

            <article class="gs-copy-card">
                <header>
                    <h3>@T("6. Spusť aplikáciu lokálne a over konfiguráciu", "6. Run locally and verify configuration")</h3>
                    <span class="gs-chip">local run</span>
                </header>
                <pre class="gs-code"><code>dotnet run --project NestStats2.csproj</code></pre>
                <ul>

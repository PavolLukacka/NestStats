    .bg-gradient-primary{
        /* summary panel ostáva, ale v light mode decentnejšie */
        background: linear-gradient(135deg, #0d6efd 0%, #3b82f6 100%);
        border-radius: var(--nep-radius);
        box-shadow: 0 10px 24px rgba(13,110,253,.22);
    }

    /* Efficiency table (ponechávame tvoje farby) */
    .efficiency-excellent {
        background: linear-gradient(135deg, #4CAF50, #81C784) !important;
        color: white;
    }
    .efficiency-very-good {
        background: linear-gradient(135deg, #8BC34A, #AED581) !important;
        color: white;
    }
    .efficiency-good {
        background: linear-gradient(135deg, #FFC107, #FFD54F) !important;
        color: #333;
    }
    .efficiency-fair {
        background: linear-gradient(135deg, #FF9800, #FFB74D) !important;
        color: white;
    }
    .efficiency-poor {
        background: linear-gradient(135deg, #F44336, #E57373) !important;
        color: white;
    }
    .efficiency-cell {
        font-weight: 800;
        font-size: 15px;
        box-shadow: 0 2px 10px rgba(0,0,0,.08);
    }

    /* ver pill */
    .ver-pill{
        display:inline-flex;
        align-items:center;
        gap:.35rem;
        padding:.2rem .6rem;
        border-radius:999px;
        font-weight:700;
        font-size:.88rem;
        line-height:1;
        background:#fff;
        border:1px solid var(--nep-border);
        box-shadow: 0 6px 14px rgba(15,23,42,.06);
        vertical-align:middle;
    }
    .ver-pill .dot{
        width:8px;height:8px;border-radius:50%;
        background: #16a34a;
        box-shadow: 0 0 0 3px rgba(22,163,74,.18);
    }
    .ver-date{ font-size:.9rem; color: var(--nep-muted); vertical-align:middle; }

    @@keyframes fadeIn{
        from{ opacity:0; transform: translateY(10px); }
        to{ opacity:1; transform: translateY(0); }
    }

    /* Presentation mode: skryje vstupy a nechá výsledky */
    body.present-mode #calcForm > .card:not(:nth-of-type(3)) { display:none; } /* 3. karta = výsledky */
    body.present-mode #computeBtn,
    body.present-mode #addStringBtn { display:none; }
    body.present-mode #exportPdfBtn { display:inline-flex; }
    body.present-mode #chartTabs { position: sticky; top: 0; background: var(--nep-bg); padding-top: .5rem; z-index: 20; }
    /* =========================
   USPORA – MOBILE FIX PACK
   Paste at the END of your <style>
   ========================= */

    /* 1) General mobile spacing + reduce heavy shadows */
    @@media (max-width: 576px){
    body{ font-size: 15px; }
    .card{ border-radius: 14px; box-shadow: 0 6px 14px rgba(15,23,42,.06); }
    .card-body{ padding: 14px; }
    .card-header{ padding: 12px 14px; }
    h3{ font-size: 1.25rem; line-height: 1.2; }
    h5{ font-size: 1.05rem; }
    .ver-pill{ font-size:.78rem; padding:.18rem .5rem; }
    .ver-date{ display:block; margin-top:.35rem; }
}

    /* 2) Make nav-tabs usable on mobile (horizontal scroll, no wrap) */
    .uspora-tabs{
        display: flex;
        flex-wrap: nowrap !important;
        overflow-x: auto;
        overflow-y: hidden;
        -webkit-overflow-scrolling: touch;
        gap: .25rem;
        padding-bottom: .25rem;
        border-bottom: 1px solid var(--nep-border);
    }
    .uspora-tabs::-webkit-scrollbar{ height: 6px; }
    .uspora-tabs .nav-item{ flex: 0 0 auto; }
    .uspora-tabs .nav-link{
        white-space: nowrap;
        border-radius: 999px;
        border: 1px solid var(--nep-border);
        padding: .5rem .8rem;
        background: #fff;
    }
    .uspora-tabs .nav-link.active{
        border-color: rgba(13,110,253,.35);
        box-shadow: 0 6px 14px rgba(13,110,253,.12);
        border-bottom: 1px solid rgba(13,110,253,.35) !important; /* override your underline style */
    }

    /* 3) Summary panel: better stacking + less “huge” typography on phones */
    @@media (max-width: 576px){
    #summaryPanel{ padding: 14px !important; }
    #summaryPanel .row{ --bs-gutter-x: .75rem; --bs-gutter-y: .75rem; }
    #summaryPanel h3{ font-size: 1.35rem; margin-bottom: .25rem; }
    #summaryPanel h6{ font-size: .9rem; margin-bottom: .25rem; opacity: .95; }
    #summaryPanel .fs-5{ font-size: 1rem !important; }
    #summaryPanel hr{ margin: .75rem 0 !important; }
}

    /* 4) Charts: shorter height on mobile so user doesn't scroll forever */
    @@media (max-width: 576px){
    #monthlyChart, #cumulativeChart, #cashflowChart, #productionChart, #roiChart, #billChart{
        height: 280px !important;
    }
    .tab-pane .card-body{ padding: 12px; }
}

    /* 5) Tables: make them feel less “cramped” */
    @@media (max-width: 576px){
    .table-responsive{ border-radius: 12px; }
    table.table{ font-size: .9rem; }
    #annualTable th, #annualTable td{ padding: .45rem .5rem; }
}

    /* 6) Form controls: better tap targets */
    @@media (max-width: 576px){
    .form-control, .form-select{ min-height: 44px; border-radius: 12px; }
    .btn{ border-radius: 12px; }
    .btn-lg{ padding: 12px 14px; }
    .form-label{ font-weight: 700; font-size: .92rem; }
    .text-muted.small{ font-size: .85rem; }
}

    /* 7) String cards: force 2-column layout on phones WITHOUT touching markup
       (your markup uses col-md-3; on phones it's col-12 -> we override to 50%)
    */
    @@media (max-width: 576px){
    .string-entry .row.g-3 > .col-md-3{
        flex: 0 0 50% !important;
        max-width: 50% !important;
    }
    .string-entry .row.g-3 > .col-md-6{
        flex: 0 0 100% !important;
        max-width: 100% !important;
    }
    .string-entry .card-header{
        position: sticky;
        top: 0;
        z-index: 5;
    }
    .string-entry .remove-btn{
        padding: .35rem .6rem;
    }
    .string-entry small.text-muted{ display:none; } /* hide orientation hint that eats space */
    }

    /* 8) Bill panel presets: wrap nicely */
    @@media (max-width: 576px){
    .preset-cons{ flex: 1 1 auto; }
    .soft-panel .btn-group{ width: 100%; }
    .soft-panel .btn-group .btn{ flex: 1 1 0; }
}

    /* 9) Action buttons: full width + sticky bottom on mobile (works even if you didn't wrap them)
       If you added the wrapper <div class="action-bar">, it becomes sticky.
    */
    @@media (max-width: 576px){
    .action-bar{
        position: sticky;
        bottom: 0;
        z-index: 30;
        background: rgba(246,247,251,.92);
        backdrop-filter: blur(8px);
        padding: .6rem .2rem;
        border-top: 1px solid var(--nep-border);
        margin-top: 12px;
    }
    #computeBtn, #exportPdfBtn{
        width: 100% !important;
    }
    #exportPdfBtn{ margin-left: 0 !important; }
}

    /* 10) Prevent “present-mode” sticky tabs from looking weird on mobile */
    @@media (max-width: 576px){
    body.present-mode #chartTabs{
        padding: .5rem .25rem;
        border-radius: 12px;
    }

        /* Move Export PDF button a bit down (mobile only) */
        @@media (max-width: 576px){
        #exportPdfBtn{
            margin-top: 10px !important;
        }

            
}
}



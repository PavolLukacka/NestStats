        padding: 14px;
        box-shadow: 0 6px 16px rgba(15,23,42,.05);
    }

    .nav-tabs .nav-link{
        border: none;
        color: var(--nep-muted);
        font-weight: 600;
        padding: .65rem .85rem;
    }
    .nav-tabs .nav-link.active{
        color: var(--nep-primary);
        border-bottom: 2px solid var(--nep-primary);
        background: transparent;
    }

    .btn-primary{
        background: var(--nep-primary);
        border: none;
        font-weight: 700;
        padding: 12px 28px;

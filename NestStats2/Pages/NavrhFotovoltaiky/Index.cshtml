                const annualFromMonthly = (Number(String(input.MonthlyBill ?? '0').replace(',', '.')) || 0) * 12;
                const annualBillBase = annualFromAnnual > 0 ? annualFromAnnual : annualFromMonthly;

                const show = annualBillBase > 0;

                // schovaj / ukaz nav položku aj pane
                navItem.classList.toggle('d-none', !show);
                pane.classList.toggle('d-none', !show);

                // ak skrývame a práve je aktívny bill tab → prepni na prvý

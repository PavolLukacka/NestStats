                                borderWidth: 2,
                                tension: 0.35,
                                fill: false
                            },
                            {
                                label: 'S FV (účet/rok)',
                                data: billAfter,
                                borderWidth: 3,
                                tension: 0.35,
                                fill: true
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        interaction: { mode: 'index', intersect: false },
                        plugins: {
                            tooltip: {
                                backgroundColor: 'rgba(0,0,0,0.85)',
                                callbacks: {
                                    label: (ctx) => {
                                        const y = ctx.parsed.y;
                                        if (y == null || !Number.isFinite(y)) return `${ctx.dataset.label}: -`;
                                        return `${ctx.dataset.label}: ${Number(y).toFixed(0)} €`;
                                    }

                                }
                            }
                        },
                        scales: {
                            x: { title: { display: true, text: 'Rok' } },
                            y: { title: { display: true, text: '€ / rok' }, beginAtZero: true }
                        }
                    }
                });
            }

            function ensureBillSeries(data, input) {
                // robustne zober ročný účet aj keď user zadá len mesačný
                const annualFromAnnual = Number(String(input.AnnualBill ?? '0').replace(',', '.')) || 0;
                const annualFromMonthly = (Number(String(input.MonthlyBill ?? '0').replace(',', '.')) || 0) * 12;
                const annualBillBase = annualFromAnnual > 0 ? annualFromAnnual : annualFromMonthly;

                if (!(annualBillBase > 0)) return;
                if (!data?.annualResults?.length) return;

                const energyInfl = (Number(input.EnergyInflationPercent || 0) / 100);
                const generalInfl = (Number(input.GeneralInflationPercent || 0) / 100);

                const sc = clamp(Number(input.SelfConsumptionPercent || 0) / 100, 0, 1);

                // ✅ Fixné poplatky (nastav si podľa reality)
                // napr. 10 €/mes. → 120 €/rok
                const fixedMonthlyFee = 10;
                const fixedAnnualBase = fixedMonthlyFee * 12;

                let cum = 0;

                for (let i = 0; i < data.annualResults.length; i++) {
                    const a = data.annualResults[i];

                    // účet pred FV rastie s infláciou energií
                    const billBefore = annualBillBase * Math.pow(1 + energyInfl, i);

                    // fixné poplatky môžu rásť všeobecnou infláciou (alebo ich nechaj fixné)
                    const fixedAnnual = fixedAnnualBase * Math.pow(1 + generalInfl, i);

                    // potenciál úspory: hodnota vyrobenej energie, ktorú reálne spotrebujem
                    const value = Number(a.valueEuros || 0);
                    const potentialSave = value * sc;

                    // úspora nemôže prekročiť účet "bez FV", ale zároveň nemôže zraziť účet pod fixné poplatky
                    const maxSaveDueToBill = billBefore;                 // nemôžeš ušetriť viac než billBefore
                    const maxSaveDueToFixed = Math.max(0, billBefore - fixedAnnual); // nemôžeš ísť pod fix
                    const maxAllowedSavings = Math.min(maxSaveDueToBill, maxSaveDueToFixed);

                    const savings = Math.max(0, Math.min(potentialSave, maxAllowedSavings));
                    const billAfter = Math.max(fixedAnnual, billBefore - savings);

                    a.billBeforeEuros = billBefore;
                    a.savingsEuros = savings;
                    a.billAfterEuros = billAfter;

                    cum += savings;
                    a.cumulativeSavingsEuros = cum;
                }
}


            

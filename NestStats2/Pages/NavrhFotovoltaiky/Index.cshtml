}



            function createBillChart(data) {
                if (!billCtx) return;

                const years = data.annualResults.map(a => a.year);
                const billBefore = data.annualResults.map(a => (Number.isFinite(a.billBeforeEuros) ? a.billBeforeEuros : null));
                const billAfter  = data.annualResults.map(a => (Number.isFinite(a.billAfterEuros)  ? a.billAfterEuros  : null));


                const hasBill = billBefore.some(v => v != null) && billAfter.some(v => v != null);
                if (!hasBill) return;


                charts.bill = new Chart(billCtx, {
                    type: 'line',
                    data: {
                        labels: years,
                        datasets: [
                            {
                                label: 'Bez FV (účet/rok)',

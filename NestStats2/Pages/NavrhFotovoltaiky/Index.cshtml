                        interaction: {
                            mode: 'index',
                            intersect: false,
                        },
                        plugins: {
                            tooltip: {
                                backgroundColor: 'rgba(0,0,0,0.8)',
                            }
                        },
                        scales: {
                            x: {
                                title: { display: true, text: 'Rok' }
                            },
                            y: {
                                type: 'linear',
                                display: true,
                                position: 'left',
                                title: { display: true, text: 'Výroba (MWh)' },
                                grid: { color: 'rgba(54, 162, 235, 0.2)' }
                            },
                            y1: {
                                type: 'linear',
                                display: true,
                                position: 'right',
                                title: { display: true, text: 'Hodnota (€)' },
                                grid: { drawOnChartArea: false },
                            }
                        }
                    }
                });
            }

            function createCashFlowChart(data, input) {
                // Prepare annual cash flow data
                const cashFlowData = data.annualResults.map((a, i) => {
                    if (i === 0) {
                        return a.valueEuros - input.InitialInvestment;
                    }
                    return a.valueEuros;
                });

                // Create the chart with only yearly cash flow
                charts.cashflow = new Chart(cashflowCtx, {
                    type: 'bar',
                    data: {
                        labels: data.annualResults.map(a => a.year),
                        datasets: [{
                            label: 'Ročný príjem (€)',
                            data: cashFlowData,
                            backgroundColor: cashFlowData.map(cf =>
                                cf >= 0 ? 'rgba(40, 167, 69, 0.8)' : 'rgba(220, 53, 69, 0.8)'
                            ),
                            borderColor: cashFlowData.map(cf =>
                                cf >= 0 ? 'rgba(40, 167, 69, 1)' : 'rgba(220, 53, 69, 1)'
                            ),
                            borderWidth: 1,
                            yAxisID: 'y'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        interaction: {
                            mode: 'index',
                            intersect: false,
                        },
                        plugins: {
                            tooltip: {
                                backgroundColor: 'rgba(0,0,0,0.8)',
                                callbacks: {
                                    label: function (context) {
                                        return `Ročný príjem: ${context.parsed.y.toFixed(0)} €`;
                                    }
                                }
                            }
                        },
                        scales: {
                            x: {
                                title: { display: true, text: 'Rok' }
                            },
                            y: {
                                type: 'linear',
                                display: true,
                                position: 'left',
                                title: { display: true, text: 'Ročný príjem (€)' }
                            }
                        }
                    }
                });
            }


            function createProductionChart(data) {
                const firstYearProduction = data.annualResults[0].productionKwh;
                const degradationPercent = parseFloat(document.getElementById('degradation').value);

                charts.production = new Chart(productionCtx, {
                    type: 'line',
                    data: {
                        labels: data.annualResults.map(a => a.year),
                        datasets: [{
                            label: 'Skutočná výroba (kWh)',
                            data: data.annualResults.map(a => a.productionKwh),
                            borderColor: 'rgba(75, 192, 192, 1)',
                            backgroundColor: 'rgba(75, 192, 192, 0.1)',
                            fill: true,
                            tension: 0.4,
                            borderWidth: 2
                        }, {
                            label: 'Bez degradácie (kWh)',
                            data: data.annualResults.map(() => firstYearProduction),
                            borderColor: 'rgba(201, 203, 207, 1)',
                            backgroundColor: 'rgba(201, 203, 207, 0.1)',
                            borderDash: [5, 5],
                            fill: false,
                            tension: 0.4,
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            tooltip: {
                                backgroundColor: 'rgba(0,0,0,0.8)',
                                callbacks: {
                                    afterLabel: function(context) {
                                        if (context.datasetIndex === 0) {
                                            const year = context.dataIndex;
                                            const degradation = (year * degradationPercent).toFixed(1);
                                            return `Degradácia: ${degradation}%`;
                                        }
                                        return '';
                                    }
                                }
                            }
                        },
                        scales: {
                            x: {
                                title: { display: true, text: 'Rok' }
                            },
                            y: {
                                title: { display: true, text: 'Výroba (kWh)' }
                            }
                        }
                    }
                });
            }

            function createROIChart(data, input) {
                const roiData = data.annualResults.map((a, i) => {
                    if (i === 0) return 0;
                    return ((a.cumulativeValueEuros - input.InitialInvestment) / input.InitialInvestment * 100);
                });

                charts.roi = new Chart(roiCtx, {
                    type: 'line',
                    data: {
                        labels: data.annualResults.map(a => a.year),
                        datasets: [{
                            label: 'Návratnosť (%)',
                            data: roiData,
                            borderColor: 'rgba(255, 99, 132, 1)',
                            backgroundColor: 'rgba(255, 99, 132, 0.1)',
                            fill: true,
                            tension: 0.4,
                            borderWidth: 3
                        }, {
                            label: 'bod zvratu (0%)',
                            data: data.annualResults.map(() => 0),
                            borderColor: 'rgba(0, 0, 0, 0.5)',
                            borderDash: [10, 5],
                            fill: false,
                            pointRadius: 0,
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            tooltip: {
                                backgroundColor: 'rgba(0,0,0,0.8)',
                                filter: function(tooltipItem) {
                                    return tooltipItem.datasetIndex === 0;
                                },
                                callbacks: {
                                    label: function(context) {
                                        return `ROI: ${context.parsed.y.toFixed(1)}%`;
                                    }
                                }
                            }
                        },
                        scales: {
                            x: {
                                title: { display: true, text: 'Rok' }
                            },
                            y: {
                                title: { display: true, text: 'Návratnosť (%)' }
                            }
                        }
                    }
                });
            }

            function updateTable(data, input) {
                tableBody.innerHTML = '';
                data.annualResults.forEach((a, i) => {
                    const cashFlow = i === 0 ? a.valueEuros - input.InitialInvestment : a.valueEuros;
                    const roi = i === 0 ? 0 : ((a.cumulativeValueEuros - input.InitialInvestment) / input.InitialInvestment * 100);
                    const roiClass = roi >= 0 ? 'text-success' : 'text-danger';
                    const cashFlowClass = cashFlow >= 0 ? 'text-success' : 'text-danger';

                    const row = `<tr>
                            <td><strong>${a.year}</strong></td>
                            <td>${a.productionKwh.toFixed(0)}</td>
                            <td>${a.cumulativeProductionKwh.toFixed(0)}</td>
                            <td>${a.pricePerKwh.toFixed(3)}</td>
                            <td>${a.valueEuros.toFixed(2)}</td>
                            <td>${a.cumulativeValueEuros.toFixed(2)}</td>
                            <td class="${cashFlowClass}">${cashFlow.toFixed(2)}</td>
                            <td class="${roiClass}">${roi.toFixed(1)}%</td>
                        </tr>`;
                    tableBody.insertAdjacentHTML('beforeend', row);
                });
            }
        })();
    </script>

    <style>
    :root{

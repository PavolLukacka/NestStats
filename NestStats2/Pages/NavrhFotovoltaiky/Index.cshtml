@page "/navrh-fotovoltaiky"
@model NestStats2.Pages.NavrhFotovoltaiky.IndexModel
@{
    ViewData["Title"] = "Kalkulačka úspory - Fotovoltika";
}

@section Head {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
}
<div class="alert alert-info mx-auto mt-3 mb-0" style="max-width: 1120px;">
    Tento nástroj je zatiaľ dostupný iba v slovenčine.
</div>
<h3 class="text-center mb-4" style="padding-top: 2rem;">
        Kalkulačka úspory - Fotovoltika
        <span class="ver-pill ms-2" title="Aktualizované: 4. . 2025">
            <span class="dot"></span> Release_v1.4
        </span>
        <small class="ver-date ms-2">
            <i class="bi bi-clock-history"></i> 20.&nbsp;1.&nbsp;2026
        </small>
    </h3>
<form id="calcForm" method="post">
    @Html.AntiForgeryToken()

    <!-- Modul 1: Vstupné parametre -->
    <div class="card mb-4">
        <div class="card-header highlight">1. Vstupné parametre</div>
        <div class="card-body">

            <h5>1.1 Konfigurácia FV polí</h5>
            <div id="stringsContainer"></div>
            <button type="button" id="addStringBtn"
                    class="btn btn-sm btn-secondary mb-3">
                Pridať string
            </button>

            <h5>1.2 Ekonomické parametre</h5>
            <div class="row g-3">
                <!--  … tu nechávame pôvodné inputy – JS ich prepíše z prefill … -->
                <input type="hidden" id="degradation" name="DegradationPercent" value="0.4" />
                <input type="hidden" id="systemLosses" name="SystemLossesPercent" value="14" />
                <input type="hidden" id="inverterEfficiency" name="InverterEfficiencyPercent" value="98" />
                <div class="col-md-4">
                    <label for="pricePerson" class="form-label">Cena el. Fyzickej osoby (€/kWh)</label>
                    <input type="number" step="0.01" min="0"
                           id="pricePerson" class="form-control editable-input" value="0.18" />
                </div>
                <div class="col-md-4">
                    <label for="priceCorp" class="form-label">Cena el. Právnickej osoby (€/kWh)</label>
                    <input type="number" step="0.01" min="0"
                           id="priceCorp" class="form-control editable-input" value="0.25" />
                </div>
                <div class="col-md-4">
                    <label for="energyInflation" class="form-label">Inflácia cien el. (%)</label>
                    <input type="number" step="0.1" min="0" max="10"
                           id="energyInflation" class="form-control editable-input" value="3" />
                </div>
                <div class="col-md-4">
                    <label for="generalInflation" class="form-label">Všeobecná inflácia (%)</label>
                    <input type="number" step="0.1" min="0" max="10"
                           id="generalInflation" class="form-control editable-input" value="2" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Prefill.CustomerType" class="form-label">Typ zákazníka</label>
                    <select asp-for="Prefill.CustomerType"
                            id="customerType"
                            class="form-control">
                        <option value="person">Fyzická osoba</option>
                        <option value="corp">Právnická osoba</option>
                    </select>
                    <span asp-validation-for="Prefill.CustomerType" class="text-danger"></span>
                </div>

            </div>
            
            <!-- 1.2.1 Účet za elektrinu (nové) -->
<div class="col-12">
    <div class="soft-panel mt-2">
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
            <div>
                <div class="fw-semibold">Účet za elektrinu</div>
                <div class="text-muted small">
                    Zadaj koľko klient platí dnes. Kalkulačka prepočíta náklady bez FV vs. s FV v čase.
                </div>
            </div>

            <div class="btn-group btn-group-sm" role="group" aria-label="bill mode">
                <input type="radio" class="btn-check" name="billMode" id="billModeMonthly" autocomplete="off" checked>
                <label class="btn btn-outline-primary" for="billModeMonthly">
                    <i class="bi bi-calendar-month me-1"></i> Mesačne
                </label>

                <input type="radio" class="btn-check" name="billMode" id="billModeAnnual" autocomplete="off">
                <label class="btn btn-outline-primary" for="billModeAnnual">
                    <i class="bi bi-calendar2-week me-1"></i> Ročne
                </label>
            </div>
        </div>

        <div class="row g-3 mt-1">
            <div class="col-md-4">
                <label class="form-label">Mesačná platba (€ / mesiac)</label>
                <input type="number" step="1" min="0" id="monthlyBill" class="form-control editable-input" value="0" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Ročná platba (€ / rok)</label>
                <input type="number" step="1" min="0" id="annualBill" class="form-control editable-input" value="0" />
            </div>

            <div class="col-md-4">
                <label class="form-label">
                    Vlastná spotreba FV (%)
                    <span class="text-muted small" title="Koľko vyrobenej energie reálne zníži účet (zvyšok ide do prebytkov).">
                        <i class="bi bi-info-circle"></i>
                    </span>
                </label>

                <input type="range" class="form-range" id="selfConsumption" min="0" max="100" step="1" value="100" />
                <div class="d-flex justify-content-between small text-muted">
                    <span>0%</span>
                    <span class="fw-semibold text-dark"><span id="selfConsumptionLbl">100</span>%</span>
                    <span>100%</span>
                </div>

                <div class="d-flex flex-wrap gap-2 mt-2">
                    <button type="button" class="btn btn-light btn-sm preset-cons" data-val="55">Bez batérie ~55%</button>
                    <button type="button" class="btn btn-light btn-sm preset-cons" data-val="80">S batériou ~80%</button>
                    <button type="button" class="btn btn-light btn-sm preset-cons" data-val="100">Ideál ~100%</button>
                </div>
            </div>
        </div>

        <div class="small text-muted mt-2">
            Pozn.: Ak platbu nezadáš, kalkulačka stále všetko prepočíta, nezobrazí sa len časť - účet za elektrinu
        </div>
    </div>
</div>


            <h5 class="mt-3">1.3 Investičné vstupy</h5>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Amount" class="form-label">
                        Počiatočná investícia s DPH (€)
                    </label>
                    <input asp-for="Amount"
                           step="0.1" min="0"
                           asp-format="{0:0.00}"
                           id="initialInvestment"
                           class="form-control editable-input" />
                    <span asp-validation-for="Amount" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label for="lifetime" class="form-label">Doba životnosti (roky) FV panelov</label>
                    <input type="number" min="1" max="50"
                           id="lifetime" class="form-control editable-input" value="30" />
                </div>
            </div>

        </div>
    </div>

    <!-- Modul 2: Tabuľka orientácie vs účinnosť -->

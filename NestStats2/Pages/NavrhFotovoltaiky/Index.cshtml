                                <th>15°<br><small>(mierne)</small></th>
                                <th>30°<br><small>(optimálne)</small></th>
                                <th>45°<br><small>(strmé)</small></th>
                                <th>60°<br><small>(veľmi strmé)</small></th>
                                <th>90°<br><small>(vertikálne)</small></th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><strong>🌅 Východ (90°)</strong></td>
                                <td class="efficiency-cell efficiency-good">0.87</td>
                                <td class="efficiency-cell efficiency-very-good">0.91</td>
                                <td class="efficiency-cell efficiency-very-good">0.93</td>
                                <td class="efficiency-cell efficiency-very-good">0.91</td>
                                <td class="efficiency-cell efficiency-fair">0.85</td>
                                <td class="efficiency-cell efficiency-poor">0.67</td>
                            </tr>
                            <tr>
                                <td><strong>🌄 Juhovýchod (135°)</strong></td>
                                <td class="efficiency-cell efficiency-good">0.87</td>
                                <td class="efficiency-cell efficiency-very-good">0.93</td>
                                <td class="efficiency-cell efficiency-very-good">0.97</td>
                                <td class="efficiency-cell efficiency-excellent">0.98</td>
                                <td class="efficiency-cell efficiency-very-good">0.94</td>
                                <td class="efficiency-cell efficiency-fair">0.77</td>
                            </tr>
                            <tr>
                                <td><strong>☀️ Juh (180°) - IDEÁL</strong></td>
                                <td class="efficiency-cell efficiency-good">0.87</td>
                                <td class="efficiency-cell efficiency-very-good">0.94</td>
                                <td class="efficiency-cell efficiency-excellent">1.00</td>
                                <td class="efficiency-cell efficiency-excellent">1.00</td>
                                <td class="efficiency-cell efficiency-excellent">0.99</td>
                                <td class="efficiency-cell efficiency-fair">0.82</td>
                            </tr>
                            <tr>
                                <td><strong>🌇 Juhozápad (225°)</strong></td>
                                <td class="efficiency-cell efficiency-good">0.87</td>
                                <td class="efficiency-cell efficiency-very-good">0.93</td>
                                <td class="efficiency-cell efficiency-very-good">0.97</td>
                                <td class="efficiency-cell efficiency-excellent">0.98</td>
                                <td class="efficiency-cell efficiency-very-good">0.94</td>
                                <td class="efficiency-cell efficiency-fair">0.77</td>
                            </tr>
                            <tr>
                                <td><strong>🌆 Západ (270°)</strong></td>
                                <td class="efficiency-cell efficiency-good">0.87</td>
                                <td class="efficiency-cell efficiency-very-good">0.91</td>
                                <td class="efficiency-cell efficiency-very-good">0.93</td>
                                <td class="efficiency-cell efficiency-very-good">0.91</td>
                                <td class="efficiency-cell efficiency-fair">0.85</td>
                                <td class="efficiency-cell efficiency-poor">0.67</td>
                            </tr>
                        </tbody>
                    </table>
            </div>
            <small class="text-muted">Hodnoty reprezentujú koeficient účinnosti relatívne k optimálnej orientácii (juh, 30°)</small>
        </div>
    </div>

    <!-- Modul 3: Výsledky a vizualizácie -->
    <div class="card mb-4">
        <div class="card-header highlight">3. Výsledky a vizualizácie</div>
        <div class="card-body">
            <!-- Enhanced Summary Panel -->
            <div id="summaryPanel" class="computed-field p-4 mb-4 bg-gradient-primary text-white rounded shadow-lg"></div>

            <!-- Chart Navigation Tabs -->
            <ul class="nav nav-tabs mb-3" id="chartTabs" style="display: none;">
                <li class="nav-item">
                    <a class="nav-link active" data-bs-toggle="tab" href="#monthlyTab">Mesačná výroba</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#cumulativeTab">Súhrnné hodnoty</a>
                </li>
                <li class="nav-item" id="billTabNavItem">
                    <a class="nav-link" data-bs-toggle="tab" href="#billTab">Účet za elektrinu</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#cashflowTab">Finančná analýza</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#productionTab">Ročná výroba vs degradácia</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#roiTab">Analýza návratnosti</a>
                </li>
                
            </ul>

            <!-- Chart Content -->
            <div class="tab-content" id="chartContent" style="display: none;">
                <div class="tab-pane fade show active" id="monthlyTab">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Mesačná výroba elektriny</h5>
                        </div>
                        <div class="card-body">
                            <canvas id="monthlyChart" style="height: 400px;"></canvas>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="cumulativeTab">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Súhrnné údaje - výroba a hodnota vyrobenej energie </h5>
                        </div>
                        <div class="card-body">
                            <canvas id="cumulativeChart" style="height: 400px;"></canvas>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="cashflowTab">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Finančná analýza</h5>
                        </div>
                        <div class="card-body">
                            <canvas id="cashflowChart" style="height: 400px;"></canvas>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="productionTab">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Ročná výroba vs degradácia</h5>
                        </div>
                        <div class="card-body">
                            <canvas id="productionChart" style="height: 400px;"></canvas>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="roiTab">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Návratnosť investície</h5>
                        </div>
                        <div class="card-body">
                            <canvas id="roiChart" style="height: 400px;"></canvas>
                        </div>
                    </div>
                </div>
                <div class="tab-pane fade" id="billTab">
                    <div class="row g-3">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-header d-flex align-items-center justify-content-between">
                                    <h5 class="mb-0">Ročný účet: bez FV vs. s FV</h5>

                                    <!-- voliteľné: mini badge, aby bolo jasné, že tam sú fixné poplatky -->
                                    <span class="badge bg-light text-dark border" title="Účet po FV má minimálnu hodnotu kvôli fixným poplatkom (distribúcia a pod.).">
                                        <i class="bi bi-info-circle me-1"></i> Účet po FV má minimálnu hodnotu kvôli fixným poplatkom.
                                    </span>
                                </div>
                                <div class="card-body">
                                    <canvas id="billChart" style="height: 420px;"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Enhanced Annual Table -->
            <div class="mt-4" id="tableSection" style="display: none;">
                <h5>Detailná ročná tabuľka</h5>
                <div class="table-responsive">
                    <table class="table table-sm table-striped table-hover" id="annualTable">
                        <thead class="table-dark">
                        <tr>
                            <th>Rok</th>
                            <th>Výroba (kWh)</th>
                            <th>Celková výroba (kWh)</th>
                            <th>Cena (€/kWh)</th>
                            <th>Hodnota (€)</th>
                            <th>Celková hodnota (€)</th>
                            <th>Finančná analýza (€)</th>
                            <th>Návratnosť (%)</th>
                        </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
            
            <!-- Nová sekcia pre súhrnnú tabuľku 1/10/20/30 rokov -->
            <div id="energySummarySection" class="card mt-4">
                <div class="card-header highlight">
                    <h5 class="mb-0">Výroba energie a hodnota</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered" id="summaryTable">
                            <thead>
                            <tr>
                                <th>Popis</th>
                                <th>Výroba energie (kWh)</th>
                                <th>Hodnota vyrobenej energie (€)</th>
                            </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="mb-3">
        <label class="form-label">Meno klienta pre PDF (nepovinné)</label>
        <input id="clientNameInp"
               class="form-control"
               placeholder="napr. Ing. Ján Novák"
               value="@ViewData["ClientName"]" />
    </div>

    <button type="button" id="computeBtn" class="btn btn-primary btn-lg">
        <i class="fas fa-calculator me-2"></i>Počítať úsporu
    </button>

    <button type="button" id="exportPdfBtn" class="btn btn-outline-secondary btn-lg ms-2">
        <i class="fas fa-file-pdf me-2"></i>Exportovať report (PDF)
    </button>

</form>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/js/all.min.js"></script>
    <script>
        const prefillData = @Html.Raw(Json.Serialize(Model.Prefill));
        (function () {
            const form = document.getElementById('calcForm');
            const token = () => document.querySelector('input[name="__RequestVerificationToken"]').value;
            const addStringBtn = document.getElementById('addStringBtn');
            const stringsContainer = document.getElementById('stringsContainer');
            const computeBtn = document.getElementById('computeBtn');
            const exportPdfBtn = document.getElementById('exportPdfBtn');
            const summaryPanel = document.getElementById('summaryPanel');
            const tableBody = document.querySelector('#annualTable tbody');
            
            // Chart contexts
            const billCtx = document.getElementById('billChart');

            const monthlyBillInp = document.getElementById('monthlyBill');
            const annualBillInp = document.getElementById('annualBill');
            const billModeMonthly = document.getElementById('billModeMonthly');
            const billModeAnnual = document.getElementById('billModeAnnual');
            const selfConsumptionInp = document.getElementById('selfConsumption');
            const selfConsumptionLbl = document.getElementById('selfConsumptionLbl');
            const presentBtn = document.getElementById('presentBtn');

            const monthlyCtx = document.getElementById('monthlyChart');
            const cumulativeCtx = document.getElementById('cumulativeChart');
            const cashflowCtx = document.getElementById('cashflowChart');
            const productionCtx = document.getElementById('productionChart');
            const roiCtx = document.getElementById('roiChart');
            
            let charts = {};
            let stringCount = 0;

            function clamp(n, min, max) { return Math.max(min, Math.min(max, n)); }

            function getBillMode() {
                return billModeAnnual?.checked ? 'annual' : 'monthly';
            }

            let billSyncLock = false;

            function getBillMode() {
                return billModeAnnual?.checked ? 'annual' : 'monthly';
            }

            function applyBillModeUI() {
                const mode = getBillMode();
                if (mode === 'monthly') {
                    monthlyBillInp.disabled = false;
                    annualBillInp.disabled = true;
                } else {
                    monthlyBillInp.disabled = true;
                    annualBillInp.disabled = false;
                }
}

            function syncBillFrom(source) {
                if (billSyncLock) return;
                billSyncLock = true;

                const monthly = parseFloat(monthlyBillInp.value) || 0;
                const annual  = parseFloat(annualBillInp.value) || 0;

                if (source === 'monthly') {
                    const newAnnual = monthly * 12;
                    annualBillInp.value = (newAnnual > 0 ? newAnnual : 0).toFixed(2);
                } else if (source === 'annual') {
                    const newMonthly = annual / 12;
                    monthlyBillInp.value = (newMonthly > 0 ? newMonthly : 0).toFixed(2);
                } else {
                    // fallback: sync z toho, čo je práve aktívne
                    if (getBillMode() === 'monthly') syncBillFrom('monthly');
                    else syncBillFrom('annual');
                    billSyncLock = false;
                    return;
                }

                billSyncLock = false;
            }

            function syncAndPersist(source) {
                applyBillModeUI();
                syncBillFrom(source);
                persistBillInputs();
            }

// MODE CHANGE → len prepne disabled + znovu zosúladí hodnoty
            billModeMonthly?.addEventListener('change', () => syncAndPersist('monthly'));
            billModeAnnual?.addEventListener('change', () => syncAndPersist('annual'));

// INPUT → okamžite prepočíta druhé pole (bez prepínania)
            monthlyBillInp?.addEventListener('input', () => syncAndPersist('monthly'));
            annualBillInp?.addEventListener('input', () => syncAndPersist('annual'));

// pri selfConsumption stačí ako máš
            selfConsumptionInp?.addEventListener('input', () => {
                selfConsumptionLbl.textContent = String(parseInt(selfConsumptionInp.value || '0', 10));
                persistBillInputs();
            });


            function persistBillInputs() {
                try {
                    localStorage.setItem('uspora_bill_mode', getBillMode());
                    localStorage.setItem('uspora_monthly_bill', String(parseFloat(monthlyBillInp.value) || 0));
                    localStorage.setItem('uspora_annual_bill', String(parseFloat(annualBillInp.value) || 0));
                    localStorage.setItem('uspora_self_consumption', String(parseFloat(selfConsumptionInp.value) || 0));
                } catch {}
}

            function loadBillInputs() {
                try {
                    const mode = localStorage.getItem('uspora_bill_mode');
                    if (mode === 'annual') billModeAnnual.checked = true;
                    else billModeMonthly.checked = true;

                    const mb = localStorage.getItem('uspora_monthly_bill');
                    const ab = localStorage.getItem('uspora_annual_bill');
                    const sc = localStorage.getItem('uspora_self_consumption');

                    if (mb != null) monthlyBillInp.value = mb;
                    if (ab != null) annualBillInp.value = ab;
                    if (sc != null) selfConsumptionInp.value = sc;

                    selfConsumptionLbl.textContent = String(parseInt(selfConsumptionInp.value || '0', 10));
                } catch {}
}

            document.querySelectorAll('.preset-cons').forEach(btn => {
                btn.addEventListener('click', () => {
                    const v = clamp(parseInt(btn.dataset.val || '0', 10), 0, 100);
                    selfConsumptionInp.value = String(v);
                    selfConsumptionLbl.textContent = String(v);
                    persistBillInputs();
                });
            });

            presentBtn?.addEventListener('click', () => {
                document.body.classList.toggle('present-mode');
                try { localStorage.setItem('uspora_present_mode', document.body.classList.contains('present-mode') ? '1' : '0'); } catch {}
});

            (function initPresentationMode() {
                try {
                    if (localStorage.getItem('uspora_present_mode') === '1') document.body.classList.add('present-mode');
                } catch {}
})();


            exportPdfBtn.addEventListener('click', async () => {
            exportPdfBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Generujem PDF...';
            exportPdfBtn.disabled = true;

            const customerType = document.getElementById('customerType').value;
            const input = {
                ClientName: (document.getElementById('clientNameInp')?.value || '').trim(),
                Strings: [],
                DegradationPercent: parseFloat(document.getElementById('degradation').value),
                SystemLossesPercent: parseFloat(document.getElementById('systemLosses').value),
                InverterEfficiencyPercent: parseFloat(document.getElementById('inverterEfficiency').value),
                PricePerson: parseFloat(document.getElementById('pricePerson').value),
                PriceCorp: parseFloat(document.getElementById('priceCorp').value),
                CustomerType: customerType,
                EnergyInflationPercent: parseFloat(document.getElementById('energyInflation').value),
                GeneralInflationPercent: parseFloat(document.getElementById('generalInflation').value),
                InitialInvestment: parseFloat(document.getElementById('initialInvestment').value),

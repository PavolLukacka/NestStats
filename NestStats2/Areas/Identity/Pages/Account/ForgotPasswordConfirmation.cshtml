@page
@model NestStats2.Areas.Identity.Pages.Account.ForgotPasswordConfirmationModel
@{
    Layout = "/Areas/Identity/Pages/_AuthLayout.cshtml";
    string T(string sk, string en) => Lang.Pick(ViewContext.HttpContext, sk, en);
    ViewData["Title"] = T("Email odoslaný", "Email sent");
}

<section class="auth-shell auth-shell--login">
    <div class="auth-card auth-card--form">
        <a class="auth-brand" asp-page="/Index">
            <span class="auth-brand__eyebrow">@T("Open-source platforma pre fotovoltiku", "Open-source platform for photovoltaics")</span>
            <strong>NestStats</strong>
        </a>

        <div class="auth-copy">
            <span class="section-eyebrow">@T("Skontroluj schránku", "Check your inbox")</span>
            <h1>@T("Ak účet existuje, poslali sme odkaz", "If the account exists, we sent a link")</h1>
            <p>@T("Otvor e-mail a pokračuj cez odkaz na reset hesla. Ak nič neprišlo, skontroluj spam alebo skús formulár znova.", "Open the email and continue through the password reset link. If nothing arrived, check spam or try again.")</p>
        </div>

        @if (Model.ShowLocalResetLink && !string.IsNullOrWhiteSpace(Model.LocalResetLink))
        {
            <div class="field" style="margin-top:20px">
                <label>@T("Lokálny development reset link", "Local development reset link")</label>
                <div class="validation-summary" style="display:block">
                    <p style="margin:0 0 10px">@T("SMTP nie je nastavené, preto aplikácia zobrazí reset link priamo tu, aby flow fungoval aj lokálne.", "SMTP is not configured, so the app shows the reset link here to keep the flow working locally.")</p>
                    <a href="@Model.LocalResetLink" style="word-break:break-all">@Model.LocalResetLink</a>
                </div>
            </div>
        }

        <div class="auth-footer">
            <span>@T("Späť na prihlásenie", "Back to sign in")</span>
            <a asp-page="./Login">@T("Prihlásiť sa", "Sign in")</a>
        </div>
    </div>

    <div class="auth-card auth-card--visual">
        <partial name="~/Areas/Identity/Pages/Shared/_AuthEnergyScene.cshtml" />
    </div>
</section>

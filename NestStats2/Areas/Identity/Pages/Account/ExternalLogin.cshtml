@page
@model NestStats2.Areas.Identity.Pages.Account.ExternalLoginModel
@{
    Layout = "/Areas/Identity/Pages/_AuthLayout.cshtml";
    string T(string sk, string en) => Lang.Pick(ViewContext.HttpContext, sk, en);
    ViewData["Title"] = T("Externé prihlásenie", "External sign-in");
}

<section class="auth-shell">
    <div class="auth-card auth-card--form">
        <a class="auth-brand" asp-page="/Index">
            <span class="auth-brand__eyebrow">@T("Open-source platforma pre fotovoltiku", "Open-source platform for photovoltaics")</span>
            <strong>NestStats</strong>
        </a>

        <div class="auth-copy">
            <span class="section-eyebrow">@Model.ProviderDisplayName</span>
            <h1>@T("Potvrď svoju adresu", "Confirm your email")</h1>
            <p>@T("Tvoj účet ešte neexistuje. Zadaj email, ktorý chceš priradiť k tomuto prihláseniu.", "Your account doesn't exist yet. Enter the email you'd like to associate with this login.")</p>
        </div>

        <form id="confirmation-form" method="post" asp-page-handler="Confirmation"
              asp-route-returnUrl="@Model.ReturnUrl" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="field">
                <label asp-for="Input.Email">@T("Email", "Email")</label>
                <input asp-for="Input.Email" autocomplete="email" placeholder="meno@firma.sk" />
                <span asp-validation-for="Input.Email" class="field-validation-error"></span>
            </div>

            <button type="submit" class="button button--primary auth-submit">
                @T("Vytvoriť účet", "Create account")
            </button>
        </form>

        <div class="auth-footer">
            <span>@T("Máš už účet?", "Already have an account?")</span>
            <a asp-page="./Login">@T("Prihlásiť sa", "Sign in")</a>
        </div>
    </div>

    <div class="auth-card auth-card--visual">
        <partial name="~/Areas/Identity/Pages/Shared/_AuthEnergyScene.cshtml" />
    </div>
</section>

@section Scripts {
    <partial name="/Pages/Shared/_ValidationScriptsPartial.cshtml" />
}

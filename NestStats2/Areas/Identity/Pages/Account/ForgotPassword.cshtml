@page
@model NestStats2.Areas.Identity.Pages.Account.ForgotPasswordModel
@{
    Layout = "/Areas/Identity/Pages/_AuthLayout.cshtml";
    string T(string sk, string en) => Lang.Pick(ViewContext.HttpContext, sk, en);
    ViewData["Title"] = T("Obnovenie hesla", "Forgot password");
}

<section class="auth-shell auth-shell--login">
    <div class="auth-card auth-card--form">
        <a class="auth-brand" asp-page="/Index">
            <span class="auth-brand__eyebrow">@T("Open-source platforma pre fotovoltiku", "Open-source platform for photovoltaics")</span>
            <strong>NestStats</strong>
        </a>

        <div class="auth-copy">
            <span class="section-eyebrow">@T("Obnova prístupu", "Access recovery")</span>
            <h1>@T("Zabudnuté heslo", "Forgot your password?")</h1>
            <p>@T("Zadaj e-mail účtu a pošleme ti odkaz na nastavenie nového hesla.", "Enter your account email and we will send a link to set a new password.")</p>
        </div>

        <form method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
            <div class="field">
                <label asp-for="Input.Email">@T("Email", "Email")</label>
                <input asp-for="Input.Email" autocomplete="email" placeholder="name@example.com" />
                <span asp-validation-for="Input.Email" class="field-validation-error"></span>
            </div>
            <button type="submit" class="button button--primary auth-submit">@T("Poslať odkaz na reset", "Send reset link")</button>
        </form>

        <div class="auth-footer">
            <span>@T("Späť na prihlásenie", "Back to sign in")</span>
            <a asp-page="./Login">@T("Prihlásiť sa", "Sign in")</a>
        </div>
    </div>

    <div class="auth-card auth-card--visual">
        <partial name="~/Areas/Identity/Pages/Shared/_AuthEnergyScene.cshtml" />
    </div>
</section>

@section Scripts {
    <partial name="/Pages/Shared/_ValidationScriptsPartial.cshtml" />
}

@page
@model NestStats2.Areas.Identity.Pages.Account.RegisterModel
@{
    Layout = "/Areas/Identity/Pages/_AuthLayout.cshtml";
    string T(string sk, string en) => Lang.Pick(ViewContext.HttpContext, sk, en);
    ViewData["Title"] = T("Registrácia", "Register");
}

<section class="auth-shell auth-shell--login auth-shell--register">
    <a class="auth-side-bubble auth-side-bubble--primary auth-side-bubble--right" asp-page="/SpoznajNas" aria-label="@T("Zisti viac o platforme NestStats", "Learn more about the NestStats platform")">
        <span class="auth-side-bubble__eyebrow">@T("Spoznaj nás", "Find more here")</span>
        <strong>@T("Viac o platforme", "Explore the platform")</strong>
        <span class="auth-side-bubble__text">@T("Monitoring, riadenie a ekonomika v jednom priestore.", "Monitoring, control, and economics in one place.")</span>
        <span class="auth-side-bubble__cta">@T("Otvoriť prehľad", "Open overview")</span>
    </a>

    <a class="auth-side-bubble auth-side-bubble--github auth-side-bubble--right" href="https://github.com/PavolLukacka/NestStats" target="_blank" rel="noopener noreferrer" aria-label="@T("Spoznaj tím a sleduj náš open-source proces", "Meet the dev team and follow our open-source process")">
        <span class="auth-side-bubble__eyebrow">@T("Meet the dev team", "Meet the dev team")</span>
        <strong>@T("Sleduj náš proces", "Follow our process")</strong>
        <span class="auth-side-bubble__text">@T("Open-source vývoj, roadmapa a workflow tímu na GitHube.", "Open-source development, roadmap, and team workflow on GitHub.")</span>
        <span class="auth-side-bubble__cta auth-side-bubble__cta--logo">
            <img src="~/github_logo.png" alt="" asp-append-version="true" />
            <span>@T("GitHub prehľad", "GitHub overview")</span>
        </span>
    </a>

    <a class="auth-side-bubble auth-side-bubble--right auth-side-bubble--support" href="https://patreon.com/Lukacka_Pavol?utm_medium=unknown&utm_source=join_link&utm_campaign=creatorshare_creator&utm_content=copyLink" target="_blank" rel="noopener noreferrer" aria-label="@T("Podpor projekt", "Support the project")">
        <span class="auth-side-bubble__eyebrow">@T("Páči sa ti to?", "Like what you see?")</span>
        <strong>@T("Podpor nás na Patreon", "Support us on Patreon")</strong>
        <span class="auth-side-bubble__text">@T("Pomôž nám financovať ďalší vývoj a nové funkcie.", "Help fund future development and new features.")</span>
        <span class="auth-side-bubble__cta auth-side-bubble__cta--logo">
            <img src="~/Patreon_logo.png" alt="" asp-append-version="true" />
            <span>@T("Podporiť projekt", "Support the project")</span>
        </span>
    </a>

    <a class="auth-side-bubble auth-side-bubble--right auth-side-bubble--contact" asp-page="/SpoznajNas" asp-fragment="kontakt" aria-label="@T("Máš otázky či návrhy? Napíš nám.", "Have questions or ideas? Write to us.")">
        <span class="auth-side-bubble__eyebrow">@T("Otázky či návrhy?", "Questions or ideas?")</span>
        <strong>@T("Napíš nám", "Write to us")</strong>
        <span class="auth-side-bubble__text">@T("Radi si pozrieme feedback, návrhy aj konkrétne use-cases z praxe.", "We are happy to hear feedback, ideas, and real-world use cases.")</span>
        <span class="auth-side-bubble__cta">@T("Poďme sa porozprávať", "Let’s talk")</span>
    </a>

    <div class="auth-card auth-card--form">
        <a class="auth-brand" asp-page="/Index">
            <span class="auth-brand__eyebrow"><span class="auth-brand__eyebrow-line">@T("Open-source platforma", "Open-source platform")</span><span class="auth-brand__eyebrow-line">@T("pre fotovoltiku", "for photovoltaics")</span></span>
            <strong>
                <img class="auth-brand__logo" src="~/logo.png" alt="" asp-append-version="true" />
                <span>NestStats</span>
            </strong>
        </a>

        <div class="auth-copy auth-copy--register">
            <div class="auth-copy__replacement">
                <h1>@T("Vytvor si účet pre monitoring a riadenie FVE", "Create an account for PV monitoring and control")</h1>
                <p>@T("Po registrácii pripojíš svoju inštaláciu, nastavíš ekonomiku domácnosti a otvoríš dashboard s telemetriou, riadením prebytkov a prehľadom návratnosti.", "After registration, you will connect your installation, configure household economics and open a dashboard with telemetry, surplus control and ROI insights.")</p>
            </div>
            <span class="section-eyebrow">@T("Prvé spustenie platformy", "First platform launch")</span>
            <h1>@T("Vytvor si účet pre monitoring a riadenie FVE", "Create an account for PV monitoring and control")</h1>
            <p>@T("Po registrácii pripojíš svoju inštaláciu, nastavíš ekonomický profil domácnosti a otvoríš dashboard s telemetriou, riadením prebytkov a ROI prehľadom.", "After registration, you will connect your installation, configure the household economics profile and open a dashboard with telemetry, surplus control and ROI overview.")</p>
        </div>

        <form id="registerForm" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
            <input type="hidden" asp-for="ReturnUrl" />

            <div class="field">
                <label asp-for="Input.Email">@T("Email", "Email")</label>
                <input asp-for="Input.Email" autocomplete="username" placeholder="meno@firma.sk" />
                <span asp-validation-for="Input.Email" class="field-validation-error"></span>
            </div>

            <div class="field">
                <label asp-for="Input.Password">@T("Heslo", "Password")</label>
                <input asp-for="Input.Password" type="password" autocomplete="new-password" placeholder="@T("Minimálne 8 znakov", "At least 8 characters")" />
                <span asp-validation-for="Input.Password" class="field-validation-error"></span>
            </div>

            <div class="field">
                <label asp-for="Input.ConfirmPassword">@T("Potvrdenie hesla", "Confirm password")</label>
                <input asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" placeholder="@T("Zopakuj heslo", "Repeat password")" />
                <span asp-validation-for="Input.ConfirmPassword" class="field-validation-error"></span>
            </div>

            <p class="auth-consent">
                @T("Vytvorením účtu potvrdzuješ, že si prečítal/-a a súhlasíš s", "By creating an account you confirm that you have read and agree to the")
                <a asp-area="" asp-page="/Privacy">@T("zásadami ochrany osobných údajov", "Privacy Policy")</a>.
            </p>
            <button id="registerSubmit" type="submit" class="button button--primary auth-submit">@T("Vytvoriť účet", "Create account")</button>
        </form>

        @if (Model.ExternalLogins.Count > 0)
        {
            <div class="auth-divider"><span>@T("alebo pokračuj cez", "or continue with")</span></div>
            <div class="auth-provider-grid">
                @foreach (var provider in Model.ExternalLogins)
                {
                    <form method="post" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl">
                        <button type="submit"
                                class="auth-provider-button auth-provider-button--@provider.Name.ToLowerInvariant()"
                                name="provider" value="@provider.Name">
                            @if (provider.Name == "Google")
                            {
                                <svg class="auth-provider-icon" viewBox="0 0 24 24" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                                    <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                                    <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                                    <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                                    <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                                </svg>
                            }
                            else if (provider.Name == "Facebook")
                            {
                                <svg class="auth-provider-icon" viewBox="0 0 24 24" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="#1877F2">
                                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                                </svg>
                            }
                            else
                            {
                                <span class="auth-provider-icon-placeholder"></span>
                            }
                            <span class="auth-provider-label">@T("PokraÄŤovaĹĄ cez", "Continue with") @provider.DisplayName</span>
                        </button>
                    </form>
                }
            </div>
        }

        <div class="auth-footer auth-footer--split">
            <span>@T("Máš už účet?", "Already have an account?")</span>
            <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">@T("Prihlásiť sa", "Sign in")</a>
            <a class="auth-footer__legal-link" asp-area="" asp-page="/Privacy">@T("Zásady ochrany osobných údajov", "Privacy Policy")</a>
        </div>
    </div>

    <div class="auth-card auth-card--visual auth-card--visual-register">
        <partial name="~/Areas/Identity/Pages/Shared/_AuthEnergyScene.cshtml" />
    </div>

    <section class="auth-mobile-stack" aria-label="@T("Doplňujúce odkazy", "Additional links")">
        <a class="auth-mobile-panel" asp-page="/SpoznajNas">
            <span class="auth-mobile-panel__eyebrow">@T("Spoznaj nás", "Find more here")</span>
            <strong>@T("Viac o platforme", "Explore the platform")</strong>
            <span>@T("Monitoring, riadenie a ekonomika v jednom priestore.", "Monitoring, control, and economics in one place.")</span>
            <span class="auth-mobile-panel__cta">@T("Otvoriť prehľad", "Open overview")</span>
        </a>

        <a class="auth-mobile-panel" href="https://github.com/PavolLukacka/NestStats" target="_blank" rel="noopener noreferrer">
            <span class="auth-mobile-panel__eyebrow">@T("Meet the dev team", "Meet the dev team")</span>
            <strong>@T("Sleduj náš proces", "Follow our process")</strong>
            <span>@T("Open-source vývoj, roadmapa a workflow tímu na GitHube.", "Open-source development, roadmap, and team workflow on GitHub.")</span>
            <span class="auth-mobile-panel__cta auth-mobile-panel__cta--logo">
                <img src="~/github_logo.png" alt="" asp-append-version="true" />
                <span>@T("GitHub prehľad", "GitHub overview")</span>
            </span>
        </a>

        <a class="auth-mobile-panel" href="https://patreon.com/Lukacka_Pavol?utm_medium=unknown&utm_source=join_link&utm_campaign=creatorshare_creator&utm_content=copyLink" target="_blank" rel="noopener noreferrer">
            <span class="auth-mobile-panel__eyebrow">@T("Páči sa ti to?", "Like what you see?")</span>
            <strong>@T("Podpor nás na Patreon", "Support us on Patreon")</strong>
            <span>@T("Pomôž nám financovať ďalší vývoj a nové funkcie.", "Help fund future development and new features.")</span>
            <span class="auth-mobile-panel__cta auth-mobile-panel__cta--logo">
                <img src="~/Patreon_logo.png" alt="" asp-append-version="true" />
                <span>@T("Podporiť projekt", "Support the project")</span>
            </span>
        </a>

        <a class="auth-mobile-panel" asp-page="/SpoznajNas" asp-fragment="kontakt">
            <span class="auth-mobile-panel__eyebrow">@T("Otázky či návrhy?", "Questions or ideas?")</span>
            <strong>@T("Napíš nám", "Write to us")</strong>
            <span>@T("Radi si pozrieme feedback, návrhy aj konkrétne use-cases z praxe.", "We are happy to hear feedback, ideas, and real-world use cases.")</span>
            <span class="auth-mobile-panel__cta">@T("Poďme sa porozprávať", "Let’s talk")</span>
        </a>
    </section>
</section>

@section Scripts {
    <partial name="/Pages/Shared/_ValidationScriptsPartial.cshtml" />
}

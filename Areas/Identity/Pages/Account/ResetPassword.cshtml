@page
@model NestStats2.Areas.Identity.Pages.Account.ResetPasswordModel
@{
    Layout = "/Areas/Identity/Pages/_AuthLayout.cshtml";
    string T(string sk, string en) => Lang.Pick(ViewContext.HttpContext, sk, en);
    ViewData["Title"] = T("Nastavenie nového hesla", "Set new password");
}

<section class="auth-shell auth-shell--login">
    <div class="auth-card auth-card--form">
        <a class="auth-brand" asp-page="/Index">
            <span class="auth-brand__eyebrow">@T("Open-source platforma pre fotovoltiku", "Open-source platform for photovoltaics")</span>
            <strong>NestStats</strong>
        </a>

        <div class="auth-copy">
            <span class="section-eyebrow">@T("Reset hesla", "Password reset")</span>
            <h1>@T("Nastav nové heslo", "Set a new password")</h1>
            <p>@T("Zvoľ nové heslo pre svoj účet NestStats.", "Choose a new password for your NestStats account.")</p>
        </div>

        <form method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
            <input asp-for="Input.Code" type="hidden" />

            <div class="field">
                <label asp-for="Input.Email">@T("Email", "Email")</label>
                <input asp-for="Input.Email" autocomplete="email" />
                <span asp-validation-for="Input.Email" class="field-validation-error"></span>
            </div>

            <div class="field">
                <label asp-for="Input.Password">@T("Nové heslo", "New password")</label>
                <input asp-for="Input.Password" type="password" autocomplete="new-password" />
                <span asp-validation-for="Input.Password" class="field-validation-error"></span>
            </div>

            <div class="field">
                <label asp-for="Input.ConfirmPassword">@T("Potvrdenie hesla", "Confirm password")</label>
                <input asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" />
                <span asp-validation-for="Input.ConfirmPassword" class="field-validation-error"></span>
            </div>

            <button type="submit" class="button button--primary auth-submit">@T("Uložiť nové heslo", "Save new password")</button>
        </form>
    </div>

    <div class="auth-card auth-card--visual">
        <partial name="~/Areas/Identity/Pages/Shared/_AuthEnergyScene.cshtml" />
    </div>
</section>

@section Scripts {
    <partial name="/Pages/Shared/_ValidationScriptsPartial.cshtml" />
}

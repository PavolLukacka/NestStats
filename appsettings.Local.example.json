{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=App_Data/neststats-auth.db"
  },
  "Supabase": {
    "Url": "https://CHANGE_ME.supabase.co",
    "AnonKey": "CHANGE_ME_SUPABASE_ANON_KEY"
  },
  "Authentication": {
    "RequireConfirmedAccount": false,
    "Google": {
      "ClientId": "CHANGE_ME_GOOGLE_CLIENT_ID",
      "ClientSecret": "CHANGE_ME_GOOGLE_CLIENT_SECRET"
    },
    "Facebook": {
      "ClientId": "CHANGE_ME_FACEBOOK_CLIENT_ID",
      "ClientSecret": "CHANGE_ME_FACEBOOK_CLIENT_SECRET"
    }
  },
  "Email": {
    "FromName": "NestStats",
    "FromAddress": "CHANGE_ME_FROM_EMAIL",
    "SmtpHost": "CHANGE_ME_SMTP_HOST",
    "SmtpPort": 587,
    "SmtpUser": "CHANGE_ME_SMTP_USER",
    "SmtpPassword": "CHANGE_ME_SMTP_PASSWORD",
    "UseSsl": true,
    "SavePreviewToDiskWhenDisabled": true
  },
  "AdminBootstrap": {
    "Email": "admin@example.com",
    "Password": "CHANGE_ME_STRONG_ADMIN_PASSWORD",
    "DisplayName": "NestStats Admin"
  }
}
